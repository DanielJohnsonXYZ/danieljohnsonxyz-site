# Cloudflare Pages custom headers
#
# Unstyled site / “no CSS”: the HTML <link> points at /_astro/BaseLayout.<hash>.css.
# If the edge caches HTML but a new deploy drops that old hashed file, the stylesheet
# URL 404s (often as HTML) and the page looks naked. Purge Cloudflare cache after
# deploy, and avoid dashboard “Cache Everything” rules that cache HTML at the edge.

# Long cache for hashed static assets
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Long cache for images
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Long cache for OG assets
/og/*
  Cache-Control: public, max-age=31536000, immutable

# HTML entry points — no-store so index never references dead hashed CSS after a deploy.
# (More specific than /* so it wins if rules merge.)
/
  Cache-Control: private, no-store, max-age=0, must-revalidate

/index.html
  Cache-Control: private, no-store, max-age=0, must-revalidate

# Do not edge-cache HTML. The custom domain may have Cloudflare cache rules
# layered above Pages, so be explicit here and in the Pages middleware.
/*
  Cache-Control: no-store, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), geolocation=(), camera=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://static.cloudflareinsights.com https://www.clarity.ms https://scripts.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://region1.google-analytics.com https://analytics.google.com https://*.analytics.google.com https://www.googletagmanager.com https://stats.g.doubleclick.net https://www.clarity.ms https://*.clarity.ms https://cloudflareinsights.com https://*.calendly.com https://comms.wescalestartups.com; frame-src https://calendly.com https://www.youtube-nocookie.com https://www.youtube.com; base-uri 'self'; form-action 'self' mailto: https://comms.wescalestartups.com; frame-ancestors 'self'

# RSS + sitemap should be crawlable and cacheable briefly
/rss.xml
  Cache-Control: public, max-age=300, s-maxage=3600
  Content-Type: application/rss+xml; charset=utf-8

/sitemap.xml
  Cache-Control: public, max-age=300, s-maxage=3600
  Content-Type: application/xml; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=300, s-maxage=3600
  Content-Type: text/plain; charset=utf-8
