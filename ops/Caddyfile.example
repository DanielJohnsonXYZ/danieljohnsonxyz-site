danieljohnsonx.xyz, www.danieljohnsonx.xyz {
	redir https://danieljohnson.xyz{uri} permanent
}

www.danieljohnson.xyz {
	redir https://danieljohnson.xyz{uri} permanent
}

danieljohnson.xyz {
	root * /var/www/danieljohnsonxyz/dist
	encode zstd gzip
	file_server

	@hasTrailingSlash path_regexp trailing ^(.+)/$
	redir @hasTrailingSlash {http.regexp.trailing.1} 308

	@static {
		path *.css *.js *.mjs *.svg *.png *.jpg *.jpeg *.webp *.woff *.woff2 *.txt *.xml
	}
	header @static Cache-Control "public, max-age=31536000, immutable"
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
	}
}
