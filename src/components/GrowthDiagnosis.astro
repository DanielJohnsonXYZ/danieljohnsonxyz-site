---
// Growth Diagnosis — 5-question interactive quiz, 4 personalised result paths
// (positioning, founder dependency, decision rhythm, channel mix) per growth hub spec.
import { ctas } from "../site";

/** Four outbound paths — answers map onto these buckets before tallying. */
type BottleneckKey = "positioning" | "founder" | "rhythm" | "channels";

interface ResultCopy {
  title: string;
  /** 2–3 sentences: ties the user's self-identified pain to the path (honest, no invented facts). */
  summary: string;
  body: string;
  recommendation: string;
  nextHref: string;
  nextLabel: string;
}

interface Question {
  id: string;
  prompt: string;
  answers: { label: string; bottleneck: BottleneckKey }[];
}

const questions: Question[] = [
  {
    id: "q1",
    prompt: "Where does most of today's revenue actually come from?",
    answers: [
      { label: "Inbound or founder's network — one-off, hard to predict", bottleneck: "founder" },
      { label: "Paid channels, but payback is unclear", bottleneck: "channels" },
      { label: "A mix of channels, but nothing is repeatable yet", bottleneck: "channels" },
      { label: "One channel that worked, now flattening out", bottleneck: "channels" }
    ]
  },
  {
    id: "q2",
    prompt: "What happens when a prospect lands on your site or signs up?",
    answers: [
      { label: "Too many drop off before converting", bottleneck: "rhythm" },
      { label: "They convert but churn quickly afterwards", bottleneck: "rhythm" },
      { label: "They stall because the message doesn't match what they need", bottleneck: "positioning" },
      { label: "The funnel mostly works — we just don't have enough traffic in it", bottleneck: "channels" }
    ]
  },
  {
    id: "q3",
    prompt: "How clearly can the team describe who you're for, in one sentence?",
    answers: [
      { label: "Not clearly — the ICP is still loose", bottleneck: "positioning" },
      { label: "Clearly on a call, not on the website", bottleneck: "positioning" },
      { label: "Clearly, but the value prop doesn't land with that ICP", bottleneck: "positioning" },
      { label: "Pretty clearly, but we're targeting too many segments at once", bottleneck: "positioning" }
    ]
  },
  {
    id: "q4",
    prompt: "Who closes most deals?",
    answers: [
      { label: "The founder. Personally. On every call.", bottleneck: "founder" },
      { label: "The founder plus a junior rep — still founder-dependent", bottleneck: "founder" },
      { label: "A small sales team, but pipeline is thin", bottleneck: "channels" },
      { label: "Self-serve, but conversion to paid is weak", bottleneck: "rhythm" }
    ]
  },
  {
    id: "q5",
    prompt: "Which of these feels most broken right now?",
    answers: [
      { label: "Ad spend going out, no clear picture of what's working", bottleneck: "channels" },
      { label: "Content and SEO running, no pipeline coming out of it", bottleneck: "channels" },
      { label: "Team is busy, but the growth number isn't moving", bottleneck: "rhythm" },
      { label: "Everything depends on the founder's calendar", bottleneck: "founder" }
    ]
  }
];

const results: Record<BottleneckKey, ResultCopy> = {
  positioning: {
    title: "Your primary bottleneck looks like positioning.",
    summary:
      "You told us the story buyers hear doesn't line up with how you win on calls, or the ICP is still fuzzy. That usually shows up before channel scale — more spend won't fix a message-market gap.",
    body:
      "The product and market are real, but the site, deck, and outbound story don't consistently carry the same sharp problem frame. That's the positioning bottleneck: not lack of effort, lack of a single narrative buyers can repeat.",
    recommendation:
      "Tighten ICP and positioning first — one sentence on who it's for, what category you're in, and what you replace. Then align homepage, demo, and top-of-funnel copy before you add channel complexity.",
    nextHref: "/gtm-systems/",
    nextLabel: "See how GTM systems frame ICP and positioning"
  },
  founder: {
    title: "Your primary bottleneck looks like founder dependency.",
    summary:
      "Revenue still moves when you're in the room — calendar, narrative, and decisions route through you. That's workable until it caps growth; the next step is to systemise what only you know.",
    body:
      "Founder-led sales often works until it doesn't: every important call, exception, and rewrite still depends on you. The risk isn't laziness — it's that the motion never becomes a playbook the team can run.",
    recommendation:
      "Run a short, fixed-scope sprint: document the winning motion, prioritise the first artefacts (ICP, narrative, weekly rhythm), and ship one handoff that doesn't need you on every thread.",
    nextHref: "/strategy-sprint/",
    nextLabel: "See the Strategy Sprint"
  },
  rhythm: {
    title: "Your primary bottleneck looks like decision rhythm and conversion mechanics.",
    summary:
      "Activity is happening, but the funnel or weekly decisions aren't producing a reliable growth number — leaks between steps, or reviews that don't change what ships.",
    body:
      "This is the 'decision rhythm' constraint: either transitions in the funnel are untested, or the team doesn't have a weekly cadence that turns data into scale/stop/fix calls.",
    recommendation:
      "Stand up a simple operating cadence — scorecard, experiment backlog, and explicit owners — and instrument the two weakest funnel transitions before widening the channel mix.",
    nextHref: "/revenue-operations/",
    nextLabel: "See revenue operations and the weekly cadence"
  },
  channels: {
    title: "Your primary bottleneck looks like channel mix and pipeline repeatability.",
    summary:
      "Pipeline arrives in bursts, or paid and organic aren't telling a single story. Channel mix bottlenecks usually need sequencing and proof before scale, not another random test.",
    body:
      "You're either light on repeatable pipeline, or spend and channels aren't tied to a clear ICP and offer story. The fix is sequencing: fewer channels, clearer attach to the segment that already converts.",
    recommendation:
      "Map what's already working, cut or pause what can't be traced to qualified conversations, and sequence one primary channel with reporting you trust before layering the next.",
    nextHref: "/growth-audit/",
    nextLabel: "Read how the Growth Audit narrows channel and funnel focus"
  }
};

const questionsJson = JSON.stringify(questions);
const resultsJson = JSON.stringify(results);
---

<section
  id="growth-diagnosis"
  aria-label="Interactive growth diagnosis"
  class="growth-diagnosis reveal mt-10"
  data-questions={questionsJson}
  data-results={resultsJson}
  data-calendly-href={ctas.primary.href}
  data-calendly-label={ctas.primary.label}
>
  <div class="card p-6 md:p-10">
    <div class="gd-progress" aria-hidden="true">
      <div class="gd-progress-bar" data-gd-progress></div>
    </div>
    <p class="gd-step-label" data-gd-step-label>Question 1 of {questions.length}</p>

    {
      questions.map((q, index) => (
        <fieldset class="gd-step" data-gd-step={index.toString()} hidden={index !== 0}>
          <legend class="mt-4 text-2xl font-extrabold leading-snug tracking-[-0.04em] md:text-3xl">
            {q.prompt}
          </legend>
          <div class="mt-6 space-y-3">
            {q.answers.map((a, ai) => (
              <label class="gd-answer">
                <input
                  type="radio"
                  name={q.id}
                  value={a.bottleneck}
                  data-gd-answer
                  data-step-index={index.toString()}
                  data-answer-index={ai.toString()}
                />
                <span>{a.label}</span>
              </label>
            ))}
          </div>

          <div class="gd-controls mt-8">
            <button type="button" class="button-secondary" data-gd-back disabled={index === 0}>
              Back
            </button>
            <button
              type="button"
              class="button-accent"
              data-gd-next
              data-is-last={(index === questions.length - 1).toString()}
            >
              {index === questions.length - 1 ? "See my diagnosis →" : "Next →"}
            </button>
          </div>
        </fieldset>
      ))
    }

    <div class="gd-result" data-gd-result hidden>
      <p class="card-label text-[color:var(--accent)]">Your diagnosis</p>
      <h3 class="mt-3 text-3xl font-extrabold tracking-[-0.05em] md:text-4xl" data-gd-result-title>
        Diagnosis
      </h3>
      <p class="mt-4 text-base font-medium leading-7 text-[color:var(--ink)]" data-gd-result-summary></p>
      <p class="mt-3 text-base leading-8 text-[color:var(--muted)]" data-gd-result-body></p>
      <div class="mt-6 border-t border-[color:var(--line)] pt-6">
        <p class="card-label">What I'd do next</p>
        <p class="mt-3 text-base leading-8" data-gd-result-reco></p>
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a class="button-accent" href="/growth-audit/" data-cta="diagnosis-primary-audit">
          Book a 20-min Growth Audit →
        </a>
        <a class="button-secondary" href="/gtm-systems/" data-cta="diagnosis-next-step" data-gd-next-step>
          Next step →
        </a>
        <a class="button-link" href={ctas.primary.href} data-cta="diagnosis-calendly-direct" data-gd-cta>
          Or grab a Calendly slot directly →
        </a>
        <button type="button" class="button-link" data-gd-restart>
          Retake the diagnosis
        </button>
      </div>
      <p class="mt-2 text-xs text-[color:var(--muted)]">
        <a class="underline underline-offset-2" href="/newsletter/">Get Growth Notes</a> — one more way to follow the
        system thinking without booking.
      </p>
      <p class="mt-4 text-xs text-[color:var(--muted)]">No data stored. Your answers never leave your browser.</p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.querySelector(".growth-diagnosis");
    if (!root) return;

    const questions = JSON.parse(root.dataset.questions || "[]");
    const results = JSON.parse(root.dataset.results || "{}");
    const total = questions.length;
    const calendlyHref = root.dataset.calendlyHref || "";
    const calendlyLabel = (root.dataset.calendlyLabel || "Book directly") + " →";

    const steps = Array.from(root.querySelectorAll("[data-gd-step]"));
    const resultEl = root.querySelector("[data-gd-result]");
    const progressBar = root.querySelector("[data-gd-progress]");
    const stepLabel = root.querySelector("[data-gd-step-label]");
    const answers = new Array(total).fill(null);
    let current = 0;

    function render() {
      steps.forEach((s, i) => {
        s.hidden = i !== current;
      });
      resultEl.hidden = true;
      const pct = Math.round(((current + 1) / total) * 100);
      if (progressBar) progressBar.style.width = pct + "%";
      if (stepLabel) stepLabel.textContent = "Question " + (current + 1) + " of " + total;
      const legend = steps[current] && steps[current].querySelector("legend");
      if (legend) legend.setAttribute("tabindex", "-1");
    }

    function selectedBottleneck(stepIndex) {
      const step = steps[stepIndex];
      if (!step) return null;
      const checked = step.querySelector("input[type=\"radio\"]:checked");
      return checked ? checked.value : null;
    }

    function showResult() {
      const counts = {};
      for (const key of answers) {
        if (!key) continue;
        counts[key] = (counts[key] || 0) + 1;
      }
      let maxCount = 0;
      Object.values(counts).forEach((c) => {
        if (c > maxCount) maxCount = c;
      });
      let winner = null;
      for (const key of answers) {
        if (key && counts[key] === maxCount) {
          winner = key;
          break;
        }
      }
      if (!winner) winner = "channels";

      const out = results[winner];
      const titleEl = root.querySelector("[data-gd-result-title]");
      const summaryEl = root.querySelector("[data-gd-result-summary]");
      const bodyEl = root.querySelector("[data-gd-result-body]");
      const recoEl = root.querySelector("[data-gd-result-reco]");
      if (titleEl) titleEl.textContent = out.title;
      if (summaryEl) summaryEl.textContent = out.summary;
      if (bodyEl) bodyEl.textContent = out.body;
      if (recoEl) recoEl.textContent = out.recommendation;

      const nextLink = root.querySelector("[data-gd-next-step]");
      if (nextLink && out.nextHref && out.nextLabel) {
        nextLink.setAttribute("href", out.nextHref);
        nextLink.textContent = out.nextLabel + " →";
        nextLink.setAttribute("data-cta", "diagnosis-next-" + winner);
      }

      const cta = root.querySelector("[data-gd-cta]");
      if (cta && calendlyHref) {
        cta.setAttribute("href", calendlyHref);
        cta.textContent = calendlyLabel;
        cta.setAttribute("data-cta", "diagnosis-calendly-" + winner);
      }

      steps.forEach((s) => (s.hidden = true));
      resultEl.hidden = false;
      if (progressBar) progressBar.style.width = "100%";
      if (stepLabel) stepLabel.textContent = "Your diagnosis";
      resultEl.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    root.addEventListener("click", function (e) {
      const target = e.target.closest("button");
      if (!target) return;

      if (target.hasAttribute("data-gd-next")) {
        const lever = selectedBottleneck(current);
        if (!lever) {
          const step = steps[current];
          step.classList.remove("gd-step-nudge");
          void step.offsetWidth;
          step.classList.add("gd-step-nudge");
          return;
        }
        answers[current] = lever;
        if (target.dataset.isLast === "true") {
          showResult();
        } else if (current < total - 1) {
          current += 1;
          render();
        }
      } else if (target.hasAttribute("data-gd-back")) {
        if (current > 0) {
          current -= 1;
          render();
        }
      } else if (target.hasAttribute("data-gd-restart")) {
        current = 0;
        for (let i = 0; i < answers.length; i += 1) answers[i] = null;
        root.querySelectorAll('input[type="radio"]').forEach((el) => {
          el.checked = false;
        });
        render();
      }
    });

    render();
  })();
</script>
