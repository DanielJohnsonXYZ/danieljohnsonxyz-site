---
// HeroDiagnosticPanel.astro
// Animated "Growth Bottleneck Scan — Sample Output" panel.
// Lives in the right column of the hero on danieljohnson.xyz.
// Inspired by the WSS h3-panel — dark card, 3 KPI boxes,
// animated SVG spark chart, 5 system-health rows, footer CTA.
import { ctas } from "../site";
---

<aside class="hdp" aria-label="Growth Bottleneck Scan — sample output">
  <div class="hdp-head">
    <div class="hdp-title">
      <span class="hdp-live" aria-hidden="true"></span>
      Growth Bottleneck Scan
      <span class="hdp-sample">sample output</span>
    </div>
    <div class="hdp-meta">WK 01 / 12</div>
  </div>

  <div class="hdp-kpis">
    <div class="hdp-kpi">
      <div class="hdp-kpi-l">Pipeline today</div>
      <div class="hdp-kpi-v">£42k <span class="hdp-kpi-u">/ wk</span></div>
      <div class="hdp-kpi-d flat">— flat 6 wks</div>
    </div>
    <div class="hdp-kpi">
      <div class="hdp-kpi-l">12-wk projection</div>
      <div class="hdp-kpi-v">£128k <span class="hdp-kpi-u">/ wk</span></div>
      <div class="hdp-kpi-d up">▲ 3.0× after fix</div>
    </div>
    <div class="hdp-kpi hdp-kpi-alert">
      <div class="hdp-kpi-l">Bottleneck</div>
      <div class="hdp-kpi-v hdp-viol">Acquisition</div>
      <div class="hdp-kpi-d hdp-viol">88% confidence</div>
    </div>
  </div>

  <div class="hdp-chart-wrap" aria-hidden="true">
    <div class="hdp-chart-legend">
      <span class="hdp-leg hdp-leg-dot">Pipeline (now)</span>
      <span class="hdp-leg hdp-leg-solid">Pipeline (system)</span>
    </div>
    <svg
      class="hdp-spark"
      id="hdp-hero-spark"
      viewBox="0 0 440 128"
      preserveAspectRatio="none"
    >
      <defs>
        <linearGradient id="hdp-grad" x1="0" x2="1" y1="0" y2="0">
          <stop offset="0%" stop-color="#5e2bff"/>
          <stop offset="55%" stop-color="#9b3dff"/>
          <stop offset="100%" stop-color="#d046ff"/>
        </linearGradient>
        <linearGradient id="hdp-fill" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="#9b3dff" stop-opacity=".22"/>
          <stop offset="100%" stop-color="#9b3dff" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <!-- grid -->
      <g stroke="rgba(255,255,255,0.06)" stroke-width="1">
        <line x1="0" x2="440" y1="28" y2="28"/>
        <line x1="0" x2="440" y1="62" y2="62"/>
        <line x1="0" x2="440" y1="96" y2="96"/>
      </g>
      <!-- fill -->
      <path
        class="hdp-area"
        d="M0,98 C55,92 110,82 165,68 C220,54 275,38 330,24 C385,12 415,8 440,6 L440,128 L0,128 Z"
        fill="url(#hdp-fill)"
      />
      <!-- flat dotted (current) -->
      <path
        d="M0,90 C30,86 60,93 90,89 C120,84 150,92 180,87 C210,82 240,90 270,85 C300,80 330,88 360,83 C390,78 415,85 440,81"
        fill="none"
        stroke="rgba(255,255,255,0.26)"
        stroke-width="1.8"
        stroke-dasharray="4 4"
      />
      <!-- system line (animated) -->
      <path
        class="hdp-draw"
        d="M0,98 C55,92 110,82 165,68 C220,54 275,38 330,24 C385,12 415,8 440,6"
        fill="none"
        stroke="url(#hdp-grad)"
        stroke-width="2.8"
        stroke-linecap="round"
      />
      <!-- annotation -->
      <g transform="translate(162,58)">
        <line x1="0" y1="0" x2="0" y2="-22" stroke="#ff7a35" stroke-width="1.2" stroke-dasharray="2 3"/>
        <circle cx="0" cy="0" r="3.5" fill="#ff7a35"/>
        <rect x="5" y="-34" width="88" height="17" rx="4.5"
          fill="rgba(255,255,255,0.05)" stroke="rgba(255,150,80,0.35)" stroke-width="0.8"/>
        <text x="11" y="-23"
          font-family="JetBrains Mono,ui-monospace,monospace"
          font-size="8" fill="#ffb47a" font-weight="700" letter-spacing="0.5">ACQUISITION FIX</text>
      </g>
      <!-- endpoint -->
      <g class="hdp-endnode">
        <circle cx="440" cy="6" r="9" fill="#d046ff" fill-opacity=".12"/>
        <circle cx="440" cy="6" r="3.8" fill="#d046ff"/>
      </g>
    </svg>
  </div>

  <div class="hdp-rows">
    <div class="hdp-row hdp-good">
      <span class="hdp-rnum">01</span>
      <span class="hdp-rlbl">Positioning
        <small>ICP clear · category owned</small>
        <span class="hdp-meter"><span style="width:78%"></span></span>
      </span>
      <span class="hdp-verdict">Healthy</span>
    </div>
    <div class="hdp-row hdp-bad">
      <span class="hdp-rnum">02</span>
      <span class="hdp-rlbl">Acquisition
        <small>Channel concentration · single-source</small>
        <span class="hdp-meter"><span style="width:88%"></span></span>
      </span>
      <span class="hdp-verdict">Bottleneck</span>
    </div>
    <div class="hdp-row hdp-warn">
      <span class="hdp-rnum">03</span>
      <span class="hdp-rlbl">Conversion
        <small>Demo → SQL leak · no playbook</small>
        <span class="hdp-meter"><span style="width:54%"></span></span>
      </span>
      <span class="hdp-verdict">Watch</span>
    </div>
    <div class="hdp-row hdp-good">
      <span class="hdp-rnum">04</span>
      <span class="hdp-rlbl">Reporting
        <small>Weekly cadence · founder-trusted</small>
        <span class="hdp-meter"><span style="width:71%"></span></span>
      </span>
      <span class="hdp-verdict">Healthy</span>
    </div>
    <div class="hdp-row hdp-warn">
      <span class="hdp-rnum">05</span>
      <span class="hdp-rlbl">Team ownership
        <small>Founder-dependent on decisions</small>
        <span class="hdp-meter"><span style="width:46%"></span></span>
      </span>
      <span class="hdp-verdict">Watch</span>
    </div>
  </div>

  <div class="hdp-foot">
    <p class="hdp-verdict-line">
      <strong>Verdict.</strong> Acquisition is the binding constraint — run a 90-day sprint.
    </p>
    <a class="hdp-cta" href={ctas.bottleneck.href} data-cta="hero-panel-get-yours">Get yours →</a>
  </div>
</aside>

<style>
  /* ── Panel shell ── */
  .hdp {
    background: #0d0c12;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    overflow: hidden;
    font-family: inherit;
    color: rgba(255, 255, 255, 0.88);
    box-shadow:
      0 0 0 1px rgba(124, 58, 237, 0.12),
      0 32px 64px rgba(0, 0, 0, 0.36);
  }

  /* ── Head ── */
  .hdp-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.03);
  }
  .hdp-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.7);
  }
  .hdp-sample {
    font-size: 0.65rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.35);
    padding: 0.15rem 0.45rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .hdp-live {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.22);
    animation: hdp-pulse 2.2s ease-in-out infinite;
  }
  @keyframes hdp-pulse {
    0%, 100% { box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.22); }
    50%       { box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12); }
  }
  .hdp-meta {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.3);
  }

  /* ── KPIs ── */
  .hdp-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  .hdp-kpi {
    padding: 0.85rem 0.9rem;
    border-right: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .hdp-kpi:last-child { border-right: none; }
  .hdp-kpi-alert { background: rgba(124, 58, 237, 0.06); }
  .hdp-kpi-l {
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    font-weight: 600;
  }
  .hdp-kpi-v {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    line-height: 1.1;
  }
  .hdp-kpi-u {
    font-size: 0.72rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.38);
    letter-spacing: 0;
  }
  .hdp-kpi-d {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .hdp-kpi-d.flat { color: rgba(255, 255, 255, 0.4); }
  .hdp-kpi-d.up   { color: #4ade80; }
  .hdp-viol { color: #b78aff !important; }

  /* ── Chart ── */
  .hdp-chart-wrap {
    padding: 0.65rem 1rem 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  .hdp-chart-legend {
    display: flex;
    gap: 0.85rem;
    margin-bottom: 0.4rem;
  }
  .hdp-leg {
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.38);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .hdp-leg::before {
    content: "";
    display: inline-block;
    width: 18px;
    height: 2px;
    border-radius: 2px;
  }
  .hdp-leg-dot::before {
    border-top: 2px dashed rgba(255, 255, 255, 0.3);
    height: 0;
  }
  .hdp-leg-solid::before {
    background: linear-gradient(90deg, #5e2bff, #d046ff);
  }
  .hdp-spark {
    display: block;
    width: 100%;
    height: 7rem;
  }

  /* SVG draw animation — line grows left-to-right */
  .hdp-draw {
    stroke-dasharray: 700;
    stroke-dashoffset: 700;
  }
  .hdp-spark.is-animated .hdp-draw {
    animation: hdp-draw 1.4s cubic-bezier(0.4, 0, 0.2, 1) 0.2s forwards;
  }
  .hdp-spark.is-animated .hdp-area {
    animation: hdp-fadein 0.9s ease 0.6s both;
  }
  .hdp-spark.is-animated .hdp-endnode {
    animation: hdp-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) 1.5s both;
  }
  @keyframes hdp-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes hdp-fadein {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes hdp-pop {
    from { transform: scale(0); transform-origin: 440px 6px; opacity: 0; }
    to   { transform: scale(1); transform-origin: 440px 6px; opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hdp-draw { stroke-dashoffset: 0; }
  }

  /* ── Health rows ── */
  .hdp-rows {
    display: flex;
    flex-direction: column;
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  .hdp-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.52rem 1rem;
    transition: background 140ms ease;
  }
  .hdp-row:hover { background: rgba(255, 255, 255, 0.03); }
  .hdp-rnum {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 700;
    width: 1.5rem;
    flex-shrink: 0;
  }
  .hdp-rlbl {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    min-width: 0;
  }
  .hdp-rlbl small {
    font-size: 0.65rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.01em;
  }
  .hdp-meter {
    display: block;
    margin-top: 0.28rem;
    height: 3px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    overflow: hidden;
    max-width: 7rem;
  }
  .hdp-meter span {
    display: block;
    height: 100%;
    border-radius: 2px;
  }
  .hdp-good .hdp-meter span { background: #4ade80; }
  .hdp-warn .hdp-meter span { background: #fbbf24; }
  .hdp-bad  .hdp-meter span { background: #b78aff; }

  /* Verdict badge */
  .hdp-verdict {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.18rem 0.45rem;
    border-radius: 999px;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .hdp-good .hdp-verdict { background: rgba(74, 222, 128, 0.12);  color: #4ade80; }
  .hdp-warn .hdp-verdict { background: rgba(251, 191, 36, 0.12);  color: #fbbf24; }
  .hdp-bad  .hdp-verdict { background: rgba(183, 138, 255, 0.15); color: #b78aff; }

  /* ── Footer ── */
  .hdp-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: rgba(124, 58, 237, 0.07);
    flex-wrap: wrap;
  }
  .hdp-verdict-line {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
  }
  .hdp-verdict-line strong {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 700;
  }
  .hdp-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.45rem 0.85rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    white-space: nowrap;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
    flex-shrink: 0;
  }
  .hdp-cta:hover {
    background: rgba(124, 58, 237, 0.2);
    border-color: rgba(124, 58, 237, 0.4);
    color: #fff;
  }
</style>

<script>
  (() => {
    const spark = document.getElementById("hdp-hero-spark");
    if (!spark) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      spark.classList.add("is-animated");
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((en) => {
          if (!en.isIntersecting) return;
          spark.classList.add("is-animated");
          io.disconnect();
        });
      },
      { threshold: 0.15 }
    );
    io.observe(spark);
  })();
</script>
