---
import { ctas } from "../site";

interface Props {
  /** If true, renders the sticky bar at all. Set false on pages that already
   *  end in a full-width booking block (e.g. /fractional-cmo after the Calendly embed). */
  enabled?: boolean;
  /** The pixel threshold (scrollY) after which the bar appears. */
  revealAfter?: number;
  /** Contextual override, e.g. "Enquire about speaking" on /speaking. */
  label?: string;
  href?: string;
  hint?: string;
}

const {
  enabled = true,
  revealAfter = 1400,
  label = `${ctas.growthNote.label} →`,
  href = ctas.growthNote.href,
  hint = ctas.growthNote.hint
} = Astro.props;
---

{enabled && (
  <div
    class="sticky-cta"
    data-reveal-after={revealAfter}
    role="complementary"
    inert
  >
    <div class="sticky-cta-inner">
      <div class="sticky-cta-copy">
        <span class="sticky-cta-hint">{hint}</span>
      </div>
      <div class="sticky-cta-actions">
        <a
          class="button-accent sticky-cta-primary"
          href={href}
          data-cta="sticky-newsletter"
        >
          {label}
        </a>
        <button
          class="sticky-cta-dismiss"
          type="button"
          aria-label="Dismiss newsletter banner"
        >
          ×
        </button>
      </div>
    </div>
  </div>
)}

<style is:global>
  @import "../styles/mobile-qa.css";

  .sticky-cta {
    position: fixed;
    inset-inline: 0;
    bottom: max(1.25rem, env(safe-area-inset-bottom, 0px));
    z-index: 45;
    display: flex;
    justify-content: center;
    padding: 0 1rem;
    pointer-events: none;
    opacity: 0;
    transform: translateY(120%);
    transition: opacity 280ms ease, transform 320ms cubic-bezier(.2,.9,.3,1);
  }

  .sticky-cta.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .sticky-cta.is-dismissed {
    display: none;
  }

  .sticky-cta-inner {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    width: min(560px, 100%);
    padding: 0.5rem 0.55rem 0.5rem 1.1rem;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--ink) 94%, transparent);
    color: #fff;
    box-shadow: 0 10px 28px -16px color-mix(in srgb, var(--ink) 55%, transparent);
    backdrop-filter: saturate(140%) blur(6px);
  }

  .sticky-cta-copy {
    display: flex;
    align-items: center;
    line-height: 1.35;
    min-width: 0;
    flex: 1;
  }

  .sticky-cta-hint {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: color-mix(in srgb, #fff 82%, transparent);
  }

  .sticky-cta-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .sticky-cta-primary {
    min-height: 0;
    padding-block: 0.45rem;
    padding-inline: 0.9rem;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .sticky-cta-dismiss {
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, #fff 18%, transparent);
    background: transparent;
    color: #fff;
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    transition: background 150ms ease;
  }

  .sticky-cta-dismiss:hover,
  .sticky-cta-dismiss:focus-visible {
    background: color-mix(in srgb, #fff 14%, transparent);
    outline: none;
  }

  @media (max-width: 520px) {
    .sticky-cta {
      bottom: 0.75rem;
    }
    .sticky-cta-inner {
      align-items: stretch;
      flex-direction: column;
      gap: 0.45rem;
      padding: 0.7rem;
      border-radius: 1.25rem;
    }
    .sticky-cta-copy {
      justify-content: center;
      padding-inline: 0.5rem;
      text-align: center;
    }
    .sticky-cta-hint {
      font-size: 0.74rem;
      line-height: 1.4;
    }
    .sticky-cta-actions {
      width: 100%;
    }
    .sticky-cta-primary {
      flex: 1;
      justify-content: center;
      min-height: 2.5rem;
    }
    .sticky-cta-dismiss {
      flex: 0 0 1.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-cta {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var bar = document.querySelector('.sticky-cta');
    if (!bar) return;

    var revealAfter = Number(bar.getAttribute('data-reveal-after') || 1400);
    var dismissKey = 'dj-sticky-cta-dismissed';
    var dismissed = false;
    var overlapSelector = 'footer, .site-footer-v2, form, .growth-diagnosis, .cta-gradient, .evergreen-updated, #proof, [aria-label="Ways to work together"], .v5-ladder, .v5-final-cta, .v5-section-proof';
    var overlapsSensitiveArea = false;

    try {
      dismissed = sessionStorage.getItem(dismissKey) === '1';
    } catch (err) {
      // sessionStorage may be blocked (Safari private). Fall back to in-memory.
    }

    if (dismissed) {
      bar.classList.add('is-dismissed');
      return;
    }

    function update() {
      if (dismissed) return;
      var shouldShow = window.scrollY > revealAfter && !overlapsSensitiveArea;
      bar.classList.toggle('is-visible', shouldShow);
      bar.toggleAttribute('inert', !shouldShow);
      // Reserve space at the bottom of the page while the bar is shown so it
      // never sits on top of body text or cards.
      document.body.style.paddingBottom = shouldShow ? '5.5rem' : '';
    }

    var dismissBtn = bar.querySelector('.sticky-cta-dismiss');
    if (dismissBtn) {
      dismissBtn.addEventListener('click', function () {
        dismissed = true;
        bar.classList.remove('is-visible');
        bar.setAttribute('inert', '');
        bar.classList.add('is-dismissed');
        try {
          sessionStorage.setItem(dismissKey, '1');
        } catch (err) {
          // ignore
        }
      });
    }

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        overlapsSensitiveArea = entries.some(function (entry) {
          return entry.isIntersecting;
        });
        update();
      }, {
        rootMargin: '40px 0px 40px 0px',
        threshold: [0, 0.05, 0.1]
      });

      document.querySelectorAll(overlapSelector).forEach(function (el) {
        observer.observe(el);
      });
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    // Run once on load so it's correct after a deep-link / back-nav.
    update();
  })();
</script>
