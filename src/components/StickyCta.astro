---
import { ctas, siteConfig } from "../site";

interface Props {
  /** If true, renders the sticky bar at all. Set false on pages that already
   *  end in a full-width booking block (e.g. /fractional-cmo after the Calendly embed). */
  enabled?: boolean;
  /** The pixel threshold (scrollY) after which the bar appears. */
  revealAfter?: number;
}

const { enabled = true, revealAfter = 640 } = Astro.props;
---

{enabled && (
  <div
    class="sticky-cta"
    data-reveal-after={revealAfter}
    aria-hidden="true"
    role="complementary"
  >
    <div class="sticky-cta-inner">
      <div class="sticky-cta-copy">
        <span class="sticky-cta-availability">{siteConfig.availability}</span>
        <span class="sticky-cta-hint">Free · 30 minutes · No pitch</span>
      </div>
      <div class="sticky-cta-actions">
        <a
          class="button-accent sticky-cta-primary"
          href={ctas.primary.href}
          data-cta="sticky-primary"
        >
          {ctas.primary.label} →
        </a>
        <button
          class="sticky-cta-dismiss"
          type="button"
          aria-label="Dismiss booking bar"
        >
          ×
        </button>
      </div>
    </div>
  </div>
)}

<style>
  .sticky-cta {
    position: fixed;
    inset-inline: 0;
    bottom: 1rem;
    z-index: 45;
    display: flex;
    justify-content: center;
    padding: 0 1rem;
    pointer-events: none;
    opacity: 0;
    transform: translateY(120%);
    transition: opacity 280ms ease, transform 320ms cubic-bezier(.2,.9,.3,1);
  }

  .sticky-cta.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .sticky-cta.is-dismissed {
    display: none;
  }

  .sticky-cta-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: min(720px, 100%);
    padding: 0.75rem 0.9rem 0.75rem 1.25rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--ink) 96%, transparent);
    color: #fff;
    box-shadow: 0 18px 42px -12px color-mix(in srgb, var(--ink) 65%, transparent),
                0 2px 8px -1px color-mix(in srgb, var(--ink) 50%, transparent);
    backdrop-filter: saturate(140%) blur(6px);
  }

  .sticky-cta-copy {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    min-width: 0;
    flex: 1;
  }

  .sticky-cta-availability {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sticky-cta-hint {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, #fff 60%, transparent);
    margin-top: 2px;
  }

  .sticky-cta-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .sticky-cta-primary {
    padding-block: 0.55rem;
    padding-inline: 1rem;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .sticky-cta-dismiss {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, #fff 18%, transparent);
    background: transparent;
    color: #fff;
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    transition: background 150ms ease;
  }

  .sticky-cta-dismiss:hover,
  .sticky-cta-dismiss:focus-visible {
    background: color-mix(in srgb, #fff 14%, transparent);
    outline: none;
  }

  /* On small screens: hide the availability line to save space — the CTA + hint are enough. */
  @media (max-width: 520px) {
    .sticky-cta {
      bottom: 0.75rem;
    }
    .sticky-cta-inner {
      padding-left: 1rem;
      gap: 0.5rem;
    }
    .sticky-cta-availability {
      display: none;
    }
    .sticky-cta-hint {
      font-size: 0.68rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-cta {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var bar = document.querySelector('.sticky-cta');
    if (!bar) return;

    var revealAfter = Number(bar.getAttribute('data-reveal-after') || 640);
    var dismissKey = 'dj-sticky-cta-dismissed';
    var dismissed = false;

    try {
      dismissed = sessionStorage.getItem(dismissKey) === '1';
    } catch (err) {
      // sessionStorage may be blocked (Safari private). Fall back to in-memory.
    }

    if (dismissed) {
      bar.classList.add('is-dismissed');
      return;
    }

    function update() {
      if (dismissed) return;
      var shouldShow = window.scrollY > revealAfter;
      bar.classList.toggle('is-visible', shouldShow);
      bar.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
    }

    var dismissBtn = bar.querySelector('.sticky-cta-dismiss');
    if (dismissBtn) {
      dismissBtn.addEventListener('click', function () {
        dismissed = true;
        bar.classList.remove('is-visible');
        bar.classList.add('is-dismissed');
        try {
          sessionStorage.setItem(dismissKey, '1');
        } catch (err) {
          // ignore
        }
      });
    }

    window.addEventListener('scroll', update, { passive: true });
    // Run once on load so it's correct after a deep-link / back-nav.
    update();
  })();
</script>
