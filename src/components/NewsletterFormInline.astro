---
// NewsletterFormInline.astro — inline Growth Notes capture; posts to Mautic.
//
// Form id and base URL: src/site.ts → mauticNewsletter (env:
// PUBLIC_MAUTIC_BASE_URL, PUBLIC_MAUTIC_NEWSLETTER_FORM_ID).
//
// Variants: `variant` = "strip" (compact) or "card" (full block).

import { mauticNewsletter } from "../site";

interface Props {
  variant?: "strip" | "card";
  /** Use on dark backgrounds (e.g. site footer). */
  tone?: "light" | "dark";
  heading?: string;
  subline?: string;
  /** Set on pages with a hero link to #anchor (e.g. /newsletter). Omit when multiple forms on one page. */
  anchorId?: string;
}

const {
  variant = "strip",
  tone = "light",
  heading = "Practical notes on founder-led growth, AI GTM, positioning, and pipeline systems.",
  subline = "Occasional. No daily drip. Unsubscribe in one click.",
  anchorId
} = Astro.props;

const { submitUrl, formId } = mauticNewsletter;
---

<section
  {...(anchorId ? { id: anchorId } : {})}
  class:list={["nl-form", `nl-form-${variant}`, tone === "dark" && "nl-form--dark"]}
  aria-labelledby="nl-form-title"
>
  <div class="nl-inner">
    <div class="nl-copy">
      <p class="nl-eyebrow">Growth Notes</p>
      <h3 id="nl-form-title">{heading}</h3>
      {subline && <p class="nl-sub">{subline}</p>}
    </div>
    <form
      class="nl-fields"
      action={submitUrl}
      method="post"
      accept-charset="UTF-8"
      data-cta="newsletter-inline-submit"
    >
      <input type="hidden" name="mauticform[formId]" value={formId} />
      <label class="nl-label" for="nl-email">
        <span class="sr-only">Email address</span>
        <input
          id="nl-email"
          class="nl-input"
          type="email"
          name="mauticform[email]"
          required
          placeholder="you@company.com"
          autocomplete="email"
          inputmode="email"
        />
      </label>
      <button class="nl-submit button-accent" type="submit">
        Subscribe →
      </button>
    </form>
  </div>
</section>

<style>
  .nl-form {
    background: var(--surface-dim);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    padding: 1.25rem 1.25rem;
  }
  @media (min-width: 768px) {
    .nl-form { padding: 1.5rem 1.75rem; }
  }

  .nl-inner {
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .nl-form-strip .nl-inner {
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 1.5rem;
    }
  }

  .nl-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.4rem;
  }

  .nl-form h3 {
    font-size: 1.1rem;
    line-height: 1.45;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
    max-width: 38ch;
  }
  @media (min-width: 768px) {
    .nl-form-card h3 { font-size: 1.35rem; }
  }

  .nl-sub {
    margin-top: 0.4rem;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .nl-fields {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 540px) {
    .nl-fields { flex-direction: row; gap: 0.5rem; }
  }

  .nl-label { flex: 1; min-width: 0; }
  .nl-input {
    width: 100%;
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    font-size: 0.9rem;
    color: var(--ink);
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }
  .nl-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .nl-submit {
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* Dark footer / band */
  .nl-form--dark {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
  }
  .nl-form--dark .nl-eyebrow {
    color: color-mix(in srgb, var(--accent) 85%, white);
  }
  .nl-form--dark h3,
  .nl-form--dark .nl-sub {
    color: rgba(255, 255, 255, 0.92);
  }
  .nl-form--dark .nl-sub {
    color: rgba(255, 255, 255, 0.6);
  }
  .nl-form--dark .nl-input {
    background: rgba(0, 0, 0, 0.25);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
  }
  .nl-form--dark .nl-input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
</style>
