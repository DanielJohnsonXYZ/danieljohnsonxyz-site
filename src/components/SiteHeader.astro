---
import { announcement, ctas, navigationGroups, siteConfig } from "../site";

interface Props {
  currentPath?: string;
  mediaCta?: boolean;
}

const { currentPath = "/", mediaCta = false } = Astro.props;
const headerCta = mediaCta
  ? {
      href: `mailto:${siteConfig.email}?subject=Media%20request%20for%20Daniel%20Johnson`,
      label: "Email Daniel"
    }
  : ctas.primary;

const normalise = (p: string) => (p.endsWith("/") ? p : `${p}/`);
const active = normalise(currentPath);

// Image card per dropdown — matches navigationGroups by .label.
// Files live in /public/images/nav/ as SVGs (light + dark friendly).
const dropdownImages: Record<string, { src: string; alt: string; eyebrow: string; tagline: string }> = {
  "Work with me": {
    src: "/images/nav/work-with-me.svg",
    alt: "Diagram of a connected growth system: ICP, channel, offer, rhythm",
    eyebrow: "Senior growth operator",
    tagline: "Embed senior judgement, build the system, transfer it clean."
  },
  "Compare": {
    src: "/images/nav/compare.svg",
    alt: "Side-by-side comparison of agency vs fractional CMO trade-offs",
    eyebrow: "vs. agency · vs. full-time",
    tagline: "Senior judgement vs junior execution. Cost, ramp, and ownership maths."
  },
  "Expertise": {
    src: "/images/nav/expertise.svg",
    alt: "Six connected nodes representing GTM, PLG, experimentation, AI, distribution, RevOps",
    eyebrow: "Six operating layers",
    tagline: "GTM, PLG, experimentation, AI workflows, founder distribution, RevOps."
  },
  "Media": {
    src: "/images/nav/media.svg",
    alt: "Audio waveform with microphone — speaking, podcasts, writing, press",
    eyebrow: "Speaking · Podcasts · Writing",
    tagline: "Press kit, podcast guest pitches, and speaking assets ready for producers."
  }
};
---

{
  announcement.enabled && (
    <div class="announcement-bar" role="region" aria-label="Site announcement">
      <div class="shell flex flex-wrap items-center justify-center gap-x-3 gap-y-1 py-2 text-center text-xs font-semibold tracking-[0.02em]">
        <span>{announcement.message}</span>
        <a class="announcement-bar-cta" href={announcement.ctaHref}>
          {announcement.ctaLabel} →
        </a>
      </div>
    </div>
  )
}

<header class="sticky top-0 z-50 px-4 pt-4">
  <div class="shell">
    <div class="site-nav-dock px-5 py-3">
      <div class="flex items-center justify-between gap-4">
        <a class="group flex items-center gap-3" href="/">
          <span class="brand-mark">DJ</span>
          <span class="text-sm font-semibold tracking-[-0.02em]">Daniel Johnson</span>
        </a>

        <nav aria-label="Primary" class="hidden items-center gap-1 rounded-full border border-[color:var(--line)] bg-white/60 p-1 lg:flex">
          {
            navigationGroups.map((group) => {
              const isActive =
                normalise(group.href) === active || group.items.some((item) => normalise(item.href) === active);
              const img = dropdownImages[group.label];
              return (
                <div class="site-nav-menu">
                  <a
                    class:list={[
                      "site-nav-link site-nav-menu-trigger rounded-full px-4 py-2 text-sm font-medium",
                      isActive ? "site-nav-link-active text-white" : "text-[color:var(--muted)] hover:text-[color:var(--ink)]"
                    ]}
                    aria-current={isActive ? "page" : undefined}
                    aria-haspopup="true"
                    href={group.href}
                  >
                    {group.label}
                  </a>
                  <div class="site-nav-dropdown site-nav-dropdown-with-image">
                    {img && (
                      <a class="site-nav-dropdown-image" href={group.href} aria-label={`${group.label} — ${img.tagline}`}>
                        <img src={img.src} alt={img.alt} loading="lazy" decoding="async" width="320" height="220" />
                        <div class="site-nav-dropdown-image-copy">
                          <p class="site-nav-dropdown-image-eyebrow">{img.eyebrow}</p>
                          <strong class="site-nav-dropdown-image-title">{group.label}</strong>
                          <p class="site-nav-dropdown-image-tag">{img.tagline}</p>
                          <span class="site-nav-dropdown-image-cta">Explore →</span>
                        </div>
                      </a>
                    )}
                    <div class="site-nav-dropdown-list">
                      {
                        group.items.map((item) => (
                          <a class="site-nav-dropdown-item" href={item.href}>
                            <span>{item.label}</span>
                            <small>{item.description}</small>
                          </a>
                        ))
                      }
                    </div>
                  </div>
                </div>
              );
            })
          }
          <a class="site-nav-link rounded-full px-4 py-2 text-sm font-medium text-[color:var(--muted)] hover:text-[color:var(--ink)]" href="/case-studies/">Results</a>
          <a class="site-nav-link rounded-full px-4 py-2 text-sm font-medium text-[color:var(--muted)] hover:text-[color:var(--ink)]" href="/about/">About</a>
        </nav>

        <div class="hidden lg:block">
          <a class="button-primary" href={headerCta.href} data-cta={mediaCta ? "header-media" : "header-primary"}>
            {headerCta.label}
          </a>
        </div>

        <details class="group relative lg:hidden">
          <summary class="button-secondary cursor-pointer list-none px-4 py-2" aria-label="Open menu">Menu</summary>
          <div class="mobile-nav-panel absolute right-0 top-[calc(100%+0.75rem)] w-72 p-3">
            <nav aria-label="Mobile" class="flex flex-col gap-1">
              {
                navigationGroups.map((group) => {
                  const isActive =
                    normalise(group.href) === active || group.items.some((item) => normalise(item.href) === active);
                  return (
                    <details class="mobile-nav-group" open={isActive}>
                      <summary class="mobile-nav-group-label">{group.label}</summary>
                      <div class="mobile-nav-group-links">
                        {
                          group.items.map((item) => (
                            <a
                              class:list={[
                                "rounded-xl px-4 py-3 text-sm font-medium transition-colors",
                                normalise(item.href) === active
                                  ? "site-nav-link-active text-white"
                                  : "text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]"
                              ]}
                              aria-current={normalise(item.href) === active ? "page" : undefined}
                              href={item.href}
                            >
                              {item.label}
                            </a>
                          ))
                        }
                      </div>
                    </details>
                  );
                })
              }
              <a class="rounded-xl px-4 py-3 text-sm font-medium text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]" href="/case-studies/">Results</a>
              <a class="rounded-xl px-4 py-3 text-sm font-medium text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]" href="/about/">About</a>
              <a class="button-primary mt-2" href={headerCta.href} data-cta={mediaCta ? "header-mobile-media" : "header-mobile-primary"}>
                {headerCta.label}
              </a>
              {mediaCta ? (
                <a class="text-center text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] mt-2 py-2" href="/media-kit/">
                  Download media kit →
                </a>
              ) : (
                <a class="text-center text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] mt-2 py-2" href={ctas.bottleneck.href}>
                  {ctas.bottleneck.label} →
                </a>
              )}
            </nav>
          </div>
        </details>
      </div>
    </div>
  </div>
</header>

<style>
  /* Image-augmented dropdown — sits to the LEFT of the link list. */
  .site-nav-dropdown-with-image {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 0;
    padding: 0;
    overflow: hidden;
    min-width: min(720px, 90vw);
  }

  .site-nav-dropdown-image {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--ink);
    overflow: hidden;
  }
  .site-nav-dropdown-image img {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
  }
  .site-nav-dropdown-image-copy {
    position: absolute;
    inset: 0;
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.4rem;
    background: linear-gradient(180deg, rgba(11,11,12,0) 50%, rgba(11,11,12,0.78) 100%);
  }
  .site-nav-dropdown-image-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin: 0;
  }
  .site-nav-dropdown-image-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .site-nav-dropdown-image-tag {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.78);
    margin: 0;
    line-height: 1.4;
  }
  .site-nav-dropdown-image-cta {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 0.3rem;
  }
  .site-nav-dropdown-image:hover .site-nav-dropdown-image-cta {
    color: #fff;
  }
  .site-nav-dropdown-image:hover .site-nav-dropdown-image-copy {
    background: linear-gradient(180deg, rgba(11,11,12,0) 30%, rgba(11,11,12,0.85) 100%);
  }

  /* Hide the image on narrow viewports — desktop only enhancement. */
  @media (max-width: 980px) {
    .site-nav-dropdown-with-image {
      grid-template-columns: 1fr;
      min-width: 0;
    }
    .site-nav-dropdown-image {
      display: none;
    }
  }
</style>
