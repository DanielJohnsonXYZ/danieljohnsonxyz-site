---
import { announcement, ctas, navigationGroups, siteConfig } from "../site";

interface Props {
  currentPath?: string;
  mediaCta?: boolean;
}

const { currentPath = "/", mediaCta = false } = Astro.props;
const headerCta = mediaCta
  ? {
      href: `mailto:${siteConfig.email}?subject=Media%20request%20for%20Daniel%20Johnson`,
      label: "Email Daniel"
    }
  : ctas.primary;

// Normalise paths so trailing-slash doesn't break active state.
const normalise = (p: string) => (p.endsWith("/") ? p : `${p}/`);
const active = normalise(currentPath);
---

{
  announcement.enabled && (
    <div class="announcement-bar" role="region" aria-label="Site announcement">
      <div class="shell flex flex-wrap items-center justify-center gap-x-3 gap-y-1 py-2 text-center text-xs font-semibold tracking-[0.02em]">
        <span>{announcement.message}</span>
        <a class="announcement-bar-cta" href={announcement.ctaHref}>
          {announcement.ctaLabel} →
        </a>
      </div>
    </div>
  )
}

<header class="sticky top-0 z-50 px-4 pt-4">
  <div class="shell">
    <div class="site-nav-dock px-5 py-3">
      <div class="flex items-center justify-between gap-4">
        <a class="group flex items-center gap-3" href="/">
          <span class="brand-mark">DJ</span>
          <span class="text-sm font-semibold tracking-[-0.02em]">
            Daniel Johnson
          </span>
        </a>

        <nav aria-label="Primary" class="hidden items-center gap-1 rounded-full border border-[color:var(--line)] bg-white/60 p-1 lg:flex">
          {
            navigationGroups.map((group) => {
              const isActive =
                normalise(group.href) === active || group.items.some((item) => normalise(item.href) === active);
              return (
                <div class="site-nav-menu">
                  <a
                    class:list={[
                      "site-nav-link site-nav-menu-trigger rounded-full px-4 py-2 text-sm font-medium",
                      isActive ? "site-nav-link-active text-white" : "text-[color:var(--muted)] hover:text-[color:var(--ink)]"
                    ]}
                    aria-current={isActive ? "page" : undefined}
                    aria-haspopup="true"
                    href={group.href}
                  >
                    {group.label}
                  </a>
                  <div class="site-nav-dropdown">
                    <a class="site-nav-dropdown-feature" href={group.href}>
                      <span>{group.label}</span>
                      <strong>Explore the full section</strong>
                    </a>
                    <div class="site-nav-dropdown-list">
                      {
                        group.items.map((item) => (
                          <a class="site-nav-dropdown-item" href={item.href}>
                            <span>{item.label}</span>
                            <small>{item.description}</small>
                          </a>
                        ))
                      }
                    </div>
                  </div>
                </div>
              );
            })
          }
          <a class="site-nav-link rounded-full px-4 py-2 text-sm font-medium text-[color:var(--muted)] hover:text-[color:var(--ink)]" href="/case-studies/">
            Results
          </a>
          <a class="site-nav-link rounded-full px-4 py-2 text-sm font-medium text-[color:var(--muted)] hover:text-[color:var(--ink)]" href="/about/">
            About
          </a>
        </nav>

        <div class="hidden lg:block">
          <a class="button-primary" href={headerCta.href} data-cta={mediaCta ? "header-media" : "header-primary"}>
            {headerCta.label}
          </a>
        </div>

        <details class="group relative lg:hidden">
          <summary class="button-secondary cursor-pointer list-none px-4 py-2" aria-label="Open menu">Menu</summary>
          <div class="mobile-nav-panel absolute right-0 top-[calc(100%+0.75rem)] w-72 p-3">
            <nav aria-label="Mobile" class="flex flex-col gap-1">
              {
                navigationGroups.map((group) => {
                  const isActive =
                    normalise(group.href) === active || group.items.some((item) => normalise(item.href) === active);
                  return (
                    <details class="mobile-nav-group" open={isActive}>
                      <summary class="mobile-nav-group-label">{group.label}</summary>
                      <div class="mobile-nav-group-links">
                        {
                          group.items.map((item) => (
                            <a
                              class:list={[
                                "rounded-xl px-4 py-3 text-sm font-medium transition-colors",
                                normalise(item.href) === active
                                  ? "site-nav-link-active text-white"
                                  : "text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]"
                              ]}
                              aria-current={normalise(item.href) === active ? "page" : undefined}
                              href={item.href}
                            >
                              {item.label}
                            </a>
                          ))
                        }
                      </div>
                    </details>
                  );
                })
              }
              <a class="rounded-xl px-4 py-3 text-sm font-medium text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]" href="/case-studies/">Results</a>
              <a class="rounded-xl px-4 py-3 text-sm font-medium text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]" href="/about/">About</a>
              <a class="button-primary mt-2" href={headerCta.href} data-cta={mediaCta ? "header-mobile-media" : "header-mobile-primary"}>
                {headerCta.label}
              </a>
              {mediaCta ? (
                <a class="text-center text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] mt-2 py-2" href="/media-kit/">
                  Download media kit →
                </a>
              ) : (
                <a class="text-center text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] mt-2 py-2" href={ctas.bottleneck.href}>
                  {ctas.bottleneck.label} →
                </a>
              )}
            </nav>
          </div>
        </details>
      </div>
    </div>
  </div>
</header>
