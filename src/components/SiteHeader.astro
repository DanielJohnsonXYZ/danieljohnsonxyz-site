---
import CfEmailOff from "./CfEmailOff.astro";
import { announcement, ctas, navigation, proofNavItems, siteConfig, workWithMeNavItems } from "../site";

interface Props {
  currentPath?: string;
  mediaCta?: boolean;
}

const { currentPath = "/", mediaCta = false } = Astro.props;
const headerCta = mediaCta
  ? {
      href: `mailto:${siteConfig.email}?subject=Media%20request%20for%20Daniel%20Johnson`,
      label: "Email Daniel"
    }
  : {
      href: ctas.primary.href,
      label: siteConfig.navBookingLabel
    };

const normalise = (p: string) => (p.endsWith("/") ? p : `${p}/`);
const active = normalise(currentPath);

const workWithMeHref = "/work-with-me/";
const workWithMeActive =
  active === normalise(workWithMeHref) || workWithMeNavItems.some((item) => normalise(item.href) === active);

const proofActive = proofNavItems.some((item) => normalise(item.href) === active);

const workDropdownImage = {
  src: "/images/nav/work-with-me.svg",
  alt: "Diagram of a connected growth system: ICP, channel, offer, rhythm",
  eyebrow: "Senior growth operator",
  tagline: "Embed senior judgement, build the system, transfer it clean."
};
---

{
  announcement.enabled && (
    <div class="announcement-bar" role="region" aria-label="Site announcement">
      <div class="shell flex flex-wrap items-center justify-center gap-x-3 gap-y-1 py-2 text-center text-xs font-semibold tracking-[0.02em]">
        <span>{announcement.message}</span>
        <a class="announcement-bar-cta" href={announcement.ctaHref}>
          {announcement.ctaLabel} →
        </a>
      </div>
    </div>
  )
}

<header id="site-header" class="site-header sticky top-0 z-50">
  <div class="site-header-shell">
    <div class="site-nav-dock">
      <div class="site-nav-bar">
        <a class="site-nav-brand group flex min-w-0 items-center gap-2.5" href="/">
          <span class="brand-mark">DJ</span>
          <span class="truncate text-sm font-semibold tracking-[-0.02em]">Daniel Johnson</span>
        </a>

        <nav aria-label="Primary" class="site-nav-links hidden xl:flex">
          {
            navigation.map((item) => {
              if (item.label === "Work with me") {
                return (
                  <div class="site-nav-menu" data-nav-menu>
                    <button
                      type="button"
                      class:list={[
                        "site-nav-link site-nav-menu-trigger",
                        workWithMeActive ? "site-nav-link-active text-white" : "text-[color:var(--muted)] hover:text-[color:var(--ink)]"
                      ]}
                      aria-current={workWithMeActive ? "page" : undefined}
                      aria-haspopup="true"
                      aria-expanded="false"
                      data-nav-trigger
                    >
                      <span>{item.label}</span>
                      <svg width="9" height="6" viewBox="0 0 9 6" aria-hidden="true" class="site-nav-caret">
                        <path fill="currentColor" d="M.7.5h7.6a.4.4 0 0 1 .3.7L4.8 5.4a.4.4 0 0 1-.6 0L.4 1.2A.4.4 0 0 1 .7.5Z" />
                      </svg>
                    </button>
                    <div class="site-nav-dropdown site-nav-dropdown-with-image">
                      <a class="site-nav-dropdown-image" href={workWithMeHref} aria-label={`Work with me, ${workDropdownImage.tagline}`}>
                        <img src={workDropdownImage.src} alt={workDropdownImage.alt} loading="lazy" decoding="async" width="320" height="220" />
                        <div class="site-nav-dropdown-image-copy">
                          <p class="site-nav-dropdown-image-eyebrow">{workDropdownImage.eyebrow}</p>
                          <strong class="site-nav-dropdown-image-title">Work with me</strong>
                          <p class="site-nav-dropdown-image-tag">{workDropdownImage.tagline}</p>
                          <span class="site-nav-dropdown-image-cta">Explore →</span>
                        </div>
                      </a>
                      <div class="site-nav-dropdown-list">
                        {workWithMeNavItems.map((sub) => (
                          <a class="site-nav-dropdown-item" href={sub.href}>
                            <span>{sub.label}</span>
                            <small>{sub.description}</small>
                          </a>
                        ))}
                      </div>
                    </div>
                  </div>
                );
              }
              if (item.label === "Proof") {
                return (
                  <div class="site-nav-menu" data-nav-menu>
                    <button
                      type="button"
                      class:list={[
                        "site-nav-link site-nav-menu-trigger",
                        proofActive ? "site-nav-link-active text-white" : "text-[color:var(--muted)] hover:text-[color:var(--ink)]"
                      ]}
                      aria-current={proofActive ? "page" : undefined}
                      aria-haspopup="true"
                      aria-expanded="false"
                      data-nav-trigger
                    >
                      <span>{item.label}</span>
                      <svg width="9" height="6" viewBox="0 0 9 6" aria-hidden="true" class="site-nav-caret">
                        <path fill="currentColor" d="M.7.5h7.6a.4.4 0 0 1 .3.7L4.8 5.4a.4.4 0 0 1-.6 0L.4 1.2A.4.4 0 0 1 .7.5Z" />
                      </svg>
                    </button>
                    <div class="site-nav-dropdown site-nav-dropdown-simple">
                      <div class="site-nav-dropdown-list">
                        {proofNavItems.map((sub) => (
                          <a class="site-nav-dropdown-item" href={sub.href}>
                            <span>{sub.label}</span>
                            <small>{sub.description}</small>
                          </a>
                        ))}
                      </div>
                    </div>
                  </div>
                );
              }
              const isActive = normalise(item.href) === active;
              return (
                <a
                  class:list={[
                    "site-nav-link",
                    isActive ? "site-nav-link-active text-white" : "text-[color:var(--muted)] hover:text-[color:var(--ink)]"
                  ]}
                  aria-current={isActive ? "page" : undefined}
                  href={item.href}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>

        <div class="site-nav-actions">
          <div class="hidden xl:block">
            {mediaCta ? (
              <CfEmailOff>
                <a class="button-primary site-nav-cta" href={headerCta.href} data-cta="header-media">
                  {headerCta.label}
                </a>
              </CfEmailOff>
            ) : (
              <a class="button-primary site-nav-cta" href={headerCta.href} data-cta="header-primary">
                {headerCta.label}
              </a>
            )}
          </div>

          <details class="group relative xl:hidden">
            <summary class="button-secondary site-nav-menu-btn cursor-pointer list-none" aria-label="Open menu">
              Menu
            </summary>
            <div class="mobile-nav-panel absolute right-0 top-[calc(100%+0.75rem)] max-h-[min(32rem,85vh)] w-[min(20rem,calc(100vw-2rem))] overflow-y-auto p-3">
              <nav aria-label="Mobile" class="flex flex-col gap-1">
                {
                  navigation.map((item) => {
                    if (item.label === "Work with me") {
                      return (
                        <details class="mobile-nav-group" open={workWithMeActive}>
                          <summary class="mobile-nav-group-label">Work with me</summary>
                          <div class="mobile-nav-group-links">
                            <a
                              class:list={[
                                "rounded-xl px-4 py-3 text-sm font-medium transition-colors",
                                active === normalise(workWithMeHref) ? "site-nav-link-active text-white" : "text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]"
                              ]}
                              href={workWithMeHref}
                            >
                              Overview
                            </a>
                            {workWithMeNavItems.map((sub) => (
                              <a
                                class:list={[
                                  "rounded-xl px-4 py-3 text-sm font-medium transition-colors",
                                  normalise(sub.href) === active ? "site-nav-link-active text-white" : "text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]"
                                ]}
                                aria-current={normalise(sub.href) === active ? "page" : undefined}
                                href={sub.href}
                              >
                                {sub.label}
                              </a>
                            ))}
                          </div>
                        </details>
                      );
                    }
                    if (item.label === "Proof") {
                      return (
                        <details class="mobile-nav-group" open={proofActive}>
                          <summary class="mobile-nav-group-label">Proof</summary>
                          <div class="mobile-nav-group-links">
                            {proofNavItems.map((sub) => (
                              <a
                                class:list={[
                                  "rounded-xl px-4 py-3 text-sm font-medium transition-colors",
                                  normalise(sub.href) === active ? "site-nav-link-active text-white" : "text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]"
                                ]}
                                aria-current={normalise(sub.href) === active ? "page" : undefined}
                                href={sub.href}
                              >
                                {sub.label}
                              </a>
                            ))}
                          </div>
                        </details>
                      );
                    }
                    const isActive = normalise(item.href) === active;
                    return (
                      <a
                        class:list={[
                          "rounded-xl px-4 py-3 text-sm font-medium transition-colors",
                          isActive ? "site-nav-link-active text-white" : "text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]"
                        ]}
                        aria-current={isActive ? "page" : undefined}
                        href={item.href}
                      >
                        {item.label}
                      </a>
                    );
                  })
                }
                {mediaCta ? (
                  <CfEmailOff>
                    <a class="button-primary mt-2 min-h-[44px] justify-center" href={headerCta.href} data-cta="header-mobile-media">
                      {headerCta.label}
                    </a>
                  </CfEmailOff>
                ) : (
                  <a class="button-primary mt-2 min-h-[44px] justify-center" href={headerCta.href} data-cta="header-mobile-primary">
                    {headerCta.label}
                  </a>
                )}
                {mediaCta ? (
                  <a class="text-center text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] mt-2 py-2" href="/media-kit/">
                    Download media kit →
                  </a>
                ) : (
                  <a class="text-center text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] mt-2 py-2" href={ctas.bookingFallback.href}>
                    {ctas.bookingFallback.label} →
                  </a>
                )}
              </nav>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header-shell {
    margin-inline: auto;
    width: 100%;
    max-width: 80rem;
    padding-inline: 0 !important;
  }

  /* Simple single-column dropdown (no feature image) — used by "Proof". */
  .site-nav-dropdown-simple {
    grid-template-columns: 1fr !important;
    width: min(22rem, calc(100vw - 2rem)) !important;
  }

  .site-nav-dropdown-with-image {
    display: grid !important;
    grid-template-columns: 240px 1fr !important;
    gap: 0;
    padding: 0;
    overflow: hidden;
    width: min(540px, 88vw) !important;
    min-width: 0 !important;
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
    /* Hide instantly (no fade-out) so a half-faded white "pill" never lingers
       while the cursor moves between nav items; fade in only. */
    transition: none;
  }
  .site-nav-menu:hover .site-nav-dropdown-with-image,
  .site-nav-menu:focus-within .site-nav-dropdown-with-image {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
    transition: opacity 140ms ease;
  }

  .site-nav-dropdown-image {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--ink);
    overflow: hidden;
  }
  .site-nav-dropdown-image img {
    display: block;
    width: 100%;
    height: 165px;
    object-fit: cover;
  }
  .site-nav-dropdown-image-copy {
    position: absolute;
    inset: 0;
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.4rem;
    background: linear-gradient(180deg, rgba(11, 11, 12, 0) 50%, rgba(11, 11, 12, 0.78) 100%);
  }
  .site-nav-dropdown-image-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }
  .site-nav-dropdown-image-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .site-nav-dropdown-image-tag {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
    line-height: 1.4;
  }
  .site-nav-dropdown-image-cta {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 0.3rem;
  }
  .site-nav-dropdown-image:hover .site-nav-dropdown-image-cta {
    color: #fff;
  }
  .site-nav-dropdown-image:hover .site-nav-dropdown-image-copy {
    background: linear-gradient(180deg, rgba(11, 11, 12, 0) 30%, rgba(11, 11, 12, 0.85) 100%);
  }

  @media (max-width: 980px) {
    .site-nav-dropdown-with-image {
      grid-template-columns: 1fr;
      min-width: 0;
    }
    .site-nav-dropdown-image {
      display: none;
    }
  }

  .site-nav-menu:hover .site-nav-dropdown-with-image,
  .site-nav-menu:focus-within .site-nav-dropdown-with-image,
  .site-nav-menu [data-nav-trigger][aria-expanded="true"] ~ .site-nav-dropdown-with-image {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  .site-nav-menu-trigger {
    cursor: pointer;
    background: transparent;
    border: 0;
    -webkit-appearance: none;
    appearance: none;
    font: inherit;
  }

  /* Active dropdown trigger: restore the dark pill — the transparent
     background above otherwise outranks .site-nav-link-active and leaves
     white text on the white nav rail. */
  .site-nav-menu-trigger.site-nav-link-active {
    background: var(--ink);
    color: #fff;
  }

  .site-nav-caret {
    display: inline-block;
    margin-top: 1px;
    opacity: 0.7;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .site-nav-menu:hover .site-nav-caret,
  .site-nav-menu:focus-within .site-nav-caret,
  .site-nav-menu [data-nav-trigger][aria-expanded="true"] .site-nav-caret {
    transform: rotate(180deg);
    opacity: 1;
  }
</style>

<script>
  (() => {
    const header = document.getElementById("site-header");
    const menus = document.querySelectorAll<HTMLElement>("[data-nav-menu]");

    function closeAllExcept(except: HTMLElement | null) {
      menus.forEach((menu) => {
        if (menu === except) return;
        const trigger = menu.querySelector<HTMLButtonElement>("[data-nav-trigger]");
        trigger?.setAttribute("aria-expanded", "false");
      });
    }

    menus.forEach((menu) => {
      const trigger = menu.querySelector<HTMLButtonElement>("[data-nav-trigger]");
      if (!trigger) return;

      trigger.addEventListener("click", (event) => {
        event.preventDefault();
        const isOpen = trigger.getAttribute("aria-expanded") === "true";
        closeAllExcept(menu);
        trigger.setAttribute("aria-expanded", isOpen ? "false" : "true");
        // Keyboard activation (Enter/Space) reports detail === 0 — on open,
        // move focus into the menu so keyboard users land on the first link.
        if (!isOpen && event.detail === 0) {
          menu.querySelector<HTMLAnchorElement>(".site-nav-dropdown a")?.focus();
        }
      });

      menu.addEventListener("mouseleave", () => {
        trigger.setAttribute("aria-expanded", "false");
      });
    });

    document.addEventListener("click", (event) => {
      const target = event.target as Element | null;
      if (!target) return;
      if (target.closest("[data-nav-menu]")) return;
      closeAllExcept(null);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeAllExcept(null);
    });

    const onScroll = () => {
      if (!header) return;
      header.classList.toggle("site-header-scrolled", window.scrollY > 14);
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>
