---
import { navigation, siteConfig } from "../site";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---

<header class="sticky top-0 z-50 px-4 pt-4">
  <div class="shell">
    <div class="site-nav-dock px-5 py-3">
      <div class="flex items-center justify-between gap-4">
        <a class="group flex items-center gap-3" href="/">
          <span class="brand-mark">DJ</span>
          <span class="text-sm font-semibold tracking-[-0.02em]">
            Daniel Johnson
          </span>
        </a>

        <nav aria-label="Primary" class="hidden items-center gap-1 rounded-full border border-[color:var(--line)] bg-white/60 p-1 lg:flex">
          {
            navigation.map((item) => {
              const active = currentPath === item.href;
              return (
                <a
                  class:list={[
                    "site-nav-link rounded-full px-4 py-2 text-sm font-medium",
                    active ? "site-nav-link-active text-white" : "text-[color:var(--muted)] hover:text-[color:var(--ink)]"
                  ]}
                  href={item.href}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>

        <div class="hidden lg:block">
          <a class="button-primary" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
            Growth Diagnosis
          </a>
        </div>

        <details class="group relative lg:hidden">
          <summary class="button-secondary cursor-pointer list-none px-4 py-2">Menu</summary>
          <div class="mobile-nav-panel absolute right-0 top-[calc(100%+0.75rem)] w-72 p-3">
            <nav aria-label="Mobile" class="flex flex-col gap-1">
              {
                navigation.map((item) => (
                  <a
                    class:list={[
                      "rounded-xl px-4 py-3 text-sm font-medium transition-colors",
                      currentPath === item.href
                        ? "site-nav-link-active text-white"
                        : "text-[color:var(--ink)] hover:bg-[color:var(--surface-dim)]"
                    ]}
                    href={item.href}
                  >
                    {item.label}
                  </a>
                ))
              }
              <a class="button-primary mt-2" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
                Growth Diagnosis
              </a>
            </nav>
          </div>
        </details>
      </div>
    </div>
  </div>
</header>
