---
import CfEmailOff from "./CfEmailOff.astro";
import NewsletterFormInline from "./NewsletterFormInline.astro";
import { ctas, footerNavigation, footerTestimonial, proofStats, siteConfig, socialLinks } from "../site";

interface Props {
  mediaCta?: boolean;
}

const { mediaCta = false } = Astro.props;
---

<footer class="dark-section pb-10 pt-20">
  <div class="shell">
    <!-- Active footer: testimonial pull-quote + proof strip so the footer does conversion work, not just navigation. -->
    <div class="mb-8 grid gap-6 md:grid-cols-[1.2fr_0.8fr] md:items-end">
      <blockquote class="rounded-2xl border border-white/[0.08] bg-white/[0.04] p-6 md:p-8">
        <p class="text-lg font-semibold leading-8 tracking-[-0.03em] text-white/90 md:text-xl">
          "{footerTestimonial.quote}"
        </p>
        <footer class="mt-4 flex items-center justify-between text-sm">
          <div>
            <p class="font-semibold text-white">{footerTestimonial.name}</p>
            <p class="text-white/65">{footerTestimonial.role}</p>
          </div>
          <a class="text-xs font-semibold uppercase tracking-[0.14em] text-white/60 hover:text-white" href={siteConfig.growthMentorReviews} rel="noreferrer" target="_blank">
            More reviews →
          </a>
        </footer>
      </blockquote>

      <aside class="flex flex-col gap-3 text-right md:items-end">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Top-rated mentor</p>
        <p class="text-5xl font-extrabold tracking-[-0.06em] text-white">{proofStats.mentorRating}<span class="text-2xl text-white/50">/5</span></p>
        <p class="text-sm text-white/65">from {proofStats.mentorReviewCount} reviews · {proofStats.mentorSessions} sessions</p>
      </aside>
    </div>

    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.03] p-8 md:p-12">
      <div class="grid gap-10 lg:grid-cols-7">
        <div class="flex flex-col gap-6 lg:col-span-2">
          <span class="eyebrow">Start a conversation</span>
          <h2 class="text-3xl font-bold tracking-[-0.05em] text-white md:text-4xl">
            {mediaCta ? "Invite Daniel, request a quote, or get the media kit." : `${ctas.primary.label}.`}
          </h2>
          <p class="max-w-md text-base leading-7 text-white/65">
            {mediaCta
              ? "For podcasts, press, speaking, panels, workshops, and newsletter interviews, email Daniel directly or use the producer-ready media kit."
              : "20 minutes, no pitch. You'll leave with a clearer read on your biggest growth bottleneck and whether working together makes sense."}
          </p>
          {!mediaCta && (
            <div class="max-w-md space-y-2">
              <p class="rounded-full border border-white/20 bg-white/[0.03] px-4 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-white/80">
                {siteConfig.availability}
              </p>
              <p class="text-xs font-medium leading-relaxed text-white/65">{siteConfig.nextStartWindow}</p>
            </div>
          )}
          <div class="flex flex-wrap gap-3">
            {mediaCta ? (
              <>
                <CfEmailOff>
                  <a class="button-accent" href={`mailto:${siteConfig.email}?subject=Media%20request%20for%20Daniel%20Johnson`} data-cta="footer-media-email">
                    Email Daniel →
                  </a>
                </CfEmailOff>
                <a class="button-secondary" href="/media-kit/" data-cta="footer-media-kit">
                  Download media kit →
                </a>
                <a class="button-secondary" href="/podcast-guest/" data-cta="footer-podcast">
                  Book Daniel for your podcast →
                </a>
              </>
            ) : (
              <>
                <a class="button-accent" href={ctas.primary.href} data-cta="footer-primary">
                  {ctas.primary.label} →
                </a>
                <a class="button-secondary" href={ctas.bookingFallback.href} data-cta="footer-booking-fallback">
                  {ctas.bookingFallback.label} →
                </a>
              </>
            )}
          </div>
          <p class="text-xs text-white/65">{siteConfig.location}</p>
        </div>

        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Work with me</p>
          <ul class="space-y-3">
            {
              footerNavigation.workWithMe.map((item) => (
                <li>
                  <a class="block min-h-[44px] py-2 text-sm font-medium text-white/75 hover:text-white sm:min-h-0" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Method</p>
          <ul class="space-y-3">
            {
              footerNavigation.method.map((item) => (
                <li>
                  <a class="block min-h-[44px] py-2 text-sm font-medium text-white/75 hover:text-white sm:min-h-0" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Proof</p>
          <ul class="space-y-3">
            {
              footerNavigation.proof.map((item) => (
                <li>
                  <a class="block min-h-[44px] py-2 text-sm font-medium text-white/75 hover:text-white sm:min-h-0" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Company</p>
          <ul class="space-y-3">
            {
              footerNavigation.company.map((item) => (
                <li>
                  <a class="block min-h-[44px] py-2 text-sm font-medium text-white/75 hover:text-white sm:min-h-0" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Contact</p>
          <ul class="space-y-3">
            {
              footerNavigation.contact.map((item) => (
                <li>
                  <a
                    class="block min-h-[44px] py-2 text-sm font-medium text-white/75 hover:text-white sm:min-h-0"
                    href={item.href}
                    {...(item.href.startsWith("http") ? { rel: "noreferrer", target: "_blank" } : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
            <li>
              <a class="block min-h-[44px] py-2 text-sm font-medium text-white/75 hover:text-white sm:min-h-0" href="/contact/">
                Contact page →
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Newsletter — full-width strip so the form gets room to breathe. -->
      <div class="mt-10 border-t border-white/[0.06] pt-8">
        <div class="max-w-2xl">
          <NewsletterFormInline
            variant="strip"
            tone="dark"
            heading="Growth Notes — practical founder-led GTM, one email at a time."
            subline="Same list as the newsletter page. Unsubscribe anytime."
            idPrefix="nl-footer"
          />
          <p class="mt-3 text-xs text-white/50">
            <a class="font-semibold text-white/70 hover:text-white" href="/newsletter/">About the newsletter →</a>
          </p>
        </div>
      </div>

      <nav aria-label="Resources and comparisons" class="mt-10 border-t border-white/[0.06] pt-6">
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Resources</p>
        <ul class="flex flex-wrap gap-x-5 gap-y-3 text-sm text-white/60">
          {
            footerNavigation.resources.map((item) => (
              <li>
                <a class="inline-flex min-h-[44px] items-center font-medium text-white/75 hover:text-white" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="mt-10 grid gap-4 border-t border-white/[0.06] pt-6 text-sm text-white/50 md:grid-cols-[1.2fr_0.8fr]">
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
          <li>
            <div>
              <CfEmailOff>
                <a class="hover:text-white" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
              </CfEmailOff>
            </div>
          </li>
          {socialLinks.filter(item => item.label !== "GrowthMentor" && item.label !== "MentorCruise").map((item) => (
            <li><a class="hover:text-white" href={item.href} rel="noreferrer" target="_blank">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="mt-8 border-t border-white/[0.06] pt-6 flex flex-col gap-3 text-sm text-white/60 md:flex-row md:items-center md:justify-between">
        <p>&copy; {new Date().getFullYear()} {siteConfig.name}. Practical growth for post-PMF founders.</p>
        <nav aria-label="Legal" class="flex flex-wrap items-center gap-4 text-xs uppercase tracking-[0.12em]">
          <a class="hover:text-white/80" href="/privacy/">Privacy</a>
          <a class="hover:text-white/80" href="/terms/">Terms</a>
          <a class="hover:text-white/80" href="/ai-policy/">AI policy</a>
          <span class="font-semibold">{siteConfig.canonicalHost}</span>
        </nav>
      </div>
    </div>
  </div>
</footer>
