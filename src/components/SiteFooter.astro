---
import { navigation, siteConfig } from "../site";
---

<footer class="dark-section pb-10 pt-20">
  <div class="shell">
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.03] p-8 md:p-12">
      <div class="grid gap-10 md:grid-cols-[1.4fr_0.9fr]">
        <div class="flex flex-col gap-6">
          <span class="eyebrow">Stay in Touch</span>
          <h2 class="text-3xl font-bold tracking-[-0.05em] text-white md:text-4xl">
            Talks, operator thinking, and the work behind durable startup growth.
          </h2>
          <p class="max-w-2xl text-base leading-7 text-white/50">
            I work with a limited number of companies at a time and take selected speaking,
            workshop, and advisory conversations where the fit is strong.
          </p>
          <div class="flex flex-wrap gap-3">
            <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
              Book a Diagnosis Call
            </a>
            <a class="button-secondary" href={`mailto:${siteConfig.email}`}>
              Email Daniel
            </a>
          </div>
        </div>

        <div class="grid gap-8 sm:grid-cols-2">
          <div class="space-y-4">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/40">Navigation</p>
            <ul class="space-y-3">
              {
                navigation.map((item) => (
                  <li>
                    <a class="text-sm font-medium text-white/70 hover:text-white" href={item.href}>
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="space-y-4">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/40">Connect</p>
            <ul class="space-y-3 text-sm text-white/50">
              <li>{siteConfig.location}</li>
              <li><a class="hover:text-white" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
              <li><a class="hover:text-white" href={siteConfig.linkedin} rel="noreferrer" target="_blank">LinkedIn</a></li>
              <li><a class="hover:text-white" href={siteConfig.companyUrl} rel="noreferrer" target="_blank">We Scale Startups</a></li>
            </ul>
          </div>
        </div>
      </div>

      <div class="mt-8 border-t border-white/[0.06] pt-6 flex flex-col gap-2 text-sm text-white/30 md:flex-row md:items-center md:justify-between">
        <p>Built as a fast static Astro site with clean semantics and a modern editorial feel.</p>
        <p class="text-xs font-semibold uppercase tracking-[0.12em]">{siteConfig.canonicalHost}</p>
      </div>
    </div>
  </div>
</footer>
