---
import { ctas, footerNavigation, siteConfig } from "../site";
---

<footer class="dark-section pb-10 pt-20">
  <div class="shell">
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.03] p-8 md:p-12">
      <div class="grid gap-10 md:grid-cols-4">
        <div class="flex flex-col gap-6 md:col-span-2">
          <span class="eyebrow">Stay in touch</span>
          <h2 class="text-3xl font-bold tracking-[-0.05em] text-white md:text-4xl">
            {siteConfig.name}
          </h2>
          <p class="max-w-md text-base leading-7 text-white/60">
            Fractional CMO and AI-native growth operator for post-PMF AI and B2B SaaS startups.
            I help founders turn traction into predictable revenue.
          </p>
          <p class="max-w-md text-sm font-semibold leading-6 text-white/75">{siteConfig.availability}</p>
          <div class="flex flex-wrap gap-3">
            <a class="button-accent" href={ctas.primary.href} data-cta="footer-primary">
              {ctas.primary.label} →
            </a>
            <a class="button-secondary" href={ctas.bottleneck.href} data-cta="footer-secondary">
              {ctas.bottleneck.label}
            </a>
          </div>
          <p class="text-xs text-white/65">{siteConfig.location}</p>
        </div>

        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Work with me</p>
          <ul class="space-y-3">
            {
              footerNavigation.workWithMe.map((item) => (
                <li>
                  <a class="text-sm font-medium text-white/70 hover:text-white" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>

          <p class="mt-6 text-xs font-semibold uppercase tracking-[0.14em] text-white/65">Speaking</p>
          <ul class="space-y-3">
            {
              footerNavigation.speaking.map((item) => (
                <li>
                  <a class="text-sm font-medium text-white/70 hover:text-white" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65">More</p>
          <ul class="space-y-3">
            {
              footerNavigation.more.map((item) => (
                <li>
                  <a class="text-sm font-medium text-white/70 hover:text-white" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mt-10 grid gap-4 border-t border-white/[0.06] pt-6 text-sm text-white/50 md:grid-cols-[1.2fr_0.8fr]">
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
          <li><a class="hover:text-white" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
          <li><a class="hover:text-white" href={siteConfig.linkedin} rel="noreferrer" target="_blank">LinkedIn</a></li>
          <li><a class="hover:text-white" href={siteConfig.youtube} rel="noreferrer" target="_blank">YouTube</a></li>
          <li><a class="hover:text-white" href={siteConfig.growthMentor} rel="noreferrer" target="_blank">GrowthMentor</a></li>
          <li><a class="hover:text-white" href={siteConfig.mentorCruise} rel="noreferrer" target="_blank">MentorCruise</a></li>
          <li><a class="hover:text-white" href={siteConfig.instagram} rel="noreferrer" target="_blank">Instagram</a></li>
        </ul>
      </div>

      <div class="mt-8 border-t border-white/[0.06] pt-6 flex flex-col gap-3 text-sm text-white/60 md:flex-row md:items-center md:justify-between">
        <p>&copy; {new Date().getFullYear()} {siteConfig.name}. Practical growth for post-PMF founders.</p>
        <nav aria-label="Legal" class="flex flex-wrap items-center gap-4 text-xs uppercase tracking-[0.12em]">
          <a class="hover:text-white/80" href="/privacy/">Privacy</a>
          <a class="hover:text-white/80" href="/terms/">Terms</a>
          <span class="font-semibold">{siteConfig.canonicalHost}</span>
        </nav>
      </div>
    </div>
  </div>
</footer>
