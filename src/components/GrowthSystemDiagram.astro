---
/**
 * Growth system diagram — inline SVG for the home-page method section.
 *
 * Renders the six method layers (research, GTM, acquisition, conversion,
 * founder-led, reporting) as a flow with a feedback loop, so "I build
 * growth systems" is shown rather than just claimed.
 *
 * Designed for dark backgrounds. Scales responsively via viewBox; on
 * narrow viewports the SVG gracefully shrinks while text stays legible
 * thanks to vector scaling.
 */
const nodes = [
  { id: "01", title: "Customer research", sub: "ICP, calls, signal", cx: 200, cy: 115 },
  { id: "02", title: "GTM systems", sub: "Positioning, ICP, cadence", cx: 500, cy: 115 },
  { id: "03", title: "Acquisition", sub: "Channels, experiments", cx: 800, cy: 115 },
  { id: "04", title: "Conversion", sub: "Funnel, activation", cx: 800, cy: 385 },
  { id: "05", title: "Founder-led distribution", sub: "Voice, content, pipeline", cx: 500, cy: 385 },
  { id: "06", title: "Reporting", sub: "Scale, stop, fix", cx: 200, cy: 385 }
] as const;

const NODE_W = 240;
const NODE_H = 90;
---

<figure class="growth-system-diagram" aria-labelledby="growth-system-diagram-caption">
  <svg
    viewBox="0 0 1000 500"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-labelledby="growth-system-diagram-title growth-system-diagram-desc"
    preserveAspectRatio="xMidYMid meet"
  >
    <title id="growth-system-diagram-title">Growth operating system</title>
    <desc id="growth-system-diagram-desc">
      Six layers in a continuous loop: customer research feeds GTM systems, which
      feeds acquisition, which feeds conversion, which feeds founder-led
      distribution, which feeds reporting, which loops back to customer research.
    </desc>

    <defs>
      <marker id="gsd-arrow" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto" markerUnits="strokeWidth">
        <path d="M0,0 L9,4.5 L0,9 Z" fill="rgba(167,139,250,0.7)" />
      </marker>
      <marker id="gsd-arrow-loop" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto" markerUnits="strokeWidth">
        <path d="M0,0 L9,4.5 L0,9 Z" fill="rgba(167,139,250,0.55)" />
      </marker>
    </defs>

    {/* Connecting flow lines (drawn under nodes) */}
    {/* 01 -> 02 */}
    <line x1="320" y1="115" x2="380" y2="115" stroke="rgba(167,139,250,0.55)" stroke-width="2" marker-end="url(#gsd-arrow)" />
    {/* 02 -> 03 */}
    <line x1="620" y1="115" x2="680" y2="115" stroke="rgba(167,139,250,0.55)" stroke-width="2" marker-end="url(#gsd-arrow)" />
    {/* 03 -> 04 (vertical down on right side) */}
    <line x1="800" y1="160" x2="800" y2="340" stroke="rgba(167,139,250,0.55)" stroke-width="2" marker-end="url(#gsd-arrow)" />
    {/* 04 -> 05 */}
    <line x1="680" y1="385" x2="620" y2="385" stroke="rgba(167,139,250,0.55)" stroke-width="2" marker-end="url(#gsd-arrow)" />
    {/* 05 -> 06 */}
    <line x1="380" y1="385" x2="320" y2="385" stroke="rgba(167,139,250,0.55)" stroke-width="2" marker-end="url(#gsd-arrow)" />
    {/* 06 -> 01 feedback loop (vertical up on left side, dashed to read as "loop") */}
    <line x1="200" y1="340" x2="200" y2="160" stroke="rgba(167,139,250,0.45)" stroke-width="2" stroke-dasharray="6,5" marker-end="url(#gsd-arrow-loop)" />
    {/* Feedback-loop label */}
    <text x="170" y="252" text-anchor="end" font-family="IBM Plex Mono, monospace" font-size="10" font-weight="700" letter-spacing="2" fill="rgba(255,255,255,0.5)" transform="rotate(-90 170 252)">FEEDBACK LOOP</text>

    {/* Center label — names what the loop is */}
    <text x="500" y="248" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="11" font-weight="700" letter-spacing="3" fill="rgba(255,255,255,0.4)">THE GROWTH SYSTEM</text>
    <text x="500" y="270" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="600" fill="rgba(255,255,255,0.7)">six layers, one loop</text>

    {/* Nodes (drawn last so they sit on top of the lines) */}
    {nodes.map((node) => (
      <g>
        <rect
          x={node.cx - NODE_W / 2}
          y={node.cy - NODE_H / 2}
          width={NODE_W}
          height={NODE_H}
          rx="14"
          ry="14"
          fill="rgba(255,255,255,0.04)"
          stroke="rgba(255,255,255,0.16)"
          stroke-width="1"
        />
        <text
          x={node.cx}
          y={node.cy - 22}
          text-anchor="middle"
          font-family="IBM Plex Mono, monospace"
          font-size="11"
          font-weight="700"
          letter-spacing="2"
          fill="rgba(167,139,250,0.85)"
        >
          {node.id}
        </text>
        <text
          x={node.cx}
          y={node.cy + 2}
          text-anchor="middle"
          font-family="Inter, sans-serif"
          font-size="17"
          font-weight="700"
          fill="white"
        >
          {node.title}
        </text>
        <text
          x={node.cx}
          y={node.cy + 24}
          text-anchor="middle"
          font-family="Inter, sans-serif"
          font-size="12"
          fill="rgba(255,255,255,0.6)"
        >
          {node.sub}
        </text>
      </g>
    ))}
  </svg>

  <figcaption id="growth-system-diagram-caption" class="sr-only">
    Diagram of the growth operating system. Six layers connected in a continuous
    loop: customer research, GTM systems, acquisition, conversion, founder-led
    distribution, and reporting. Reporting feeds back into customer research,
    closing the loop.
  </figcaption>
</figure>

<style>
  .growth-system-diagram {
    margin: 0;
    width: 100%;
    max-width: 1080px;
    margin-inline: auto;
  }
  .growth-system-diagram svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
