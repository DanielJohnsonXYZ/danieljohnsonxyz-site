---
import EasterEgg from "../components/EasterEgg.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import StickyCta from "../components/StickyCta.astro";
import { buildPageTitle, normalizeMetaDescription } from "../lib/seo";
import { buildOrganizationSchema, buildPersonSchema, buildWebSiteSchema } from "../lib/schema";
import { absoluteUrl } from "../lib/utils";
import { siteConfig } from "../site";
import "../styles/global.css";
import "../styles/visual-system.css";

interface Props {
  title?: string;
  description?: string;
  /** Optional discoverability meta for hub and money pages. */
  keywords?: string;
  path?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  /** Per-page override: set false to hide the sticky booking bar on pages that end in a full-width booking block. */
  stickyCta?: boolean;
  /** Switch shared header/footer CTAs from commercial booking to media-specific contact links. */
  mediaCta?: boolean;
  /** Opt in to preloading the hero headshot (homepage, about — pages where the image is above the fold). */
  preloadHeadshot?: boolean;
  lastUpdated?: string | false;
  /** Override default robots meta (e.g. noindex for 404). */
  metaRobots?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  keywords,
  path = Astro.url.pathname,
  ogImage = siteConfig.ogImage,
  ogType = "website",
  schema = [],
  stickyCta = true,
  mediaCta = false,
  preloadHeadshot = false,
  lastUpdated = siteConfig.lastUpdated,
  metaRobots = "index,follow,max-image-preview:large"
} = Astro.props;

const canonical = absoluteUrl(path);
const imageUrl = absoluteUrl(ogImage);
const pageTitle = buildPageTitle(title);
const pageDescription = normalizeMetaDescription(description);
const pageSchemas = Array.isArray(schema) ? schema : [schema];
const allSchemas = [
  buildPersonSchema(),
  buildOrganizationSchema(),
  buildWebSiteSchema(),
  ...pageSchemas
].filter(Boolean);
const serializedSchemas = allSchemas.map((item) => JSON.stringify(item).replace(/</g, "\\u003c"));
const bingSiteVerification = import.meta.env.PUBLIC_BING_MS_VALIDATE?.trim() ?? "";
const uiRevealScript = `const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
const revealObserver = prefersReducedMotion
  ? null
  : new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver?.unobserve(entry.target);
        }
      });
    }, { threshold: 0.18 });

document.querySelectorAll('.reveal').forEach((element) => {
  if (!revealObserver) {
    element.classList.add('is-visible');
    return;
  }

  revealObserver.observe(element);
});`;
const analyticsScript = `window.dataLayer = window.dataLayer || [];
window.dataLayer.push({
  event: 'page_context',
  page_path: window.location.pathname,
  page_title: document.title,
  page_location: window.location.href
});

(() => {
  const AI_SOURCES = ['chatgpt', 'openai', 'perplexity', 'gemini', 'claude', 'copilot', 'you.com', 'phind'];
  const params = new URLSearchParams(window.location.search);
  const utmSource = (params.get('utm_source') || '').toLowerCase();
  const utmMedium = (params.get('utm_medium') || '').toLowerCase();
  let referrerHost = '';
  try {
    referrerHost = document.referrer ? new URL(document.referrer).hostname.toLowerCase() : '';
  } catch {}
  const matchedSource = AI_SOURCES.find((source) => utmSource.includes(source) || referrerHost.includes(source));
  if (!matchedSource && utmMedium !== 'ai' && utmMedium !== 'llm') return;
  window.dataLayer.push({
    event: 'ai_referral_session',
    ai_source: matchedSource || utmSource || 'unknown',
    ai_medium: utmMedium || 'referrer',
    ai_referrer_host: referrerHost || 'none',
    page_path: window.location.pathname,
    page_location: window.location.href
  });
})();

document.addEventListener('click', (event) => {
  const target = event.target;
  const link = target instanceof Element ? target.closest('a') : null;
  if (!link) return;

  const label = link.dataset.cta || link.dataset.download || link.textContent?.trim();
  if (!label) return;

  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: link.dataset.download ? 'resource_download_click' : 'cta_click',
    cta_label: label,
    cta_href: link.href,
    page_path: window.location.pathname
  });
});

document.addEventListener('submit', (event) => {
  const form = event.target;
  if (!(form instanceof HTMLFormElement)) return;
  if (form.hasAttribute('data-fc-intake-form')) return;
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: 'form_submit',
    form_id: form.id || form.name || 'unknown',
    form_action: form.action || 'unknown',
    page_path: window.location.pathname
  });
});`;
const gtmLoaderScript = `(() => {
  const gtmId = '${siteConfig.gtmId}';
  let loaded = false;
  const loadGtm = () => {
    if (loaded) return;
    loaded = true;
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ 'gtm.start': Date.now(), event: 'gtm.js' });
    const firstScript = document.getElementsByTagName('script')[0];
    if (!firstScript || !firstScript.parentNode) return;
    const gtm = document.createElement('script');
    gtm.async = true;
    gtm.src = 'https://www.googletagmanager.com/gtm.js?id=' + encodeURIComponent(gtmId);
    firstScript.parentNode.insertBefore(gtm, firstScript);
  };

  const schedule = () => {
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(loadGtm, { timeout: 2500 });
      return;
    }
    window.setTimeout(loadGtm, 1800);
  };

  if (document.readyState === 'complete') {
    schedule();
  } else {
    window.addEventListener('load', schedule, { once: true });
  }
})();`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b0b0c" />
    <!-- Analytics: dataLayer is initialized inline; GTM script is deferred until load/idle. -->
    <script is:inline set:html={analyticsScript}></script>
    <script is:inline set:html={gtmLoaderScript}></script>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={metaRobots} />
    {bingSiteVerification ? <meta name="msvalidate.01" content={bingSiteVerification} /> : null}
    <meta name="author" content={siteConfig.name} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Performance hints -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <!-- Calendly is linked from multiple CTAs — preconnect so the booking page opens fast. -->
    <link rel="preconnect" href="https://calendly.com" crossorigin />
    <link rel="dns-prefetch" href="https://calendly.com" />
    {preloadHeadshot && (
      <link
        rel="preload"
        as="image"
        href={siteConfig.headshot}
        fetchpriority="high"
      />
    )}

    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} — Writing`} href="/rss.xml" />

    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.twitterHandle} />
    <meta name="twitter:creator" content={siteConfig.twitterHandle} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={pageTitle} />

    <!-- Hints for AI answer engines (GEO). Values kept in sync with site.ts + llms.txt. -->
    <meta name="ai:summary" content={pageDescription} />
    <meta name="ai:role" content="Fractional CMO & AI-Native Growth Operator" />
    <meta name="ai:serves" content="Seed to Series B AI and B2B SaaS founders" />
    <meta name="ai:contact" content={siteConfig.bookingUrl} />

    <!-- Per-page <head> additions (e.g. extra font links). -->
    <slot name="head" />

    <!--email_off-->
    {serializedSchemas.map((json) => <script is:inline type="application/ld+json" set:html={json} />)}
    <!--/email_off-->
  </head>

  <body class="overflow-x-hidden">
    <!-- Google Tag Manager (noscript) — immediately after <body> per GTM install instructions. -->
    <noscript>
      <iframe
        height="0"
        src={`https://www.googletagmanager.com/ns.html?id=${siteConfig.gtmId}`}
        style="display:none;visibility:hidden"
        width="0"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <a class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-full focus:bg-black focus:px-4 focus:py-2 focus:text-white" href="#main-content">
      Skip to content
    </a>

    <SiteHeader currentPath={Astro.url.pathname} mediaCta={mediaCta} />

    <main class="site-main" id="main-content">
      <slot />
      {lastUpdated && (
        <section class="evergreen-updated shell" aria-label="Page freshness">
          <p>Last updated: {lastUpdated}</p>
        </section>
      )}
    </main>

    <SiteFooter mediaCta={mediaCta} />

    <StickyCta enabled={stickyCta} />

    <EasterEgg />
    <script is:inline set:html={uiRevealScript}></script>
  </body>
</html>
