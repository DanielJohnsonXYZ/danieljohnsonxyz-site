---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "I help ambitious startups build repeatable growth systems through sharp strategy, experimentation, and operator-level commercial judgment." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index,follow,max-image-preview:large">
  <link rel="canonical" href="https://danieljohnson.xyz/">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <meta property="og:site_name" content="Daniel Johnson">
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content="https://danieljohnson.xyz/">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@djohnsonxyz">
  <meta name="twitter:creator" content="@djohnsonxyz">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://danieljohnson.xyz/#person",
    "name": "Daniel Johnson",
    "jobTitle": "Growth strategist, fractional CMO, and speaker",
    "description": "Daniel Johnson is a growth strategist, speaker, and founder helping ambitious startups turn early traction into durable, repeatable growth systems.",
    "url": "https://danieljohnson.xyz",
    "image": "https://danieljohnson.xyz/images/daniel-headshot.png",
    "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "United Kingdom" },
    "worksFor": { "@type": "Organization", "name": "We Scale Startups", "url": "https://www.wescalestartups.com" },
    "sameAs": [
      "https://www.linkedin.com/in/danieljohnsonxyz/",
      "https://app.growthmentor.com/mentors/daniel-johnson",
      "https://www.wescalestartups.com"
    ]
  })} />
</head>
<body class="overflow-x-hidden">
  <a class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-full focus:bg-black focus:px-4 focus:py-2 focus:text-white" href="#main-content">Skip to content</a>

  <slot name="header" />
  <main class="site-main" id="main-content">
    <slot />
  </main>
  <slot name="footer" />

  <script>
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealObserver = prefersReducedMotion
      ? null
      : new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver?.unobserve(entry.target);
            }
          });
        }, { threshold: 0.18 });
    document.querySelectorAll('.reveal').forEach((element) => {
      if (!revealObserver) { element.classList.add('is-visible'); return; }
      revealObserver.observe(element);
    });
  </script>
</body>
</html>
