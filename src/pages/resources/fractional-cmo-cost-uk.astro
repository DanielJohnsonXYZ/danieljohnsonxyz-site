---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { buildBreadcrumbSchema, buildFaqPageSchema } from "../../lib/schema";
import { ctas, siteConfig } from "../../site";

const faq = [
  {
    question: "What do UK fractional CMO engagements typically cost?",
    answer:
      "Daniel’s public anchors are a £4k Strategy Sprint (2–4 weeks), £5k/month for embedded Fractional CMO (1 day/week, 3-month minimum), and £8k/month for Fractional CMO Plus (~2 days/week). Final scope depends on days per week, reporting depth, and how many channels need senior ownership."
  },
  {
    question: "What moves the price up or down?",
    answer:
      "Days per week, number of acquisition channels in scope, agency or contractor coordination, reporting and CRM hygiene, international go-to-market complexity, and how much of the first 90 days is diagnosis versus execution. A sprint is fixed-duration; ongoing retainers scale with embedded time."
  },
  {
    question: "How does a monthly retainer relate to a quoted day rate?",
    answer:
      "Useful fractional work is priced as embedded days per week with clear scope, not ad-hoc hours. If you reverse-engineer £5k/month for roughly one day a week, you get a blended four-figure GBP day equivalent before VAT (roughly £156/hour at ~32 hours a month), but quoting day rate without rhythm, channels-in-scope, and reporting depth is what creates mismatched expectations. The Growth Audit aligns those inputs before a retainer is final."
  },
  {
    question: "When is a Strategy Sprint enough without a retainer?",
    answer:
      "When leadership needs diagnosis, a 90-day priority stack, and first artefacts or tests, and already has a credible internal owner for weekly execution after the sprint. If nobody will run the cadence, learning stalls and the sprint becomes a deck. For engagement-shape trade-offs, see Compare six growth options on this site."
  },
  {
    question: "How does that compare to a full-time UK CMO?",
    answer:
      "A full-time marketing leader is often £120–180k base plus bonus, pension, and recruitment fees, with a multi-month ramp. Fractional work buys senior judgement in days per week without that fixed cost. See the full-time comparison page for TCO framing."
  },
  {
    question: "How does it compare to a marketing agency retainer?",
    answer:
      "Agency retainers often land in a similar monthly band for execution-heavy scopes, but the job is different: agencies run channels; a fractional CMO owns cross-channel priorities, narrative, and the weekly decision rhythm. Many post-PMF teams use both, with fractional setting the system and the agency executing one channel inside it. See Fractional CMO vs agency."
  },
  {
    question: "Is VAT included?",
    answer:
      "Quotes are discussed on the call. UK B2B buyers should assume VAT may apply depending on entity and place of supply. The Growth Audit call is the right place to align commercial shape."
  },
  {
    question: "Where can I model ROI in UK terms?",
    answer:
      "Use the on-site ROI calculator to stress-test payback against your pipeline assumptions, then book a Growth Audit if you want a human read on whether fractional support fits."
  }
];

const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Resources", url: "/resources/" },
    { name: "Fractional CMO cost (UK)", url: "/resources/fractional-cmo-cost-uk/" }
  ]),
  buildFaqPageSchema(faq)
];

const anchors = [
  {
    title: "Strategy Sprint",
    range: "From £4,000",
    body: "Two to four weeks. Diagnosis, 90-day priorities, first artefacts, and the first tests in motion. Best when you need clarity and momentum before a retainer."
  },
  {
    title: "Fractional CMO",
    range: "From £5,000 / month",
    body: "One day a week of embedded senior ownership, 3-month minimum. Weekly rhythm, reporting, acquisition and positioning decisions, team and agency context."
  },
  {
    title: "Fractional CMO Plus",
    range: "From £8,000 / month",
    body: "Roughly two days a week. For teams that need faster execution, heavier agency management, or more parallel channel work while keeping one senior owner."
  }
];

const ukBands = [
  {
    title: "£4k sprint band",
    expect:
      "Fixed window, heavy diagnosis, prioritised 90-day plan, first credible tests or artefacts. Not a substitute for an internal owner if you need ongoing weekly leadership."
  },
  {
    title: "≈£5k / month band",
    expect:
      "One embedded day a week: weekly steering, clearer narrative and channel bets, reporting discipline, agency or junior marketer direction. Best when complexity is real but not every function needs daily executive cover."
  },
  {
    title: "≈£8k / month band",
    expect:
      "Roughly two days a week: faster iteration, heavier stakeholder surface, multi-channel or international complexity, more parallel experiments while keeping a single senior owner accountable."
  }
];
---

<BaseLayout
  description="UK fractional CMO cost guide: benchmark ranges for sprints and retainers, what moves price, comparison to a full-time hire, and ROI modelling."
  keywords="fractional CMO cost UK, fractional CMO pricing UK, CMO retainer UK, startup marketing leadership cost"
  path="/resources/fractional-cmo-cost-uk/"
  schema={schemas}
  stickyCta={false}
  title="Fractional CMO Cost (UK) | Daniel Johnson"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <span class="service-label justify-center">Pricing · UK context</span>
        <h1 class="text-5xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-7xl">
          What a UK fractional CMO <span class="hero-accent">actually costs</span>
        </h1>
        <p class="hero-subcopy mx-auto max-w-2xl text-lg leading-8 md:text-xl">
          Public anchors for sprint and retainer work, what changes the number, and how that compares to a full-time hire, so finance and founders can sanity-check the decision before a call.
        </p>
        <div class="flex flex-wrap justify-center gap-3 pt-2">
          <a class="button-accent" href="/growth-audit/" data-cta="cost-uk-primary">
            {ctas.primary.label} →
          </a>
          <a class="button-link" href="/roi-calculator/" data-cta="cost-uk-roi">
            Model ROI (UK) →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Benchmarks"
        title="Three shapes founders actually buy."
        intro="These are the same anchors as the Fractional CMO service page, repeated here for search and finance reviewers who land on cost-first queries."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {anchors.map((tier) => (
          <article class="card p-7">
            <p class="card-label">{tier.title}</p>
            <p class="mt-3 text-2xl font-extrabold tracking-[-0.05em]">{tier.range}</p>
            <p class="mt-4 leading-7 text-[color:var(--muted)]">{tier.body}</p>
          </article>
        ))}
      </div>
      <p class="mt-8 text-center text-sm leading-7 text-[color:var(--muted)]">
        Full scope, week structure, and fit filters live on{" "}
        <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/fractional-cmo/">
          the Fractional CMO page
        </a>
        . TCO versus a full-time CMO is on{" "}
        <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/resources/fractional-cmo-vs-full-time-cmo/">
          the comparison page
        </a>
        .
      </p>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-start">
      <div>
        <SectionHeader
          eyebrow="UK benchmarks"
          title="How these numbers sit in the UK market."
          intro="Founders compare fractional support with London-weighted marketing leadership salaries, specialist agency retainers, and senior independent day rates. These anchors are intentionally public so the first conversation is about fit, not sticker shock."
        />
        <ul class="mt-6 space-y-3 text-base leading-7 text-[color:var(--muted)]">
          <li>
            <strong class="text-[color:var(--ink)]">Full-time CMO/VP Marketing:</strong> all-in employer cost often lands meaningfully above £120k base once bonus,
            pension, tools, and recruiter fees are included, before ramp.
          </li>
          <li>
            <strong class="text-[color:var(--ink)]">Agency retainers:</strong> many specialist B2B agencies sit in a wide £6k–£20k/month band depending on channel depth
            and account team seniority. That buys execution, not executive GTM ownership.
          </li>
          <li>
            <strong class="text-[color:var(--ink)]">Senior independents:</strong> day rates vary by urgency, sector, and scope; credible operators are rarely “cheap per hour”
            if the work is true leadership, not slide production.
          </li>
        </ul>
      </div>
      <article class="card-muted p-6 md:p-8">
        <p class="card-label">Monthly retainer vs day-rate framing</p>
        <p class="mt-4 leading-7 text-[color:var(--muted)]">
          Retainers should reflect a <strong class="text-[color:var(--ink)]">weekly rhythm and decision surface</strong>, not a laundry list of tasks billed as fractional
          hours. Day-rate quotes can be useful for finance models, but without “days per week + what is in scope,” they mislead both sides.
        </p>
        <p class="mt-4 leading-7 text-[color:var(--muted)]">
          If you are modelling cash flow, assume a <strong class="text-[color:var(--ink)]">3-month minimum</strong> on ongoing fractional work alongside any sprint you run first.
          VAT may apply depending on entity and place of supply; confirm on the call, not in a blog footnote.
        </p>
        <p class="mt-4 text-sm leading-6 text-[color:var(--muted)]">
          Essay with wider pricing context:{" "}
          <a class="font-semibold text-[color:var(--accent)] underline underline-offset-4" href="/writing/fractional-cmo-pricing-benchmarks/">
            Fractional CMO pricing benchmarks →
          </a>
        </p>
      </article>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-start">
      <div>
        <span class="service-label text-white/80">What moves price</span>
        <h2 class="mt-4 text-3xl font-extrabold tracking-[-0.05em] text-white md:text-4xl">Senior judgement is priced in days per week and decision surface area.</h2>
        <p class="mt-4 leading-8 text-white/75">
          More channels, more stakeholders, weaker reporting, or a messy handoff from founder-led sales usually increases the time required to run a clean weekly rhythm. That is why the call focuses on bottleneck and team shape before quoting.
        </p>
        <p class="mt-4 leading-8 text-white/75">
          Geography rarely changes the underlying economics for remote-first engagements: UK buyers still benchmark against London salary bands and agency rate cards even when the operator is distributed.
        </p>
      </div>
      <ul class="grid gap-3 text-white">
        {[
          "Embedded days per week (1 vs ~2)",
          "Depth of reporting, CRM, and funnel instrumentation",
          "Number of live acquisition experiments in parallel",
          "Agency or contractor coordination load",
          "International or multi-segment GTM complexity"
        ].map((item) => (
          <li class="rounded-2xl border border-white/15 bg-white/5 px-5 py-4 text-sm font-semibold leading-6">{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Comparison"
        title="Fractional vs agency vs full-time: different jobs, different invoices."
        intro="The right choice is usually a function of whether you need executive GTM ownership, channel execution, or a permanent internal executive layer, not which line item looks smallest in isolation."
      />
      <div class="mt-10 grid gap-4 lg:grid-cols-3">
        <article class="card p-7">
          <p class="card-label">Fractional CMO</p>
          <p class="mt-3 text-sm font-semibold text-[color:var(--accent)]">From £5–8k / month (public anchors)</p>
          <p class="mt-4 leading-7 text-[color:var(--muted)]">
            Owns priorities, narrative, weekly rhythm, and team/agency direction in a part-time embedded cadence. Best when complexity is real but a full-time exec hire is premature.
          </p>
          <a class="mt-4 inline-block font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/fractional-cmo/">
            Service scope →
          </a>
        </article>
        <article class="card p-7">
          <p class="card-label">Agency</p>
          <p class="mt-3 text-sm font-semibold text-[color:var(--accent)]">Often £6k–£20k / month depending on scope</p>
          <p class="mt-4 leading-7 text-[color:var(--muted)]">
            Delivers channel work with an account team. Strong when the strategy is already sound and you need throughput. Weak when leadership still cannot agree what to sell or to whom.
          </p>
          <a class="mt-4 inline-block font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/resources/fractional-cmo-vs-agency/">
            Fractional vs agency →
          </a>
        </article>
        <article class="card p-7">
          <p class="card-label">Full-time CMO</p>
          <p class="mt-3 text-sm font-semibold text-[color:var(--accent)]">Typically £120–£180k+ base (UK)</p>
          <p class="mt-4 leading-7 text-[color:var(--muted)]">
            Right when you need always-on executive leadership and internal headcount. Higher TCO, longer ramp, and a longer commitment, often preceded by fractional work to stabilise the system.
          </p>
          <a class="mt-4 inline-block font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/resources/fractional-cmo-vs-full-time-cmo/">
            Fractional vs full-time →
          </a>
        </article>
      </div>
      <p class="mt-8 text-center text-sm text-[color:var(--muted)]">
        Six-option menu (freelancer, junior hire, consultant, agency, full-time, fractional):{" "}
        <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/resources/compare-growth-options/">
          Compare growth options →
        </a>
      </p>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Expectations" title="What you should expect at each public anchor." intro="Bands describe judgement and cadence, not vanity deliverable counts." />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {ukBands.map((band) => (
          <article class="card-muted p-6">
            <p class="card-label">{band.title}</p>
            <p class="mt-4 leading-7 text-[color:var(--muted)]">{band.expect}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space pt-0" id="faq" aria-label="Fractional CMO cost FAQ">
    <div class="shell">
      <SectionHeader eyebrow="FAQ" title="Cost questions that show up before the first call." />
      <div class="faq-stack mt-8 mx-auto max-w-3xl">
        {faq.map((item, index) => (
          <details class="faq-item" open={index === 0}>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <article class="card grid gap-6 p-8 md:grid-cols-[1fr_auto] md:items-center md:p-10">
        <div>
          <p class="card-label">Next step</p>
          <h2 class="mt-3 text-3xl font-extrabold tracking-[-0.05em]">Sanity-check the number against your pipeline.</h2>
          <p class="mt-3 text-[color:var(--muted)]">
            Use the ROI calculator, then book a 20-minute Growth Audit if you want a direct read on fit. No pitch deck, no obligation.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <a class="button-accent" href="/roi-calculator/" data-cta="cost-uk-footer-roi">
            Open ROI calculator →
          </a>
          <a class="button-link" href="/growth-audit/" data-cta="cost-uk-footer-book">
            {siteConfig.bookingLabel} →
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
