---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../../lib/schema";

const schema = buildBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Resources", url: "/resources/" }
]);

// Grouped by the question the visitor is actually asking, most-used groups first.
const groups = [
  {
    label: "Pricing",
    items: [
      { href: "/resources/fractional-cmo-cost-uk/", label: "Fractional CMO cost (UK)", description: "Benchmark ranges, what moves price, and the full-time comparison." },
      { href: "/roi-calculator/", label: "ROI calculator", description: "Plug in your numbers and model the payback on senior GTM help." }
    ]
  },
  {
    label: "Comparisons",
    items: [
      { href: "/resources/compare-growth-options/", label: "Compare six growth options", description: "Agency, freelancer, junior hire, full-time, consultant, fractional." },
      { href: "/resources/fractional-cmo-vs-agency/", label: "Fractional CMO vs. agency", description: "Who owns strategy, who executes, and when you need both." },
      { href: "/resources/fractional-cmo-vs-full-time-cmo/", label: "Fractional CMO vs. full-time CMO", description: "Cost, speed, risk, and the bridge-to-hire pattern." }
    ]
  },
  {
    label: "Diagnostics",
    items: [
      { href: "/growth-bottleneck-checklist/", label: "Growth bottleneck checklist", description: "Self-diagnose where your growth system is leaking." },
      { href: "/resources/faq/", label: "FAQ", description: "The questions founders ask before a first call." }
    ]
  },
  {
    label: "Definitions",
    items: [
      { href: "/resources/glossary/", label: "Glossary", description: "The terms used across this site, defined plainly." }
    ]
  },
  {
    label: "Media & updates",
    items: [
      { href: "/podcast-guest/", label: "Podcast guest", description: "Topics, sample questions, and producer assets." },
      { href: "/newsletter/", label: "Growth Notes", description: "Practical founder-led GTM, one email at a time." }
    ]
  }
];
---

<BaseLayout
  description="Resources hub: FAQ, glossary, fractional CMO comparisons, UK pricing guide, ROI calculator, and diagnostics for founders comparing GTM support options."
  path="/resources/"
  schema={schema}
  title="Resources | Daniel Johnson"
>
  <section class="section-space conversion-hero">
    <div class="shell">
      <span class="service-label">Resources</span>
      <h1 class="mt-4 max-w-4xl text-5xl font-semibold tracking-[-0.07em] text-balance md:text-7xl">
        Guides, comparisons, and definitions for high-intent GTM questions.
      </h1>
      <p class="conversion-subcopy mt-6 max-w-3xl text-lg leading-9 text-[color:var(--muted)]">
        For founders, finance reviewers, and operators weighing up GTM support: what a fractional CMO costs in the UK,
        how the options compare, and how to diagnose your own growth bottleneck before you spend anything.
      </p>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell grid gap-10">
      {
        groups.map((group) => (
          <div>
            <h2 class="card-label">{group.label}</h2>
            <ul class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {group.items.map((item) => (
                <li>
                  <a class="card block h-full p-6 transition-colors hover:border-[color:var(--accent)]" href={item.href}>
                    <span class="block text-lg font-bold tracking-[-0.03em]">{item.label}</span>
                    <span class="mt-2 block text-sm leading-6 text-[color:var(--muted)]">{item.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
