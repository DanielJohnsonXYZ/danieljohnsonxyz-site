---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout description="Page not found." title="Not Found | Daniel Johnson">
  <section class="section-space">
    <div class="shell">
      <div class="reveal card mx-auto max-w-3xl p-8 text-center md:p-12">
        <span class="eyebrow">404</span>
        <h1 class="mt-6 text-4xl font-semibold tracking-[-0.05em] md:text-6xl">That page is not here.</h1>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-[color:var(--muted)]">
          The content may have moved, or the link may be outdated. The home page is the best place to start again.
        </p>
        <div class="mt-8">
          <a class="button-primary" href="/">Back Home</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
