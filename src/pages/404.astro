---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site";
---

<BaseLayout
  description="That page is not on this site. Start again from home, Start here, or writing."
  path="/404"
  title="Not Found | Daniel Johnson"
  metaRobots="noindex,follow"
  stickyCta={false}
>
  <section class="section-space" aria-labelledby="dj-404-title">
    <div class="shell">
      <div class="reveal card mx-auto max-w-3xl p-8 text-center md:p-12">
        <span class="eyebrow">404</span>
        <h1 id="dj-404-title" class="mt-6 text-4xl font-semibold tracking-[-0.05em] md:text-6xl">
          That page is not here.
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-[color:var(--muted)]">
          The content may have moved, or the link may be outdated. Pick a common destination below or go home.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a class="button-primary" href="/" data-cta="404-home">Home</a>
          <a class="button-secondary" href="/start-here/" data-cta="404-start-here">Start here</a>
          <a class="button-secondary" href="/writing/" data-cta="404-writing">Writing</a>
          <a class="button-secondary" href="/fractional-cmo/" data-cta="404-fractional-cmo">Fractional CMO</a>
        </div>
        <nav class="mt-10 border-t border-[color:var(--line)] pt-8 text-left" aria-label="More recovery links">
          <p class="text-sm font-semibold text-[color:var(--ink)]">Related</p>
          <ul class="mt-4 space-y-2 text-sm text-[color:var(--muted)]">
            <li>
              <a class="link-arrow" href="/newsletter/#newsletter-signup" data-cta="404-newsletter">Newsletter signup →</a>
            </li>
            <li>
              <a class="link-arrow" href={siteConfig.companyUrl + "/"} data-cta="404-wss-company">
                {siteConfig.companyName} — growth systems for teams →
              </a>
            </li>
            <li>
              <a class="link-arrow" href={siteConfig.companyUrl + "/newsletter/"} data-cta="404-wss-newsletter">
                We Scale Startups newsletter →
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>
