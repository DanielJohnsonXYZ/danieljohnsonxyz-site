---
import CfEmailOff from "../components/CfEmailOff.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { buildFaqPageSchema } from "../lib/schema";
import { siteConfig } from "../site";

const focusAreas = [
  "Finding the real GTM bottleneck before adding more activity",
  "Sharper customer, problem, message, and journey decisions",
  "Prioritising experiments by impact, confidence, and ease",
  "Turning founder instinct into a cadence the team can keep using"
];

const sessionShapes = [
  {
    title: "Founder session",
    body: "A focused working session for a specific growth, positioning, acquisition, or funnel decision."
  },
  {
    title: "Mentor sprint",
    body: "A short sequence of sessions for founders who need accountability while they turn insight into experiments."
  },
  {
    title: "Programme support",
    body: "Mentoring for accelerator, university, or ecosystem programmes that want practical GTM guidance for cohorts."
  }
];

const faq = [
  {
    question: "Who is mentoring a good fit for?",
    answer: "Mentoring is best for early-stage founders, solo operators, and product leads who already have momentum but want a sharper read on customer, message, funnel, or the next experiment. It suits people who want senior GTM judgment in the room for a specific decision, rather than a long engagement."
  },
  {
    question: "How is mentoring different from advisory or fractional CMO work?",
    answer: "Mentoring is lighter-touch and session-led. The founder owns the decision; Daniel provides direct senior input, challenges assumptions, and helps reframe the problem. Advisory adds a repeating cadence across growth decisions. Fractional CMO is embedded leadership across GTM, positioning, reporting, and hiring. Mentoring is the lightest useful level of support."
  },
  {
    question: "What happens in a typical mentoring session?",
    answer: "The founder brings the real, messy decision — a positioning call, a funnel drop-off, a channel choice, a narrative problem. The session is a working conversation that ends with a clearer read on the customer, a sharper decision, and a concrete next move. It is practical, not theoretical."
  },
  {
    question: "How long are sessions and how are they structured?",
    answer: "Most founder sessions are 45-60 minutes. Mentor sprints run as a short sequence of 3-5 sessions over a few weeks for founders who want accountability while turning insight into experiments. Programme mentoring is scoped per cohort."
  },
  {
    question: "Does mentoring work for accelerators and university programmes?",
    answer: "Yes. Daniel mentors for accelerators, university entrepreneurship programmes, and ecosystem initiatives that want practical GTM guidance for founder cohorts. Engagements are scoped around cohort stage, format, and desired outcomes."
  },
  {
    question: "How do I know if I need mentoring instead of advisory?",
    answer: "Choose mentoring if you have a specific decision or bottleneck and want a sharp working session on it. Choose advisory if you want a repeating rhythm across multiple growth decisions. Choose fractional CMO support if you need senior marketing leadership embedded in the team. If it is unclear, the 30-minute diagnosis call is the right starting point."
  },
  {
    question: "What does a mentoring engagement cost?",
    answer: "Pricing depends on session count, cadence, and whether the engagement is with an individual founder, a company, or a programme. Daniel shares a direct quote after the initial diagnosis call once the scope and format are clear."
  },
  {
    question: "How do I start?",
    answer: "Book a 30-minute diagnosis call. We identify the current growth or decision bottleneck, discuss the context, and decide whether a single mentoring session, a mentor sprint, or a different engagement is the best next step. It is a diagnosis, not a pitch."
  }
];
---

<BaseLayout
  description="Mentoring sessions with Daniel Johnson for founders who need sharper GTM, customer, and growth decisions."
  keywords="founder mentoring, GrowthMentor, startup GTM advice, office hours growth"
  path="/mentoring"
  schema={buildFaqPageSchema(faq)}
  title="Mentoring | Daniel Johnson"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div class="reveal flex flex-col gap-6">
          <span class="service-label">Mentoring</span>
          <h1 class="max-w-5xl text-5xl font-extrabold leading-[0.98] tracking-[-0.07em] text-balance md:text-7xl">
            Focused founder support when the next growth decision matters.
          </h1>
          <p class="max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            Practical sessions for founders who need a clearer read on the customer, message, funnel, or next experiment.
          </p>
          <div class="flex flex-wrap gap-3">
            <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
            <CfEmailOff>
              <a class="button-secondary" href={`mailto:${siteConfig.email}?subject=Mentoring%20enquiry`}>Ask about mentoring</a>
            </CfEmailOff>
          </div>
        </div>

        <article class="reveal card p-6 md:p-8">
          <p class="card-label">Best fit</p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-[-0.05em]">
            Founders who want sharper judgment, not a generic marketing checklist.
          </h2>
          <ul class="mt-6 list-disc space-y-3 pl-5 text-base leading-7 text-[color:var(--muted)] marker:text-[color:var(--accent)]">
            {focusAreas.map((item) => <li class="pl-1">{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="section-head">
        <div class="section-head-grid">
          <div class="space-y-5">
            <span class="eyebrow">Session formats</span>
            <h2 class="section-title">Use the lightest useful level of support.</h2>
          </div>
          <p class="lede">
            The work is direct, practical, and tied to the decision in front of the founder.
          </p>
        </div>
      </div>

      <div class="signal-map-grid reveal">
        {
          sessionShapes.map((item) => (
            <article>
              <span>Mentoring</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="FAQ"
        intro="A few practical questions founders and programme teams usually ask before booking a session."
        title="Common questions."
      />
      <div class="faq-stack mt-10">
        {
          faq.map((item, index) => (
            <details class="reveal faq-item card p-6 md:p-7" open={index === 0}>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-gradient section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-8 text-center">
        <span class="eyebrow justify-center text-white/60">Next step</span>
        <h2 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance text-white md:text-7xl">
          Bring the messy decision. Leave with the next move.
        </h2>
        <p class="mx-auto max-w-2xl text-lg leading-8 text-white/68">
          Useful for founders, accelerators, and teams that need practical GTM judgment in the room.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">Book a mentoring session</a>
          <CfEmailOff>
            <a class="button-secondary button-secondary-dark" href={`mailto:${siteConfig.email}?subject=Mentoring%20enquiry`}>Ask about mentoring</a>
          </CfEmailOff>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
