---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ctas } from "../site";
---

<BaseLayout
  title="Growth Experimentation for Startups | Daniel Johnson"
  description="Experimentation systems for post-PMF startups: prioritisation, hypotheses, test design, learning loops, and decision cadence."
  path="/experimentation"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="service-label">Experimentation</span>
        <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">Run fewer experiments and learn more from each one.</h1>
        <p class="hero-subcopy text-xl leading-9 md:text-2xl">A practical system for prioritising tests, writing useful hypotheses, setting decision rules, and turning results into better growth judgement.</p>
        <div class="flex flex-wrap gap-3">
          <a class="button-accent" href={ctas.primary.href}>{ctas.primary.label} →</a>
          <a class="button-link" href={ctas.bottleneck.href}>{ctas.bottleneck.label} →</a>
        </div>
      </div>
    </div>
  </section>
  <section class="section-space pt-0">
    <div class="shell grid gap-5 md:grid-cols-3">
      <article class="card p-6"><h2 class="text-2xl font-bold">Outputs</h2><p class="mt-3 text-[color:var(--muted)]">Experiment backlog, scoring model, test briefs, weekly review cadence, and learning archive.</p></article>
      <article class="card p-6"><h2 class="text-2xl font-bold">Best For</h2><p class="mt-3 text-[color:var(--muted)]">Teams doing lots of marketing work but struggling to explain what they have learned.</p></article>
      <article class="card p-6"><h2 class="text-2xl font-bold">What Changes</h2><p class="mt-3 text-[color:var(--muted)]">Growth activity becomes a learning system tied to revenue, conversion, and pipeline quality.</p></article>
    </div>
  </section>
</BaseLayout>
