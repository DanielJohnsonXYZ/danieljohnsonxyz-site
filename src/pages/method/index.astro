---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../../lib/schema";
import { absoluteUrl } from "../../lib/utils";
import { ctas } from "../../site";

const methodSchema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Method",
    description:
      "The operating method behind the work: GTM systems, AI-native workflows, experimentation, revenue operations, product-led growth, and founder-led distribution.",
    url: absoluteUrl("/method/")
  },
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Method", url: "/method/" }
  ])
];

const methods = [
  { href: "/gtm-systems/", label: "GTM systems", description: "ICP, positioning, and channel architecture — the system the rest plugs into." },
  { href: "/ai-native-workflows/", label: "AI-native workflows", description: "Practical AI inside the growth function — research, content, and ops that compound." },
  { href: "/experimentation/", label: "Experimentation", description: "A weekly test cadence and decision rules so the team learns fast and scales what works." },
  { href: "/revenue-operations/", label: "Revenue operations", description: "Reporting, attribution, and the weekly growth meeting that keeps decisions honest." },
  { href: "/product-led-growth/", label: "Product-led growth", description: "Activation, onboarding, and in-product growth loops that lower CAC." },
  { href: "/founder-led-distribution/", label: "Founder-led distribution", description: "Turning the founder's reach into a repeatable, transferable channel." }
];
---

<BaseLayout
  title="Method | Daniel Johnson"
  description="The operating method behind the work: GTM systems, AI-native workflows, experimentation, revenue operations, product-led growth, and founder-led distribution."
  path="/method/"
  schema={methodSchema}
>
  <section class="section-space">
    <div class="shell">
      <p class="service-label">Method</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-[-0.07em] text-balance md:text-7xl">How the growth system actually works.</h1>
      <p class="conversion-subcopy mt-6 max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">Six layers that turn founder-dependent growth into a repeatable, transferable system. Each one is a working playbook, not a buzzword.</p>
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {methods.map((m) => (
          <a class="card p-6 transition-colors hover:border-[color:var(--accent)]" href={m.href}>
            <h2 class="text-xl font-bold tracking-[-0.04em]">{m.label}</h2>
            <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{m.description}</p>
            <span class="link-arrow mt-5 inline-block">Explore</span>
          </a>
        ))}
      </div>
      <div class="mt-12 flex flex-wrap gap-3">
        <a class="button-accent" href={ctas.primary.href} data-cta="method-primary">{ctas.primary.label}</a>
        <a class="button-secondary" href="/work-with-me/" data-cta="method-services">See the engagements</a>
      </div>
    </div>
  </section>
</BaseLayout>
