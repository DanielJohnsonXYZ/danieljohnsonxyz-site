---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ctas } from "../site";
---

<BaseLayout
  title="GTM Systems for AI & B2B SaaS Startups | Daniel Johnson"
  description="GTM systems for post-PMF AI and B2B SaaS startups: ICP, positioning, channel strategy, acquisition design, and operating cadence."
  path="/gtm-systems"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="service-label">GTM Systems</span>
        <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">Turn messy GTM into a system your team can run.</h1>
        <p class="hero-subcopy text-xl leading-9 md:text-2xl">For founders with traction, unclear channel sequence, and too many growth decisions living in the founder's head.</p>
        <div class="flex flex-wrap gap-3">
          <a class="button-accent" href={ctas.primary.href}>{ctas.primary.label} →</a>
          <a class="button-link" href={ctas.bottleneck.href}>{ctas.bottleneck.label} →</a>
        </div>
      </div>
    </div>
  </section>
  <section class="section-space pt-0">
    <div class="shell grid gap-5 md:grid-cols-3">
      <article class="card p-6"><h2 class="text-2xl font-bold">Outputs</h2><p class="mt-3 text-[color:var(--muted)]">ICP, positioning, channel strategy, experiment roadmap, reporting cadence, and handoff rules.</p></article>
      <article class="card p-6"><h2 class="text-2xl font-bold">Best For</h2><p class="mt-3 text-[color:var(--muted)]">Seed to Series B teams where acquisition exists but pipeline is inconsistent or hard to explain.</p></article>
      <article class="card p-6"><h2 class="text-2xl font-bold">What Changes</h2><p class="mt-3 text-[color:var(--muted)]">The team gets a shared operating system instead of another list of tactics.</p></article>
    </div>
  </section>
</BaseLayout>
