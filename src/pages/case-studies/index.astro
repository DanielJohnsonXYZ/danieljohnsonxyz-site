---
import { getCollection } from "astro:content";
import SectionHeader from "../../components/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, sortByFeaturedThenOrder } from "../../lib/utils";
import { siteConfig } from "../../site";

const caseStudies = sortByFeaturedThenOrder(await getCollection("caseStudies"));

// Honest state: if we only have one case study live, the page still needs
// to look intentional rather than thin. These "coming next" placeholders
// render as upcoming cards so the grid isn't a single lonely tile.
const comingNext = [
  {
    stage: "Series A",
    sector: "AI DevTools",
    title: "CAC down 35% in 8 weeks by rebuilding paid structure and ICP segmentation.",
    description:
      "Full write-up publishing shortly — the short version is in the homepage proof strip. Book a call and I'll walk you through the detail now."
  },
  {
    stage: "Seed",
    sector: "US B2B Fintech",
    title: "500+ qualified signups from a single campaign at 8.6% CTR.",
    description:
      "Engagement diagnosed ICP and positioning before touching channel. Publishing the detailed write-up after client review."
  },
  {
    stage: "Growth",
    sector: "eCommerce",
    title: "21% less churn in 90 days through lifecycle and win-back messaging.",
    description:
      "Case study in final review with the client. Email daniel@wescalestartups.com if you'd like the numbers in the meantime."
  }
];
---

<BaseLayout
  description="Case studies and outcomes from Daniel Johnson's fractional CMO, growth operator, and GTM engagements with post-PMF AI and B2B SaaS startups. Real numbers, real attribution."
  path="/case-studies"
  title="Case studies | Fractional CMO engagements | Daniel Johnson"
>
  <section class="section-space">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div class="reveal max-w-4xl space-y-6">
          <span class="service-label">Case studies</span>
          <h1 class="text-5xl font-semibold tracking-[-0.07em] text-balance md:text-7xl">
            What the work actually looks like.
          </h1>
          <p class="max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            Selected engagements, anonymised where needed. Each one is written to show the starting bottleneck, the approach, and the decision changes that produced the outcome — not just the headline number.
          </p>
        </div>

        <aside class="reveal card p-6 md:p-8">
          <p class="card-label">How to read these</p>
          <div class="mt-6 grid gap-4">
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you're evaluating fit</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">
                Look at the stage, engagement mode, and starting bottleneck — not the metrics.
              </p>
            </article>
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you're solving a similar problem</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">
                The approach section is the important part. Metrics are context, not the claim.
              </p>
            </article>
          </div>
          <div class="mt-6 rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-4">
            <p class="text-sm font-bold tracking-[-0.02em]">{siteConfig.availability}</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Engagements"
        intro="Embedded GTM leadership, fractional CMO, and focused sprint work across AI, B2B SaaS, and founder-led startups."
        title="Selected case studies."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        {
          caseStudies.map((item) => (
            <article class="reveal card p-6 md:p-8">
              <div class="flex flex-wrap items-center gap-2">
                <span class="chip">{item.data.engagementMode}</span>
                <span class="chip">{item.data.stage}</span>
                <span class="chip">{item.data.sector}</span>
              </div>
              <h2 class="mt-5 text-2xl font-bold tracking-[-0.04em] md:text-3xl">
                <a class="link-cover" href={`/case-studies/${item.id}`}>{item.data.title}</a>
              </h2>
              <p class="mt-4 text-base leading-7 text-[color:var(--muted)]">{item.data.description}</p>
              {item.data.metrics && item.data.metrics.length > 0 && (
                <dl class="mt-6 grid grid-cols-3 gap-4 border-t border-[color:var(--line)] pt-5">
                  {item.data.metrics.slice(0, 3).map((metric) => (
                    <div>
                      <dt class="mono text-[0.68rem] uppercase tracking-[0.16em] text-[color:var(--muted)]">{metric.label}</dt>
                      <dd class="mt-2 text-2xl font-extrabold tracking-[-0.05em]">{metric.value}</dd>
                    </div>
                  ))}
                </dl>
              )}
              <div class="mt-6 flex items-center justify-between text-sm text-[color:var(--muted)]">
                <span>{item.data.timeframe}</span>
                <span>{formatDate(item.data.publishedAt)}</span>
              </div>
              <a class="link-arrow mt-5" href={`/case-studies/${item.id}`}>Read the full case study →</a>
            </article>
          ))
        }
      </div>

      <!-- "Coming next" placeholders so the page doesn't look thin at one live case study. -->
      {caseStudies.length < 3 && (
        <div class="mt-10">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--muted)]">Publishing next</p>
          <div class="grid gap-5 lg:grid-cols-2">
            {comingNext.map((item) => (
              <article class="card p-6 md:p-8 bg-[color:var(--surface-dim)] border-dashed">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="chip">{item.stage}</span>
                  <span class="chip">{item.sector}</span>
                  <span class="chip bg-[color:var(--accent)]/10 text-[color:var(--accent)]">Publishing next</span>
                </div>
                <h2 class="mt-5 text-2xl font-bold tracking-[-0.04em] md:text-3xl">
                  {item.title}
                </h2>
                <p class="mt-4 text-base leading-7 text-[color:var(--muted)]">{item.description}</p>
                <a class="link-arrow mt-5" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
                  Ask for the numbers on a call →
                </a>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Start Here</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              Have a similar bottleneck?
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              Start with a 30-minute growth diagnosis. You'll know whether the right next step is a sprint, advisory rhythm, fractional support, or no engagement at all.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
            <a class="button-secondary" href={`mailto:${siteConfig.email}`}>Email Daniel</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
