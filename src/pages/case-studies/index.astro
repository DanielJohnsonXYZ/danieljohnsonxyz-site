---
import { getCollection } from "astro:content";
import CfEmailOff from "../../components/CfEmailOff.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../../lib/schema";
import { absoluteUrl, formatDate, sortByFeaturedThenOrder } from "../../lib/utils";
import { siteConfig } from "../../site";

const caseStudies = sortByFeaturedThenOrder(await getCollection("caseStudies"));

const sectors = [...new Set(caseStudies.map((c) => c.data.sector))].sort();
const modes = [...new Set(caseStudies.map((c) => c.data.engagementMode))].sort();
const tagSet = new Set<string>();
caseStudies.forEach((c) => c.data.tags.forEach((t) => tagSet.add(t)));
const filterTags = [...tagSet].sort((a, b) => a.localeCompare(b));

const caseStudiesSchema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Case studies",
    description:
      "Fractional CMO case studies for post-PMF AI and B2B SaaS companies, with bottlenecks, interventions, and measurable outcomes.",
    url: absoluteUrl("/case-studies/")
  },
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Case studies", url: "/case-studies/" }
  ])
];
---

<BaseLayout
  description="Explore Daniel Johnson's fractional CMO case studies for post-PMF AI and B2B SaaS companies, with bottlenecks, interventions, and measurable outcomes."
  path="/case-studies/"
  schema={caseStudiesSchema}
  title="Case studies | Fractional CMO engagements"
>
  <section class="section-space conversion-hero">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div class="reveal max-w-4xl space-y-6">
          <span class="service-label">Case studies</span>
          <h1 class="text-5xl font-semibold tracking-[-0.07em] text-balance md:text-7xl">
            What the work actually looks like.
          </h1>
          <p class="conversion-subcopy max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            Selected engagements, anonymised where needed. Each one is written to show the starting bottleneck, the approach, and the decision changes that produced the outcome, rather than only the headline number.
          </p>
        </div>

        <aside class="reveal card p-6 md:p-8">
          <p class="card-label">How to read these</p>
          <div class="mt-6 grid gap-4">
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you're evaluating fit</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">
                Look at the stage, engagement mode, and starting bottleneck, not the metrics.
              </p>
            </article>
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you're solving a similar problem</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">
                The approach section is the important part. Metrics are context, not the claim.
              </p>
            </article>
          </div>
          <div class="mt-6 rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-4">
            <p class="text-sm font-bold tracking-[-0.02em]">{siteConfig.availability}</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Engagements"
        intro="Embedded GTM leadership, fractional CMO, and focused sprint work across AI, B2B SaaS, and founder-led startups."
        title="Selected case studies."
      />

      <div class="reveal mt-8 space-y-4" data-case-filter-root>
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--subtle)]">Filter</p>
        <div class="flex flex-wrap gap-2" data-case-chips aria-label="Filter case studies">
          <button type="button" class="chip case-chip case-chip-active" data-case-filter="all">
            All ({caseStudies.length})
          </button>
          {
            sectors.map((sector) => (
              <button type="button" class="chip case-chip" data-case-filter={`sector:${sector}`}>
                {sector}
              </button>
            ))
          }
          {
            modes.map((mode) => (
              <button type="button" class="chip case-chip" data-case-filter={`mode:${mode}`}>
                {mode}
              </button>
            ))
          }
          {
            filterTags.map((tag) => (
              <button type="button" class="chip case-chip chip-quiet" data-case-filter={`tag:${tag}`}>
                {tag}
              </button>
            ))
          }
        </div>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-2" data-case-grid>
        {
          caseStudies.map((item) => (
            <article
              class="reveal card case-study-card p-6 md:p-8"
              data-case-sector={item.data.sector}
              data-case-mode={item.data.engagementMode}
              data-case-tags={item.data.tags.join("|")}
            >
              <div class="flex flex-wrap items-center gap-2">
                <span class="chip">{item.data.engagementMode}</span>
                <span class="chip">{item.data.stage}</span>
                <span class="chip">{item.data.sector}</span>
              </div>
              <h2 class="mt-5 text-2xl font-bold tracking-[-0.04em] md:text-3xl">
                <a class="link-cover" href={`/case-studies/${item.id}/`}>{item.data.title}</a>
              </h2>
              <p class="mt-4 text-base leading-7 text-[color:var(--muted)]">{item.data.description}</p>
              {item.data.metrics && item.data.metrics.length > 0 && (
                <dl class="mt-6 grid grid-cols-3 gap-4 border-t border-[color:var(--line)] pt-5">
                  {item.data.metrics.slice(0, 3).map((metric) => (
                    <div>
                      <dt class="mono text-[0.68rem] uppercase tracking-[0.16em] text-[color:var(--muted)]">{metric.label}</dt>
                      <dd class="mt-2 text-2xl font-extrabold tracking-[-0.05em]">{metric.value}</dd>
                    </div>
                  ))}
                </dl>
              )}
              <div class="mt-6 flex items-center justify-between text-sm text-[color:var(--muted)]">
                <span>{item.data.timeframe}</span>
                <span>{formatDate(item.data.publishedAt)}</span>
              </div>
              <a class="link-arrow mt-5" href={`/case-studies/${item.id}/`}>Read the full case study</a>
            </article>
          ))
        }
      </div>

      {caseStudies.length === 0 && (
        <div class="mt-10 reveal card max-w-3xl p-6 md:p-8">
          <p class="card-label">More write-ups</p>
          <p class="mt-4 text-base leading-7 text-[color:var(--muted)]">
            Additional anonymised case studies will be added here when each one is ready to publish. Until then, see the{" "}
            <a class="link-arrow" href="/#proof">outcome snapshots on the homepage</a>
            {" "}or{" "}
            <a class="link-arrow" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
              book a call
            </a>
            {" "}to walk through similar engagements in detail.
          </p>
        </div>
      )}
    </div>
  </section>

  <script is:inline>
    (function () {
      const root = document.querySelector("[data-case-filter-root]");
      if (!root) return;
      const chips = root.querySelectorAll("[data-case-filter]");
      const cards = document.querySelectorAll(".case-study-card");

      function apply(filter) {
        cards.forEach(function (card) {
          if (filter === "all") {
            card.hidden = false;
            return;
          }
          var idx = filter.indexOf(":");
          var kind = filter.slice(0, idx);
          var raw = filter.slice(idx + 1);
          var show = false;
          if (kind === "sector") show = card.getAttribute("data-case-sector") === raw;
          if (kind === "mode") show = card.getAttribute("data-case-mode") === raw;
          if (kind === "tag") {
            var tags = (card.getAttribute("data-case-tags") || "").split("|");
            show = tags.indexOf(raw) !== -1;
          }
          card.hidden = !show;
        });
      }

      chips.forEach(function (chip) {
        chip.addEventListener("click", function () {
          var f = chip.getAttribute("data-case-filter") || "all";
          chips.forEach(function (c) {
            c.classList.remove("case-chip-active");
          });
          chip.classList.add("case-chip-active");
          apply(f);
        });
      });
    })();
  </script>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Start Here</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              Have a similar bottleneck?
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              Start with a 20-minute growth diagnosis. You'll know whether the right next step is a sprint, advisory rhythm, fractional support, or no engagement at all.
            </p>
          </div>
          <div class="cta-stack">
            <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
            <CfEmailOff>
              <a class="button-secondary" href={`mailto:${siteConfig.email}`}>Email Daniel</a>
            </CfEmailOff>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
