        title="More signal, fewer claims."
      />

      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        {
          imageStoryCards.map((card) => (
            <article class="reveal image-story-card">
              <img alt={card.alt} decoding="async" height="720" loading="lazy" src={card.image} width="960" />
              <div>
                <p class="card-label">{card.eyebrow}</p>
                <h3>{card.title}</h3>
                <p>{card.body}</p>
                <a class="link-arrow" href={card.href}>{card.cta} →</a>
              </div>
            </article>
          ))
        }
      </div>

      <!-- Audience reaction snippets — lightweight social proof for speaking/workshop CTA -->
      <div class="mt-8 reveal">
        <p class="card-label text-center text-xs uppercase tracking-[0.16em] text-[color:var(--subtle)]">Recent attendee feedback</p>
        <div class="mx-auto mt-3 flex max-w-3xl flex-wrap justify-center gap-3">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-[color:var(--line)] bg-[color:var(--surface)]/70 px-3 py-1.5 text-xs font-medium text-[color:var(--muted)]">
            <span class="text-[color:var(--accent)] text-[10px]">✦</span> "Excellent presentation"
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-[color:var(--line)] bg-[color:var(--surface)]/70 px-3 py-1.5 text-xs font-medium text-[color:var(--muted)]">
            <span class="text-[color:var(--accent)] text-[10px]">✦</span> "Very helpful"
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-[color:var(--line)] bg-[color:var(--surface)]/70 px-3 py-1.5 text-xs font-medium text-[color:var(--muted)]">
            <span class="text-[color:var(--accent)] text-[10px]">✦</span> "Great succinct intro to scaling"
          </span>
        </div>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        <a class="reveal media-link-card card p-5" href="/podcast-appearances/">
          <span class="card-label">Podcast archive</span>
          <strong>Interviews and conversations</strong>
          <small>AI-native GTM, founder-led growth, experimentation, and fractional leadership.</small>
        </a>
        <a class="reveal media-link-card card p-5" href="/now/">
          <span class="card-label">Now</span>
          <strong>Current work and availability</strong>
          <small>The most current picture of what I am working on this month.</small>
        </a>
        {
          featuredMedia.slice(0, 2).map((item) => (
            <a class="reveal media-link-card card p-5" href={item.data.href} rel="noreferrer" target="_blank">
              <span class="card-label">{item.data.source}</span>
              <strong>{item.data.title}</strong>
              <small>{item.data.description}</small>
            </a>
          ))
        }
      </div>
    </div>
