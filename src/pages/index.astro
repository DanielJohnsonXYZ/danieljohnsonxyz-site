---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import GrowthDiagnosis from "../components/GrowthDiagnosis.astro";
import GrowthSystemDiagram from "../components/GrowthSystemDiagram.astro";
import CfEmailOff from "../components/CfEmailOff.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildAggregateRatingSchema, buildFaqPageSchema, buildServiceSchema } from "../lib/schema";
import { absoluteUrl, sortByFeaturedThenOrder } from "../lib/utils";
import {
  agencyVsMe,
  ctas,
  fitSignals,
  homeServiceLadder,
  lifetimeTotals,
  positioning,
  proofBar,
  singleIdea,
  siteConfig,
  trustLogos
} from "../site";

// ─── Content data ───────────────────────────────────────────────────────
const articles = (await getCollection("articles"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const media = sortByFeaturedThenOrder(await getCollection("media"));
const featuredMedia = media.slice(0, 4);

const testimonials = sortByFeaturedThenOrder(await getCollection("testimonials"));

// Lead testimonial — strongest specific result.
const leadTestimonial = testimonials.find((t) => t.data.name === "Christian A");

// Two supporting testimonials with named attribution.
const supportingTestimonials = [
  testimonials.find((t) => t.data.name === "Camiel Roex"),
  testimonials.find((t) => t.data.name === "Greg Weinstein")
].filter(Boolean) as typeof testimonials;

// ─── Method layers (one source of truth so the number never drifts) ─────
const methodLayers = [
  { title: "GTM systems", body: "ICP doc, positioning test results, weekly growth dashboard.", href: "/gtm-systems/" },
  { title: "Acquisition", body: "Channel test map, experiment backlog, paid and organic decision rules.", href: "/experimentation/" },
  { title: "Conversion", body: "Homepage message tests, funnel notes, activation and demo-booking fixes.", href: "/product-led-growth/" },
  { title: "AI-assisted research", body: "Customer-call synthesis, competitor teardown, message bank.", href: "/ai-native-workflows/" },
  { title: "Founder-led distribution", body: "Founder content pillars, proof library, content-to-pipeline loop.", href: "/founder-led-distribution/" },
  { title: "Reporting", body: "Growth scorecard, pipeline view, weekly stop / scale / fix notes.", href: "/revenue-operations/" }
];
const layerCount = methodLayers.length;

// ─── Proof — real outcomes (four cards) ─────────────────────────────────
const outcomeCards = [
  {
    metric: "6×",
    metricSuffix: "app downloads",
    context: "2k → 12k+ monthly downloads in 6 months after acquisition and lifecycle rebuild.",
    sector: "HealthTech · AI"
  },
  {
    metric: "35%",
    metricSuffix: "lower CAC",
    context: "CAC down 35% in 8 weeks — segmentation, paid account structure, landing-page routing.",
    sector: "Fintech · Crypto"
  },
  {
    metric: "500+",
    metricSuffix: "qualified signups",
    context: "500+ qualified signups from a single campaign at 8.6% CTR. US B2B fintech.",
    sector: "Fintech · B2B SaaS"
  },
  {
    metric: "21%",
    metricSuffix: "less churn",
    context: "Retention up 21% in 3 months. Targeted lifecycle and win-back messaging.",
    sector: "eCommerce"
  }
];

const imageStoryCards = [
  {
    eyebrow: "Speaking",
    title: "Founder rooms, startup cohorts, practical commercial work.",
    body: "Talks and workshops are built around the decision the room needs to make next, not a theatre of frameworks.",
    href: "/speaking/",
    cta: "See speaking assets",
    image: "/images/cambridge-judge-business-school-960.webp",
    alt: "Cambridge Judge Business School, one of Daniel Johnson's selected teaching and speaking affiliations"
  },
  {
    eyebrow: "Operator mindset",
    title: "Systems, instruments, judgment under uncertainty.",
    body: "The same bias shows up in the work: define the signal, read the instruments, make the next decision before the system drifts.",
    href: "/about/",
    cta: "Read about Daniel",
    image: "/images/daniel-aircraft.webp",
    alt: "Daniel Johnson in a small aircraft, connecting systems thinking with growth operating work"
  }
];

// ─── FAQ (homepage objections — matches hub brief; visible block + FAQPage schema) ─
const homepageFaq: Array<{
  question: string;
  answer: string;
  link?: { href: string; label: string };
}> = [
  {
    question: "What does a fractional CMO actually do day-to-day?",
    answer:
      "Owns the weekly GTM rhythm: sharp ICP and positioning, channel and experiment priorities, reporting that drives scale/stop/fix decisions, and the handoffs between founder, sales, and any agencies. It is operator work in your Slack and meetings — not a monthly slide deck."
  },
  {
    question: "How is this different from hiring a full-time CMO?",
    answer:
      "You buy a slice of senior time with a clear scope — usually one to two days a week — instead of a £120–180k+ base, equity, and a six-month ramp before the system shows up. Most teams use fractional to install the operating system, then hire full-time into something that already runs.",
    link: { href: "/fractional-cmo-vs-full-time-cmo/", label: "Fractional vs full-time →" }
  },
  {
    question: "What stage should my startup be at?",
    answer:
      "Post-PMF with real revenue and repeat buyers — typically Seed to Series B — where the constraint is execution and ownership, not finding the problem. Pre-revenue teams should stay focused on customers and product; the GTM system comes after that clarity.",
    link: { href: "/fractional-cmo-vs-full-time-cmo/", label: "When each model fits →" }
  },
  {
    question: "How quickly will I see results?",
    answer:
      "You should see sharper decisions and cleaner reporting within the first few weeks; meaningful pipeline and conversion movement usually shows in 30–90 days depending on sales cycle length and how fast tests ship. I do not promise miracles — I promise a visible system and honest calls on what is working."
  },
  {
    question: "What does it cost?",
    answer:
      "UK engagements typically start around £6k for a short strategy sprint, £7.5–12k/month for fractional CMO (3-month minimum), scoped to days per week and depth. The service page lists how the week runs; the UK cost page lists benchmark ranges and what moves price.",
    link: { href: "/fractional-cmo-cost-uk/", label: "Fractional CMO cost (UK) →" }
  },
  {
    question: "How do I know if this will work for my business?",
    answer:
      "If growth still depends on you reading every dashboard and approving every message, and the team does not share one constraint map, the model fits. The 30-minute audit is deliberately designed to name the bottleneck and say no when the shape of help is wrong."
  }
];

// ─── Structured data ────────────────────────────────────────────────────
const schemas = [
  buildFaqPageSchema(homepageFaq.map(({ question, answer }) => ({ question, answer }))),
  buildAggregateRatingSchema(),
  buildServiceSchema({
    name: "Fractional CMO for Seed to Series B AI & B2B SaaS",
    description:
      "Embedded senior GTM leadership for post-PMF AI and B2B SaaS startups. Predictable pipeline, sharper positioning, senior growth judgement — without a £150k+ full-time hire.",
    url: absoluteUrl("/fractional-cmo/"),
    priceRange: "£6,000 – £12,000",
    serviceType: "Fractional CMO",
    offers: [
      {
        name: "30-min Growth Audit",
        description: "Free 30-minute diagnostic call. Bottleneck read, fit decision, recommendation.",
        price: "0",
        billingIncrement: "per call"
      },
      {
        name: "Strategy Sprint",
        description: "2–4 weeks. Diagnose the bottleneck, set 90-day priorities, ship first artefacts.",
        price: "6000",
        billingIncrement: "per engagement"
      },
      {
        name: "Fractional CMO",
        description: "3-month minimum. Embedded senior ownership 1 day a week.",
        price: "7500",
        billingIncrement: "per month"
      },
      {
        name: "Fractional CMO Plus",
        description: "Deeper operating support, agency management, faster execution.",
        price: "12000",
        billingIncrement: "per month"
      }
    ]
  })
];
---

<BaseLayout
  description={positioning.metaDescription}
  path="/"
  preloadHeadshot
  schema={schemas}
  title="Fractional CMO for AI & B2B SaaS Startups | Daniel Johnson"
>
  <!-- 1. Hero ─────────────────────────────────────────────────────────── -->
  <section class="hero-section hero-section-compact section-space" aria-labelledby="hero-heading">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,0.82fr)] lg:items-center">
        <div class="reveal flex flex-col gap-5">
          <span class="service-label">Fractional CMO · {singleIdea.short}</span>

          <div class="space-y-4">
            <h1 id="hero-heading" class="max-w-4xl text-5xl font-extrabold leading-[1.02] tracking-[-0.055em] text-balance md:text-[3.65rem] lg:text-[3.95rem] xl:text-[4.05rem]">
              If growth still depends on the founder, <span class="hero-accent">I fix that.</span>
            </h1>
            <p class="hero-subcopy max-w-3xl text-lg leading-8 md:text-xl">
              <strong class="font-semibold text-[color:var(--ink)]">Predictable pipeline. Sharper positioning. Senior growth leadership.</strong> For Seed to Series B AI and B2B SaaS founders — without a £150k full-time hire.
            </p>
          </div>

          <div class="hero-proof-bar" aria-label="Daniel's track record at a glance">
            {
              proofBar.slice(0, 4).map((item) => (
                <div>
                  <strong><span aria-hidden="true">{item.icon}</span> {item.value}</strong>
                  <span>{item.label}</span>
                </div>
              ))
            }
          </div>

          <div class="cta-cluster">
            <div class="flex flex-wrap items-center gap-3">
              <a class="button-accent" href={ctas.primary.href} data-cta="hero-primary">
                {ctas.primary.label} →
              </a>
              <a class="button-link" href={ctas.startHere.href} data-cta="hero-start-here">
                New here? Start here →
              </a>
            </div>
            <p class="availability-line">{siteConfig.availability}</p>
          </div>

          <p class="reveal max-w-2xl text-sm leading-6 text-[color:var(--muted)]">
            Not ready to book?{" "}
            <a
              class="font-semibold text-[color:var(--ink)] underline decoration-[color:var(--border)] underline-offset-4 hover:text-[color:var(--accent)]"
              href="/newsletter/"
              data-cta="hero-soft-newsletter"
            >
              Get practical notes on AI-native GTM and founder-led growth
            </a>
            ,{" "}
            <a
              class="font-semibold text-[color:var(--ink)] underline decoration-[color:var(--border)] underline-offset-4 hover:text-[color:var(--accent)]"
              href="/growth-bottleneck-checklist/"
              data-cta="hero-soft-checklist"
            >
              download the Growth Bottleneck Checklist
            </a>
            , or{" "}
            <a
              class="font-semibold text-[color:var(--ink)] underline decoration-[color:var(--border)] underline-offset-4 hover:text-[color:var(--accent)]"
              href={ctas.bottleneck.href}
              data-cta="hero-soft-diagnostic"
            >
              run the 2-minute diagnostic
            </a>
            .
          </p>

          <aside
            class="commercial-path-note reveal mt-5 max-w-2xl rounded-lg border border-[color:var(--border)] bg-[color:var(--surface-elevated)] p-4 text-sm leading-6 text-[color:var(--muted)]"
            aria-label="How this site relates to We Scale Startups"
          >
            <strong class="font-semibold text-[color:var(--ink)]">We Scale Startups vs this site.</strong>{" "}
            <a class="font-medium text-[color:var(--ink)] underline decoration-[color:var(--border)] underline-offset-2" href={siteConfig.companyUrl}>
              We Scale Startups
            </a>{" "}
            is the operator bench for teams: diagnosis, sprints, and embedded fractional leadership. This site is Daniel as fractional CMO, speaker, and
            writer — use the audit here for a personal engagement; broader bench engagements typically run through WSS.
          </aside>
        </div>

        <div class="reveal">
          <article class="hero-photo-card hero-offer-card">
            <img
              alt="Daniel Johnson, fractional CMO and AI-native growth operator"
              class="aspect-[4/5] w-full object-cover object-top hero-portrait"
              decoding="async"
              fetchpriority="high"
              height="960"
              loading="eager"
              src={siteConfig.headshot}
              width="768"
            />
            <div class="hero-authority-panel">
              <p class="card-label">Primary Offer</p>
              <h2 class="mt-2 text-2xl font-extrabold tracking-[-0.05em]">
                Fractional CMO for post-PMF AI and SaaS.
              </h2>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-[color:var(--muted)]">
                <li>Best for £1m to £10m ARR</li>
                <li>Founder-led, growth stuck, no senior GTM owner</li>
                <li>Senior help without a £150k+ full-time hire</li>
                <li>Recent work: AI health, B2B fintech, edtech, SaaS tooling</li>
              </ul>
            </div>
          </article>
        </div>
      </div>

      <div class="trust-strip trust-strip-large hero-trust-strip reveal" aria-label="Selected affiliations and platforms">
        <p class="trust-strip-label">Selected affiliations</p>
        <div class="trust-strip-logos">
          {
            trustLogos.map((item) => (
              <img
                alt={item.alt}
                class={`trust-logo trust-logo-${item.id}`}
                decoding="async"
                height="48"
                loading="lazy"
                src={item.src}
                width="180"
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Problem statement — tighter copy (was 3 paragraphs, now 2) ──── -->
  <section class="section-space pt-0" aria-labelledby="problem-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <h2 id="problem-heading" class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-6xl">
          You've got traction. <span class="hero-accent">So why does growth still feel like guessing?</span>
        </h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          Paying customers. Revenue line moving. A deck that holds up. But the acquisition engine? Plateaued. Founder-led sales that doesn't scale. No repeatable pipeline. A GTM stack that's three tools taped together.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          You don't need more tactics. You need a senior operator who can walk in, see the whole system at once, and tell you — with specifics — which two levers matter for your company right now.
        </p>
      </div>
    </div>
  </section>

  <!-- 5. Growth Diagnosis — interactive quiz ────────────────────────── -->
  <section class="section-space pt-0" id="growth-diagnosis" aria-labelledby="diagnosis-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="AI-assisted diagnosis · Free · 2 minutes"
        intro="Five questions. Tailored output. A clearer read on which lever matters most before another campaign, hire, or AI workflow gets bolted on."
        title="Find your biggest growth bottleneck."
      />
      <GrowthDiagnosis />
    </div>
  </section>

  <!-- 4. Buying ladder — Audit → Sprint → Fractional CMO ──────────── -->
  <!-- Was: Fractional CMO + Growth Advisory + Speaking (mixed shapes).  -->
  <!-- Now: a clean 3-tier buying ladder with explicit price/scope.       -->
  <section class="section-space pt-0" id="services">
    <div class="shell">
      <SectionHeader
        eyebrow="Three ways in"
        intro="Pick the smallest commitment that answers the question. You can move up the ladder later."
        title="Where do you want to start?"
      />

      <!-- Visual ladder — numbered step badges + connecting line on desktop -->
      <!-- so the progression reads as Audit -> Sprint -> Fractional CMO,    -->
      <!-- not three side-by-side equal-weight cards.                         -->
      <div class="ladder-grid mt-10">
        {
          homeServiceLadder.map((tier, index) => (
            <article class:list={["ladder-card card p-6 md:p-8", tier.primary && "ladder-card-primary"]}>
              <div class="ladder-step" aria-hidden="true">
                <span class="ladder-step-num">0{index + 1}</span>
                {index < homeServiceLadder.length - 1 && <span class="ladder-step-arrow">→</span>}
              </div>
              <p class="card-label mt-4">{tier.tier}</p>
              <h3 class="mt-3 text-2xl font-extrabold tracking-[-0.05em]">{tier.heading}</h3>
              <div class="mt-3 flex items-baseline gap-1">
                <span class="text-2xl font-extrabold tracking-[-0.06em]">{tier.price}</span>
                <span class="text-sm text-[color:var(--muted)]">{tier.cadence}</span>
              </div>
              <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{tier.body}</p>
              <p class="mt-5 border-t border-[color:var(--line)] pt-4 text-sm leading-6 text-[color:var(--muted)]">
                <strong class="font-semibold text-[color:var(--ink)]">Best for:</strong> {tier.bestFor}
              </p>
              <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">
                <strong class="font-semibold text-[color:var(--ink)]">Outcome:</strong> {tier.outcome}
              </p>
              <a class="link-arrow mt-6" href={tier.href}>{tier.cta} →</a>
            </article>
          ))
        }
      </div>

      <p class="reveal mt-8 text-center text-sm leading-7 text-[color:var(--muted)]">
        Looking for <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/mentoring/">founder office hours</a>, <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/speaking/">speaking, or workshops</a>? See all the ways we can work together.
      </p>
    </div>
  </section>

  <!-- 5. Who this is for / not for ──────────────────────────────────── -->
  <section class="section-space pt-0" aria-labelledby="fit-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Fit"
        intro="I'd rather save us both a 30-minute call if we're not the right match."
        title="Who this is for, and who it's not."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label text-[color:var(--accent)]">Best fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {fitSignals.bestFor.map((point) => (
              <li class="fit-row fit-row-yes">{point}</li>
            ))}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">Not a fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {fitSignals.notFor.map((point) => (
              <li class="fit-row fit-row-no">{point}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- 6. Why me vs agency ─────────────────────────────────────────── -->
  <section class="section-space pt-0" aria-labelledby="vs-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Why not an agency"
        intro="You don't need another agency layer when the real problem is senior growth judgement."
        title="Senior growth judgement, not junior execution."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">{agencyVsMe.agency.heading}</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {agencyVsMe.agency.points.map((point) => <li class="fit-row fit-row-no">{point}</li>)}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8 card-accent-border">
          <p class="card-label text-[color:var(--accent)]">{agencyVsMe.me.heading}</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {agencyVsMe.me.points.map((point) => <li class="fit-row fit-row-yes">{point}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- 7. The method — sharper anchor: campaigns vs. systems ───────── -->
  <section class="dark-section section-space" aria-labelledby="method-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="eyebrow justify-center text-white/60">The method</span>
        <h2 id="method-heading" class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-white md:text-6xl">
          I don't run campaigns. <span class="hero-accent">I build growth systems that run without you.</span>
        </h2>
      </div>

      <div class="reveal mx-auto mt-10 max-w-3xl space-y-5 text-lg leading-8 text-white/72">
        <p>Most growth consultants arrive, ship a deck, and disappear. Not how I work.</p>
        <p>
          Every engagement builds the same thing: a growth system. A repeatable architecture your team can run after I'm gone.
        </p>
        <p class="text-sm uppercase tracking-[0.16em] text-white/50">
          {layerCount} layers, one loop
        </p>
      </div>

      <!-- System diagram — shows the loop visually so "growth system" -->
      <!-- isn't just an abstract claim. -->
      <div class="reveal mt-12">
        <GrowthSystemDiagram />
      </div>

      <p class="reveal mt-6 text-center text-sm uppercase tracking-[0.14em] text-white/45">
        Each layer also exists as a deeper page — click below
      </p>

      <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          methodLayers.map((layer, index) => (
            <a class="reveal card p-6" href={layer.href}>
              <p class="card-label text-white/55">0{index + 1}</p>
              <h3 class="mt-3 text-xl font-bold tracking-[-0.04em] text-white">{layer.title}</h3>
              <p class="mt-3 text-sm leading-7 text-white/68">{layer.body}</p>
            </a>
          ))
        }
      </div>

      <div class="reveal mt-10 text-center">
        <p class="text-base leading-8 text-white/68">
          If "growth system" sounds vague, that's fine. I'll show you exactly what it looks like on a 30-minute audit.
        </p>
        <div class="mt-6 flex justify-center">
          <a class="button-accent" href={ctas.primary.href} data-cta="method-primary">
            {ctas.primary.label} →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. What AI-native GTM means here (concrete homepage block) ───── -->
  <section class="section-space" aria-labelledby="ai-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-5xl space-y-6">
        <span class="eyebrow">How I work</span>
        <h2 id="ai-heading" class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-5xl">
          What AI-native GTM means <span class="hero-accent">here.</span>
        </h2>
        <p class="max-w-3xl text-lg leading-8 text-[color:var(--muted)]">
          AI should make GTM faster, not vaguer — with human judgement still owning ICP, budget, sequencing, and what ships.
        </p>
        <div
          class="rounded-xl border border-[color:var(--line)] bg-[color:var(--surface)] p-6 shadow-[var(--shadow-sm)] md:p-8"
          aria-labelledby="ai-native-block-heading"
        >
          <p class="card-label">On engagements</p>
          <h3 id="ai-native-block-heading" class="mt-3 text-2xl font-bold tracking-[-0.04em] text-balance md:text-3xl">
            Not replacing judgement with automation — compressing the work that feeds decisions.
          </h3>
          <p class="mt-4 text-base leading-7 text-[color:var(--muted)] md:text-lg md:leading-8">
            AI-native GTM does not mean replacing judgement with content automation. It means using AI to compress customer-call synthesis, competitor research, message testing, CRM diagnosis, campaign learning, and weekly decision-making, so founders and teams can make better commercial decisions faster.
          </p>
          <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_minmax(0,17rem)] lg:gap-8">
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-[color:var(--subtle)]">Where AI speeds up the loop</p>
              <ul class="mt-3 grid gap-2 sm:grid-cols-2">
                {
                  [
                    "Customer-call synthesis",
                    "Competitor research",
                    "Message testing",
                    "CRM diagnosis",
                    "Campaign learning",
                    "Weekly decision-making"
                  ].map((label) => (
                    <li class="flex items-start gap-2 text-sm leading-6 text-[color:var(--ink)] md:text-base">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--accent)]" aria-hidden="true" />
                      {label}
                    </li>
                  ))
                }
              </ul>
            </div>
            <aside
