---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildFaqPageSchema } from "../lib/schema";
import { sortByFeaturedThenOrder } from "../lib/utils";
import { navigation, siteConfig, trustLogos } from "../site";

// Content data
const articles = (await getCollection("articles"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
const testimonials = sortByFeaturedThenOrder(await getCollection("testimonials"));

// Pick three named, attributed quotes for the homepage
const homepageTestimonials = [
  testimonials.find((t) => t.data.name === "Christian A"),
  testimonials.find((t) => t.data.name === "Hal Zeitlin"),
  testimonials.find((t) => t.data.name === "James Lethem")
].filter(Boolean) as typeof testimonials;

// Hero
const eyebrow = "AI-Native GTM & Growth Operator · For post-PMF AI & B2B SaaS";
const proofBar = [
  { value: "£18M+", label: "revenue generated" },
  { value: "£6M+", label: "ad spend managed" },
  { value: "20+", label: "AI & SaaS startups" },
  { value: "479+ · 4.97/5", label: "mentor sessions rated" }
];

// Social proof strip
const affiliationLogos = trustLogos.slice(0, 5);

// "What I do" three cards
const serviceCards = [
  {
    heading: "Fractional GTM leadership",
    primary: true,
    strap: "Embedded GTM & growth operator for post-PMF AI & SaaS startups.",
    body:
      "1–2 days a week, running growth end-to-end. I own the GTM strategy, build the systems, hire the people, and operate until you're ready for a full-time Head of Growth or VP Marketing.",
    bestFor: "Seed to Series B teams without a senior growth leader — or between full-time hires.",
    href: "/fractional-cmo",
    cta: "See the engagement details"
  },
  {
    heading: "Speaking",
    strap: "Keynotes and workshops on AI-native growth, GTM, and founder-led distribution.",
    body:
      "Real campaigns, not recycled conference material. I speak to founder audiences, accelerator cohorts, and corporate innovation teams.",
    bestFor: "Conferences, accelerators, founder offsites, podcasts.",
    href: "/speaking",
    cta: "See speaking"
  },
  {
    heading: "Mentoring",
    strap: "1:1 sessions for founders working through a specific growth question.",
    body:
      "30- or 60-minute working sessions. 479+ done, rated 4.97/5 on GrowthMentor. Good for founders who need a senior outside brain for an hour.",
    bestFor: "Pre-seed to Series A founders with a specific question.",
    href: "/mentoring",
    cta: "Book a mentoring session"
  }
];

// The method — six layers
const methodLayers = [
  {
    title: "GTM systems",
    body: "ICP, positioning, channel strategy, acquisition engine design."
  },
  {
    title: "Product-led growth",
    body: "Activation, retention, freemium and trial conversion."
  },
  {
    title: "Experimentation frameworks",
    body: "Prioritisation, test design, learning loops."
  },
  {
    title: "AI-native workflows",
    body: "Generative and agentic AI for research, messaging, content, enrichment."
  },
  {
    title: "Founder-led distribution",
    body: "LinkedIn systems, content-to-pipeline loops."
  },
  {
    title: "Revenue operations",
    body: "Channel and ICP alignment, pipeline design, reporting cadence."
  }
];

// Proof — real outcomes (four cards)
const outcomeCards = [
  {
    metric: "6×",
    metricSuffix: "app downloads",
    context: "Rebuilt the GTM and acquisition system for a B2B HealthTech startup.",
    sector: "HealthTech · AI"
  },
  {
    metric: "35%",
    metricSuffix: "lower CAC",
    context: "Redesigned acquisition segmentation and paid channel mix for a crypto trading platform.",
    sector: "Fintech · Crypto"
  },
  {
    metric: "500+",
    metricSuffix: "qualified signups",
    context: "Single campaign at 8.6% CTR for a US B2B fintech.",
    sector: "Fintech · B2B SaaS"
  },
  {
    metric: "21%",
    metricSuffix: "less churn",
    context: "Targeted lifecycle and retention programme for scaling eCommerce brands.",
    sector: "eCommerce"
  }
];

const lifetimeTotals = [
  "£18M+ revenue generated",
  "£6M+ ad spend managed",
  "20+ startups scaled",
  "£15M+ raised supported (Seed–Series B)"
];

// FAQ (kept short — full FAQ lives on /fractional-cmo)
const faq = [
  {
    question: "Who do you work with?",
    answer:
      "Founders of post-PMF AI and B2B SaaS startups, typically Pre-Seed to Series B. Product-strong teams where growth feels noisy and hard to prioritise. UK-based or remote-first; US clients remotely from the UK, with occasional in-person days."
  },
  {
    question: "What's the difference between a GTM growth operator and a fractional CMO?",
    answer:
      "Same seniority, different framing. 'Growth operator' signals that I work at the intersection of product and growth, build systems rather than campaigns, and operate rather than just advise. 'Fractional CMO' is the label buyers expect on job boards and mentoring platforms, so it appears where that's useful."
  },
  {
    question: "What does \"AI-native\" mean in practice?",
    answer:
      "Every engagement uses generative and agentic AI to accelerate ICP research, messaging tests, competitor teardowns, outbound sequences, and content — reducing execution time without sacrificing rigour. You pay for senior judgement, not manual consulting deliverables."
  },
  {
    question: "Are you open to full-time roles too?",
    answer:
      "Yes. I'm currently open to select fractional CMO engagements and full-time Head of Growth or VP Marketing roles at post-PMF AI and B2B SaaS startups. Book a growth call to discuss fit either way."
  }
];
---

<BaseLayout
  description="AI-Native GTM & Growth Operator for post-PMF AI and B2B SaaS startups. I build repeatable growth systems — PLG, AI-native workflows, and founder-led distribution. £18M+ revenue generated."
  path="/"
  schema={buildFaqPageSchema(faq)}
  title="AI-Native GTM & Growth Operator for AI & B2B SaaS Startups | Daniel Johnson"
>
  <!-- 1. Hero -->
  <section class="hero-section section-space">
    <div class="shell">
      <div class="grid gap-12 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
        <div class="reveal flex flex-col gap-6">
          <span class="service-label">{eyebrow}</span>

          <div class="space-y-5">
            <h1 class="max-w-5xl text-5xl font-extrabold leading-[0.98] tracking-[-0.07em] text-balance md:text-7xl lg:text-[5.2rem]">
              I help AI and B2B SaaS founders turn growth guesswork into a <span class="hero-accent">clear, repeatable system.</span>
            </h1>
            <p class="hero-subcopy max-w-3xl text-xl leading-9 md:text-2xl">
              I'm Daniel Johnson — an <a class="highlight-text" href="/fractional-cmo">AI-native GTM &amp; growth operator</a> for post-PMF AI and B2B SaaS startups.
              From Seed to Series B, I help product-strong teams build the GTM systems, PLG pathways, and AI-native workflows
              that turn scattered experiments into predictable acquisition.
            </p>
          </div>

          <div class="hero-proof-bar" aria-label="Daniel's track record at a glance">
            {
              proofBar.map((item) => (
                <div>
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                </div>
              ))
            }
          </div>

          <div class="cta-cluster">
            <div class="flex flex-wrap items-center gap-3">
              <a class="button-accent" href="/book-a-call">Book a free 30-min growth call →</a>
              <a class="button-link" href="/fractional-cmo">See how I work →</a>
            </div>
            <p class="availability-line">{siteConfig.availability}</p>
          </div>
        </div>

        <div class="reveal">
          <article class="hero-photo-card hero-offer-card">
            <img
              alt="Daniel Johnson — AI-native GTM and growth operator for AI and B2B SaaS startups"
              class="aspect-[4/5] w-full object-cover object-top hero-portrait"
              decoding="async"
              fetchpriority="high"
              height="960"
              loading="eager"
              src={siteConfig.headshot}
              width="768"
            />
            <div class="hero-authority-panel">
              <p class="card-label">Currently open to</p>
              <h2 class="mt-2 text-2xl font-extrabold tracking-[-0.05em]">
                Select fractional CMO engagements and full-time Head of Growth / VP Marketing roles.
              </h2>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-[color:var(--muted)]">
                <li>Post-PMF AI &amp; B2B SaaS · Pre-Seed to Series B</li>
                <li>UK-based or remote-first</li>
                <li>Starts with a free growth call</li>
              </ul>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Social proof strip -->
  <section class="section-space pt-0">
    <div class="shell">
      <div class="trust-strip trust-strip-large" aria-label="Selected affiliations and platforms from Daniel's public footprint">
        <p class="trust-strip-label">Mentor / advisor affiliations</p>
        <div class="trust-strip-logos">
          {
            affiliationLogos.map((item) => (
              <img alt={item.alt} decoding="async" height="48" loading="lazy" src={item.src} width="180" />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Problem statement -->
  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-6xl">
          You've built something people pay for. <span class="hero-accent">So why does growth still feel like guessing?</span>
        </h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          You've got a product. You've got paying customers. You've got traction you can point to in a fundraising deck.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          What you don't have is a repeatable way to turn any of that into pipeline. You've tried paid. You've tried
          content. You've tried hiring a generalist marketer. Something worked, most of it didn't, and you're not sure why.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          You don't need more tactics. You need someone senior who can walk in, see the whole system at once, and tell you
          — with specifics — which two levers actually matter for your company right now.
        </p>
      </div>
    </div>
  </section>

  <!-- 4. What I do -->
  <section class="section-space pt-0" id="services">
    <div class="shell">
      <SectionHeader
        eyebrow="What I do"
        intro="Three ways to work with me. Start wherever the shape fits."
        title="What I actually do."
      />

      <div class="explore-grid mt-10">
        {
          serviceCards.map((card) => (
            <article class:list={["explore-card card p-6 md:p-8", card.primary && "explore-card-primary"]}>
              <p class="card-label">{card.primary ? "Primary path" : "Also offered"}</p>
              <h3 class="mt-4 text-2xl font-extrabold tracking-[-0.05em]">{card.heading}</h3>
              <p class="mt-2 text-base font-semibold leading-7 tracking-[-0.02em]">{card.strap}</p>
              <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{card.body}</p>
              <p class="mt-5 border-t border-[color:var(--line)] pt-4 text-sm leading-6 text-[color:var(--muted)]">
                <strong class="font-semibold text-[color:var(--ink)]">Best for:</strong> {card.bestFor}
              </p>
              <a class="link-arrow mt-6" href={card.href}>{card.cta}</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. The method -->
  <section class="dark-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="eyebrow justify-center text-white/60">The method</span>
        <h2 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-white md:text-6xl">
          I don't sell services. <span class="hero-accent">I build systems.</span>
        </h2>
      </div>

      <div class="reveal mx-auto mt-10 max-w-3xl space-y-5 text-lg leading-8 text-white/72">
        <p>Most growth consultants arrive, ship a deck, and disappear. That's not how I work.</p>
        <p>
          Every engagement builds the same thing — a growth system. Not a campaign. Not a funnel. A repeatable architecture
          your team can run after I'm gone.
        </p>
        <p class="text-sm uppercase tracking-[0.16em] text-white/50">Six layers, tailored to where you are</p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          methodLayers.map((layer, index) => (
            <article class="reveal card p-6">
              <p class="card-label text-white/55">0{index + 1}</p>
              <h3 class="mt-3 text-xl font-bold tracking-[-0.04em] text-white">{layer.title}</h3>
              <p class="mt-3 text-sm leading-7 text-white/68">{layer.body}</p>
            </article>
          ))
        }
      </div>

      <div class="reveal mt-10 text-center">
        <p class="text-base leading-8 text-white/68">
          If "growth system" sounds vague, that's fine — I'll show you exactly what it looks like on a 30-minute call.
        </p>
        <div class="mt-6 flex justify-center">
          <a class="button-accent" href="/book-a-call">Book a free 30-min growth call →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Why AI-native matters -->
  <section class="section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-5xl space-y-6">
        <span class="eyebrow">Category</span>
        <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-5xl">
          There's a gap between AI-curious and AI-native.
          <span class="hero-accent">Most growth operators are on the wrong side of it.</span>
        </h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          AI-curious teams use ChatGPT to draft blog posts. AI-native teams rebuild their growth stack around generative
          and agentic workflows — research, message testing, prospect enrichment, campaign iteration, content at scale —
          and ship 5× faster because of it.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          I work on the <a class="highlight-text" href="/fractional-cmo">AI-native side</a>. Every engagement I run uses AI
          to cut the execution time on the work that used to eat weeks: ICP research, positioning tests, competitor
          teardowns, outbound sequences, SEO-brief generation, experiment design.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          That means you're not paying a growth operator for slow, manual consulting deliverables. You're paying for senior
          judgement applied to work that's already been accelerated by the tools — and a repeatable system your team can run
          after I've gone.
        </p>
        <p>
          <a class="link-arrow" href="/writing">Read: What AI-native GTM actually means →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- 7. Proof — real outcomes -->
  <section class="dark-section section-space" id="proof">
    <div class="shell">
      <SectionHeader
        eyebrow="Proof"
        intro="The short list — full case studies live at We Scale Startups."
        title="Real campaigns. Real numbers. Real attribution."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          outcomeCards.map((card) => (
            <article class="reveal card p-6">
              <p class="text-5xl font-extrabold tracking-[-0.07em] text-white">{card.metric}</p>
              <p class="mt-2 text-sm font-semibold uppercase tracking-[0.12em] text-white/65">{card.metricSuffix}</p>
              <p class="mt-5 text-sm leading-7 text-white/70">{card.context}</p>
              <p class="mt-5 border-t border-white/[0.08] pt-3 text-xs font-semibold uppercase tracking-[0.14em] text-white/45">
                {card.sector}
              </p>
            </article>
          ))
        }
      </div>

      <div class="reveal mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-center text-sm font-semibold uppercase tracking-[0.12em] text-white/60">
        {lifetimeTotals.map((item) => <span>{item}</span>)}
      </div>

      <div class="reveal mt-6 text-center">
        <a class="link-arrow" href="/case-studies">See full case studies →</a>
      </div>
    </div>
  </section>

  <!-- 8. Testimonials -->
  <section class="section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Testimonials"
        intro="Real quotes from founders I've mentored and worked with."
        title="What founders say."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          homepageTestimonials.map((item) => (
            <blockquote class="reveal card p-6 md:p-7">
              <p class="text-lg font-semibold leading-8 tracking-[-0.03em]">
                "{item.data.quote}"
              </p>
              <footer class="mt-6 border-t border-[color:var(--line)] pt-4 text-sm">
                <p class="font-semibold">{item.data.name}</p>
                <p class="text-[color:var(--muted)]">{item.data.role} &bull; {item.data.organisation}</p>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 9. About preview -->
  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="eyebrow">About</span>
        <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-5xl">About Daniel.</h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          I've spent 10+ years in growth — as a co-founder, an embedded Head of Growth, and a fractional CMO. I've worked
          with 20+ AI and B2B SaaS startups, managed £6M+ in paid spend, generated £18M+ in revenue, and helped founders
          raise £15M+. I've co-founded two companies, one in mental-health tech (eQuoo) and one in eCommerce.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          I mentor founders through Google for Startups, Techstars, and GrowthMentor (479+ sessions, 4.97/5 rating). I've
          lectured at Cambridge Judge Business School and Imperial College London, and delivered growth workshops at
          Google Launchpad programmes across the UK, Europe, and Africa. I sit on the board of BASIC and live in the UK —
          I work with US clients remotely, with occasional in-person days.
        </p>
        <p>
          <a class="link-arrow" href="/about">Read more about Daniel →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- 10. Writing -->
  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Writing"
        intro="Essays on AI-native GTM, growth systems, and why most startup growth advice is wrong."
        title="Writing."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          articles.map((article) => (
            <article class="reveal card p-6 md:p-7">
              <p class="card-label">
                {article.data.publishedAt.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
                {article.data.readingTime ? ` · ${article.data.readingTime}` : ""}
              </p>
              <h3 class="mt-3 text-xl font-bold tracking-[-0.04em]">{article.data.title}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{article.data.description}</p>
              <a class="link-arrow mt-5" href={`/writing/${article.id}`}>Read essay →</a>
            </article>
          ))
        }
      </div>

      <div class="reveal mt-8 flex flex-wrap items-center gap-3">
        <a class="button-accent" href="/writing">Read all writing →</a>
        <a class="button-link" href={`mailto:${siteConfig.email}?subject=Subscribe%20me%20to%20Growth%20Notes`}>
          Subscribe — one short email a month →
        </a>
      </div>
    </div>
  </section>

  <!-- 11. Final CTA -->
  <section class="cta-gradient section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <span class="eyebrow justify-center text-white/60">Next step</span>
        <h2 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance text-white md:text-7xl">
          Book a free 30-min growth call.
        </h2>
        <p class="mx-auto max-w-2xl text-lg leading-8 text-white/72">
          We'll spend 30 minutes on your specific situation — no pitch, no deck, no trying-to-close. You'll leave with a
          clearer read on your biggest growth bottleneck and whether working together makes sense. If it doesn't, I'll
          tell you what I'd do instead and point you to the right operator, agency, or mentor.
        </p>
        <p class="text-sm font-semibold text-white/70">I reply to every enquiry within 48 hours.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a class="button-accent" href="/book-a-call">Book a 30-min call →</a>
        </div>
        <p class="text-sm text-white/60">
          Prefer email first? <a class="text-white underline" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
