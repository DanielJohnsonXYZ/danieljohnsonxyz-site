---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import GrowthDiagnosis from "../components/GrowthDiagnosis.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildFaqPageSchema } from "../lib/schema";
import { sortByFeaturedThenOrder } from "../lib/utils";
import {
  agencyVsMe,
  ctas,
  fitSignals,
  proofBar,
  siteConfig,
  trustBadges,
  trustLogos
} from "../site";

// ─── Content data ───────────────────────────────────────────────────────
const articles = (await getCollection("articles"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const testimonials = sortByFeaturedThenOrder(await getCollection("testimonials"));

// Lead testimonial — strongest specific result.
const leadTestimonial = testimonials.find((t) => t.data.name === "Christian A");

// Two supporting testimonials with named attribution.
const supportingTestimonials = [
  testimonials.find((t) => t.data.name === "Camiel Roex"),
  testimonials.find((t) => t.data.name === "Greg Weinstein")
].filter(Boolean) as typeof testimonials;

// ─── Method layers (one source of truth so the number never drifts) ─────
const methodLayers = [
  { title: "GTM systems", body: "Output: ICP doc, positioning test results, weekly growth dashboard.", href: "/gtm-systems/" },
  { title: "Acquisition", body: "Output: channel test map, experiment backlog, paid and organic decision rules.", href: "/experimentation/" },
  { title: "Conversion", body: "Output: homepage message tests, funnel notes, activation and demo-booking fixes.", href: "/product-led-growth/" },
  { title: "AI-assisted research", body: "Output: customer-call synthesis, competitor teardown, message bank.", href: "/ai-native-workflows/" },
  { title: "Founder-led distribution", body: "Output: founder content pillars, proof library, content-to-pipeline loop.", href: "/founder-led-distribution/" },
  { title: "Reporting", body: "Output: growth scorecard, pipeline view, weekly stop / scale / fix notes.", href: "/revenue-operations/" }
];
const layerCount = methodLayers.length;

// ─── "What I do" three cards ─────────────────────────────────────────────
const serviceCards = [
  {
    heading: "Fractional CMO",
    primary: true,
    strap: "Primary Offer · Senior growth operator, embedded 1 to 2 days a week.",
    body:
      "I own the GTM priorities, reporting rhythm, acquisition tests, and team decisions until growth no longer depends on founder instinct.",
    bestFor: "£1m to £10m ARR, founder-led, growth stuck, senior help needed before or alongside a full-time CMO hire.",
    href: "/fractional-cmo/",
    cta: "Explore Fractional CMO"
  },
  {
    heading: "Growth Advisory",
    strap: "Focused decision sessions for founders not ready for an embedded engagement.",
    body:
      "Use this when you need sharper positioning, a channel decision, a hiring read, or a second brain before spending more.",
    bestFor: "Pre-PMF or early post-PMF founders with a specific GTM decision.",
    href: "/mentoring/",
    cta: "See founder office hours"
  },
  {
    heading: "Speaking / Workshops",
    strap: "Practical talks for founders, accelerators, and startup teams.",
    body:
      "Founder audiences get concrete frameworks, examples, and artefacts they can use after the session.",
    bestFor: "Conferences, accelerators, founder offsites, podcasts.",
    href: "/speaking/",
    cta: "See speaking"
  }
];

// ─── Proof — real outcomes (four cards) ─────────────────────────────────
const outcomeCards = [
  {
    metric: "6×",
    metricSuffix: "app downloads",
    context: "From roughly 2k monthly downloads to 12k+ after six months of acquisition and lifecycle rebuild.",
    sector: "HealthTech · AI"
  },
  {
    metric: "35%",
    metricSuffix: "lower CAC",
    context: "Reduced CAC after eight weeks by rebuilding segmentation, paid account structure, and landing-page routing.",
    sector: "Fintech · Crypto"
  },
  {
    metric: "500+",
    metricSuffix: "qualified signups",
    context: "Generated 500+ qualified signups from one campaign at 8.6% CTR for a US B2B fintech.",
    sector: "Fintech · B2B SaaS"
  },
  {
    metric: "21%",
    metricSuffix: "less churn",
    context: "Improved retention after three months with targeted lifecycle and win-back messaging.",
    sector: "eCommerce"
  }
];

const lifetimeTotals = [
  "£18M+ revenue generated for clients",
  "£6.8M+ ad spend managed",
  "20+ startups scaled",
  "Helped founders raise £15M+"
];

// ─── FAQ ────────────────────────────────────────────────────────────────
const faq = [
  {
    question: "Who do you work with?",
    answer:
      "Founders of post-PMF AI and B2B SaaS startups, typically Seed to Series B. Product-strong teams where growth has plateaued or feels noisy and hard to prioritise. UK-based, currently working from Asia, serving US, UK, Europe, and APAC clients remotely."
  },
  {
    question: "What's the difference between a fractional CMO and a growth operator?",
    answer:
      "Same seniority, different framing. 'Growth operator' signals that I work at the intersection of product and growth, build systems rather than campaigns, and operate rather than just advise. 'Fractional CMO' is the label buyers expect on job boards and mentoring platforms, so it appears where that's useful."
  },
  {
    question: "What does \"AI-native\" mean in practice?",
    answer:
      "Every engagement uses generative and agentic AI to accelerate ICP research, messaging tests, competitor teardowns, outbound sequences, and content, reducing execution time without sacrificing rigour. You pay for senior judgement, not manual consulting deliverables."
  },
  {
    question: "Are you open to full-time roles?",
    answer:
      "Primary focus is fractional CMO engagements. I'll consider a full-time Head of Growth or VP Marketing role for the right post-PMF AI or B2B SaaS company. Book a growth audit to discuss either way."
  }
];
---

<BaseLayout
  description="Fractional CMO for founder-led AI and B2B SaaS startups that need repeatable pipeline, sharper positioning, and senior growth leadership."
  path="/"
  schema={buildFaqPageSchema(faq)}
  title="Fractional CMO for AI & B2B SaaS Startups | Daniel Johnson"
>
  <!-- 1. Hero ─────────────────────────────────────────────────────────── -->
  <section class="hero-section hero-section-compact section-space" aria-labelledby="hero-heading">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,0.82fr)] lg:items-center">
        <div class="reveal flex flex-col gap-5">
          <span class="service-label">Fractional CMO · AI-Native Growth Operator</span>

          <div class="space-y-5">
            <h1 id="hero-heading" class="max-w-4xl text-5xl font-extrabold leading-[1.02] tracking-[-0.055em] text-balance md:text-[3.65rem] lg:text-[3.95rem] xl:text-[4.05rem]">
              Growth still depends on you. <span class="hero-accent">I build the pipeline system around you.</span>
            </h1>
            <p class="hero-subcopy max-w-3xl text-lg leading-8 md:text-xl">
              For founder-led AI and B2B SaaS startups where channels are active, GTM feels messy, and nothing compounds yet.
              I embed as your fractional CMO to sharpen positioning, build repeatable pipeline, and reduce the founder bottleneck.
            </p>
          </div>

          <div class="hero-proof-bar" aria-label="Daniel's track record at a glance">
            {
              proofBar.slice(0, 4).map((item) => (
                <div>
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                </div>
              ))
            }
          </div>

          <div class="cta-cluster">
            <div class="flex flex-wrap items-center gap-3">
              <a class="button-accent" href={ctas.primary.href} data-cta="hero-primary">
                {ctas.primary.label} →
              </a>
              <a class="button-link" href={ctas.bottleneck.href} data-cta="hero-bottleneck">
                {ctas.bottleneck.label} →
              </a>
            </div>
            <p class="availability-line">{siteConfig.availability}</p>
          </div>
        </div>

        <div class="reveal">
          <article class="hero-photo-card hero-offer-card">
            <img
              alt="Daniel Johnson, fractional CMO and AI-native growth operator"
              class="aspect-[4/5] w-full object-cover object-top hero-portrait"
              decoding="async"
              fetchpriority="high"
              height="960"
              loading="eager"
              src={siteConfig.headshot}
              width="768"
            />
            <div class="hero-authority-panel">
              <p class="card-label">Primary Offer</p>
              <h2 class="mt-2 text-2xl font-extrabold tracking-[-0.05em]">
                Fractional CMO for post-PMF AI and SaaS.
              </h2>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-[color:var(--muted)]">
                <li>Best for £1m to £10m ARR</li>
                <li>Founder-led, growth stuck, no senior GTM owner</li>
                <li>Senior help without a £150k+ full-time hire</li>
                <li>Recent work: AI health, B2B fintech, edtech, SaaS tooling</li>
              </ul>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Social proof strip ─────────────────────────────────────────── -->
  <section class="section-space pt-0">
    <div class="shell">
      <div class="trust-strip trust-strip-large" aria-label="Selected affiliations and platforms">
        <p class="trust-strip-label">As featured on / affiliated with</p>
        <div class="trust-strip-logos">
          {
            trustLogos.map((item) => (
              <img
                alt={item.alt}
                class={`trust-logo trust-logo-${item.id}`}
                decoding="async"
                height="48"
                loading="lazy"
                src={item.src}
                width="180"
              />
            ))
          }
          {
            trustBadges.map((item) => (
              <span class={`trust-badge trust-badge-${item.variant}`}>{item.label}</span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Problem statement ─────────────────────────────────────────── -->
  <section class="section-space pt-0" aria-labelledby="problem-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <h2 id="problem-heading" class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-6xl">
          You've got traction. <span class="hero-accent">So why does growth still feel like guessing?</span>
        </h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          Paying customers. Revenue line moving. A fundraising deck that holds up. But the acquisition engine?
          Growth plateauing, founder-led sales that doesn't scale, no repeatable pipeline, and a GTM stack that's
          three tools taped together.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          You've tried paid. You've tried content. You've tried hiring a generalist marketer. Something worked,
          most of it didn't, and nobody on the team can tell you why.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          You don't need more tactics. You need a senior operator who can walk in, see the whole system at once,
          and tell you, with specifics, which two levers actually matter for your company right now.
        </p>
      </div>
    </div>
  </section>

  <!-- 4. Growth Diagnosis — interactive quiz ────────────────────────── -->
  <section class="section-space pt-0" id="growth-diagnosis" aria-labelledby="diagnosis-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Free · 2 minutes"
        intro="Five questions. Tailored output. A clear read on which lever matters most for your company right now."
        title="Find your biggest growth bottleneck."
      />
      <GrowthDiagnosis />
    </div>
  </section>

  <!-- 5. What I do ──────────────────────────────────────────────────── -->
  <section class="section-space pt-0" id="services">
    <div class="shell">
      <SectionHeader
        eyebrow="What I do"
        intro="Three ways to work with me. Start wherever the shape fits."
        title="Work with me."
      />

      <div class="explore-grid mt-10">
        {
          serviceCards.map((card) => (
            <article class:list={["explore-card card p-6 md:p-8", card.primary && "explore-card-primary"]}>
              <p class="card-label">{card.primary ? "Primary Offer" : "Secondary"}</p>
              <h3 class="mt-4 text-2xl font-extrabold tracking-[-0.05em]">{card.heading}</h3>
              <p class="mt-2 text-base font-semibold leading-7 tracking-[-0.02em]">{card.strap}</p>
              <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{card.body}</p>
              <p class="mt-5 border-t border-[color:var(--line)] pt-4 text-sm leading-6 text-[color:var(--muted)]">
                <strong class="font-semibold text-[color:var(--ink)]">Best for:</strong> {card.bestFor}
              </p>
              <a class="link-arrow mt-6" href={card.href}>{card.cta}</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 6. Who this is for / not for ──────────────────────────────────── -->
  <section class="section-space pt-0" aria-labelledby="fit-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Fit"
        intro="I'd rather save us both a 30-minute call if we're not the right match."
        title="Who this is for, and who it's not."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label text-[color:var(--accent)]">Best fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {fitSignals.bestFor.map((point) => (
              <li class="fit-row fit-row-yes">{point}</li>
            ))}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">Not a fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {fitSignals.notFor.map((point) => (
              <li class="fit-row fit-row-no">{point}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- 7. Why me vs agency ─────────────────────────────────────────── -->
  <section class="section-space pt-0" aria-labelledby="vs-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Why not an agency"
        intro="You do not need another agency layer when the real problem is senior growth judgement."
        title="Senior growth judgement, not junior execution."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">{agencyVsMe.agency.heading}</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {agencyVsMe.agency.points.map((point) => <li class="fit-row fit-row-no">{point}</li>)}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8 card-accent-border">
          <p class="card-label text-[color:var(--accent)]">{agencyVsMe.me.heading}</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {agencyVsMe.me.points.map((point) => <li class="fit-row fit-row-yes">{point}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- 8. The method ───────────────────────────────────────────────── -->
  <section class="dark-section section-space" aria-labelledby="method-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="eyebrow justify-center text-white/60">The method</span>
        <h2 id="method-heading" class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-white md:text-6xl">
          I don't sell services. <span class="hero-accent">I build systems.</span>
        </h2>
      </div>

      <div class="reveal mx-auto mt-10 max-w-3xl space-y-5 text-lg leading-8 text-white/72">
        <p>Most growth consultants arrive, ship a deck, and disappear. That's not how I work.</p>
        <p>
          Every engagement builds the same thing, a growth system. Not a campaign. Not a funnel. A repeatable architecture
          your team can run after I'm gone.
        </p>
        <p class="text-sm uppercase tracking-[0.16em] text-white/50">
          {layerCount} layers, tailored to where you are
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          methodLayers.map((layer, index) => (
            <a class="reveal card p-6" href={layer.href}>
              <p class="card-label text-white/55">0{index + 1}</p>
              <h3 class="mt-3 text-xl font-bold tracking-[-0.04em] text-white">{layer.title}</h3>
              <p class="mt-3 text-sm leading-7 text-white/68">{layer.body}</p>
            </a>
          ))
        }
      </div>

      <div class="reveal mt-10 text-center">
        <p class="text-base leading-8 text-white/68">
          If "growth system" sounds vague, that's fine. I'll show you exactly what it looks like on a 30-minute audit.
        </p>
        <div class="mt-6 flex justify-center gap-3 flex-wrap">
          <a class="button-accent" href={ctas.primary.href} data-cta="method-primary">
            {ctas.primary.label} →
          </a>
          <a class="button-link-invert" href={ctas.bottleneck.href} data-cta="method-secondary">
            {ctas.bottleneck.label} →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. Why AI-native matters ─────────────────────────────────────── -->
  <section class="section-space" aria-labelledby="ai-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-5xl space-y-6">
        <span class="eyebrow">Category</span>
        <h2 id="ai-heading" class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-5xl">
          AI should make GTM work faster, not vaguer.
          <span class="hero-accent">The human decisions still matter.</span>
        </h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          In practice, I use AI to shorten research synthesis, customer-call review, competitor teardowns,
          message testing, reporting, and campaign iteration. That means less manual drag and faster decisions.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          You still need a human operator deciding which customer signal matters, which channel deserves budget,
          and which message is strong enough to test. AI helps produce the raw material faster.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          The practical output is simple: faster research, sharper briefs, cleaner reporting, and fewer wasted weeks
          between seeing a problem and testing the fix.
        </p>
        <p>
          <a class="link-arrow" href="/writing/">Read: What AI-native GTM actually means →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- 10. Proof — real outcomes ──────────────────────────────────── -->
  <section class="dark-section section-space" id="proof" aria-labelledby="proof-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Proof"
        intro="The short list. Full case studies live below."
        title="Real campaigns. Real numbers. Real attribution."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          outcomeCards.map((card) => (
            <article class="reveal card p-6">
              <p class="text-5xl font-extrabold tracking-[-0.07em] text-white">{card.metric}</p>
              <p class="mt-2 text-sm font-semibold uppercase tracking-[0.12em] text-white/65">{card.metricSuffix}</p>
              <p class="mt-5 text-sm leading-7 text-white/70">{card.context}</p>
              <p class="mt-5 border-t border-white/[0.08] pt-3 text-xs font-semibold uppercase tracking-[0.14em] text-white/45">
                {card.sector}
              </p>
            </article>
          ))
        }
      </div>

      <div class="reveal mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-center text-sm font-semibold uppercase tracking-[0.12em] text-white/60">
        {lifetimeTotals.map((item) => <span>{item}</span>)}
      </div>

      <div class="reveal mt-6 text-center">
        <a class="link-arrow" href="/case-studies/">See full case studies →</a>
      </div>
    </div>
  </section>

  <!-- 11. Testimonials ─────────────────────────────────────────────── -->
  <section class="section-space" aria-labelledby="testimonials-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Testimonials"
        intro="Founder feedback from mentoring, advisory, and growth sessions."
        title="What founders say."
      />

      {leadTestimonial && (
        <blockquote class="reveal mt-10 card p-8 md:p-12 testimonial-lead">
          <p class="text-2xl font-semibold leading-10 tracking-[-0.04em] md:text-3xl">
            "{leadTestimonial.data.quote}"
          </p>
          <footer class="mt-6 border-t border-[color:var(--line)] pt-4 text-sm">
            <p class="font-semibold">{leadTestimonial.data.name}</p>
            <p class="text-[color:var(--muted)]">{leadTestimonial.data.role}{leadTestimonial.data.organisation ? ` · ${leadTestimonial.data.organisation}` : ""}</p>
          </footer>
        </blockquote>
      )}

      <div class="mt-5 grid gap-5 md:grid-cols-2">
        {
          supportingTestimonials.map((item) => (
            <blockquote class="reveal card p-6 md:p-7">
              <p class="text-lg font-semibold leading-8 tracking-[-0.03em]">
                "{item.data.quote}"
              </p>
              <footer class="mt-6 border-t border-[color:var(--line)] pt-4 text-sm">
                <p class="font-semibold">{item.data.name}</p>
                <p class="text-[color:var(--muted)]">{item.data.role}{item.data.organisation ? ` · ${item.data.organisation}` : ""}</p>
              </footer>
            </blockquote>
          ))
        }
      </div>

      <div class="reveal mt-6 text-center">
        <a class="link-arrow" href={siteConfig.growthMentorReviews} rel="noreferrer" target="_blank">
          Read more founder feedback →
        </a>
      </div>
    </div>
  </section>

  <!-- 12. About preview ────────────────────────────────────────────── -->
  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="eyebrow">About</span>
        <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-5xl">About Daniel.</h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          10+ years in growth as a co-founder, an embedded Head of Growth, and a fractional CMO. I've worked with
          20+ AI and B2B SaaS startups, managed £6.8M+ in paid spend, generated £18M+ in revenue, and helped founders
          raise £15M+. I've co-founded two companies, one in mental-health tech (eQuoo) and one in eCommerce.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          I mentor founders through Google for Startups, Techstars, and GrowthMentor. I've
          lectured at Cambridge Judge Business School and Imperial College London, and delivered growth workshops at
          Google Launchpad programmes across the UK, Europe, and Africa. {siteConfig.location}
        </p>
        <p>
          <a class="link-arrow" href="/about/">Read more about Daniel →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- 13. Writing ─────────────────────────────────────────────────── -->
  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Writing"
        intro="Essays on AI-native GTM, growth systems, and why most startup growth advice is wrong."
        title="Writing."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          articles.map((article) => (
            <article class="reveal card p-6 md:p-7">
              <p class="card-label">
                {article.data.publishedAt.toLocaleDateString("en-US", { day: "numeric", month: "short", year: "numeric" })}
                {article.data.readingTime ? ` · ${article.data.readingTime}` : ""}
              </p>
              <h3 class="mt-3 text-xl font-bold tracking-[-0.04em]">{article.data.title}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{article.data.description}</p>
              <a class="link-arrow mt-5" href={`/writing/${article.id}/`}>Read essay →</a>
            </article>
          ))
        }
      </div>

      <div class="reveal mt-8 flex flex-wrap items-center gap-3">
        <a class="button-accent" href="/writing/">Read all writing →</a>
        <a class="button-link" href="/newsletter/">Subscribe to Growth Notes →</a>
        <a class="button-link" href="/growth-bottleneck-checklist/">Open the bottleneck checklist →</a>
      </div>
    </div>
  </section>

  <!-- 14. Final CTA ───────────────────────────────────────────────── -->
  <section class="cta-gradient section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <span class="eyebrow justify-center text-white/60">Next step</span>
        <h2 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance text-white md:text-7xl">
          {ctas.primary.label}.
        </h2>
        <p class="mx-auto max-w-2xl text-lg leading-8 text-white/72">
          30 minutes on your specific situation. No pitch, no deck, no trying-to-close. You'll leave with a clearer
          read on your biggest growth bottleneck and whether working together makes sense. If it doesn't, I'll tell
          you what I'd do instead and point you to the right operator, agency, or mentor.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a class="button-accent" href={ctas.primary.href} data-cta="final-primary">
            {ctas.primary.label} →
          </a>
          <a class="button-link-invert" href={ctas.bottleneck.href} data-cta="final-secondary">
            {ctas.bottleneck.label}
          </a>
        </div>
        <p class="text-sm text-white/60">
          Prefer email first? <a class="text-white underline" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
