              </ul>
            </aside>
          </div>
        </div>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          <a class="link-arrow" href="/ai-native-workflows/">AI-native workflows on engagements →</a>
          <a class="link-arrow" href="/writing/">Read: What AI-native GTM actually means →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. Image-led credibility ────────────────────────────────────── -->
  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Beyond the deck"
