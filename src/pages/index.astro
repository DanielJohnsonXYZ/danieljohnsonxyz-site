---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortByFeaturedThenOrder } from "../lib/utils";
import { siteConfig, trustLogos } from "../site";

const proof = sortByFeaturedThenOrder(await getCollection("proof")).slice(0, 4);
const testimonials = sortByFeaturedThenOrder(await getCollection("testimonials")).slice(0, 6);
const [primaryProof, ...supportingProof] = proof;
const featuredTestimonial = testimonials.find((item) => item.data.name === "Christian A") ?? testimonials[0];
const supportingTestimonials = testimonials
  .filter((item) => item.id !== featuredTestimonial.id)
  .slice(0, 2);

const fitChips = ["Seed to Series A", "Post-traction", "SaaS, AI, fintech, commerce", "Founder-led teams"];

const heroStats = [
  { value: "10+ yrs", label: "Growth operating work" },
  { value: "2 exits", label: "Founder perspective" },
  { value: "20+", label: "Startups advised" },
  { value: "479+", label: "Founder sessions" }
];

const bottlenecks = [
  "Demand exists, but acquisition is inconsistent.",
  "Channels are active, but learning is not compounding.",
  "The founder is still making too many GTM decisions by instinct."
];

const pipeline = [
  {
    step: "01",
    title: "Diagnose",
    body: "Find where growth is actually breaking: narrative, measurement, activation, retention, or team focus.",
    example: "At NAVA, this meant looking past installs and into the retention system behind the first 30K+ downloads."
  },
  {
    step: "02",
    title: "Prioritise",
    body: "Turn founder instinct and dashboard noise into a ranked set of decisions the team can defend.",
    example: "For paid acquisition work, this often means clarifying who the channel should serve before increasing spend."
  },
  {
    step: "03",
    title: "Execute",
    body: "Work with the team to ship the experiments, positioning, funnels, and operating rhythms that matter now.",
    example: "At Shoprocket, research-led positioning and digital execution supported a 30% lift in customer LTV."
  },
  {
    step: "04",
    title: "Compound",
    body: "Feed the learning back into the system so growth becomes less dependent on a single founder or campaign.",
    example: "Across 479+ mentor sessions, the useful handoff is usually a clearer cadence founders can keep running."
  }
];

const outcomeBars = [
  { label: "Retention lift", value: "+40%", note: "NAVA growth system" },
  { label: "CAC reduction", value: "-35%", note: "Confidential crypto trading platform" },
  { label: "LTV gain", value: "+30%", note: "Shoprocket positioning work" },
  { label: "Churn reduction", value: "-21%", note: "Lifecycle work across ecommerce clients" }
];

const miniCases = [
  {
    company: "NAVA",
    problem: "Mobile app traction needed stronger retention signals.",
    outcome: "30K+ downloads in eight months and a 40%+ retention lift."
  },
  {
    company: "Shoprocket",
    problem: "Revenue growth needed better positioning and customer value quality.",
    outcome: "30% lift in LTV while the business doubled revenue."
  },
  {
    company: "GrowthMentor",
    problem: "Founders needed practical bottleneck diagnosis, not broad marketing advice.",
    outcome: "479+ founder sessions with a 4.97/5 average review score."
  }
];

const deeperLinks = [
  {
    eyebrow: "Primary path",
    title: "Advisory",
    body: "Fractional CMO, growth advisory, and focused strategic sprints for post-traction teams.",
    href: "/advisory",
    cta: "Explore advisory",
    primary: true
  },
  {
    eyebrow: "Authority platform",
    title: "Speaking",
    body: "Talk themes, proof points, and selected rooms from Google Launchpad to Cambridge and Imperial.",
    href: "/speaking",
    cta: "See speaking topics"
  },
  {
    eyebrow: "Point of view",
    title: "Insights",
    body: "Native essays plus a curated archive of useful interviews, profiles, talks, and growth resources.",
    href: "/insights",
    cta: "Read selected thinking"
  }
];
---

<BaseLayout
  description={siteConfig.description}
  title="Daniel Johnson | Fractional CMO and Growth Advisor"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="grid gap-12 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
        <div class="reveal flex flex-col gap-6">
          <span class="service-label">Fractional CMO / Growth Advisor</span>

          <div class="space-y-5">
            <h1 class="max-w-5xl text-5xl font-extrabold leading-[0.98] tracking-[-0.07em] text-balance md:text-7xl lg:text-[5.55rem]">
              I help post-traction startups build a repeatable <span class="hero-accent">GTM system.</span>
            </h1>
            <p class="hero-subcopy max-w-3xl text-xl leading-9 md:text-2xl">
              For seed-to-Series A teams with demand, but no reliable acquisition rhythm yet. I turn scattered growth
              activity into clearer priorities, stronger experiments, and a system the team can run.
            </p>
          </div>

          <div class="hero-scan-list" aria-label="Best fit situations">
            {bottlenecks.map((item) => <span>{item}</span>)}
          </div>

          <div class="flex flex-wrap gap-2">
            {fitChips.map((item) => <span class="chip chip-quiet">{item}</span>)}
          </div>

          <div class="trust-strip" aria-label="Selected institutions and platforms from Daniel Johnson's public footprint">
            <p class="trust-strip-label">Trusted in rooms with</p>
            <div class="trust-strip-logos">
              {
                trustLogos.slice(0, 5).map((item) => (
                  <img alt={item.alt} height="48" loading="eager" src={item.src} width="180" />
                ))
              }
            </div>
          </div>

          <div class="cta-cluster">
            <div class="flex flex-wrap gap-3">
              <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
              <a class="button-secondary" href="#proof">See results and examples</a>
            </div>
            <p>{siteConfig.bookingNote}</p>
            <p class="availability-line">{siteConfig.availability}</p>
          </div>
        </div>

        <div class="reveal">
          <article class="hero-photo-card hero-offer-card">
            <img
              alt="Portrait of Daniel Johnson"
              class="aspect-[4/5] w-full object-cover object-top"
              height="960"
              loading="eager"
              src={siteConfig.headshot}
              width="768"
            />
            <div class="hero-authority-panel">
              <p class="card-label">Best fit</p>
              <h2 class="mt-2 text-2xl font-extrabold tracking-[-0.05em]">
                Teams that have traction, but need senior GTM judgment before hiring the next full-time leader.
              </h2>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-[color:var(--muted)]">
                <li>Typically seed to Series A</li>
                <li>Useful for acquisition, activation, positioning, and growth operating rhythm</li>
                <li>WSS is context; this is Daniel's personal advisory practice</li>
              </ul>
              <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-xl bg-[color:var(--line)]">
                {
                  heroStats.map((item) => (
                    <div class="bg-[color:var(--surface)] p-4">
                      <p class="text-2xl font-extrabold tracking-[-0.07em]">{item.value}</p>
                      <p class="mt-1 text-xs leading-5 text-[color:var(--muted)]">{item.label}</p>
                    </div>
                  ))
                }
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="dark-section section-space" id="proof">
    <div class="shell">
      <SectionHeader
        eyebrow="Proof"
        intro="A cold visitor should not have to infer the credibility. The numbers, rooms, and founder feedback sit together here."
        title="Results and examples."
      />

      <div class="proof-grid mt-10">
        <article class="reveal proof-primary card p-6 md:p-8">
          <p class="card-label text-white/55">Primary signal</p>
          <p class="mt-5 text-6xl font-extrabold leading-none tracking-[-0.08em] text-white md:text-8xl">
            {primaryProof.data.metric}
          </p>
          <h2 class="mt-6 text-3xl font-extrabold tracking-[-0.05em] text-white md:text-4xl">{primaryProof.data.title}</h2>
          <p class="mt-4 max-w-2xl text-base leading-8 text-white/68">{primaryProof.data.summary}</p>
        </article>

        <div class="grid gap-4">
          {
            supportingProof.map((item) => (
              <article class="reveal proof-secondary card p-5">
                <p class="text-4xl font-extrabold tracking-[-0.07em] text-white">{item.data.metric}</p>
                <h3 class="mt-3 text-lg font-bold tracking-[-0.04em] text-white/90">{item.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-white/60">{item.data.summary}</p>
              </article>
            ))
          }
        </div>
      </div>

      <div class="case-study-strip mt-8">
        {
          miniCases.map((item) => (
            <article class="reveal case-study-card">
              <p class="card-label text-white/45">{item.company}</p>
              <h3>{item.problem}</h3>
              <p>{item.outcome}</p>
            </article>
          ))
        }
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label text-white/55">Outcome pattern</p>
          <p class="mt-4 text-4xl font-extrabold tracking-[-0.07em] text-white md:text-5xl">Better signal, less waste.</p>
          <p class="mt-3 text-base leading-8 text-white/68">
            The point is not more activity. It is sharper learning across the parts of growth that actually decide revenue quality.
          </p>
          <dl class="metric-list mt-8">
            {
              outcomeBars.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>
                    <strong>{item.value}</strong>
                    <span>{item.note}</span>
                  </dd>
                </div>
              ))
            }
          </dl>
        </article>

        <article class="reveal testimonial-feature card p-6 md:p-8">
          <p class="card-label text-white/55">Founder feedback</p>
          <blockquote class="mt-5">
            <p class="text-3xl font-extrabold leading-[1.12] tracking-[-0.06em] text-white md:text-5xl">
              "{featuredTestimonial.data.quote}"
            </p>
            <footer class="mt-6 border-t border-white/[0.08] pt-5 text-sm text-white/65">
              <p class="font-semibold text-white">{featuredTestimonial.data.name}</p>
              <p>{featuredTestimonial.data.role} &bull; {featuredTestimonial.data.organisation}</p>
              <p class="mt-2 text-xs text-white/45">GrowthMentor founder session; company not public.</p>
            </footer>
          </blockquote>
        </article>
      </div>

      <div class="mt-5 grid gap-5 md:grid-cols-2">
        {
          supportingTestimonials.map((item) => (
            <blockquote class="reveal testimonial-compact card p-6">
              <p class="text-lg font-semibold leading-8 tracking-[-0.03em] text-white/88">"{item.data.quote}"</p>
              <footer class="mt-5 text-sm text-white/55">
                <p class="font-semibold text-white/85">{item.data.name}</p>
                <p>{item.data.role} &bull; {item.data.organisation}</p>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="System"
        intro="The Growth Operating System is deliberately simple, but it gets tangible fast. Each stage is tied to the practical work of making growth less dependent on guesswork."
        title="A four-stage operating system with real examples."
      />

      <div class="pipeline-card reveal mt-10">
        {
          pipeline.map((item, index) => (
            <article class="pipeline-step">
              {index < pipeline.length - 1 && <span aria-hidden="true" class="pipeline-arrow">-&gt;</span>}
              <p class="pipeline-num">{item.step}</p>
              <h2 class="mt-4 text-2xl font-bold tracking-[-0.04em]">{item.title}</h2>
              <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">{item.body}</p>
              <p class="mt-5 border-t border-[color:var(--line)] pt-4 text-sm font-semibold leading-6 tracking-[-0.02em]">
                {item.example}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal grid gap-5 lg:grid-cols-[1.35fr_0.82fr_0.82fr]">
        {
          deeperLinks.map((item) => (
            <article class:list={["explore-card card p-6 md:p-7", item.primary && "explore-card-primary"]}>
              <p class="card-label">{item.eyebrow}</p>
              <h2 class="mt-4 text-2xl font-extrabold tracking-[-0.05em]">{item.title}</h2>
              <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">{item.body}</p>
              <a class="link-arrow mt-6" href={item.href}>{item.cta}</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-gradient section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-8 text-center">
        <span class="eyebrow justify-center text-white/60">Next step</span>
        <h2 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance text-white md:text-7xl">
          Start with the bottleneck. <span class="hero-accent">Then build the system.</span>
        </h2>
        <p class="mx-auto max-w-2xl text-lg leading-8 text-white/68">
          {siteConfig.bookingNote} Low-friction, practical, and useful even if the next step is not an engagement.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
          <a class="button-secondary" href={`mailto:${siteConfig.email}?subject=Speaking%20and%20media%20enquiry`}>Speaking and media enquiries</a>
        </div>
        <p class="text-sm font-semibold text-white/60">{siteConfig.availability}</p>
      </div>
    </div>
  </section>
</BaseLayout>
