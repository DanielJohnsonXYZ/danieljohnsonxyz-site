---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import GrowthSystemDiagram from "../components/GrowthSystemDiagram.astro";
import CfEmailOff from "../components/CfEmailOff.astro";
import RotatingTextBars from "../components/RotatingTextBars.astro";
import AnswerEvidenceBlock from "../components/AnswerEvidenceBlock.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildAggregateRatingSchema, buildFaqPageSchema, buildServiceSchema } from "../lib/schema";
import { absoluteUrl, sortByFeaturedThenOrder } from "../lib/utils";
import {
  agencyVsMe,
  ctas,
  fitSignals,
  homeServiceLadder,
  icpFirmographics,
  lifetimeTotals,
  positioning,
  proofBar,
  singleIdea,
  siteConfig,
  trustLogos
} from "../site";
import "../styles/hero-v3.css";

// ─── Content data ───────────────────────────────────────────────────────
const articles = (await getCollection("articles"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const media = sortByFeaturedThenOrder(await getCollection("media"));
const featuredMedia = media.slice(0, 4);

const testimonials = sortByFeaturedThenOrder(await getCollection("testimonials"));
const leadTestimonial = testimonials.find((t) => t.data.name === "Christian A");
const supportingTestimonials = [
  testimonials.find((t) => t.data.name === "Camiel Roex"),
  testimonials.find((t) => t.data.name === "Greg Weinstein")
].filter(Boolean) as typeof testimonials;

// ─── Method layers ──────────────────────────────────────────────────────
const methodLayers = [
  { title: "GTM systems", body: "ICP doc, positioning test results, weekly growth dashboard.", href: "/gtm-systems/" },
  { title: "Acquisition", body: "Channel test map, experiment backlog, paid and organic decision rules.", href: "/experimentation/" },
  { title: "Conversion", body: "Homepage message tests, funnel notes, activation and demo-booking fixes.", href: "/product-led-growth/" },
  { title: "AI-assisted research", body: "Customer-call synthesis, competitor teardown, message bank.", href: "/ai-native-workflows/" },
  { title: "Founder-led distribution", body: "Founder content pillars, proof library, content-to-pipeline loop.", href: "/founder-led-distribution/" },
  { title: "Reporting", body: "Growth scorecard, pipeline view, weekly stop / scale / fix notes.", href: "/revenue-operations/" }
];

// Hero proof — pick the three most evocative numbers (compact ticker)
const heroProofTicker = proofBar.slice(0, 3);

// Hero credentials — just the four marquee affiliations
const heroCredentialIds = new Set(["growthmentor", "cambridge-judge", "techstars", "imperial"]);
const heroCredentialLogos = trustLogos.filter((item) => heroCredentialIds.has(item.id));

// Hero engagement card — three rungs of the ladder, in one tap each
const heroEngagementRows = [
  {
    step: "01",
    title: "20-min Growth Audit",
    sub: "Free call. Bottleneck read, honest fit, no pitch.",
    href: siteConfig.bookingPageUrl,
    cta: "hero-engage-audit"
  },
  {
    step: "02",
    title: "Strategy Sprint",
    sub: "£6k fixed scope. Plan, artefacts, first wins in 2–4 weeks.",
    href: "/strategy-sprint/",
    cta: "hero-engage-sprint"
  },
  {
    step: "03",
    title: "Fractional CMO",
    sub: "Senior growth leadership without a full-time hire.",
    href: "/fractional-cmo/",
    cta: "hero-engage-cmo",
    recommended: true
  }
];

// ─── Proof — real outcomes ───────────────────────────────────────────────
const outcomeCards = [
  {
    metric: "6×",
    metricSuffix: "app downloads",
    context: "2k → 12k+ monthly downloads in 6 months after acquisition and lifecycle rebuild.",
    sector: "HealthTech · AI"
  },
  {
    metric: "35%",
    metricSuffix: "lower CAC",
    context: "CAC down 35% in 8 weeks — segmentation, paid account structure, landing-page routing.",
    sector: "Fintech · Crypto"
  },
  {
    metric: "500+",
    metricSuffix: "qualified signups",
    context: "500+ qualified signups from a single campaign at 8.6% CTR. US B2B fintech.",
    sector: "Fintech · B2B SaaS"
  },
  {
    metric: "21%",
    metricSuffix: "less churn",
    context: "Retention up 21% in 3 months. Targeted lifecycle and win-back messaging.",
    sector: "eCommerce"
  }
];

const imageStoryCards = [
  {
    eyebrow: "Speaking",
    title: "Founder rooms, startup cohorts, practical commercial work.",
    body: "Talks and workshops are built around the decision the room needs to make next, not a theatre of frameworks.",
    href: "/speaking/",
    cta: "See speaking assets",
    image: "/images/cambridge-judge-business-school-960.webp",
    alt: "Cambridge Judge Business School, one of Daniel Johnson's selected teaching and speaking affiliations"
  },
  {
    eyebrow: "Operator mindset",
    title: "Systems, instruments, judgment under uncertainty.",
    body: "The same bias shows up in the work: define the signal, read the instruments, make the next decision before the system drifts.",
    href: "/about/",
    cta: "Read about Daniel",
    image: "/images/daniel-aircraft.webp",
    alt: "Daniel Johnson in a small aircraft, connecting systems thinking with growth operating work"
  }
];

// ─── FAQ ─────────────────────────────────────────────────────────────────
const homepageFaq: Array<{
  question: string;
  answer: string;
  link?: { href: string; label: string };
}> = [
  {
    question: "What does a fractional CMO actually do day-to-day?",
    answer:
      "Owns the weekly GTM rhythm: sharp ICP and positioning, channel and experiment priorities, reporting that drives scale/stop/fix decisions, and the handoffs between founder, sales, and any agencies. It is operator work in your Slack and meetings — not a monthly slide deck."
  },
  {
    question: "How is this different from hiring a full-time CMO?",
    answer:
      "You buy a slice of senior time with a clear scope — usually one to two days a week — instead of a £120–180k+ base, equity, and a six-month ramp before the system shows up. Most teams use fractional to install the operating system, then hire full-time into something that already runs.",
    link: { href: "/resources/fractional-cmo-vs-full-time-cmo/", label: "Fractional vs full-time →" }
  },
  {
    question: "What stage should my startup be at?",
    answer:
      "Post-PMF with real revenue and repeat buyers — typically Seed to Series B — where the constraint is execution and ownership, not finding the problem. Pre-revenue teams should stay focused on customers and product; the GTM system comes after that clarity.",
    link: { href: "/resources/fractional-cmo-vs-full-time-cmo/", label: "When each model fits →" }
  },
  {
    question: "How quickly will I see results?",
    answer:
      "You should see sharper decisions and cleaner reporting within the first few weeks; meaningful pipeline and conversion movement usually shows in 30–90 days depending on sales cycle length and how fast tests ship. I do not promise miracles — I promise a visible system and honest calls on what is working."
  },
  {
    question: "What does it cost?",
    answer:
      "UK engagements typically start around £6k for a short strategy sprint, £7.5–12k/month for fractional CMO (3-month minimum), scoped to days per week and depth. The service page lists how the week runs; the UK cost page lists benchmark ranges and what moves price.",
    link: { href: "/resources/fractional-cmo-cost-uk/", label: "Fractional CMO cost (UK) →" }
  },
  {
    question: "How do I know if this will work for my business?",
    answer:
      "If growth still depends on you reading every dashboard and approving every message, and the team does not share one constraint map, the model fits. The 20-minute audit is deliberately designed to name the bottleneck and say no when the shape of help is wrong."
  }
];

// ─── Structured data ────────────────────────────────────────────────────
const schemas = [
  buildFaqPageSchema(homepageFaq.map(({ question, answer }) => ({ question, answer }))),
  buildAggregateRatingSchema(),
  buildServiceSchema({
    name: "Fractional CMO for Seed to Series B AI & B2B SaaS",
    description:
      "Embedded senior GTM leadership for post-PMF AI and B2B SaaS startups. Predictable pipeline, sharper positioning, senior growth judgement — without a £150k+ full-time hire. Typical UK engagement range: £6,000 – £12,000/month.",
    url: absoluteUrl("/fractional-cmo/"),
    serviceType: "Fractional CMO",
    offers: [
      {
        name: "20-min Growth Audit",
        description: "Free 20-minute diagnostic call. Bottleneck read, fit decision, recommendation.",
        price: "0",
        billingIncrement: "per call"
      },
      {
        name: "Strategy Sprint",
        description: "2–4 weeks. Diagnose the bottleneck, set 90-day priorities, ship first artefacts.",
        price: "6000",
        billingIncrement: "per engagement"
      },
      {
        name: "Fractional CMO",
        description: "3-month minimum. Embedded senior ownership 1 day a week.",
        price: "7500",
        billingIncrement: "per month"
      },
      {
        name: "Fractional CMO Plus",
        description: "Deeper operating support, agency management, faster execution.",
        price: "12000",
        billingIncrement: "per month"
      }
    ]
  })
];
---

<BaseLayout
  description={positioning.metaDescription}
  path="/"
  preloadHeadshot
  schema={schemas}
  title="Fractional CMO for AI & B2B SaaS Startups | Daniel Johnson"
>
  <!-- ════════════════════════════════════════════════════════════════════
       1 · HERO — confident, premium, focused
       ════════════════════════════════════════════════════════════════════ -->
  <section class="dj-hero" aria-labelledby="hero-heading">
    <div class="shell">
      <div class="dj-hero-layout">
        <!-- Left column: text & CTA stack -->
        <div class="dj-hero-content">
          <span class="dj-hero-eyebrow">
            <span class="dj-hero-eyebrow-dot" aria-hidden="true"></span>
            <span>Fractional CMO · {singleIdea.short}</span>
          </span>

          <h1 id="hero-heading" class="dj-hero-h1">
            Your growth still depends on you.
            <span class="dj-hero-h1-accent">That&rsquo;s the bottleneck I fix.</span>
          </h1>

          <p class="dj-hero-subcopy">
            I embed with B2B SaaS and AI founders as a fractional CMO — find the real constraint, build the growth system, hand it off to your team.
          </p>

          <div class="dj-hero-proof-row" aria-label="Daniel's track record at a glance">
            {
              heroProofTicker.map((item) => (
                <div>
                  <strong>
                    {item.source.startsWith("http") ? (
                      <a href={item.source} rel="noreferrer noopener" target="_blank">{item.value}</a>
                    ) : (
                      <a href={item.source}>{item.value}</a>
                    )}
                  </strong>
                  <span>{item.label}</span>
                </div>
              ))
            }
          </div>

          <div class="dj-hero-cta-row">
            <a class="dj-hero-cta-primary" href={ctas.primary.href} data-cta="hero-primary">
              <span>{ctas.primary.label}</span>
              <span class="dj-arr" aria-hidden="true">→</span>
            </a>
            <a class="dj-hero-cta-secondary" href={ctas.caseStudies.href} data-cta="hero-case-studies">
              <span>See case studies</span>
              <span aria-hidden="true">→</span>
            </a>

          </div>

          <div class="flex flex-col gap-2">
            <p class="dj-hero-availability">
              <span class="dj-hero-availability-dot" aria-hidden="true"></span>
              {siteConfig.availability}
            </p>
            <p class="dj-hero-icp">
              <strong>Best fit:</strong> {icpFirmographics.oneLiner}
            </p>
          </div>
        </div>

        <!-- Right column: portrait, badge, credentials, engagement card -->
        <aside class="dj-hero-side" aria-label="About Daniel">
          <div class="dj-hero-portrait-frame">
            <div class="dj-hero-portrait-inner">
              <img
                alt="Daniel Johnson, fractional CMO and AI-native growth operator"
                decoding="async"
                fetchpriority="high"
                height="960"
                loading="eager"
                src={siteConfig.headshot}
                width="768"
              />
              <span class="dj-hero-portrait-tag">Fractional CMO</span>
              <span class="dj-hero-portrait-badge">
                <span class="dj-hero-portrait-badge-dot" aria-hidden="true"></span>
                Available · {siteConfig.availability.includes("2026") ? "2026" : "now"}
              </span>
            </div>
          </div>

          <div class="dj-hero-creds" aria-label="Selected external affiliations">
            <p class="dj-hero-creds-label">Selected affiliations</p>
            <div class="dj-hero-creds-logos">
              {
                heroCredentialLogos.map((item) => (
                  <img alt={item.alt} decoding="async" loading="lazy" src={item.src} />
                ))
              }
            </div>
          </div>

          <nav class="dj-hero-engagement" aria-label="Ways to work with Daniel">
            <header class="dj-hero-engagement-head">
              <p class="dj-hero-engagement-eyebrow">Ways to work together</p>
              <p class="dj-hero-engagement-title">Pick the smallest commitment that answers your question.</p>
            </header>
            <ul class="dj-hero-engagement-rows" role="list">
              {
                heroEngagementRows.map((row) => (
                  <li class:list={["dj-hero-engagement-row", row.recommended && "dj-hero-engagement-row--recommended"]}>
                    <a class="dj-hero-engagement-link" href={row.href} data-cta={row.cta}>
                      <span class="dj-hero-engagement-step" aria-hidden="true">{row.step}</span>
                      <span class="dj-hero-engagement-body">
                        <strong>{row.title}</strong>
                        <small>{row.sub}</small>
                      </span>
                      <span class="dj-hero-engagement-arr" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </aside>
      </div>

      <!-- Hairline + refined trust strip -->
      <div class="dj-hero-hairline" aria-hidden="true"></div>
      <div class="dj-trust-strip reveal" aria-label="Selected affiliations and platforms">
        <p class="dj-trust-strip-label">Trusted by founders &amp; platforms</p>
        <div class="dj-trust-strip-logos">
          {
            trustLogos.map((item) => (
              <img alt={item.alt} decoding="async" height="32" loading="lazy" src={item.src} width="160" />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       2 · PROBLEM — pulled-quote framing
       ════════════════════════════════════════════════════════════════════ -->
  <section class="section-space" aria-labelledby="problem-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl">
        <div class="dj-problem">
          <span class="dj-eyebrow">The bottleneck</span>
          <h2 id="problem-heading" class="mt-4 dj-section-title">
            You&rsquo;ve got traction. <span class="hero-accent">Growth still feels like guessing.</span>
          </h2>
          <p class="mt-5 dj-section-lede">
            The product works. Revenue is moving. You&rsquo;ve got paying customers and a deck that holds up. But the acquisition engine has plateaued, pipeline arrives in bursts and then goes quiet, and every important growth call still routes through you &mdash; because nobody else has the full picture.
          </p>
          <p class="mt-4 dj-section-lede">
            The instinct is to add something: a new channel, an agency, another campaign. But that&rsquo;s rarely the problem. The problem is that the whole growth function still lives in your head, and there&rsquo;s no system running underneath it.
          </p>
          <p class="mt-4 dj-section-lede">
            What you need isn&rsquo;t more activity. It&rsquo;s a senior operator who can walk in, see the whole machine at once, and tell you &mdash; with specifics &mdash; which one or two levers actually matter for your company right now. Then build the system to run those levers without you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3 · Visual divider — rotating bars ─────────────────────────────── -->
  <div class="reveal overflow-hidden">
    <div class="shell">
      <RotatingTextBars />
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════════════
       4 · BUYING LADDER — three ways in
       ════════════════════════════════════════════════════════════════════ -->
  <section class="section-space pt-8" id="services">
    <div class="shell">
      <SectionHeader
        eyebrow="Three ways in"
        intro="Pick the smallest commitment that answers the question. You can move up the ladder later."
        title="Where do you want to start?"
      />

      <div class="ladder-grid mt-10">
        {
          homeServiceLadder.map((tier, index) => (
            <article class:list={["ladder-card card p-6 md:p-8", tier.primary && "ladder-card-primary"]}>
              <div class="ladder-step" aria-hidden="true">
                <span class="ladder-step-num">0{index + 1}</span>
                {index < homeServiceLadder.length - 1 && <span class="ladder-step-arrow">→</span>}
              </div>
              <p class="card-label mt-4">{tier.tier}</p>
              <h3 class="mt-3 text-2xl font-extrabold tracking-[-0.05em]">{tier.heading}</h3>
              <div class="mt-3 flex flex-wrap items-baseline gap-2">
                <span class="text-2xl font-extrabold tracking-[-0.06em]">{tier.price}</span>
                <span class="text-sm text-[color:var(--muted)]">· {tier.cadence}</span>
              </div>
              <div class="ladder-reveal-details">
                <div class="ladder-reveal-inner">
                  <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{tier.body}</p>
                  <p class="mt-5 border-t border-[color:var(--line)] pt-4 text-sm leading-6 text-[color:var(--muted)]">
                    <strong class="font-semibold text-[color:var(--ink)]">Best for:</strong> {tier.bestFor}
                  </p>
                  <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">
                    <strong class="font-semibold text-[color:var(--ink)]">Outcome:</strong> {tier.outcome}
                  </p>
                  <a class="link-arrow mt-6 block" href={tier.href}>{tier.cta} →</a>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <p class="reveal mt-8 text-center text-sm leading-7 text-[color:var(--muted)]">
        Looking for <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/founder-office-hours/">founder office hours</a>, <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/speaking/">speaking, or workshops</a>? See <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/work-with-me/">all the ways we can work together</a>.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       5 · FIT — best fit vs not a fit
       ════════════════════════════════════════════════════════════════════ -->
  <section class="section-space pt-0" aria-labelledby="fit-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Fit"
        intro="I&rsquo;d rather save us both a 20-minute call if we&rsquo;re not the right match."
        title="Who this is for, and who it&rsquo;s not."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label text-[color:var(--accent)]">Best fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {fitSignals.bestFor.map((point) => (
              <li class="fit-row fit-row-yes">{point}</li>
            ))}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">Not a fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {fitSignals.notFor.map((point) => (
              <li class="fit-row fit-row-no">{point}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       6 · WHY ME vs agency
       ════════════════════════════════════════════════════════════════════ -->
  <section class="section-space pt-0" aria-labelledby="vs-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Why not an agency"
        intro="You don&rsquo;t need another agency layer when the real problem is senior growth judgement."
        title="Senior growth judgement, not junior execution."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">{agencyVsMe.agency.heading}</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {agencyVsMe.agency.points.map((point) => <li class="fit-row fit-row-no">{point}</li>)}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8 card-accent-border">
          <p class="card-label text-[color:var(--accent)]">{agencyVsMe.me.heading}</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {agencyVsMe.me.points.map((point) => <li class="fit-row fit-row-yes">{point}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       7 · THE METHOD — dark section
       ════════════════════════════════════════════════════════════════════ -->
  <section class="dark-section section-space" aria-labelledby="method-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="dj-eyebrow justify-center" style="color: #c4b5fd;">The method</span>
        <h2 id="method-heading" class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-white md:text-6xl text-balance">
          I don&rsquo;t run campaigns. <span class="hero-accent">I build growth systems that run without you.</span>
        </h2>
      </div>

      <div class="reveal mx-auto mt-10 max-w-3xl space-y-5 text-lg leading-8 text-white/72">
        <p>Most growth consultants arrive, ship a deck, and disappear. Not how I work.</p>
        <p>
          Every engagement builds the same thing: a growth system. A repeatable architecture your team can run after I&rsquo;m gone.
        </p>
        <p class="text-sm uppercase tracking-[0.16em] text-white/50">
          Six layers, one loop
        </p>
      </div>

      <div class="reveal mt-12">
        <GrowthSystemDiagram />
      </div>

      <p class="reveal mt-6 text-center text-sm uppercase tracking-[0.14em] text-white/45">
        Each layer also exists as a deeper page — click below
      </p>

      <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          methodLayers.map((layer, index) => (
            <a class="reveal card p-6" href={layer.href}>
              <p class="card-label text-white/55">0{index + 1}</p>
              <h3 class="mt-3 text-xl font-bold tracking-[-0.04em] text-white">{layer.title}</h3>
              <p class="mt-3 text-sm leading-7 text-white/68">{layer.body}</p>
            </a>
          ))
        }
      </div>

      <div class="reveal mt-10 text-center">
        <p class="text-base leading-8 text-white/68">
          If &ldquo;growth system&rdquo; sounds vague, that&rsquo;s fine. I&rsquo;ll show you exactly what it looks like on a 20-minute audit.
        </p>
        <div class="mt-6 flex justify-center">
          <a class="button-accent" href={ctas.primary.href} data-cta="method-primary">
            {ctas.primary.label} →
          </a>
        </div>
      </div>
    </div>
  </section>





  <!-- ════════════════════════════════════════════════════════════════════
       9 · IMAGE-LED CREDIBILITY
       ════════════════════════════════════════════════════════════════════ -->
  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Beyond the deck"
        intro="A few more ways to read the work before you book: rooms, interviews, current focus, and the operator story behind the process."
        title="More signal, fewer claims."
      />

      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        {
          imageStoryCards.map((card) => (
            <article class="reveal image-story-card">
              <img alt={card.alt} decoding="async" height="720" loading="lazy" src={card.image} width="960" />
              <div>
                <p class="card-label">{card.eyebrow}</p>
                <h3>{card.title}</h3>
                <p>{card.body}</p>
                <a class="link-arrow" href={card.href}>{card.cta} →</a>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-8 reveal">
