  <script>
    // ── Homepage kinetics: count-up stats, engine loop sync, hero parallax ──
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Count-up numbers when they scroll into view.
    const formatValue = (el: HTMLElement, value: number) => {
      const decimals = Number(el.dataset.decimals || 0);
      const prefix = el.dataset.prefix || "";
      const suffix = el.dataset.suffix || "";
      el.textContent = `${prefix}${value.toFixed(decimals)}${suffix}`;
    };

    const countEls = document.querySelectorAll<HTMLElement>("[data-countup]");
    if (reduceMotion || !("IntersectionObserver" in window)) {
      countEls.forEach((el) => formatValue(el, Number(el.dataset.target || 0)));
    } else {
      const countObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            countObserver.unobserve(el);
            const target = Number(el.dataset.target || 0);
            const duration = 1200;
            const start = performance.now();
            const tick = (now: number) => {
              const progress = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              formatValue(el, target * eased);
              if (progress < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
          });
        },
        { threshold: 0.5 }
      );
      countEls.forEach((el) => countObserver.observe(el));
    }

    // Engine: auto-cycle the active layer; hovering or focusing a row takes over.
    const engine = document.querySelector("[data-engine]");
    if (engine) {
      const items = engine.querySelectorAll<HTMLElement>("[data-engine-item]");
      const nodes = engine.querySelectorAll<SVGGElement>("[data-engine-node]");
      let active = 0;
      let paused = false;

      const setActive = (index: number) => {
        active = index;
        items.forEach((item, i) => item.classList.toggle("is-active", i === index));
        nodes.forEach((node, i) => node.classList.toggle("is-active", i === index));
      };

      items.forEach((item, i) => {
        item.addEventListener("mouseenter", () => { paused = true; setActive(i); });
        item.addEventListener("focus", () => { paused = true; setActive(i); });
        item.addEventListener("mouseleave", () => { paused = false; });
        item.addEventListener("blur", () => { paused = false; });
      });

      setActive(0);
      if (!reduceMotion) {
        window.setInterval(() => {
          if (!paused) setActive((active + 1) % items.length);
        }, 2600);
      }
    }

    // Hero: cursor-reactive orb + gentle photo parallax (fine pointers only).
    const finePointer = window.matchMedia("(pointer: fine)").matches;
    const hero = document.querySelector<HTMLElement>(".v5-hero");
    const orb = document.querySelector<HTMLElement>("[data-hero-orb]");
    const photo = document.querySelector<HTMLElement>("[data-hero-photo]");
    if (hero && orb && finePointer && !reduceMotion) {
      let targetX = 0, targetY = 0, x = 0, y = 0, raf = 0;
      const render = () => {
        x += (targetX - x) * 0.08;
        y += (targetY - y) * 0.08;
        orb.style.transform = `translate(${x}px, ${y}px)`;
        if (photo) photo.style.transform = `translate(${x * -0.018}px, ${y * -0.018}px)`;
        if (Math.abs(targetX - x) > 0.2 || Math.abs(targetY - y) > 0.2) {
          raf = requestAnimationFrame(render);
        } else {
          raf = 0;
        }
      };
      hero.addEventListener("mousemove", (event) => {
        const rect = hero.getBoundingClientRect();
        targetX = event.clientX - rect.left - rect.width * 0.55;
        targetY = (event.clientY - rect.top - rect.height * 0.45) * 0.6;
        if (!raf) raf = requestAnimationFrame(render);
      });
    }
  </script>
