                <p class="text-[color:var(--muted)]">{item.data.role}{item.data.organisation ? ` · ${item.data.organisation}` : ""}</p>
              </footer>
            </blockquote>
          ))
        }
      </div>
      <!-- Internal testimonials page replaces the old external GrowthMentor link. -->
      <div class="reveal mt-6 text-center">
        <a class="link-arrow" href="/testimonials/" data-cta="home-see-all-testimonials">
          Read all testimonials &amp; founder feedback →
        </a>
      </div>
    </div>
  </section>

  <!-- 12. About preview ────────────────────────────────────────────── -->
  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="eyebrow">About</span>
        <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-5xl">About Daniel.</h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          10+ years in growth as a co-founder, embedded Head of Growth, and fractional CMO. 20+ AI and B2B SaaS startups advised. £6.8M+ paid spend managed, £18M+ revenue generated, £15M+ helped founders raise. Two exits on the founder side: one mental-health tech (eQuoo), one eCommerce.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          I mentor founders through Google for Startups, Techstars, and GrowthMentor. I've lectured at Cambridge Judge Business School and Imperial College London, and delivered Google Launchpad workshops across the UK, Europe, and Africa. {siteConfig.location}
        </p>
        <p>
          <a class="link-arrow" href="/about/">Read more about Daniel</a>
        </p>
      </div>
    </div>
  </section>

  <!-- 13. Writing ─────────────────────────── -->
  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Writing"
