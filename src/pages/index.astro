---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import GrowthDiagnosis from "../components/GrowthDiagnosis.astro";
import GrowthSystemDiagram from "../components/GrowthSystemDiagram.astro";
import HeroEngagementCard from "../components/HeroEngagementCard.astro";
import NewsletterFormInline from "../components/NewsletterFormInline.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildAggregateRatingSchema, buildFaqPageSchema, buildServiceSchema } from "../lib/schema";
import { absoluteUrl, sortByFeaturedThenOrder } from "../lib/utils";
import {
  agencyVsMe,
  aiWorkflowExamples,
  ctas,
  fitSignals,
  homeServiceLadder,
  lifetimeTotals,
  positioning,
  proofBar,
  singleIdea,
  siteConfig,
  siteImages,
  trustAffiliations,
  trustLogos
} from "../site";

// ─── Content data ───────────────────────────────────────────────────────
const articles = (await getCollection("articles"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const media = sortByFeaturedThenOrder(await getCollection("media"));
const featuredMedia = media.slice(0, 4);

const testimonials = sortByFeaturedThenOrder(await getCollection("testimonials"));

const leadTestimonial = testimonials.find((t) => t.data.name === "Christian A");
const supportingTestimonials = [
  testimonials.find((t) => t.data.name === "Camiel Roex"),
  testimonials.find((t) => t.data.name === "Greg Weinstein")
].filter(Boolean) as typeof testimonials;

// ─── Method layers ──────────────────────────────────────────────────────
const methodLayers = [
  { title: "GTM systems", body: "ICP doc, positioning test results, weekly growth dashboard.", href: "/gtm-systems/" },
  { title: "Acquisition", body: "Channel test map, experiment backlog, paid and organic decision rules.", href: "/experimentation/" },
  { title: "Conversion", body: "Homepage message tests, funnel notes, activation and demo-booking fixes.", href: "/product-led-growth/" },
  { title: "AI-assisted research", body: "Customer-call synthesis, competitor teardown, message bank.", href: "/ai-native-workflows/" },
  { title: "Founder-led distribution", body: "Founder content pillars, proof library, content-to-pipeline loop.", href: "/founder-led-distribution/" },
  { title: "Reporting", body: "Growth scorecard, pipeline view, weekly stop / scale / fix notes.", href: "/revenue-operations/" }
];
const layerCount = methodLayers.length;

// ─── Proof — real outcomes ──────────────────────────────────────────────
const outcomeCards = [
  { metric: "6×",  metricSuffix: "app downloads",     context: "2k → 12k+ monthly downloads in 6 months after acquisition and lifecycle rebuild.",   sector: "HealthTech · AI" },
  { metric: "35%", metricSuffix: "lower CAC",         context: "CAC down 35% in 8 weeks — segmentation, paid account structure, landing-page routing.", sector: "Fintech · Crypto" },
  { metric: "500+",metricSuffix: "qualified signups", context: "500+ qualified signups from a single campaign at 8.6% CTR. US B2B fintech.",          sector: "Fintech · B2B SaaS" },
  { metric: "21%", metricSuffix: "less churn",        context: "Retention up 21% in 3 months. Targeted lifecycle and win-back messaging.",            sector: "eCommerce" }
];

const imageStoryCards = [
  {
    eyebrow: "Speaking",
    title: "Founder rooms, startup cohorts, practical commercial work.",
    body: "Talks and workshops are built around the decision the room needs to make next, not a theatre of frameworks.",
    href: "/speaking/",
    cta: "See speaking assets",
    image: siteImages.speakingStageBw.src,
    alt: siteImages.speakingStageBw.alt
  },
  {
    eyebrow: "Operator mindset",
    title: "Systems, instruments, judgment under uncertainty.",
    body: "The same bias shows up in the work: define the signal, read the instruments, make the next decision before the system drifts.",
    href: "/about/",
    cta: "Read about Daniel",
    image: siteImages.outdoorPortrait.src,
    alt: siteImages.outdoorPortrait.alt
  }
];

// ─── FAQ ────────────────────────────────────────────────────────────────
const faq = [
  {
    question: "Who do you work with?",
    answer:
      "Founder-led companies where growth has plateaued or feels noisy and hard to prioritise. Specialist focus on Seed to Series B AI and B2B SaaS, but I also work with healthtech, fintech, edtech, and eCommerce teams. UK-based, currently working from Asia, serving US, UK, Europe, and APAC clients remotely."
  },
  {
    question: "What's the difference between a fractional CMO and a growth operator?",
    answer:
      "Same seniority, different framing. 'Growth operator' signals that I work at the intersection of product and growth, build systems rather than campaigns, and operate rather than just advise. 'Fractional CMO' is the label buyers expect on job boards and mentoring platforms, so it appears where that's useful."
  },
  {
    question: "What does \"AI-native\" mean in practice?",
    answer:
      "Every engagement uses generative and agentic AI to accelerate ICP research, messaging tests, competitor teardowns, outbound sequences, and content, reducing execution time without sacrificing rigour. You pay for senior judgement, not manual consulting deliverables."
  },
  {
    question: "Are you open to full-time roles?",
    answer:
      "Primary focus is fractional CMO engagements. I'll consider a full-time Head of Growth or VP Marketing role for the right post-PMF AI or B2B SaaS company. Book a growth audit to discuss either way."
  }
];

// ─── Structured data ────────────────────────────────────────────────────
const schemas = [
  buildFaqPageSchema(faq),
  buildAggregateRatingSchema(),
  buildServiceSchema({
    name: "Fractional CMO for founder-led companies",
    description:
      "Embedded senior GTM leadership for founder-led companies. Predictable pipeline, sharper positioning, senior growth judgement — without a £150k+ full-time hire. Specialist experience across Seed to Series B AI and B2B SaaS.",
    url: absoluteUrl("/fractional-cmo/"),
    serviceType: "Fractional CMO",
    offers: [
      { name: "30-min Growth Audit", description: "Free 30-minute diagnostic call. Bottleneck read, fit decision, recommendation.", price: "0", billingIncrement: "per call" },
      { name: "Strategy Sprint", description: "2–4 weeks. Diagnose the bottleneck, set 90-day priorities, ship first artefacts.", price: "6000", billingIncrement: "per engagement" },
      { name: "Fractional CMO", description: "3-month minimum. Embedded senior ownership 1 day a week.", price: "7500", billingIncrement: "per month" },
      { name: "Fractional CMO Plus", description: "Deeper operating support, agency management, faster execution.", price: "12000", billingIncrement: "per month" }
    ]
  })
];
---

<BaseLayout
  description={positioning.subheadline}
  path="/"
  preloadHeadshot
  schema={schemas}
  title="Fractional CMO for AI & B2B SaaS Startups | Daniel Johnson"
>
  <!-- 1. Hero ─────────────────────────────────────────────────────────── -->
  <section class="hero-section hero-section-compact section-space" aria-labelledby="hero-heading">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,0.78fr)] lg:items-start">
        <div class="reveal flex flex-col gap-5">
          <span class="service-label">Fractional CMO · {singleIdea.short}</span>

          <div class="space-y-4">
            <!-- Hero headline: full-line subtle ink → violet gradient. -->
            <h1
              id="hero-heading"
              class="hero-gradient-line max-w-4xl text-5xl font-extrabold leading-[1.02] tracking-[-0.055em] text-balance md:text-[3.65rem] lg:text-[3.95rem] xl:text-[4.05rem]"
            >
              If growth still depends on the founder, I fix that.
            </h1>
            <p class="hero-subcopy max-w-3xl text-lg leading-8 md:text-xl">
              <strong class="font-semibold text-[color:var(--ink)]">Predictable pipeline. Sharper positioning. Senior growth leadership for founder-led companies,</strong> with specialist experience across Seed to Series B AI and B2B SaaS.
            </p>
            <p class="max-w-3xl text-base leading-7 text-[color:var(--muted)]">
              Founder of{" "}
              <a
                class="font-semibold text-[color:var(--accent)] underline decoration-[color:var(--line-strong)] underline-offset-4 hover:opacity-90"
                href={siteConfig.companyUrl}
                rel="noopener noreferrer"
                target="_blank"
              >
                We Scale Startups
              </a>
              — structured growth engagements (diagnostics, sprints, and system builds) for teams that need the work to stick after the consultant leaves.
            </p>
            <p class="max-w-3xl text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--subtle)]">
              Available for podcasts, press commentary, and talks on AI-native GTM, founder-led growth, and startup growth systems.
            </p>
          </div>

          <div class="hero-proof-bar" aria-label="Daniel's track record at a glance">
            {
              proofBar.slice(0, 4).map((item) => (
                <div>
                  <strong><span aria-hidden="true">{item.icon}</span> {item.value}</strong>
                  <span>{item.label}</span>
                </div>
              ))
            }
          </div>

          <div class="cta-cluster">
            <div class="flex flex-wrap items-center gap-3">
              <a class="button-accent" href={ctas.primary.href} data-cta="hero-primary">
                {ctas.primary.label} →
              </a>
              <a class="button-link" href={ctas.startHere.href} data-cta="hero-start-here">
                New here? Start here →
              </a>
            </div>
            <p class="availability-line">{siteConfig.availability}</p>
          </div>
        </div>

        <!-- Right column: smaller portrait on top, engagement-model card below. -->
        <div class="reveal hero-right-stack">
          <figure class="hero-portrait-compact">
            <img
              alt="Daniel Johnson, fractional CMO and AI-native growth operator"
              decoding="async"
              fetchpriority="high"
              height={siteImages.heroCutout.height}
              loading="eager"
              src={siteImages.heroCutout.src}
              width={siteImages.heroCutout.width}
            />
          </figure>
          <HeroEngagementCard />
        </div>
      </div>

      <!-- Newsletter inline strip — quiet, sits under hero, full-width inside shell. -->
      <div class="reveal mt-10">
        <NewsletterFormInline
          variant="strip"
          heading="Get practical notes on founder-led growth, AI GTM, positioning, and pipeline systems."
          subline="Occasional. No daily drip. Unsubscribe in one click."
        />
      </div>

      <div class="trust-strip trust-strip-large hero-trust-strip reveal mt-10" aria-label="Selected affiliations and platforms">
        <p class="trust-strip-label">Selected affiliations</p>
        <div class="trust-strip-logos">
          {
            trustLogos.map((item) => (
              <img
                alt={item.alt}
                class={`trust-logo trust-logo-${item.id}`}
                decoding="async"
                height="48"
                loading="lazy"
                src={item.src}
                width="180"
              />
            ))
          }
          {
            trustAffiliations.map((item) => (
              <span class="trust-text-badge">{item}</span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Problem statement ───────────────────────────────────────────── -->
  <section class="section-space pt-0" aria-labelledby="problem-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <h2 id="problem-heading" class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-6xl">
          You've got traction. <span class="hero-accent">So why does growth still feel like guessing?</span>
        </h2>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          Paying customers. Revenue line moving. A deck that holds up. But the acquisition engine? Plateaued. Founder-led sales that doesn't scale. No repeatable pipeline. A GTM stack that's three tools taped together.
        </p>
        <p class="text-lg leading-8 text-[color:var(--muted)]">
          You don't need more tactics. You need a senior operator who can walk in, see the whole system at once, and tell you — with specifics — which two levers matter for your company right now.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Growth Diagnosis — interactive quiz ────────────────────────── -->
  <section class="section-space pt-0" id="growth-diagnosis" aria-labelledby="diagnosis-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="AI-assisted diagnosis · Free · 2 minutes"
        intro="Five questions. Tailored output. A clearer read on which lever matters most before another campaign, hire, or AI workflow gets bolted on."
        title="Find your biggest growth bottleneck."
      />
      <GrowthDiagnosis />
    </div>
  </section>

  <!-- 4. Buying ladder ───────────────────────────────────────────── -->
  <section class="section-space pt-0" id="services">
    <div class="shell">
      <SectionHeader
        eyebrow="Three ways in"
        intro="Pick the smallest commitment that answers the question. You can move up the ladder later."
        title="Where do you want to start?"
      />
      <div class="ladder-grid mt-10">
        {
          homeServiceLadder.map((tier, index) => (
            <a class:list={["ladder-card card p-6 md:p-8", tier.primary && "ladder-card-primary"]} href={tier.href} aria-label={`${tier.heading}: ${tier.cta}`}>
              <div class="ladder-step" aria-hidden="true">
                <span class="ladder-step-num">0{index + 1}</span>
                {index < homeServiceLadder.length - 1 && <span class="ladder-step-arrow">→</span>}
              </div>
              <p class="card-label mt-4">{tier.tier}</p>
              <h3 class="mt-3 text-2xl font-extrabold tracking-[-0.05em]">{tier.heading}</h3>
              <div class="mt-3 flex items-baseline gap-1">
                <span class="text-2xl font-extrabold tracking-[-0.06em]">{tier.price}</span>
                <span class="text-sm text-[color:var(--muted)]">{tier.cadence}</span>
              </div>
              <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{tier.body}</p>
              <p class="mt-5 border-t border-[color:var(--line)] pt-4 text-sm leading-6 text-[color:var(--muted)]">
                <strong class="font-semibold text-[color:var(--ink)]">Best for:</strong> {tier.bestFor}
              </p>
              <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">
                <strong class="font-semibold text-[color:var(--ink)]">Outcome:</strong> {tier.outcome}
              </p>
              <span class="link-arrow mt-6">{tier.cta}</span>
            </a>
          ))
        }
      </div>
      <p class="reveal mt-8 text-center text-sm leading-7 text-[color:var(--muted)]">
        Looking for <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/mentoring/">founder office hours</a>, <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/speaking/">speaking, or workshops</a>? See all the ways we can work together.
      </p>
    </div>
  </section>

  <!-- 5. Who this is for / not for ──────────────────────────────────── -->
  <section class="section-space pt-0" aria-labelledby="fit-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Fit"
        intro="I'd rather save us both a 30-minute call if we're not the right match."
        title="Who this is for, and who it's not."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label text-[color:var(--accent)]">Best fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {fitSignals.bestFor.map((point) => (<li class="fit-row fit-row-yes">{point}</li>))}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">Not a fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {fitSignals.notFor.map((point) => (<li class="fit-row fit-row-no">{point}</li>))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- 6. Why me vs agency ─────────────────────────────────────────── -->
  <section class="section-space pt-0" aria-labelledby="vs-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Why not an agency"
        intro="You don't need another agency layer when the real problem is senior growth judgement."
        title="Senior growth judgement, not junior execution."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">{agencyVsMe.agency.heading}</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {agencyVsMe.agency.points.map((point) => <li class="fit-row fit-row-no">{point}</li>)}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8 card-accent-border">
          <p class="card-label text-[color:var(--accent)]">{agencyVsMe.me.heading}</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {agencyVsMe.me.points.map((point) => <li class="fit-row fit-row-yes">{point}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- 7. The method ──────────────────────────────────────────── -->
  <section class="dark-section section-space" aria-labelledby="method-heading">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="eyebrow justify-center text-white/60">The method</span>
        <h2 id="method-heading" class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-white md:text-6xl">
          I don't run campaigns. <span class="hero-accent">I build growth systems that run without you.</span>
        </h2>
      </div>
      <div class="reveal mx-auto mt-10 max-w-3xl space-y-5 text-lg leading-8 text-white/72">
        <p>Most growth consultants arrive, ship a deck, and disappear. Not how I work.</p>
        <p>Every engagement builds the same thing: a growth system. A repeatable architecture your team can run after I'm gone.</p>
        <p class="text-sm uppercase tracking-[0.16em] text-white/50">{layerCount} layers, one loop</p>
      </div>
      <div class="reveal mt-12">
        <GrowthSystemDiagram />
      </div>
      <p class="reveal mt-6 text-center text-sm uppercase tracking-[0.14em] text-white/45">
        Each layer also exists as a deeper page — click below
      </p>
      <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          methodLayers.map((layer, index) => (
            <a class="reveal card p-6" href={layer.href}>
              <p class="card-label text-white/55">0{index + 1}</p>
              <h3 class="mt-3 text-xl font-bold tracking-[-0.04em] text-white">{layer.title}</h3>
              <p class="mt-3 text-sm leading-7 text-white/68">{layer.body}</p>
            </a>
          ))
        }
      </div>
      <div class="reveal mt-10 text-center">
        <p class="text-base leading-8 text-white/68">
          If "growth system" sounds vague, that's fine. I'll show you exactly what it looks like on a 30-minute audit.
        </p>
        <div class="mt-6 flex justify-center">
          <a class="button-accent" href={ctas.methodDeepDive.href} data-cta="method-primary">
            {ctas.methodDeepDive.label} →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. Why AI-native matters ─────────────────────────────────────── -->
  <section class="section-space" aria-labelledby="ai-heading">
    <div class="shell">
      <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
        <div class="reveal space-y-6">
          <span class="eyebrow">AI-native GTM</span>
          <h2 id="ai-heading" class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-5xl">
            AI should turn messy signal into sharper commercial decisions.
          </h2>
          <p class="text-lg leading-8 text-[color:var(--muted)]">
            The useful bit is not "AI content". It's faster synthesis: call notes, competitor pages, CRM exports, funnel reports, and sales objections turned into the raw material for better tests.
          </p>
          <p class="text-lg leading-8 text-[color:var(--muted)]">
            The judgement still sits with the operator: which signal matters, which promise is believable, which channel deserves the next week of effort.
          </p>
          <a class="link-arrow" href="/ai-native-workflows/">See AI-native workflows</a>
        </div>
        <div class="reveal ai-workflow-panel">
          <div class="ai-workflow-head">
            <p class="card-label">How the work moves</p>
            <div class="ai-workflow-labels" aria-hidden="true">
              <span>Input</span>
              <span>AI-assisted synthesis</span>
              <span>Human decision</span>
              <span>Commercial output</span>
            </div>
          </div>
          <div class="ai-workflow-grid">
            {
              aiWorkflowExamples.map((item) => (
                <article class="ai-workflow-row">
                  <span>{item.input}</span>
                  <span>{item.synthesis}</span>
                  <span>{item.decision}</span>
                  <strong>{item.output}</strong>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. Image-led credibility ────────────────────────────────────── -->
  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Beyond the deck"
        intro="A few more ways to read the work before you book: rooms, interviews, current focus, and the operator story behind the process."
        title="More signal, fewer claims."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        {
          imageStoryCards.map((card) => (
            <article class="reveal image-story-card">
              <img alt={card.alt} decoding="async" height="720" loading="lazy" src={card.image} width="960" />
              <div>
                <p class="card-label">{card.eyebrow}</p>
                <h3>{card.title}</h3>
                <p>{card.body}</p>
                <a class="link-arrow" href={card.href}>{card.cta}</a>
              </div>
            </article>
          ))
        }
      </div>
      <div class="mt-5 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        <a class="reveal media-link-card card p-5" href="/podcast-guest/">
          <span class="card-label">Podcast guest</span>
          <strong>Book Daniel for your podcast</strong>
          <small>AI-native GTM, founder-led growth, experimentation, and repeatable growth systems.</small>
        </a>
        <a class="reveal media-link-card card p-5" href="/media-kit/">
          <span class="card-label">Media kit</span>
          <strong>Press, podcasts, and producer assets</strong>
          <small>Bios, headshots, topics, proof points, and copy/paste host intros.</small>
        </a>
        <a class="reveal media-link-card card p-5" href="/now/">
          <span class="card-label">Now</span>
          <strong>Current work and availability</strong>
          <small>The most current picture of what I am working on this month.</small>
        </a>
        {
          featuredMedia.slice(0, 2).map((item) => (
            <a class="reveal media-link-card card p-5" href={item.data.href} rel="noreferrer" target="_blank">
              <span class="card-label">{item.data.source}</span>
              <strong>{item.data.title}</strong>
              <small>{item.data.description}</small>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal social-panel">
        <div>
          <p class="card-label">Follow Daniel's thinking</p>
          <h2>Press page builds authority. Writing proves the thinking. LinkedIn keeps people warm.</h2>
          <p>The personal site is the media and authority hub; We Scale Startups converts commercial demand when the conversation turns into a growth problem.</p>
        </div>
        <div class="social-link-grid">
          <a href={siteConfig.linkedin} rel="noreferrer" target="_blank">LinkedIn: practical notes on AI-native GTM, founder-led growth, and growth systems</a>
          <a href={siteConfig.youtube} rel="noreferrer" target="_blank">YouTube: talks, podcast clips, and founder-facing explainers</a>
          <a href="/writing/">Writing: deeper essays on startup growth, AI GTM, and decision-making</a>
          <a href="/media-kit/">Media kit</a>
          <a href="/podcast-guest/">Podcast guest page</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. Proof — real outcomes ──────────────────────────────────── -->
  <section class="dark-section section-space" id="proof" aria-labelledby="proof-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Proof"
        intro="The short list. Full case studies linked below."
        title="Real campaigns. Real numbers. Real attribution."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          outcomeCards.map((card) => (
            <article class="reveal card p-6">
              <p class="text-5xl font-extrabold tracking-[-0.07em] text-white">{card.metric}</p>
              <p class="mt-2 text-sm font-semibold uppercase tracking-[0.12em] text-white/65">{card.metricSuffix}</p>
              <p class="mt-5 text-sm leading-7 text-white/70">{card.context}</p>
              <p class="mt-5 border-t border-white/[0.08] pt-3 text-xs font-semibold uppercase tracking-[0.14em] text-white/45">{card.sector}</p>
            </article>
          ))
        }
      </div>
      <div class="reveal mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-center text-sm font-semibold uppercase tracking-[0.12em] text-white/60">
        {lifetimeTotals.map((item) => <span>{item}</span>)}
      </div>
      <div class="reveal mt-6 text-center">
        <a class="link-arrow" href="/case-studies/">See full case studies</a>
      </div>
