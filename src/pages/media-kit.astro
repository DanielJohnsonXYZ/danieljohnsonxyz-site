---
import BaseLayout from "../layouts/BaseLayout.astro";
import CfEmailOff from "../components/CfEmailOff.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { proofStats, siteConfig, trustLogos } from "../site";

const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Media kit", url: "/media-kit" }
  ])
];

const doNotDescribeAs = [
  "a generic marketing consultant",
  "an AI influencer",
  "a growth hacker",
  "a motivational speaker",
  "an agency owner focused only on paid ads"
];

const preferredDescription = "Daniel Johnson is a fractional CMO and GTM operator helping post-PMF AI and B2B SaaS startups build repeatable growth systems.";

/** Plain text for producer copy buttons (Notion: media kit downloadable assets). */
const bioShortOneLine =
  "Daniel Johnson is a fractional CMO helping post-PMF AI and B2B SaaS startups build growth systems that run without the founder.";
const bioStandardTwoLines =
  "Daniel Johnson is a fractional CMO and AI-native growth operator for post-PMF AI and B2B SaaS startups. He embeds as senior GTM leadership to build repeatable acquisition systems, then transfers them to the team.";
const approvedPodcastIntro =
  "Daniel Johnson is a fractional CMO and GTM operator for post-PMF AI and B2B SaaS startups. He helps teams diagnose growth bottlenecks, build repeatable acquisition systems, and transfer ownership back to the company.";

// "Fast facts" — the scannable single-card block journalists, producers,
// and event organisers copy directly into briefs and booking forms.
// Source: Notion 353f99a79fdb81c9a29ed1d16b70cbb4
const fastFacts = [
  { label: "Name", value: "Daniel Johnson" },
  { label: "Role", value: "Fractional CMO and GTM operator" },
  { label: "Company", value: "Founder, We Scale Startups (wescalestartups.com)" },
  { label: "Focus", value: "Post-PMF AI & B2B SaaS startups, Seed–Series B" },
  { label: "Best topics", value: "AI-native GTM, founder-led growth, startup positioning, product-led growth, growth operating systems" },
  { label: "Location", value: "UK-based, currently in Asia. Serving US, UK, Europe, APAC" },
  { label: "Available for", value: "Expert quotes, podcast guest spots, panels, keynotes, workshops, newsletter interviews" },
  { label: "Start window", value: siteConfig.nextStartWindow.replace(/^Next start window:\s*/i, "") },
  {
    label: "Track record",
    value: `${proofStats.startupsAdvised} startups · ${proofStats.revenueImpact} revenue generated · ${proofStats.mentorRating}/5 from ${proofStats.mentorReviewCount} GrowthMentor reviews`
  },
  { label: "Community", value: "Moderator, Online Geniuses (53,000+ member marketing Slack)" },
  { label: "Contact", value: siteConfig.email }
];

// Kept for backward-compatibility with the existing Quick-facts section
// further down the page.
const quickFacts = [
  { label: "Primary role", value: "Fractional CMO / Growth Operator" },
  { label: "Focus", value: "Post-PMF AI & B2B SaaS, Seed–Series B" },
  { label: "Geography", value: "UK-based, serving US, UK, Europe, APAC" },
  { label: "Typical engagement", value: "£7.5–12k/month, 3-month minimum" },
  { label: "Track record", value: "20+ startups, £18M+ revenue generated" }
];

const affiliations = trustLogos.map((logo) => ({
  name: logo.label,
  relationship: logo.alt.split(" — ").pop() || "Affiliation"
}));

/** Sharp producer hooks — Notion 353f99a79fdb818d9c96cc8e837cc982 */
const mediaTopicHooks = [
  {
    title: "Most AI startups do not have a product problem — they have a GTM problem.",
    body: "When the tech is similar, wins come from ICP clarity, narrative, and distribution judgment — not another feature slide."
  },
  {
    title: "Founder-led growth breaks after early traction.",
    body: "What worked in the first customers becomes a bottleneck when pipeline, messaging, and decisions still route through the founder."
  },
  {
    title: "AI changes marketing teams without replacing judgement.",
    body: "Execution gets cheaper and faster; the scarce skill is deciding what is worth doing and what to stop."
  },
  {
    title: "Build the growth system before you hire the CMO.",
    body: "A senior hire cannot fix a missing rhythm, weak instrumentation, or unclear ownership — the system has to be legible first."
  },
  {
    title: "Smaller, AI-enabled teams can outperform bloated marketing departments.",
    body: "Lean teams with tight loops and clear accountability often beat large groups busy with activity metrics."
  },
  {
    title: "More traffic rarely fixes weak positioning.",
    body: "If the story and ICP are fuzzy, paid and organic spend mostly amplify confusion — not demand."
  }
];

/** Headline-ready press hooks — Notion 353f99a79fdb81ddab97ef250be0c702 */
const recentQuoteAngles = [
  "Why AI startups are starting to sound the same.",
  "Why founder-led growth breaks between Seed and Series A.",
  "Why smaller AI-enabled marketing teams may outperform bloated departments.",
  "Why fractional CMOs are becoming more attractive than agencies for post-PMF startups.",
  "Why pipeline problems are often positioning problems in disguise.",
  "Why AI makes tactics cheaper, but judgment more valuable."
];
---

<BaseLayout
  stickyCtaLabel="Download media kit →"
  stickyCtaHref="/media-kit-download/"
  stickyCtaHint="Bio · headshots · topics · facts"
  title="Media Kit | Daniel Johnson"
  description="Official media kit for Daniel Johnson — bio, headshots, logos, speaking topics, and how to describe (and not describe) Daniel in press."
  path="/media-kit"
  schema={schemas}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Media Kit</p>
      <h1>Assets and guidance for press, podcasts, and events.</h1>
      <p>Everything you need to introduce Daniel Johnson accurately — bio, headshots, logos, speaking topics, and positioning guidance.</p>
      <p class="mt-3 max-w-2xl text-sm font-semibold text-[color:var(--ink)]">{siteConfig.nextStartWindow}</p>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-[color:var(--muted)]">
        For <strong>company</strong> boilerplate, logos, and proof points, use the
        <a
          class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]"
          href={`${siteConfig.companyUrl}/press/`}
          rel="noreferrer"
          target="_blank"
        >
          We Scale Startups press kit →
        </a>
      </p>
    </div>
  </section>

  <!-- Producer pack — one-click downloads + copy (Notion 353f99a79fdb819a8f43ca5abb57d50d) -->
  <section class="section section-alt" aria-labelledby="producer-pack-heading">
    <div class="shell">
      <h2 id="producer-pack-heading" class="sr-only">Producer pack</h2>
      <div class="max-w-3xl mx-auto card p-6 md:p-8 border-2 border-[color:var(--accent)]/35">
        <p class="eyebrow">Producer pack</p>
        <p class="mt-2 text-lg font-semibold text-[color:var(--ink)]">Grab assets in one place — download or copy to clipboard.</p>
        <p class="mt-2 text-sm text-[color:var(--muted)]">
          Full printable kit: <a class="font-semibold underline underline-offset-4" href="/media-kit-download/">Media kit download →</a>
        </p>
        <ul class="mt-6 grid gap-3 sm:grid-cols-2">
          <li>
            <a class="button-accent block text-center" href="/images/daniel-headshot.webp" download> Download headshot (WebP · 960×1000) → </a>
          </li>
          <li>
            <a class="button-accent block text-center" href="/images/daniel-headshot-640.webp" download> Download headshot (WebP · 640×800) → </a>
          </li>
        </ul>
        <div class="mt-6 grid gap-2 sm:grid-cols-2">
          <button type="button" class="button-link producer-copy-btn w-full justify-center border border-[color:var(--line)] rounded-lg py-3" data-copy={bioShortOneLine}>
            Copy short bio
          </button>
          <button type="button" class="button-link producer-copy-btn w-full justify-center border border-[color:var(--line)] rounded-lg py-3" data-copy={bioStandardTwoLines}>
            Copy standard bio
          </button>
          <button type="button" class="button-link producer-copy-btn w-full justify-center border border-[color:var(--line)] rounded-lg py-3" data-copy={preferredDescription}>
            Copy preferred description
          </button>
          <button type="button" class="button-link producer-copy-btn w-full justify-center border border-[color:var(--line)] rounded-lg py-3" data-copy={approvedPodcastIntro}>
            Copy show intro
          </button>
          <button type="button" class="button-link producer-copy-btn w-full justify-center border border-[color:var(--line)] rounded-lg py-3 sm:col-span-2" data-copy={siteConfig.email}>
            Copy email ({siteConfig.email})
          </button>
        </div>
        <p class="producer-copy-status mt-4 text-center text-sm font-medium text-[color:var(--accent)] min-h-[1.25rem]" aria-live="polite"></p>
      </div>
    </div>
  </section>

  <!-- Fast facts — single scannable card near top of media kit so producers and -->
  <!-- journalists can copy directly into briefs. Source: Notion 353f99a79fdb81c9a29ed1d16b70cbb4 -->
  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Fast facts"
        title="Copy and paste — everything in one card."
        intro="Designed for producers, journalists, and event organisers writing briefs at speed. One card, all of it."
      />
      <div class="max-w-3xl mx-auto">
        <article class="card p-8 md:p-10 border-2 border-[color:var(--accent)]/40">
          <dl class="grid gap-4 md:grid-cols-[10rem_1fr]">
            {fastFacts.map((fact) => (
              <Fragment>
                <dt class="text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] md:pt-1">{fact.label}</dt>
                <dd class="text-base leading-7 text-[color:var(--ink)]">{fact.value}</dd>
              </Fragment>
            ))}
          </dl>
        </article>
      </div>
    </div>
  </section>

  <!-- For journalists — expert topics + press contact (Notion 353f99a79fdb816b94c1e129960ddec5) -->
  <section class="section section-alt" aria-labelledby="for-journalists-heading">
    <div class="shell">
      <div class="max-w-3xl mx-auto card p-8 md:p-10 border-2 border-[color:var(--accent)]/25">
        <p class="eyebrow">For journalists</p>
        <h2 id="for-journalists-heading" class="mt-2 text-2xl font-bold tracking-[-0.04em] text-[color:var(--ink)]">
          Expert comment on request
        </h2>
        <p class="mt-3 text-[color:var(--muted)] leading-7">
          Daniel can provide expert comment on:
        </p>
        <ul class="mt-4 space-y-2.5 text-[color:var(--ink)] leading-7 list-disc pl-5 marker:text-[color:var(--accent)]">
          <li>AI-native GTM and how AI changes marketing teams</li>
          <li>Why AI startup messaging sounds increasingly generic</li>
          <li>Founder-led growth and when it becomes a bottleneck</li>
          <li>Fractional CMO models and senior growth leadership</li>
          <li>B2B SaaS positioning, pipeline, PLG, and acquisition systems</li>
          <li>Why startups confuse channel problems with strategy problems</li>
        </ul>
        <p class="mt-6 text-[color:var(--muted)] leading-7">
          For time-sensitive quotes, email{" "}
          <CfEmailOff>
            <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
          </CfEmailOff>
          . Typical response: same day where possible.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Press hooks"
        title="Recent quote angles."
        intro="Concrete, headline-friendly lines editors can place in a story today — not abstract expertise labels."
      />
      <div class="max-w-3xl mx-auto">
        <ul
          class="card p-8 md:p-10 border-2 border-[color:var(--accent)]/25 space-y-3 list-disc pl-5 marker:text-[color:var(--accent)] text-[color:var(--ink)] leading-7"
        >
          {recentQuoteAngles.map((line) => (
            <li>{line}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Positioning"
        title="Please avoid describing Daniel as…"
        intro="Using the right language protects Daniel's positioning across press, podcasts, and events."
      />
      <div class="max-w-3xl">
        <div class="card p-8 md:p-10 border-2 border-[color:var(--accent)]/30 bg-[color:var(--accent)]/5">
          <h3 class="text-xl font-bold tracking-[-0.04em] mb-4 text-[color:var(--accent)]">Do not use these descriptions</h3>
          <ul class="space-y-3">
            {doNotDescribeAs.map((item) => (
              <li class="flex items-start gap-3">
                <span class="text-[color:var(--accent)] mt-0.5">✕</span>
                <span class="text-lg">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card p-8 md:p-10 mt-6">
          <h3 class="text-xl font-bold tracking-[-0.04em] mb-4">Preferred description</h3>
          <p class="text-lg leading-8 text-[color:var(--ink)] bg-[color:var(--surface)] p-4 rounded-lg border border-[color:var(--line)]">
            {preferredDescription}
          </p>
        </div>

        <div class="card p-8 md:p-10 mt-6">
          <h3 class="text-xl font-bold tracking-[-0.04em] mb-4">One-line bio (short)</h3>
          <p class="text-lg leading-8 text-[color:var(--muted)]">
            Daniel Johnson is a fractional CMO helping post-PMF AI and B2B SaaS startups build growth systems that run without the founder.
          </p>
        </div>

        <div class="card p-8 md:p-10 mt-6">
          <h3 class="text-xl font-bold tracking-[-0.04em] mb-4">Two-line bio (standard)</h3>
          <p class="text-lg leading-8 text-[color:var(--muted)]">
            Daniel Johnson is a fractional CMO and AI-native growth operator for post-PMF AI and B2B SaaS startups. He embeds as senior GTM leadership to build repeatable acquisition systems, then transfers them to the team.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionHeader
        eyebrow="Quick facts"
        title="Key details for producers and editors."
        intro="Use these facts for intros, bios, and speaker blurbs."
      />
      <div class="max-w-3xl">
        <div class="grid gap-4">
          {quickFacts.map((fact) => (
            <div class="card p-4 flex items-center gap-4">
              <span class="text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] w-40 shrink-0">{fact.label}</span>
              <span class="text-base font-medium text-[color:var(--ink)]">{fact.value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Affiliations"
        title="How to reference each relationship."
        intro="Daniel works with the following organisations in various capacities. Please reference the relationship accurately."
      />
      <div class="max-w-3xl">
        <div class="grid gap-4">
          {affiliations.map((item) => (
            <div class="card p-4 flex items-center gap-4">
              <span class="font-semibold text-[color:var(--ink)] min-w-[140px]">{item.name}</span>
              <span class="text-[color:var(--muted)]">{item.relationship}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Platforms — strongest media-credibility links only. -->
  <section class="section section-alt">
    <div class="shell">
      <SectionHeader
        eyebrow="Platforms & communities"
        title="Where to find Daniel online."
        intro="Key platforms for organisers, podcast hosts, and community managers to reference."
      />
      <div class="max-w-3xl">
        <p class="card-label">Primary credibility</p>
        <div class="grid gap-3 mt-3">
          <div class="card p-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="font-semibold text-[color:var(--ink)]">GrowthMentor</span>
              <span class="text-xs uppercase tracking-[0.12em] text-[color:var(--accent)]">Top-rated mentor · {proofStats.mentorRating}/5 · {proofStats.mentorReviewCount} reviews</span>
            </div>
            <a href={siteConfig.growthMentor} class="text-sm link-arrow" target="_blank" rel="noreferrer">View profile →</a>
          </div>
          <div class="card p-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="font-semibold text-[color:var(--ink)]">LinkedIn</span>
              <span class="text-xs uppercase tracking-[0.12em] text-[color:var(--muted)]">Professional network</span>
            </div>
            <a href={siteConfig.linkedin} class="text-sm link-arrow" target="_blank" rel="noreferrer">View profile →</a>
          </div>
          <div class="card p-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="font-semibold text-[color:var(--ink)]">YouTube</span>
              <span class="text-xs uppercase tracking-[0.12em] text-[color:var(--muted)]">Video content</span>
            </div>
            <a href={siteConfig.youtube} class="text-sm link-arrow" target="_blank" rel="noreferrer">View channel →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Positioning reinforcement"
        title="What the feedback consistently says."
        intro="Direct quotes from founders and organisers that reinforce Daniel's positioning as a clear, practical, no-nonsense operator."
      />
      <div class="max-w-3xl grid gap-4">
        <div class="card p-5 border-l-4 border-[color:var(--accent)]">
          <p class="text-base leading-7 text-[color:var(--ink)]">"Finally, a growth talk that cuts through the fluff. Clear frameworks I could use the next day."</p>
          <p class="mt-2 text-xs uppercase tracking-[0.12em] text-[color:var(--subtle)]">Nomad Summit attendee</p>
        </div>
        <div class="card p-5 border-l-4 border-[color:var(--accent)]">
          <p class="text-base leading-7 text-[color:var(--ink)]">"No-nonsense, practical, and specific to our stage. Exactly what we needed."</p>
          <p class="mt-2 text-xs uppercase tracking-[0.12em] text-[color:var(--subtle)]">SaaS & AI SEO session</p>
        </div>
        <div class="card p-5 border-l-4 border-[color:var(--accent)]">
          <p class="text-base leading-7 text-[color:var(--ink)]">"The clearest positioning session we've had. No theory, just what to change."</p>
          <p class="mt-2 text-xs uppercase tracking-[0.12em] text-[color:var(--subtle)]">Growth workshop attendee</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionHeader
        eyebrow="Speaking topics"
        title="Hooks, not generic themes."
        intro="Framed for producers and editors who need a sharp segment — commercial AI, GTM judgment, and founder-led growth."
      />
      <div class="max-w-3xl grid gap-5">
        {mediaTopicHooks.map((hook) => (
          <div class="card p-6">
            <h3 class="font-bold text-lg leading-snug">{hook.title}</h3>
            <p class="mt-2 text-[color:var(--muted)] leading-7">{hook.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Assets"
        title="Headshots and logos."
        intro="Download high-resolution assets for press and event use."
      />
      <div class="max-w-3xl grid gap-5 md:grid-cols-2">
        <a class="card p-6" href="/images/daniel-headshot.webp" download>
          <h3 class="font-bold">Daniel Headshot (WebP)</h3>
          <p class="mt-2 text-sm text-[color:var(--muted)]">High-resolution headshot for press use. WebP · 960×1000.</p>
          <span class="link-arrow mt-4">Download →</span>
        </a>
        <a class="card p-6" href="/images/daniel-headshot-640.webp" download>
          <h3 class="font-bold">Daniel Headshot (Small)</h3>
          <p class="mt-2 text-sm text-[color:var(--muted)]">Smaller version for web and digital use. WebP · 640×800.</p>
          <span class="link-arrow mt-4">Download →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cta-gradient section">
    <div class="shell text-center">
      <p class="eyebrow justify-center text-white/60">Book Daniel</p>
      <h2 class="text-4xl font-extrabold tracking-[-0.06em] text-white md:text-5xl">For speaking, workshops, or fractional CMO enquiries.</h2>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a class="button-accent" href={siteConfig.bookingUrl}>Book a 20-min Growth Audit →</a>
        <a class="button-link-invert" href="/speaking/">Speaking assets →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  (function () {
    const status = document.querySelector(".producer-copy-status");
    document.querySelectorAll(".producer-copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.getAttribute("data-copy");
        if (!text) return;
        const writeFallback = () => {
          // execCommand fallback for older Safari / non-secure contexts
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.setAttribute("readonly", "");
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          const ok = document.execCommand("copy");
          document.body.removeChild(ta);
          return ok;
        };
        let copied = false;
        try {
          await navigator.clipboard.writeText(text);
          copied = true;
        } catch {
          try {
            copied = writeFallback();
          } catch {
            copied = false;
          }
        }
        if (copied) {
          const original = btn.textContent;
          btn.textContent = "Copied ✓";
          btn.setAttribute("disabled", "");
          window.setTimeout(() => {
            btn.textContent = original;
            btn.removeAttribute("disabled");
          }, 2000);
          if (status) {
            status.textContent = "Copied to clipboard.";
            window.setTimeout(() => {
              if (status) status.textContent = "";
            }, 2500);
          }
        } else if (status) {
          status.textContent = "Copy failed — select text manually or use the printable page.";
        }
      });
    });
  })();
</script>
