---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { buildBreadcrumbSchema, buildFaqPageSchema } from "../lib/schema";
import { ctas, siteConfig, vsFulltimeCMO } from "../site";

const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Fractional CMO", url: "/fractional-cmo/" },
    { name: "vs. Full-time CMO", url: "/fractional-cmo-vs-full-time-cmo/" }
  ]),
  buildFaqPageSchema([...vsFulltimeCMO.faq])
];

const tldr =
  "A fractional CMO is usually the lower-risk bridge when a post-PMF startup needs senior growth ownership now but is not ready for a permanent executive hire. A full-time CMO makes more sense once growth is proven, the marketing org is large enough, and external leadership is part of the role.";
---

<BaseLayout
  description="Fractional vs full-time CMO for post-PMF AI & B2B SaaS: cost, ramp, ownership, notice periods & when each model fits—senior fractional view."
  keywords="fractional CMO vs full-time CMO, CMO hire cost UK, interim marketing leadership, bridge CMO"
  path="/fractional-cmo-vs-full-time-cmo/"
  schema={schemas}
  stickyCta={false}
  title="Fractional CMO vs. Full-time CMO | Daniel Johnson"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <span class="service-label justify-center">Comparison</span>
        <h1 class="text-5xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-7xl">
          Fractional CMO vs. full-time CMO: <span class="hero-accent">when each is the right call.</span>
        </h1>
        <p class="hero-subcopy mx-auto max-w-2xl text-lg leading-8 md:text-xl">
          Both can run growth. They cost different amounts, take different lengths of time to start, and carry different risk profiles. Below: the trade-offs, written for founders who don't need to be sold to.
        </p>
        <aside class="tldr-block text-left">
          <p class="mono text-xs uppercase tracking-[0.18em] text-[color:var(--accent)]">TL;DR</p>
          <p>{tldr}</p>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Side-by-side"
        title="Eight dimensions, side-by-side."
        intro="Cost, time-to-start, commitment, risk, and what each role actually owns."
      />
      <p class="mt-4 text-center text-sm text-[color:var(--muted)]">
        <span class="inline-block h-3 w-3 align-middle" style="background: rgba(124,58,237,0.15); box-shadow: inset 3px 0 0 var(--accent);"></span>
        <span class="ml-2">Stronger choice in this row (highlighted by use-case, not absolute winner)</span>
      </p>
      <div class="mt-6 overflow-x-auto rounded-[1.5rem] border border-[color:var(--line)] bg-white">
        <table class="w-full min-w-[820px] text-left text-sm">
          <thead class="bg-[color:var(--surface-dim)]">
            <tr>
              <th class="p-4">Dimension</th>
              <th class="p-4">Fractional CMO</th>
              <th class="p-4">Full-time CMO</th>
            </tr>
          </thead>
          <tbody>
            {vsFulltimeCMO.rows.map((row) => (
              <tr class="border-t border-[color:var(--line)]">
                <td class="p-4 align-top font-bold leading-6 text-[color:var(--ink)]">{row.dimension}</td>
                <td class:list={["p-4 align-top leading-6", row.winner === "fractional" ? "compare-winner-cell" : "text-[color:var(--ink)]"]}>{row.fractional}</td>
                <td class:list={["p-4 align-top leading-6", row.winner === "fulltime" ? "compare-winner-cell" : "text-[color:var(--muted)]"]}>{row.fulltime}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="UK hiring maths"
        title="Total cost of a full-time UK CMO in year one."
        intro="Founders compare retainer lines to salary lines. The honest comparison needs employer costs, recruiter fees, and ramp — not just the base number on the job spec."
      />
      <div class="mt-8 grid gap-6 lg:grid-cols-[1fr_1fr]">
        <article class="card p-7">
          <p class="card-label">Worked example</p>
          <p class="mt-4 leading-8 text-[color:var(--muted)]">
            Take a <strong class="text-[color:var(--ink)]">£120k</strong> base. Employer National Insurance is broadly{" "}
            <strong class="text-[color:var(--ink)]">13.8%</strong> on earnings above the secondary threshold (~£16.6k on this band in 2025/26 terms — verify with your payroll).
            Pension auto-enrolment employer contribution is often <strong class="text-[color:var(--ink)]">3–5%</strong> of qualifying
            earnings (£3.6–6k on a £120k base depending on scheme rules). Specialist CMO search fees commonly land around{" "}
            <strong class="text-[color:var(--ink)]">£24–36k</strong> (20–30% of first-year cash compensation). Add three to six months of
            ramp where pipeline impact is still building. That first year is rarely &quot;just&quot; £120k.
          </p>
        </article>
        <article class="card p-7">
          <p class="card-label">Contrast with fractional anchors</p>
          <p class="mt-4 leading-8 text-[color:var(--muted)]">
            Published fractional anchors: <strong class="text-[color:var(--ink)]">£7.5k/month</strong> (1 day/week) and{" "}
            <strong class="text-[color:var(--ink)]">£12k/month</strong> (deeper support) with a 3-month minimum — see{" "}
            <a class="font-semibold text-[color:var(--accent)] underline underline-offset-4" href="/fractional-cmo-cost-uk/">
              the UK cost page
            </a>{" "}
            and{" "}
            <a class="font-semibold text-[color:var(--accent)] underline underline-offset-4" href="/roi-calculator/">
              ROI calculator
            </a>
            . This is not a like-for-like replacement for a five-day executive — it is a bridge that buys senior judgement and an operating system without the full employment stack.
          </p>
        </article>
      </div>
      <div class="mt-6 overflow-x-auto rounded-[1.5rem] border border-[color:var(--line)] bg-white">
        <table class="w-full min-w-[520px] text-left text-sm">
          <thead class="bg-[color:var(--surface-dim)]">
            <tr>
              <th class="p-4">Line item</th>
              <th class="p-4">Full-time CMO (illustrative year 1)</th>
              <th class="p-4">Fractional (illustrative 12 months)</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-[color:var(--line)]">
              <td class="p-4 font-semibold">Cash compensation</td>
              <td class="p-4 text-[color:var(--muted)]">£120k base (+ bonus if offered)</td>
              <td class="p-4 text-[color:var(--muted)]">£90k at £7.5k/mo · £144k at £12k/mo</td>
            </tr>
            <tr class="border-t border-[color:var(--line)]">
              <td class="p-4 font-semibold">Employer NI + pension (order of magnitude)</td>
              <td class="p-4 text-[color:var(--muted)]">Often ~£20–25k combined on this base — confirm with payroll</td>
              <td class="p-4 text-[color:var(--muted)]">N/A — B2B services engagement</td>
            </tr>
            <tr class="border-t border-[color:var(--line)]">
              <td class="p-4 font-semibold">Recruitment</td>
              <td class="p-4 text-[color:var(--muted)]">Often £24–36k for senior marketing search</td>
              <td class="p-4 text-[color:var(--muted)]">None in this model</td>
            </tr>
            <tr class="border-t border-[color:var(--line)]">
              <td class="p-4 font-semibold">Commitment / exit</td>
              <td class="p-4 text-[color:var(--muted)]">Permanent — notice, severance risk, equity grants</td>
              <td class="p-4 text-[color:var(--muted)]">3-month minimum then rolling — scope-led exit</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell grid gap-6 md:grid-cols-2">
      <article class="card p-6 md:p-8 card-accent-border">
        <p class="card-label text-[color:var(--accent)]">Pick a fractional CMO when…</p>
        <ul class="mt-4 space-y-3 text-base leading-8">
          {vsFulltimeCMO.whenFractional.map((item) => <li class="fit-row fit-row-yes">{item}</li>)}
        </ul>
      </article>
      <article class="card p-6 md:p-8">
        <p class="card-label">Pick a full-time CMO when…</p>
        <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
          {vsFulltimeCMO.whenFulltime.map((item) => <li class="fit-row fit-row-yes">{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="eyebrow justify-center text-white/60">The bridge pattern</span>
        <h2 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-white md:text-5xl">
          Fractional first, full-time later. <span class="hero-accent">Cleanest path for most teams.</span>
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-white/72">
          {vsFulltimeCMO.bridge}
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a class="button-accent" href={ctas.primary.href} data-cta="vs-fulltime-cta-primary">
            {ctas.primary.label} →
          </a>
          <a class="button-link-invert" href="/fractional-cmo/" data-cta="vs-fulltime-cta-fcmo">
            See the Fractional CMO scope →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space" aria-labelledby="vs-fulltime-faq-heading">
    <div class="shell">
      <SectionHeader eyebrow="FAQ" title="Questions founders ask before they choose." />
      <div class="faq-stack mt-8 mx-auto max-w-3xl">
        {vsFulltimeCMO.faq.map((item, index) => (
          <details class="faq-item" open={index === 0}>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center space-y-4">
        <p class="text-base leading-8 text-[color:var(--muted)]">
          Also worth reading: <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/fractional-cmo-vs-agency/">Fractional CMO vs. agency</a> · <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/fractional-cmo/">Full Fractional CMO scope and pricing</a> · <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="https://wescalestartups.com/services/fractional-cmo" rel="noreferrer" target="_blank">WSS Fractional CMO service</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
