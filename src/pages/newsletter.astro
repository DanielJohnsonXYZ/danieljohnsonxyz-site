---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterFormInline from "../components/NewsletterFormInline.astro";
import { buildBreadcrumbSchema, buildWebPageSchema } from "../lib/schema";
import { absoluteUrl } from "../lib/utils";
import { ctas, siteConfig } from "../site";

const newsletterDescription =
  "Subscribe to Daniel Johnson's occasional growth notes on AI-native GTM, fractional CMO work, founder-led growth, and repeatable startup growth systems.";

const newsletterSchema = [
  buildWebPageSchema({ name: "Newsletter", description: newsletterDescription, url: absoluteUrl("/newsletter/") }),
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Newsletter", url: "/newsletter/" }
  ])
];

const notes = [
  "How to decide whether your bottleneck is ICP, channel, conversion, or cadence.",
  "What AI-native GTM looks like when it is practical rather than performative.",
  "How founder-led distribution can create pipeline without turning the founder into a content machine.",
  "What to fix before hiring a full-time CMO or another agency."
];
---

<BaseLayout
  description={newsletterDescription}
  path="/newsletter/"
  schema={newsletterSchema}
  title="Newsletter | Daniel Johnson"
>
  <section class="section-space conversion-hero">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.85fr] lg:items-start">
        <div class="reveal space-y-6">
          <span class="service-label">Newsletter</span>
          <h1 class="max-w-4xl text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">
            Short notes on making startup growth less noisy.
          </h1>
          <p class="hero-subcopy conversion-subcopy max-w-3xl text-xl leading-9 md:text-2xl">
            Occasional writing for founders and operators who want clearer GTM decisions, better systems, and fewer
            growth theatre exercises.
          </p>
          <p class="max-w-3xl text-base leading-7 text-[color:var(--muted)]">
            Want the We Scale Startups list instead (fortnightly, acquisition systems for post-PMF teams)?{" "}
            <a class="link-arrow" href={`${siteConfig.companyUrl}/newsletter/`} rel="noopener">
              Here's Some Growth on {siteConfig.companyName} →
            </a>
          </p>
          <div class="cta-cluster">
            <a class="button-accent" href="#newsletter-signup">Subscribe to Growth Notes →</a>
            <a class="button-secondary" href="/writing/">Read recent essays →</a>
          </div>
        </div>
        <aside class="reveal card p-6 md:p-8">
          <p class="card-label">What you get</p>
          <ul class="mt-5 space-y-4 text-base leading-8 text-[color:var(--muted)]">
            {notes.map((note) => <li class="fit-row fit-row-yes">{note}</li>)}
          </ul>
          <div class="mt-6 space-y-4">
            <NewsletterFormInline
              variant="card"
              anchorId="newsletter-signup"
              headingLevel={2}
              idPrefix="nl-newsletter-main"
              heading="Subscribe here"
              subline="No daily drip sequence. No recycled LinkedIn thread pretending to be strategy."
            />
            <p class="text-sm leading-7 text-[color:var(--subtle)]">
              Clients and newsletter subscribers occasionally get access to the Founder Growth Clinic — a small monthly
              group call.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Prefer action now?</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              Find the bottleneck before you add more activity.
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              Use the checklist or book a 20-minute growth audit if you already know the current system is stuck.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a class="button-accent" href="/growth-bottleneck-checklist/">Open the checklist</a>
            <a class="button-secondary" href={ctas.primary.href} data-cta="newsletter-audit-soft">
              Talk it through in 20 minutes
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
