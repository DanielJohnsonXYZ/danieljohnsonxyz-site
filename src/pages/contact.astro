---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site";
import { buildBreadcrumbSchema } from "../lib/schema";

const title = "Contact Daniel Johnson | AI-Native GTM & Growth Operator";
const description =
  "Get in touch about fractional CMO, full-time Head of Growth / VP Marketing, advisory, mentoring, or speaking enquiries. Response within two working days.";

const breadcrumb = buildBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Contact", url: "/contact" }
]);
---

<BaseLayout description={description} title={title} schema={breadcrumb}>
  <section class="section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl">
        <span class="eyebrow">Contact</span>
        <h1 class="mt-6 text-5xl font-extrabold tracking-[-0.06em] md:text-7xl">Get in touch.</h1>
        <p class="mt-5 text-lg leading-8 text-[color:var(--muted)]">
          The fastest way to start a conversation is a 30-minute Growth Diagnosis call. If that is not the right fit, an email works too.
        </p>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          <article class="card p-6">
            <p class="card-label">Book a call</p>
            <h2 class="mt-3 text-2xl font-bold tracking-[-0.04em]">{siteConfig.bookingLabel}</h2>
            <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">{siteConfig.bookingNote}</p>
            <a class="button-primary mt-6 inline-flex" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
              Open Calendly
            </a>
          </article>

          <article class="card p-6">
            <p class="card-label">Email</p>
            <h2 class="mt-3 text-2xl font-bold tracking-[-0.04em]">Write direct</h2>
            <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">
              For speaking, media, and advisory enquiries. A short note about context helps the first reply.
            </p>
            <a class="button-secondary mt-6 inline-flex" href={`mailto:${siteConfig.email}`}>
              {siteConfig.email}
            </a>
          </article>
        </div>

        <div class="mt-10 rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface)] p-6 md:p-8">
          <p class="card-label">Also</p>
          <ul class="mt-4 space-y-3 text-sm leading-6 text-[color:var(--muted)]">
            <li><strong>LinkedIn</strong> &ndash; <a class="underline" href={siteConfig.linkedin} rel="noreferrer" target="_blank">{siteConfig.linkedin}</a></li>
            <li><strong>YouTube</strong> &ndash; <a class="underline" href={siteConfig.youtube} rel="noreferrer" target="_blank">Field Notes channel</a></li>
            <li><strong>GrowthMentor</strong> &ndash; <a class="underline" href={siteConfig.growthMentor} rel="noreferrer" target="_blank">Book a mentoring session</a></li>
            <li><strong>Location</strong> &ndash; {siteConfig.location}</li>
          </ul>
        </div>

        <p class="mt-8 text-sm text-[color:var(--muted)]">{siteConfig.availability}</p>
      </div>
    </div>
  </section>
</BaseLayout>
