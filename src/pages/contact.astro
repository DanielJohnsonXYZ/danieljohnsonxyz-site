---
import BaseLayout from "../layouts/BaseLayout.astro";
import CfEmailOff from "../components/CfEmailOff.astro";
import { siteConfig, socialLinks } from "../site";
import { buildBreadcrumbSchema } from "../lib/schema";

const title = "Book a Growth Audit | Contact Daniel Johnson";
const description =
  "Book a 20-minute Growth Audit with Daniel Johnson or get in touch about fractional CMO, founder office hours, or speaking enquiries.";
const calendlyEmbedUrl = `${siteConfig.bookingUrl}?hide_gdpr_banner=1`;

const breadcrumb = buildBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Contact", url: "/contact" }
]);
---

<BaseLayout
  description={description}
  keywords="contact Daniel Johnson, fractional CMO enquiry, growth audit booking, speaking enquiry"
  path="/contact/"
  title={title}
  schema={breadcrumb}
>
  <section class="section-space conversion-hero contact-booking-page">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl">
        <span class="eyebrow">Contact</span>
        <h1 class="mt-6 text-5xl font-extrabold tracking-[-0.06em] md:text-7xl">Book a Growth Audit.</h1>
        <p class="conversion-subcopy mt-5 text-lg leading-8 text-[color:var(--muted)]">
          Pick a time for the 20-minute Growth Audit below. If that is not the right fit, email works too.
        </p>

        <div class="mt-10 grid gap-5 lg:grid-cols-[minmax(0,1fr)_18rem]">
          <section
            id="book-growth-audit"
            class="contact-calendly-panel overflow-hidden rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface)]"
            aria-label="Book a 20-minute Growth Audit"
          >
            <iframe
              title="Book a 20-minute Growth Audit with Daniel Johnson"
              src={calendlyEmbedUrl}
              class="contact-calendly-iframe"
              loading="lazy"
            ></iframe>
            <p class="border-t border-[color:var(--line)] px-4 py-3 text-xs leading-5 text-[color:var(--muted)]">
              Calendar not loading? It needs cookies enabled for Calendly. Either accept cookies and refresh,
              <a class="underline" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">open the booking page directly</a>,
              or email <a class="underline" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
            </p>
          </section>
          <article class="card p-6">
            <p class="card-label">Email</p>
            <h2 class="mt-3 text-2xl font-bold tracking-[-0.04em]">Write direct</h2>
            <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">
              For speaking, media, and advisory enquiries. A short note about context helps the first reply.
            </p>
            <p class="mt-4 text-xs leading-5 text-[color:var(--muted)]">
              Fastest reply: include company, stage, the growth problem, what you've tried, and your timeline.
            </p>
            <CfEmailOff>
              <a class="button-secondary mt-6 inline-flex" href={`mailto:${siteConfig.email}`}>
                {siteConfig.email}
              </a>
            </CfEmailOff>
          </article>
        </div>

        <div class="mt-10 rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface)] p-6 md:p-8">
          <p class="card-label">Also</p>
          <ul class="mt-4 space-y-3 text-sm leading-6 text-[color:var(--muted)]">
            <li><strong>Profiles:</strong> {socialLinks.map((item, index) => (
              <>
                <a class="underline" href={item.href} rel="noreferrer" target="_blank">{item.label}</a>{index < socialLinks.length - 1 ? ", " : ""}
              </>
            ))}</li>
            <li><strong>Media:</strong> <a class="underline" href="/podcast-guest/">podcast guest page</a>, <a class="underline" href="/media-kit/">media kit</a>, <a class="underline" href="/speaking/">speaking assets</a>, <a class="underline" href="/now/">now page</a></li>
            <li><strong>Location:</strong> {siteConfig.location}</li>
          </ul>
        </div>

        <p class="mt-8 text-sm text-[color:var(--muted)]">{siteConfig.availability}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-calendly-panel {
    min-height: min(720px, calc(100vh - 7rem));
    scroll-margin-top: 7rem;
  }

  .contact-calendly-iframe {
    display: block;
    width: 100%;
    min-height: min(720px, calc(100vh - 7rem));
    border: 0;
  }

  @media (max-width: 47.9375rem) {
    .contact-calendly-panel,
    .contact-calendly-iframe {
      min-height: 680px;
    }
  }
</style>
