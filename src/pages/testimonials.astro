---
// /testimonials — named, metric-bearing testimonials by engagement type + Review JSON-LD.

import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {
  buildBreadcrumbSchema,
  buildTestimonialReviewSchemas,
  buildWebPageSchema
} from "../lib/schema";
import { absoluteUrl, sortByFeaturedThenOrder } from "../lib/utils";
import { ctas, proofStats, siteConfig } from "../site";

type PageSection = "fractional-cmo" | "strategy-sprint" | "speaking";

const sectionMeta: Record<
  PageSection,
  { title: string; intro: string; href: string; linkLabel: string }
> = {
  "fractional-cmo": {
    title: "Fractional CMO",
    intro:
      "Embedded GTM leadership, reporting rhythm, and sequencing work — outcomes from deeper engagements.",
    href: "/fractional-cmo/",
    linkLabel: "Fractional CMO scope & pricing →"
  },
  "strategy-sprint": {
    title: "Strategy Sprint",
    intro:
      "Intensive diagnostics, GrowthMentor sessions, and short sprints where a sharp bottleneck call changes the quarter.",
    href: "/strategy-sprint/",
    linkLabel: "Strategy Sprint overview →"
  },
  speaking: {
    title: "Speaking",
    intro: "Programme partners and organisers who have seen the work in front of founder rooms.",
    href: "/speaking/",
    linkLabel: "Speaking & workshops →"
  }
};

const sectionOrder: PageSection[] = ["fractional-cmo", "strategy-sprint", "speaking"];

const all = sortByFeaturedThenOrder(await getCollection("testimonials"));

const bySection = sectionOrder.reduce<Record<PageSection, typeof all>>(
  (acc, key) => {
    acc[key] = all.filter((t) => t.data.pageSection === key);
    return acc;
  },
  { "fractional-cmo": [], "strategy-sprint": [], speaking: [] }
);

const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Testimonials", url: "/testimonials/" }
  ]),
  buildWebPageSchema({
    name: "Client testimonials | Daniel Johnson",
    description:
      "Named founder and operator testimonials with specific outcomes across fractional CMO work, strategy sprints, and speaking.",
    url: absoluteUrl("/testimonials/")
  }),
  ...buildTestimonialReviewSchemas(
    all.map((t) => ({
      name: t.data.name,
      quote: t.data.quote,
      outcomeMetric: t.data.outcomeMetric,
      date: t.data.date
    }))
  )
];
---

<BaseLayout
  description="Named testimonials with specific metrics — fractional CMO, strategy sprints, and speaking. Social proof for AI and B2B SaaS founders."
  keywords="Daniel Johnson testimonials, fractional CMO reviews, startup growth advisor outcomes"
  path="/testimonials/"
  schema={schemas}
  title="Testimonials — named outcomes | Daniel Johnson"
>
  <!-- Hero -->
  <section class="section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center space-y-5">
        <span class="service-label justify-center">Testimonials</span>
        <h1 class="text-5xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-7xl">
          Named people. Real companies. Specific outcomes.
        </h1>
        <p class="text-lg leading-8 text-[color:var(--muted)] md:text-xl">
          {proofStats.mentorSessions} mentor sessions, {proofStats.startupsAdvised} startups advised,
          {proofStats.mentorRating}/5 from {proofStats.mentorReviewCount}+ public reviews — organised here by how we worked together.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a class="button-accent" href={ctas.primary.href} data-cta="testimonials-hero-book">
            {ctas.primary.label} →
          </a>
          <a class="button-link" href="/case-studies/" data-cta="testimonials-hero-cases">
            Case studies →
          </a>
        </div>
        <nav class="flex flex-wrap justify-center gap-2 pt-4 text-sm font-semibold" aria-label="Jump to testimonial sections">
          {sectionOrder.map((key) =>
            bySection[key].length ? (
              <a
                class="rounded-full border border-[color:var(--line)] bg-[color:var(--surface)] px-4 py-2 text-[color:var(--muted)] hover:border-[color:var(--accent)]/40 hover:text-[color:var(--ink)]"
                href={`#${key}`}
              >
                {sectionMeta[key].title}
                <span class="ml-1 tabular-nums opacity-60">({bySection[key].length})</span>
              </a>
            ) : null
          )}
        </nav>
      </div>
    </div>
  </section>

  {
    sectionOrder.map((key) =>
      bySection[key].length ? (
        <section
          class="section-space pt-0"
          id={key}
          aria-label={`${sectionMeta[key].title} testimonials`}
        >
          <div class="shell">
            <SectionHeader
              eyebrow={sectionMeta[key].title}
              intro={sectionMeta[key].intro}
              title={`${sectionMeta[key].title} testimonials.`}
            />
            <p class="reveal mt-6">
              <a class="link-arrow" href={sectionMeta[key].href} data-cta={`testimonials-link-${key}`}>
                {sectionMeta[key].linkLabel}
              </a>
            </p>

            <div class="tm-grid mt-10">
              {bySection[key].map((t) => (
                <figure class="reveal card p-6 md:p-7 tm-card">
                  <p class="card-label tm-metric">{t.data.outcomeMetric}</p>
                  <blockquote>
                    <p class="text-base leading-7 md:text-lg md:leading-8 font-medium tracking-[-0.01em]">
                      &ldquo;{t.data.quote}&rdquo;
                    </p>
                  </blockquote>
                  <figcaption class="mt-5 flex gap-4 border-t border-[color:var(--line)] pt-4">
                    {t.data.logoUrl && (
                      <img
                        alt=""
                        class="tm-logo h-12 w-12 shrink-0 rounded-lg object-cover"
                        height="48"
                        loading="lazy"
                        src={t.data.logoUrl}
                        width="48"
                      />
                    )}
                    <div class="min-w-0">
                      <p class="font-semibold text-[color:var(--ink)]">{t.data.name}</p>
                      <p class="text-sm text-[color:var(--muted)]">
                        {t.data.role}
                        {t.data.organisation ? ` · ${t.data.organisation}` : ""}
                      </p>
                      {t.data.source && (
                        <p class="mt-1 text-xs uppercase tracking-[0.12em] text-[color:var(--subtle)]">
                          {t.data.source}
                          {t.data.date ? ` · ${t.data.date}` : ""}
                        </p>
                      )}
                      {t.data.permission && t.data.permission !== "public" && (
                        <p
                          class:list={[
                            "mt-1 text-xs font-medium",
                            t.data.permission === "anonymous"
                              ? "text-[color:var(--muted)]"
                              : "text-amber-600"
                          ]}
                        >
                          {t.data.permission === "anonymous"
                            ? "Anonymous"
                            : "Permission required for public use"}
                        </p>
                      )}
                    </div>
                  </figcaption>
                </figure>
              ))}
            </div>
          </div>
        </section>
      ) : null
    )
  }

  <section class="section-space pt-0">
    <div class="shell">
      <p class="reveal text-center text-sm text-[color:var(--muted)]">
        Want the unfiltered mentor feed? See&nbsp;
        <a
          class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]"
          href={siteConfig.growthMentorReviews}
          rel="noreferrer"
          target="_blank"
        >
          {proofStats.mentorReviewCount}+ public reviews on GrowthMentor →
        </a>
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="cta-gradient section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <span class="eyebrow justify-center text-white/60">Next step</span>
        <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance text-white md:text-6xl">
          Want this kind of feedback from your team?
        </h2>
        <p class="mx-auto max-w-2xl text-lg leading-8 text-white/72">
          The fastest way to find out if it would work for your company is a 30-minute call.
          No deck, no pitch, just the bottleneck.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a class="button-accent" href={ctas.primary.href} data-cta="testimonials-final-book">
            {ctas.primary.label} →
          </a>
          <a class="button-link-invert" href="/start-here/" data-cta="testimonials-final-start">
            Or, start here →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tm-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .tm-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1080px) {
    .tm-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .tm-card {
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .tm-metric {
    color: var(--accent);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.35;
  }

  .tm-logo {
    border: 1px solid var(--line);
  }
</style>
