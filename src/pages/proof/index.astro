---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { buildBreadcrumbSchema, buildFaqPageSchema } from "../../lib/schema";
import { proofBar, proofStats, siteConfig } from "../../site";

const cases = (await getCollection("caseStudies"))
  .sort((a, b) => (b.data.order || 0) - (a.data.order || 0));

const testimonials = (await getCollection("testimonials"))
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

const proofEntries = await getCollection("proof");
const proofById = Object.fromEntries(proofEntries.map((entry) => [entry.id, entry.data]));

// Headline numbers: the four canonical stats, same sources as the homepage.
const headlineStats = proofBar.slice(0, 4).map((stat) => ({
  ...stat,
  sourceLabel: stat.source.startsWith("http") ? "Verify on GrowthMentor" : "See the case studies"
}));

// The remaining metrics, grouped by what actually moved. Values are taken
// verbatim from the proof collection and the case-study frontmatter; do not
// edit a number here without updating its source file.
const metricGroups = [
  {
    name: "Revenue impact",
    items: [
      {
        value: proofById["shoprocket-ltv"].metric,
        label: proofById["shoprocket-ltv"].title,
        source: proofById["shoprocket-ltv"].source
      },
      {
        value: "2.4×",
        label: "Qualified pipeline at a Seed B2B SaaS, vs. the 90 days before the engagement",
        source: "Anonymised case study",
        href: "/case-studies/fractional-cmo-seed-b2b-saas/"
      },
      {
        value: "+18%",
        label: "Lifecycle revenue contribution at an eCommerce brand, vs. the preceding quarter",
        source: "Anonymised case study",
        href: "/case-studies/ecommerce-retention-21-percent-uplift/"
      }
    ]
  },
  {
    name: "Acquisition",
    items: [
      {
        value: proofById["nava-growth"].metric,
        label: proofById["nava-growth"].title,
        source: proofById["nava-growth"].source
      },
      {
        value: "6×",
        label: "Monthly app downloads at an AI healthtech, 2k to 12k+ over six months",
        source: "Anonymised case study",
        href: "/case-studies/healthtech-ai-6x-app-downloads/"
      },
      {
        value: "-35%",
        label: "Customer acquisition cost at a consumer fintech, with paid spend held roughly flat",
        source: "Anonymised case study",
        href: "/case-studies/fintech-cac-down-35-percent/"
      }
    ]
  },
  {
    name: "Retention",
    items: [
      {
        value: "+21%",
        label: "90-day repeat purchase rate at an eCommerce brand, three months from rebuild start",
        source: "Anonymised case study",
        href: "/case-studies/ecommerce-retention-21-percent-uplift/"
      },
      {
        value: "3.2×",
        label: "Win-back conversion rate, triggered and cohort-specific vs. the prior monthly batch",
        source: "Anonymised case study",
        href: "/case-studies/ecommerce-retention-21-percent-uplift/"
      },
      {
        value: "+38%",
        label: "Activation rate at an AI healthtech after a lifecycle rebuild keyed to first action",
        source: "Anonymised case study",
        href: "/case-studies/healthtech-ai-6x-app-downloads/"
      }
    ]
  },
  {
    name: "Mentoring & advisory",
    items: [
      {
        value: proofById["mentor-sessions"].metric,
        label: proofById["mentor-sessions"].title,
        source: "Verify on GrowthMentor",
        href: siteConfig.growthMentor
      },
      {
        value: proofStats.startupsAdvised,
        label: "AI & B2B SaaS startups advised",
        source: "See the case studies",
        href: "/case-studies/"
      },
      {
        value: proofById["startup-exits"].metric,
        label: proofById["startup-exits"].title,
        source: proofById["startup-exits"].source
      }
    ]
  }
];

const proofFaqs = [
  {
    question: "How should I verify these outcomes?",
    answer:
      "Read the individual case studies, check the GrowthMentor reviews, or book a 20-min Growth Audit to discuss your specific context."
  },
  {
    question: "Does this guarantee the same result for my company?",
    answer:
      "No. Every company has a different constraint map. The proof shows what was fixed in each context, and your bottleneck may be different."
  },
  {
    question: "Can I use these numbers in my own materials?",
    answer:
      "Yes, with attribution. Please cite Daniel Johnson or We Scale Startups when referencing specific metrics."
  }
];

const proofSchema = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Proof", url: "/proof/" }
  ]),
  buildFaqPageSchema(proofFaqs)
];
---

<BaseLayout
  title="Proof | Daniel Johnson"
  description="See proof of Daniel Johnson's fractional CMO work: headline numbers with sources, case studies, testimonials and mentor credentials for post-PMF startups."
  path="/proof/"
  schema={proofSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Proof</p>
      <h1>The numbers, and where each one comes from.</h1>
      <p class="lede">
        Headline results first, then the rest grouped by what moved: revenue, acquisition, retention, and mentoring. Every figure keeps its source.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="mx-auto max-w-3xl card p-6 md:p-8">
        <p class="card-label">How to read this page</p>
        <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">
          Two kinds of numbers appear here. <strong class="text-[color:var(--ink)]">Publicly verifiable:</strong> mentor ratings, review counts and session numbers, which you can check on
          <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href={siteConfig.growthMentor} rel="noreferrer" target="_blank">GrowthMentor</a>.
          <strong class="text-[color:var(--ink)]">Client-reported:</strong> revenue, spend and engagement outcomes, drawn from client records, CV material and LinkedIn, anonymised where clients asked. Case-study metrics state the measurement window alongside each number.
        </p>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Headline numbers"
        title="Four numbers that summarise the record."
      />
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {headlineStats.map((stat) => (
          <article class="card p-6 text-center">
            <p class="text-4xl font-extrabold tracking-[-0.04em] text-[color:var(--accent)] md:text-5xl">{stat.value}</p>
            <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">{stat.label}</p>
            <a
              class="mt-4 inline-block text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--subtle)] underline underline-offset-4 hover:text-[color:var(--accent)]"
              href={stat.source}
              rel={stat.source.startsWith("http") ? "noreferrer" : undefined}
              target={stat.source.startsWith("http") ? "_blank" : undefined}
            >
              {stat.sourceLabel}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionHeader
        eyebrow="The detail"
        title="The rest of the numbers, grouped by what moved."
        intro="Each metric keeps its source: a public profile, a named engagement, or an anonymised case study with the measurement window stated."
      />
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {metricGroups.map((group) => (
          <article class="card p-6 md:p-8">
            <h3 class="text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)]">{group.name}</h3>
            <ul class="mt-5 space-y-5">
              {group.items.map((item) => (
                <li class="flex gap-4">
                  <span class="w-20 shrink-0 text-xl font-bold tracking-[-0.03em] text-[color:var(--accent)]">{item.value}</span>
                  <div>
                    <p class="text-sm leading-6 text-[color:var(--ink)]">{item.label}</p>
                    {item.href ? (
                      <a
                        class="mt-1 inline-block text-xs font-semibold text-[color:var(--subtle)] underline underline-offset-4 hover:text-[color:var(--accent)]"
                        href={item.href}
                        rel={item.href.startsWith("http") ? "noreferrer" : undefined}
                        target={item.href.startsWith("http") ? "_blank" : undefined}
                      >
                        {item.source}
                      </a>
                    ) : (
                      <p class="mt-1 text-xs text-[color:var(--subtle)]">{item.source}</p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Case Studies"
        title="The full stories behind the metrics."
        intro="Each case study follows the same structure: problem, intervention, system built, numbers, timeline, and why it worked."
      />
      <div class="grid-2">
        {cases.map((c) => (
          <article class="card p-6 md:p-8">
            <p class="card-label">{c.data.sector}</p>
            <h3 class="text-xl font-bold tracking-[-0.04em]">{c.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{c.data.excerpt}</p>
            <div class="mt-4 grid grid-cols-2 gap-4">
              {c.data.metrics.slice(0, 3).map((result) => (
                <div>
                  <span class="text-lg font-bold text-[color:var(--accent)]">{result.value}</span>
                  <span class="text-xs text-[color:var(--muted)]">{result.label}</span>
                </div>
              ))}
            </div>
            <a class="link-arrow mt-4" href={`/case-studies/${c.id}/`}>Read the case</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionHeader
        eyebrow="Mentoring credentials"
        title="Where the mentoring numbers come from."
        intro={`${proofStats.mentorRating}/5 average across ${proofStats.mentorReviewCount} reviews and ${proofStats.mentorSessions} sessions.`}
      />
      <div class="max-w-3xl mx-auto grid gap-4">
        <div class="card p-4 flex items-center gap-4">
          <span class="text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] w-40">GrowthMentor</span>
          <span class="text-base font-medium text-[color:var(--ink)]">{proofStats.mentorRating}/5 · {proofStats.mentorReviewCount} reviews · {proofStats.mentorSessions} sessions</span>
        </div>
        <div class="card p-4 flex items-center gap-4">
          <span class="text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] w-40">MentorCruise</span>
          <span class="text-base font-medium text-[color:var(--ink)]">Verified mentor profile</span>
        </div>
        <div class="card p-4 flex items-center gap-4">
          <span class="text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] w-40">Techstars</span>
          <span class="text-base font-medium text-[color:var(--ink)]">Active mentor · startup accelerator programmes</span>
        </div>
        <div class="card p-4 flex items-center gap-4">
          <span class="text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] w-40">UK Space Agency</span>
          <span class="text-base font-medium text-[color:var(--ink)]">Innovation talk speaker and workshop facilitator</span>
        </div>
        <div class="card p-4 flex items-center gap-4">
          <span class="text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)] w-40">Google Launchpad</span>
          <span class="text-base font-medium text-[color:var(--ink)]">Startup mentor and workshop facilitator</span>
        </div>
      </div>
      <div class="mt-6 text-center">
        <a class="button-accent" href={siteConfig.growthMentor} rel="noreferrer" target="_blank">Read mentor reviews →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Testimonials"
        title="What founders say after the work."
        intro="Feedback from mentoring, advisory, and growth sessions."
      />
      <div class="grid-2">
        {testimonials.slice(0, 4).map((t) => (
          <blockquote class="card p-6 md:p-8 border-l-4 border-[color:var(--accent)]">
            <p class="text-lg font-medium leading-7">"{t.data.quote}"</p>
            <footer class="mt-4 text-sm text-[color:var(--muted)]">
              <p class="font-semibold">{t.data.name}</p>
              <p>{t.data.role}{t.data.organisation ? ` · ${t.data.organisation}` : ""}</p>
            </footer>
          </blockquote>
        ))}
      </div>
      <div class="mt-6 text-center">
        <a class="link-arrow" href="/testimonials/">See all testimonials</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionHeader
        eyebrow="FAQ"
        title="Questions about the proof."
        intro="How to read the evidence and what it means for your company."
      />
      <div class="grid-3">
        {proofFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-gradient section">
    <div class="shell text-center">
      <p class="eyebrow justify-center text-white/60">Next step</p>
      <h2 class="text-4xl font-extrabold tracking-[-0.06em] text-white md:text-5xl">
        {siteConfig.bookingLabel}.
      </h2>
      <p class="mx-auto max-w-2xl text-lg leading-8 text-white/72">
       20 minutes on your specific situation. You'll leave with a clearer read on your biggest growth bottleneck.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
          {siteConfig.bookingLabel} →
        </a>
        <a class="button-link-invert" href="/case-studies/">See all case studies →</a>
      </div>
    </div>
  </section>
</BaseLayout>
