---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { sortByFeaturedThenOrder } from "../lib/utils";
import { siteConfig } from "../site";

const talks = sortByFeaturedThenOrder(await getCollection("talks"));
const pastEvents = talks.filter((t) => t.data.yearLabel && t.data.yearLabel !== "Upcoming");

const topics = [
  {
    title: "AI-native growth systems",
    description:
      "How to rebuild the GTM stack around generative and agentic workflows — ICP research, message testing, enrichment, content, experiment design — and ship faster without adding headcount."
  },
  {
    title: "Founder-led distribution",
    description:
      "Content-to-pipeline loops, LinkedIn systems, and the patient-enough cadence that turns founder voice into an acquisition channel."
  },
  {
    title: "How to build a repeatable growth system",
    description:
      "A practical model for turning fragmented marketing activity into a clearer operating rhythm — customer, message, channel, offer, cadence."
  },
  {
    title: "GTM judgement for early teams",
    description:
      "How to choose what to test, what to ignore, and connect message, channel, and customer learning into compounding decisions."
  },
  {
    title: "Turning innovation into commercial traction",
    description:
      "A bridge between invention, market clarity, and demand creation — built for technical founders and R&D-heavy teams."
  }
];

const schema = buildBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Speaking", url: "/speaking" },
  { name: "Topics & Talks", url: "/topics-and-talks" }
]);
---

<BaseLayout
  description="Speaking topics and past events for Daniel Johnson — keynotes and workshops on AI-native growth, GTM systems, and founder-led distribution."
  path="/topics-and-talks"
  schema={schema}
  title="Topics & Talks | Daniel Johnson"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="service-label">Topics & Talks</span>
        <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">
          Topics I speak on &mdash; and where I've delivered them.
        </h1>
        <p class="hero-subcopy text-xl leading-9 md:text-2xl">
          Five talk tracks for founder audiences, accelerator cohorts, and corporate innovation teams. Each one can run as a
          keynote, workshop, fireside chat, or training session.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a class="button-accent" href="/book-daniel-to-speak">Book Daniel to speak →</a>
          <a class="button-link" href="/speaking">Back to Speaking overview →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Talk tracks" intro="Five starting points. Each one is tailored to the audience." title="Speaking topics." />
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          topics.map((topic) => (
            <article class="reveal card p-6">
              <h3 class="text-xl font-bold tracking-[-0.04em]">{topic.title}</h3>
              <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{topic.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {pastEvents.length > 0 && (
    <section class="section-space pt-0">
      <div class="shell">
        <SectionHeader eyebrow="Past events" intro="A working list. Not exhaustive." title="Where I've spoken." />
        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {
            pastEvents.map((event) => (
              <article class="reveal card p-6">
                <div class="flex flex-wrap gap-2">
                  <span class="chip">{event.data.yearLabel}</span>
                  {event.data.format && <span class="chip">{event.data.format}</span>}
                </div>
                <h3 class="mt-4 text-xl font-bold tracking-[-0.04em]">{event.data.title}</h3>
                {event.data.description && <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{event.data.description}</p>}
              </article>
            ))
          }
        </div>
      </div>
    </section>
  )}

  <section class="cta-gradient section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-white md:text-5xl">
          Event coming up? Let's talk.
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          <a class="button-accent" href="/book-daniel-to-speak">Book Daniel to speak →</a>
          <a class="button-secondary button-secondary-dark" href={`mailto:${siteConfig.email}?subject=Speaking%20enquiry`}>Email directly</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
