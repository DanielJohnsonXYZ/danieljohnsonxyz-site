---
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site";

const proofStats = [
  { value: "£18M+", label: "Revenue generated for clients" },
  { value: "£6M+", label: "Ad spend managed" },
  { value: "20+", label: "AI & SaaS startups" },
  { value: "4.97/5", label: "Across 479+ mentor sessions" }
];

const timeline = [
  {
    year: "2013",
    title: "Built and exited early ventures",
    body: "Daniel's founder perspective started with hands-on venture building, ecommerce launches, and the awkward early lessons that come from selling something before the system is fully tidy."
  },
  {
    year: "2015-2018",
    title: "Led growth inside Shoprocket and NAVA",
    body: "Senior operating roles connected positioning, acquisition, retention, and revenue quality, including 30K+ NAVA downloads, lifecycle work, and a 30% LTV lift at Shoprocket."
  },
  {
    year: "2016-Present",
    title: "Built We Scale Startups as the advisory vehicle",
    body: "WSS became the home for Daniel's advisory, mentoring, content, and fractional work across SaaS, AI, fintech, commerce, and innovation-led teams."
  },
  {
    year: "2019-Present",
    title: "Turned the work into a public body of thinking",
    body: "Mentoring, teaching, and speaking through Google Launchpad, Techstars, GrowthMentor, Cambridge, Imperial, General Assembly, and the UK Space Agency."
  },
  {
    year: "2024-Present",
    title: "Focused the work on founder-led GTM systems",
    body: "The current practice is built around post-traction teams that need sharper customer insight, message-market fit, prioritisation, creative testing, and a repeatable growth cadence."
  }
];

const principles = [
  {
    title: "Find the real bottleneck",
    body: "Before adding spend, clarify whether growth is breaking in positioning, activation, retention, measurement, or team decision-making."
  },
  {
    title: "Turn evidence into choices",
    body: "Good research and data should reduce ambiguity for the team, not create a bigger reporting ritual."
  },
  {
    title: "Leave a system behind",
    body: "The best engagement makes the team better after it ends: sharper priorities, clearer rhythm, and better hiring or handoff paths."
  }
];
---

<BaseLayout
  description="About Daniel Johnson — AI-Native GTM and growth operator for post-PMF AI and B2B SaaS startups. 10+ years, 20+ startups, £18M+ revenue generated, £6M+ ad spend, £15M+ raised."
  title="About Daniel Johnson | AI-Native GTM & Growth Operator"
>
  <section class="section-space">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-start">
        <div class="reveal space-y-6">
          <span class="service-label">About Daniel</span>
          <h1 class="max-w-4xl text-5xl font-bold tracking-[-0.06em] text-balance md:text-7xl">
            AI-Native GTM &amp; growth operator for AI and B2B SaaS founders.
          </h1>
          <p class="max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            I help post-PMF AI and B2B SaaS companies build repeatable GTM systems — spanning PLG/self-service
            conversion, AI-enhanced growth planning, and founder-led distribution. Founders bring me in when scattered
            experiments have stopped compounding and they need clearer priorities, sharper evidence, and an operating
            rhythm the team can run.
          </p>
        </div>

        <aside class="reveal card overflow-hidden">
          <img alt="Portrait of Daniel Johnson" class="aspect-[4/3] w-full object-cover object-top" height="720" src={siteConfig.headshot} width="960" />
          <div class="p-6 md:p-8">
            <p class="card-label">Why it matters</p>
            <p class="mt-3 text-base leading-8">
              Founder of <a class="underline decoration-[color:var(--accent)]/40 underline-offset-4" href={siteConfig.companyUrl}>We Scale Startups</a>,
              long-time mentor across Google, Techstars, and GrowthMentor, and a speaker on startup growth, GTM, and innovation.
            </p>
            <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-xl bg-[color:var(--line)]">
              {
                proofStats.map((item) => (
                  <div class="bg-[color:var(--surface)] p-4">
                    <p class="text-2xl font-extrabold tracking-[-0.07em]">{item.value}</p>
                    <p class="mt-1 text-xs leading-5 text-[color:var(--muted)]">{item.label}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Principles"
        intro="The useful work is practical: clearer choices, cleaner evidence, and a team that knows what to do next."
        title="How the judgment shows up in the work."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
        <article class="reveal card p-6 md:p-8">
          <p class="text-3xl font-extrabold leading-[1.12] tracking-[-0.06em] text-white md:text-5xl">
            Growth gets easier to manage when the team can see what is working, what is guesswork, and what should stop.
          </p>
        </article>
        <div class="grid gap-4">
          {
            principles.map((item, index) => (
              <article class="reveal card p-5 md:p-6">
                <p class="card-label text-white/45">0{index + 1}</p>
                <h2 class="mt-3 text-xl font-bold tracking-[-0.04em] text-white">{item.title}</h2>
                <p class="mt-3 text-sm leading-7 text-white/68">{item.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Operating History"
        intro="The through-line is practical growth: founder-side experience, in-house operating roles, advisory work, and public teaching."
        title="Where the point of view comes from."
      />
      <div class="timeline-feature mt-10">
        {
          timeline.map((item) => (
            <article class="timeline-feature-row reveal">
              <p>{item.year}</p>
              <div>
                <h2>{item.title}</h2>
                <span>{item.body}</span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Next Step</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              See how I advise teams.
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              The advisory page breaks down engagement modes, first-two-week priorities, and the kinds of teams where the fit is strongest.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a class="button-accent" href="/advisory">Explore Advisory</a>
            <a class="button-secondary" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
