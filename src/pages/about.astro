---
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { proofStats, siteConfig, siteImages } from "../site";

const proofTiles = [
  { value: "10+ yrs", label: "Founder, operator, and advisor work" },
  { value: proofStats.startupsAdvised, label: "AI and SaaS startups advised" },
  { value: "2 exits", label: "Founder-side: eQuoo (mental-health tech) + an eCommerce brand" },
  { value: proofStats.adSpend, label: "Paid acquisition spend managed" }
];

// Timeline split: always-on vs time-bounded. Chapters that are still running
// show `ongoing: true` so we can render them visually differently.
const timeline = [
  {
    year: "2013–2016",
    title: "Founder-side: built and exited early ventures",
    body: "First founder chapter — ecommerce, early SaaS, the awkward early lessons that come from selling something before the system is fully tidy. Two exits on the founder side.",
    ongoing: false
  },
  {
    year: "2015–2018",
    title: "In-house: Head of Growth, Shoprocket & NAVA",
    body: "Senior operating roles covering positioning, acquisition, retention, and revenue quality. 30K+ NAVA downloads, lifecycle rebuild, 30% LTV lift at Shoprocket.",
    ongoing: false
  },
  {
    year: "2016 → now",
    title: "Advisory: We Scale Startups",
    body: "The advisory vehicle for fractional CMO, mentoring, content, and speaking across SaaS, AI, fintech, commerce, and innovation-led teams.",
    ongoing: true
  },
  {
    year: "2019 → now",
    title: "Teaching & mentoring at scale",
    body: `Google Launchpad, Techstars, GrowthMentor, Cambridge Judge Business School, Imperial College London, General Assembly, UK Space Agency. ${proofStats.mentorSessions} sessions delivered, ${proofStats.mentorRating}/5 rating.`,
    ongoing: true
  },
  {
    year: "2024 → now",
    title: "Current focus: founder-led GTM systems",
    body: "Post-traction AI and B2B SaaS teams that need sharper customer insight, message-market fit, prioritisation, creative testing, and a repeatable growth cadence.",
    ongoing: true
  }
];

const principles = [
  {
    title: "Find the real bottleneck",
    body: "Before adding spend, clarify whether growth is breaking in positioning, activation, retention, measurement, or team decision-making."
  },
  {
    title: "Turn evidence into choices",
    body: "Good research and data should reduce ambiguity for the team, not create a bigger reporting ritual."
  },
  {
    title: "Leave a system behind",
    body: "The best engagement makes the team better after it ends: sharper priorities, clearer rhythm, better hiring or handoff paths."
  }
];
---

<BaseLayout
  description="About Daniel Johnson—fractional CMO & senior GTM operator for founder-led AI & B2B SaaS: founder-side, in-house, advisory & public teaching path."
  keywords="Daniel Johnson bio, fractional CMO background, GTM operator, startup advisor, We Scale Startups founder"
  path="/about/"
  preloadHeadshot
  title="About Daniel Johnson | Fractional CMO & GTM Operator"
>
  <section class="section-space">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-start">
        <div class="reveal space-y-6">
          <span class="service-label">About Daniel</span>
          <h1 class="max-w-4xl text-5xl font-bold tracking-[-0.06em] text-balance md:text-7xl">
            A founder-side growth operator, now working as a fractional CMO.
          </h1>
          <p class="max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            Founders bring me in when growth still depends too much on them: unclear positioning, inconsistent pipeline, scattered channel activity, and a team that needs better decisions before another hire or agency brief.
          </p>

          <!-- Why founders trust me — short personal story block. -->
          <div class="rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-6">
            <p class="card-label">Why founders work with me</p>
            <p class="mt-3 text-base leading-8 text-[color:var(--ink)]">
              I've been the founder staring at a flat chart at 2am. I've been the Head of Growth who had to turn activity into pipeline with three people and no playbook. That's why the work isn't theoretical. I bring senior operator judgement to the messy calls founders actually have to make — pricing, positioning, who to hire next, which channel to stop — not a deck of best-practice slides.
            </p>
          </div>
        </div>

        <aside class="reveal card overflow-hidden">
          <img alt={siteImages.outdoorPortrait.alt} class="aspect-[4/3] w-full object-cover object-top" height={siteImages.outdoorPortrait.height} src={siteImages.outdoorPortrait.src} width={siteImages.outdoorPortrait.width} />
          <div class="p-6 md:p-8">
            <p class="card-label">Why it matters</p>
            <p class="mt-3 text-base leading-8">
              Founder of <a class="underline decoration-[color:var(--accent)]/40 underline-offset-4" href={siteConfig.companyUrl}>We Scale Startups</a>, long-time mentor across Google, Techstars, and GrowthMentor, and a speaker on startup growth, GTM, and innovation.
            </p>
            <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-xl bg-[color:var(--line)]">
              {
                proofTiles.map((item) => (
                  <div class="bg-[color:var(--surface)] p-4">
                    <p class="text-2xl font-extrabold tracking-[-0.07em]">{item.value}</p>
                    <p class="mt-1 text-xs leading-5 text-[color:var(--muted)]">{item.label}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card overflow-hidden md:grid md:grid-cols-[0.8fr_1fr] md:items-stretch">
        <img alt={siteImages.speakingCircle.alt} class="h-full min-h-[22rem] w-full object-cover" height={siteImages.speakingCircle.height} loading="lazy" src={siteImages.speakingCircle.src} width={siteImages.speakingCircle.width} />
        <div class="p-6 md:p-10">
          <p class="card-label">Teaching style</p>
          <h2 class="mt-4 text-3xl font-bold tracking-[-0.05em] md:text-4xl">Practical, direct, and built around the next decision.</h2>
          <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">
            The public speaking and mentoring work is the same style as the client work: take a messy growth question, separate signal from noise, and make the next commercial decision easier to see.
          </p>
          <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">
            Founders do not need a theatre of frameworks. They need sharper choices: which segment to focus on, which message to test, which channel to stop, and what the team should do this week.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Principles"
        intro="The useful work is practical: clearer choices, cleaner evidence, and a team that knows what to do next."
        title="How the judgment shows up in the work."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
        <article class="reveal card p-6 md:p-8">
          <p class="text-3xl font-extrabold leading-[1.12] tracking-[-0.06em] text-white md:text-5xl">
            Growth gets easier to manage when the team can see what's working, what's guesswork, and what should stop.
          </p>
        </article>
        <div class="grid gap-4">
          {
            principles.map((item, index) => (
              <article class="reveal card p-5 md:p-6">
                <p class="card-label text-white/45">0{index + 1}</p>
                <h2 class="mt-3 text-xl font-bold tracking-[-0.04em] text-white">{item.title}</h2>
                <p class="mt-3 text-sm leading-7 text-white/68">{item.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Operating History"
        intro="Founder-side experience, in-house operating roles, advisory work, and public teaching. The chapters marked ongoing are still active today."
        title="Where the point of view comes from."
      />
      <div class="timeline-feature mt-10">
        {
          timeline.map((item) => (
            <article class="timeline-feature-row reveal">
              <p>
                {item.year}
                {item.ongoing && <span class="ml-2 inline-block rounded-full border border-[color:var(--accent)]/30 bg-[color:var(--accent)]/10 px-2 py-0.5 align-middle text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-[color:var(--accent)]">Ongoing</span>}
              </p>
              <div>
                <h2>{item.title}</h2>
                <span>{item.body}</span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Next Step</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              See how I advise teams.
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              The Fractional CMO page breaks down scope, 30/60/90-day priorities, pricing anchors, and the kinds of teams where the fit is strongest.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a class="button-accent" href="/fractional-cmo/">Explore Fractional CMO</a>
            <a class="button-secondary" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
