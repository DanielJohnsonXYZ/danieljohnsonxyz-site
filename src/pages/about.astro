---
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import outdoorPortrait from "../assets/images/daniel-outdoor-portrait.webp";
import { buildBreadcrumbSchema } from "../lib/schema";
import { absoluteUrl } from "../lib/utils";
import { entityGraph, icpFirmographics, proofStats, siteConfig, siteImages } from "../site";

const aboutDescription =
  "About Daniel Johnson—fractional CMO & senior GTM operator for founder-led AI & B2B SaaS: founder-side, in-house, advisory & public teaching path.";

const aboutSchema = [
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    name: "About Daniel Johnson",
    description: aboutDescription,
    url: absoluteUrl("/about/"),
    mainEntity: { "@id": entityGraph.danielPerson }
  },
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "About", url: "/about/" }
  ])
];

const proofTiles = [
  { value: "10+ yrs", label: "Founder, operator, and advisor work" },
  { value: proofStats.startupsAdvised, label: "AI and SaaS startups advised" },
  { value: "2 exits", label: "Founder-side operator experience, including eQuoo (mental-health tech)" },
  { value: proofStats.adSpend, label: "Paid acquisition spend managed" }
];

// Timeline split: always-on vs time-bounded. Chapters that are still running
// show `ongoing: true` so we can render them visually differently.
const timeline = [
  {
    year: "2013–2016",
    title: "Founder-side: built and exited early ventures",
    body: "First founder chapter — mental-health tech, early SaaS, and the awkward lessons that come from selling before the system is fully tidy. The useful part was learning founder-led growth from inside the company.",
    ongoing: false
  },
  {
    year: "2015–2018",
    title: "In-house: Head of Growth, Shoprocket & NAVA",
    body: "Senior operating roles covering positioning, acquisition, retention, and revenue quality. 30K+ NAVA downloads, lifecycle rebuild, 30% LTV lift at Shoprocket.",
    ongoing: false
  },
  {
    year: "2016 → now",
    title: "Advisory: We Scale Startups",
    body: "The advisory vehicle for fractional CMO, mentoring, content, and speaking across SaaS, AI, fintech, and innovation-led teams.",
    ongoing: true
  },
  {
    year: "2019 → now",
    title: "Teaching & mentoring at scale",
    body: `Google Launchpad, Techstars, GrowthMentor, Cambridge Judge Business School, Imperial College London, General Assembly, UK Space Agency. ${proofStats.mentorSessions} sessions delivered, ${proofStats.mentorRating}/5 rating.`,
    ongoing: true
  },
  {
    year: "2024 → now",
    title: "Current focus: founder-led GTM systems",
    body: "Post-PMF B2B SaaS and AI startups at £1M–£20M ARR, typically 10-50 people, with a functional product but inconsistent GTM: sharper customer insight, message-market fit, prioritisation, creative testing, and a repeatable growth cadence.",
    ongoing: true
  }
];

const principles = [
  {
    title: "Find the real bottleneck",
    body: "Before adding spend, clarify whether growth is breaking in positioning, activation, retention, measurement, or team decision-making."
  },
  {
    title: "Turn evidence into choices",
    body: "Good research and data should reduce ambiguity for the team, not create a bigger reporting ritual."
  },
  {
    title: "Leave a system behind",
    body: "The best engagement makes the team better after it ends: sharper priorities, clearer rhythm, better hiring or handoff paths."
  }
];
---

<BaseLayout
  description={aboutDescription}
  keywords="Daniel Johnson bio, fractional CMO background, GTM operator, startup advisor, We Scale Startups founder"
  path="/about/"
  schema={aboutSchema}
  title="About | Fractional CMO & GTM Operator"
>
  <section class="section-space">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-start">
        <div class="reveal space-y-6">
          <span class="service-label">About Daniel</span>
          <h1 class="max-w-4xl text-5xl font-bold tracking-[-0.06em] text-balance md:text-7xl">
            I've been the founder with a working product and a flat chart at 2am.
          </h1>
          <p class="max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            The first company was eQuoo — gamified emotional fitness training, evidence-based, built with real clinical input. Good product. A mission worth caring about. A go-to-market strategy that amounted to hoping the right people would find us. They didn't. Not fast enough. We navigated through two exits across that chapter, but somewhere between the 2am spreadsheet stares and the awkward conversations about channel strategy, the lesson crystallised: execution without a system isn't scrappy. It's expensive improvisation with a deadline.
          </p>
          <p class="max-w-3xl text-base leading-8 text-[color:var(--ink)] md:text-lg">
            {icpFirmographics.oneLiner}
          </p>

          <!-- Why founders trust me — short personal story block. -->
          <div class="rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-6">
            <p class="card-label">Why founders work with me</p>
            <p class="mt-3 text-base leading-8 text-[color:var(--ink)]">
              After those early chapters I took in-house roles — Head of Growth at Shoprocket and then NAVA — and kept seeing the same thing: functional products, founders personally owning every GTM call, and growth that was reactive rather than designed. We got results: 30% LTV improvement at Shoprocket, 30K+ downloads at NAVA. But mostly I was watching what breaks when no operating system exists behind the activity. That repeating pattern is what We Scale Startups was built to fix. Not with a framework deck that gets filed after the workshop. With a structured approach to positioning, pipeline, and growth decisions — built from first principles across 20+ AI and SaaS startups in 12 countries, applied against £6.8M+ in managed acquisition spend, and refined through {proofStats.mentorSessions} mentor sessions at a {proofStats.mentorRating}/5 rating. The methodology has been taught at Cambridge Judge Business School, Google Launchpad, Techstars, and Imperial College. That's not credential stacking — it's proof the approach holds up under pressure from multiple directions.
            </p>
          </div>
        </div>

        <aside class="reveal card overflow-hidden">
          <Image src={outdoorPortrait} widths={[600, 1200]} sizes="(max-width: 1024px) 100vw, 40vw" alt={siteImages.outdoorPortrait.alt} class="aspect-[4/3] w-full object-cover object-top" loading="lazy" />
          <div class="p-6 md:p-8">
            <p class="card-label">The short version</p>
            <p class="mt-3 text-base leading-8">
              Founder of <a class="underline decoration-[color:var(--accent)]/40 underline-offset-4" href={siteConfig.companyUrl}>We Scale Startups</a>. Long-time mentor at Google Launchpad, Techstars, and GrowthMentor. Speaker on startup growth and GTM at Cambridge Judge, Imperial, and beyond. Currently splitting time between the UK and Southeast Asia, working with teams across Europe, the US, and APAC.
            </p>
            <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-xl bg-[color:var(--line)]">
              {
                proofTiles.map((item) => (
                  <div class="bg-[color:var(--surface)] p-4">
                    <p class="text-2xl font-extrabold tracking-[-0.07em]">{item.value}</p>
                    <p class="mt-1 text-xs leading-5 text-[color:var(--muted)]">{item.label}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card overflow-hidden md:grid md:grid-cols-[0.8fr_1fr] md:items-stretch">
        <img alt={siteImages.speakingCircle.alt} class="h-full min-h-[22rem] w-full object-cover" height={siteImages.speakingCircle.height} loading="lazy" src={siteImages.speakingCircle.src} width={siteImages.speakingCircle.width} />
        <div class="p-6 md:p-10">
          <p class="card-label">Teaching style</p>
          <h2 class="mt-4 text-3xl font-bold tracking-[-0.05em] md:text-4xl">Practical, direct, and built around the next decision.</h2>
          <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">
            Whether it is a mentoring session or a keynote in front of a Cambridge cohort, the approach is the same: take a messy growth question, separate signal from noise, and make the next commercial decision easier to see. No theatre. No complexity added for the sake of looking thorough.
          </p>
          <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">
            If you have sat through a pitch that was mostly frameworks with no through-line to your actual problem, you know what I am trying to avoid. The methodology behind this work is 520 slides deep — built on patterns from 100+ startups across 12 countries — but in a session it shows up as a sharper diagnosis and a clearer next step, not a slide deck.
          </p>
          <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">
            Outside the work: I am usually reading something about behavioural economics, watching a founder pitch something they are genuinely excited about, or navigating a new city with a camera and a bad sense of direction. Currently splitting time between the UK and Southeast Asia.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Principles"
        intro="Not rules. Just the things that have proven consistently true across 100+ startup engagements in 12 countries."
        title="How the judgment shows up in the work."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
        <article class="reveal card p-6 md:p-8">
          <p class="text-3xl font-extrabold leading-[1.12] tracking-[-0.06em] text-white md:text-5xl">
            Growth gets easier to manage when the team can see what's working, what's guesswork, and what should stop.
          </p>
        </article>
        <div class="grid gap-4">
          {
            principles.map((item, index) => (
              <article class="reveal card p-5 md:p-6">
                <p class="card-label text-white/45">0{index + 1}</p>
                <h2 class="mt-3 text-xl font-bold tracking-[-0.04em] text-white">{item.title}</h2>
                <p class="mt-3 text-sm leading-7 text-white/68">{item.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Operating History"
        intro="Founder-side experience, in-house operating roles, advisory work, and public teaching. The chapters marked ongoing are still active today."
        title="Where the point of view comes from."
      />
      <div class="timeline-feature mt-10">
        {
          timeline.map((item) => (
            <article class="timeline-feature-row reveal">
              <p>
                {item.year}
                {item.ongoing && <span class="ml-2 inline-block rounded-full border border-[color:var(--accent)]/30 bg-[color:var(--accent)]/10 px-2 py-0.5 align-middle text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-[color:var(--accent)]">Ongoing</span>}
              </p>
              <div>
                <h2>{item.title}</h2>
                <span>{item.body}</span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Next Step</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              If this sounds like your current situation.
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              The fit is strongest with B2B SaaS or AI teams at £1M–£20M ARR, 10–50 people, where the founder is still making most of the weekly GTM calls and growth feels more reactive than designed. The Fractional CMO page breaks down scope, 30/60/90-day priorities, and where to start. For named founders and specific outcomes, the{" "}
              <a class="font-semibold text-[color:var(--accent)] underline underline-offset-4 hover:text-[color:var(--ink)]" href="/testimonials/">
                testimonials page
              </a>{" "}
              has the evidence.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a class="button-accent" href="/fractional-cmo/">Explore Fractional CMO</a>
            <a class="button-secondary" href="/testimonials/">Client testimonials</a>
            <a class="button-secondary" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
