---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { buildBreadcrumbSchema } from "../../lib/schema";
import { siteConfig, proofStats } from "../../site";

const cases = (await getCollection("caseStudies"))
  .sort((a, b) => (b.data.order || 0) - (a.data.order || 0));

const resultsSchema = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Results", url: "/results/" }
  ])
];
---

<BaseLayout
  title="Results | Daniel Johnson"
  description="Metrics-led case studies from post-PMF AI and B2B SaaS startups. Before/after growth system results."
  path="/results/"
  schema={resultsSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Results</p>
      <h1>Metrics-led case studies.</h1>
      <p class="hero-copy">
        Before/after evidence with problem, baseline, intervention, system built, results, and timeline.
        Anonymous where needed — use company type and stage rather than name if the client prefers.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="hero-proof" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
        <div>
          <strong>{proofStats.revenueImpact}</strong>
          <span>revenue generated</span>
        </div>
        <div>
          <strong>{proofStats.adSpend}</strong>
          <span>paid spend managed</span>
        </div>
        <div>
          <strong>6×</strong>
          <span>app downloads (healthtech)</span>
        </div>
        <div>
          <strong>35%</strong>
          <span>lower CAC (fintech)</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Case Studies"
        title="How the system was built."
        intro="Each case study follows the same structure: problem, baseline, intervention, system, results, timeline."
      />
      <div class="grid-2">
        {cases.map((c) => (
          <article class="card p-6 md:p-8">
            <p class="card-label">{c.data.sector} · {c.data.stage}</p>
            <h3 class="mt-3 text-2xl font-bold tracking-[-0.04em]">{c.data.title}</h3>
            <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">{c.data.summary}</p>
            <div class="mt-4 grid grid-cols-2 gap-4">
              {c.data.metrics.slice(0, 3).map((result) => (
                <div>
                  <span class="text-lg font-bold text-[color:var(--accent)]">{result.value}</span>
                  <span class="text-xs text-[color:var(--muted)]">{result.label}</span>
                </div>
              ))}
            </div>
            <div class="mt-4 text-sm text-[color:var(--muted)]">
              <strong>What made it work:</strong> {c.data.outcome}
            </div>
            <a class="link-arrow mt-4" href={`/case-studies/${c.id}/`}>Read the case →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionHeader
        eyebrow="Template"
        title="How to read each case study."
        intro="Use this structure to evaluate whether the work fits your company."
      />
      <div class="grid gap-8 md:grid-cols-2">
        <div class="card p-6">
          <h3 class="font-bold">Company</h3>
          <p class="mt-2 text-sm text-[color:var(--muted)]">Type, stage, team size. Anonymous if needed.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-bold">The Problem</h3>
          <p class="mt-2 text-sm text-[color:var(--muted)]">What was breaking in plain language.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-bold">Baseline Metrics</h3>
          <p class="mt-2 text-sm text-[color:var(--muted)]">MQLs, CAC, conversion rate, channel dependency.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-bold">What We Changed</h3>
          <p class="mt-2 text-sm text-[color:var(--muted)]">3–5 specific interventions, not generic "improved positioning".</p>
        </div>
        <div class="card p-6">
          <h3 class="font-bold">System Built</h3>
          <p class="mt-2 text-sm text-[color:var(--muted)]">Artefacts, processes, rhythms handed over.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-bold">Results</h3>
          <p class="mt-2 text-sm text-[color:var(--muted)]">At 3–6 months. Metrics or qualitative outcomes.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-gradient section">
    <div class="shell text-center">
      <p class="eyebrow justify-center text-white/60">Next step</p>
      <h2 class="text-4xl font-extrabold tracking-[-0.06em] text-white md:text-5xl">
        {siteConfig.bookingLabel}.
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-lg leading-8 text-white/72">
        {siteConfig.bookingNote}
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
          {siteConfig.bookingLabel} →
        </a>
        <a class="button-link-invert" href="/case-studies/">See all cases →</a>
      </div>
    </div>
  </section>
</BaseLayout>
