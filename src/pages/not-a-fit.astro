---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildFaqPageSchema } from "../lib/schema";
import { ctas, fitSignals, siteConfig } from "../site";

const betterRoutes = [
  {
    title: "If you are pre-PMF",
    body: "Work with customers, sales calls, and product evidence before building a growth system. A mentor session may still help you decide what to test next.",
    href: siteConfig.growthMentor,
    cta: "Book a mentoring session"
  },
  {
    title: "If you need junior execution",
    body: "Hire a freelancer or channel specialist with a narrow scope. Fractional CMO support is most useful when the question is what to do, not simply who can do it.",
    href: "/writing/do-customer-research-before-you-buy-more-traffic/",
    cta: "Read the research note"
  },
  {
    title: "If you want a full agency pod",
    body: "We Scale Startups may be the cleaner route if you want a company-side growth system rather than Daniel embedded as the primary operator.",
    href: siteConfig.companyUrl,
    cta: "Visit We Scale Startups"
  }
];

const faq = [
  {
    question: "Why have a not-a-fit page?",
    answer:
      "Because a good fractional CMO engagement needs the right stage, urgency, and decision-making context. This page saves founders time when a different route is more useful."
  },
  {
    question: "Can I still ask Daniel a question if I am not a fit?",
    answer:
      "Yes. A focused mentoring call is often better than a fractional engagement when the company is earlier, the question is narrow, or the team needs a second opinion rather than ongoing leadership."
  }
];
---

<BaseLayout
  description="When Daniel Johnson's fractional CMO work is not the right fit, and what founders should do instead."
  path="/not-a-fit"
  schema={buildFaqPageSchema(faq)}
  title="Not a Fit | Daniel Johnson"
>
  <section class="section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="service-label">Not a Fit</span>
        <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">
          The right answer is not always “hire Daniel.”
        </h1>
        <p class="hero-subcopy text-xl leading-9 md:text-2xl">
          Fractional CMO work is useful when there is traction, urgency, and a real need for senior growth judgement.
          If the timing is wrong, a lighter route will usually be faster and cheaper.
        </p>
        <div class="cta-cluster">
          <a class="button-accent" href={ctas.primary.href}>{ctas.primary.label} →</a>
          <a class="button-link" href={ctas.bottleneck.href}>{ctas.bottleneck.label} →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="grid gap-5 md:grid-cols-2">
        <article class="reveal card p-6 md:p-8 card-accent-border">
          <p class="card-label text-[color:var(--accent)]">Good fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8">
            {fitSignals.bestFor.map((point) => <li class="fit-row fit-row-yes">{point}</li>)}
          </ul>
        </article>
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">Poor fit</p>
          <ul class="mt-4 space-y-3 text-base leading-8 text-[color:var(--muted)]">
            {fitSignals.notFor.map((point) => <li class="fit-row fit-row-no">{point}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="eyebrow justify-center">Better routes</span>
        <h2 class="mt-4 text-4xl font-extrabold tracking-[-0.06em] md:text-5xl">
          If this is not the right engagement, start here instead.
        </h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {betterRoutes.map((route) => (
          <article class="reveal card p-6 md:p-7">
            <h2 class="text-2xl font-bold tracking-[-0.04em]">{route.title}</h2>
            <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{route.body}</p>
            <a class="link-arrow mt-6" href={route.href}>{route.cta}</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
