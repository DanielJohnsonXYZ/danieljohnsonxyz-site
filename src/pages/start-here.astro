---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { buildBreadcrumbSchema, buildHowToSchema } from "../lib/schema";
import { afterYouBookSteps, siteConfig } from "../site";

// One branch per buyer situation. Each card has exactly one CTA so a
// first-time visitor can read top to bottom and leave with a single next step.
const situations = [
  {
    label: "Not sure what's broken",
    you: "Growth has slowed and you can't confidently name the constraint. You want a senior read before spending anything.",
    next: "Start with the free 20-minute Growth Audit. We diagnose the bottleneck together and agree the next move, whatever that turns out to be.",
    cta: "Book a free Growth Audit",
    href: siteConfig.bookingUrl,
    external: true
  },
  {
    label: "Know the problem, need a plan",
    you: "You can name the constraint and want a costed plan, with the first experiments shipped in 2–4 weeks.",
    next: "The Strategy Sprint gives you the plan, the artefacts, and the first wins on the board.",
    cta: "See the Strategy Sprint",
    href: "/strategy-sprint/",
    external: false
  },
  {
    label: "Need ongoing senior ownership",
    you: "You need embedded GTM leadership: someone inside the team running the cadence, the dashboard, and the decisions.",
    next: "The Fractional CMO engagement puts me in the team, building a growth system your people keep after I leave.",
    cta: "See the Fractional CMO scope",
    href: "/fractional-cmo/",
    external: false
  },
  {
    label: "Just need a decision made",
    you: "One recurring GTM question and no appetite for a long engagement. You want a senior second brain on call.",
    next: "Founder Office Hours are focused working sessions with no ongoing commitment.",
    cta: "See Founder Office Hours",
    href: "/founder-office-hours/",
    external: false
  }
];

const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Start here", url: "/start-here" }
  ]),
  buildHowToSchema({
    name: "How to start with Daniel Johnson's fractional CMO site",
    description:
      "Pick the situation that matches yours, follow the single next step for that branch, and know what happens after you book.",
    url: "/start-here/",
    steps: situations.map((item) => ({
      name: item.label,
      text: `${item.you} ${item.next}`,
      url: item.href
    }))
  })
];
---

<BaseLayout
  description="Start here: a two-minute decision path to the right way to work with Daniel Johnson, from a free Growth Audit to Strategy Sprint, Fractional CMO or Office Hours."
  keywords="Daniel Johnson start here, fractional CMO fit, post-PMF founder orientation, growth audit vs sprint"
  path="/start-here/"
  schema={schemas}
  title="Start Here"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <span class="service-label justify-center">Start here · 2-minute orientation</span>
        <h1 class="text-5xl font-extrabold leading-[1.05] tracking-[-0.06em] text-balance md:text-7xl">
          Find the right next step in two minutes.
        </h1>
        <p class="hero-subcopy text-lg leading-8 md:text-xl">
          Four ways to work with me, one decision path. Check the fit below, pick the situation that sounds like yours, and follow the single next step.
        </p>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Who this is for"
        title="Post-PMF founders with a growth plateau."
        intro="I work with Seed to Series B AI and B2B SaaS founders, roughly £1M–£20M ARR, who have paying customers and real demand but whose growth has slowed or still depends on the founder."
      />
      <p class="reveal mx-auto mt-6 max-w-3xl text-base leading-8 text-[color:var(--muted)]">
        If you're pre-PMF or pre-revenue, I'm probably not the right operator yet. Spend the time on customer research and product rather than GTM, starting with
        <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/writing/do-customer-research-before-you-buy-more-traffic/">Do customer research before you buy more traffic</a>.
      </p>
    </div>
  </section>

  <section class="section-space pt-0" aria-labelledby="situations-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="Pick your situation"
        title="Four situations, one next step each."
        intro="Each branch has a single next step. If none of them fit, the Growth Audit is the safe default: it costs nothing and ends with a recommendation either way."
      />

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          situations.map((item) => (
            <article class="reveal card p-6 md:p-7">
              <p class="card-label">{item.label}</p>
              <p class="mt-4 text-base leading-8 font-semibold tracking-[-0.02em]">{item.you}</p>
              <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{item.next}</p>
              <a
                class="link-arrow mt-6"
                href={item.href}
                data-cta={`start-here-${item.label.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}
                rel={item.external ? "noreferrer" : undefined}
                target={item.external ? "_blank" : undefined}
              >
                {item.cta} →
              </a>
            </article>
          ))
        }
      </div>

      <p class="reveal mx-auto mt-8 max-w-3xl text-center text-sm leading-7 text-[color:var(--muted)]">
        Want evidence before you pick? The <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/proof/">proof page</a> has the numbers and sources, and the <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/case-studies/">case studies</a> show the work in full.
      </p>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="eyebrow justify-center text-white/60">What happens after you book</span>
        <h2 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] text-white md:text-5xl">
          Twenty minutes, no pitch.
        </h2>
      </div>
      <div class="mt-10 grid gap-8 md:grid-cols-3">
        {
          afterYouBookSteps.map((step, i) => (
            <article class="reveal">
              <p class="mono text-sm text-white/50">{String(i + 1).padStart(2, "0")}</p>
              <h3 class="mt-3 text-lg font-bold tracking-[-0.03em] text-white">{step.title}</h3>
              <p class="mt-3 text-base leading-7 text-white/72">{step.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
