---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import AnswerEvidenceBlock from "../components/AnswerEvidenceBlock.astro";
import FractionalCmoIntakeThenCalendly from "../components/FractionalCmoIntakeThenCalendly.astro";
import RotatingTextBars from "../components/RotatingTextBars.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {
  buildAggregateRatingSchema,
  buildBreadcrumbSchema,
  buildFaqPageSchema,
  buildServiceSchema,
  buildWebPageSchema
} from "../lib/schema";
import { absoluteUrl, sortByFeaturedThenOrder } from "../lib/utils";
import { ctas, fitSignals, homeServiceLadder, icpFirmographics, roiFrames, siteConfig, whyDaniel } from "../site";

const caseStudyEntries = sortByFeaturedThenOrder(await getCollection("caseStudies"));
const fractionalTestimonials = sortByFeaturedThenOrder(await getCollection("testimonials"))
  .filter((t) => t.data.pageSection === "fractional-cmo" || t.data.category === "Fractional CMO")
  .slice(0, 4);

const sprintTier = homeServiceLadder[1];
const fractionalTier = homeServiceLadder[2];

const painPoints = [
  "The founder is still carrying too many revenue decisions.",
  "Pipeline arrives in bursts, then goes quiet.",
  "The team is busy, but the work isn't compounding.",
  "Paid, content, outbound, and partnerships are active without a clear owner.",
  "Reporting shows activity, not what to scale, stop, or fix."
];

const deliverables = [
  ["GTM clarity", "ICP, positioning, category narrative, customer pain map, and offer tests."],
  ["Acquisition system", "Channel map, experiment backlog, landing-page tests, campaign briefs, budget decisions."],
  ["Operating rhythm", "Weekly growth meeting, decision notes, owner map, stop / scale / fix rules."],
  ["Decision support", "Hiring, agency, tooling, pricing, investor narrative — senior context on the calls that matter."],
  ["Reporting", "Pipeline dashboard, funnel reads, payback notes, a board-ready growth summary."]
];

const modes = [
  ["Embedded Fractional CMO", "1 to 2 days a week. When growth needs a senior owner now."],
  ["Strategy Sprint", "Two to four weeks. When the team needs the plan, artefacts, and decision rules first."],
  ["Founder Office Hours", "A lower-ticket route for founders with one sharp GTM decision in front of them."]
];

const first30 = [
  "Week 1–2: Full GTM audit — ICP, pipeline, funnel, CRM hygiene, live acquisition channels, positioning, and how reporting is read today. Founder, sales, and customer-facing interviews plus 3–5 customer conversations where possible.",
  "Week 2–3: Constraint map — where pipeline, conversion, retention, or decision speed actually breaks (not where the team is busiest). Agree the 90-day priorities and the weekly operating rhythm: scorecard, owners, stop/scale/fix rules.",
  "Week 3–4: First fixes in market — homepage or demo narrative tests, campaign or outbound brief, reporting view, or channel test — sequenced from the bottleneck, not from channel noise.",
  "Ongoing: Weekly growth meeting, experiment backlog hygiene, and agency or contractor steering so work compounds instead of resetting every Monday."
];

const plan = [
  ["Days 1-30", "Diagnose the bottleneck, clean up reporting, decide the first two growth priorities, remove obvious friction."],
  ["Days 31-60", "Run focused acquisition and conversion tests, sharpen positioning, set the team rhythm."],
  ["Days 61-90", "Scale what works, stop weak activity, document the operating system, decide hiring or handoff needs."]
];

const week = [
  ["Monday", "Review pipeline, channel numbers, and founder priorities."],
  ["Tuesday", "Customer or sales-call review, messaging edits, experiment planning."],
  ["Wednesday", "Campaign, landing page, or outbound build with the team or agency."],
  ["Thursday", "Growth meeting: decisions, blockers, next tests, owners."],
  ["Friday", "Short written update: what changed, what to scale, what to stop, what needs founder input."]
];

const pricing = [
  {
    name: "Strategy Sprint",
    price: "From £6k",
    cadence: "2–4 week engagement",
    body: "Diagnose the bottleneck, set 90-day priorities, ship the first artefacts.",
    primary: false
  },
  {
    name: "Fractional CMO",
    price: "From £7.5k",
    cadence: "/ month · 3-month minimum",
    body: "Embedded senior ownership 1 day a week. GTM priorities, reporting, weekly rhythm.",
    primary: true
  },
  {
    name: "Fractional CMO Plus",
    price: "From £12k",
    cadence: "/ month · 3-month minimum",
    body: "Deeper operating support, agency management, and faster execution. Best when the team needs ~2 days a week of senior ownership.",
    primary: false
  }
];

const fit = [...fitSignals.bestFor];

const notFit = [...fitSignals.notFor];

const faq = [
  {
    question: "When should a startup hire a fractional CMO?",
    answer:
      "The useful window is after product-market fit, when demand is real but pipeline is inconsistent, the founder is still carrying revenue, and the company needs senior GTM decisions before or alongside a full-time hire."
  },
  {
    question: "How is this different from hiring an agency or a junior marketer?",
    answer:
      "Agencies execute a defined channel scope — paid, SEO, content. They don't own the full GTM system or make senior calls. Junior marketers need your direction, so you stay the CMO. A fractional CMO gives you senior operator judgement, embedded ownership, and a system the team can run after."
  },
  {
    question: "How long does an engagement last?",
    answer:
      "Most fractional CMO engagements run 3 to 9 months. The first 90 days create the diagnosis, operating rhythm, and first growth system. After that, we either scale, hand off, or move to a lighter advisory rhythm."
  },
  {
    question: "Do you replace an agency or internal marketer?",
    answer:
      "Usually not. I often work alongside founders, marketers, agencies, and sales teams. The role is to set priorities, make senior decisions, improve the system, and help the people already doing the work produce better outcomes."
  },
  {
    question: "What happens on the first call?",
    answer:
      "20 minutes. No pitch. We map the current growth bottleneck, your stage, the team around you, what's already been tried, and whether fractional CMO support is the right shape. If it's not, you'll leave with a clearer next step anyway."
  },
  {
    question: "What does AI-assisted GTM mean here?",
    answer:
      "AI speeds up customer research synthesis, competitor reviews, message tests, content workflows, and reporting. It doesn't replace judgement. It reduces manual drag so senior decisions happen faster."
  }
];

const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Fractional CMO", url: "/fractional-cmo/" }
  ]),
  buildFaqPageSchema(faq),
  buildAggregateRatingSchema(),
  buildServiceSchema({
    name: "Fractional CMO for Seed to Series B AI & B2B SaaS",
    description:
      "Embedded senior GTM leadership for post-PMF AI and B2B SaaS startups. Predictable pipeline, sharper positioning, senior growth judgement — without a £150k+ full-time hire.",
    url: absoluteUrl("/fractional-cmo/"),
    serviceType: "Fractional CMO",
    offers: [
      { name: "Strategy Sprint", description: "2–4 weeks. Diagnose the bottleneck, set 90-day priorities, ship first artefacts.", price: "6000", billingIncrement: "per engagement" },
      { name: "Fractional CMO", description: "3-month minimum. Embedded senior ownership 1 day a week.", price: "7500", billingIncrement: "per month" },
      { name: "Fractional CMO Plus", description: "Deeper operating support, agency management, faster execution.", price: "12000", billingIncrement: "per month" }
    ]
  }),
  buildWebPageSchema({
    name: "Fractional CMO for Founder-Led AI & B2B SaaS Startups",
    description:
      "Embedded senior growth leadership for post-PMF founders who need predictable pipeline and GTM decision ownership.",
    url: absoluteUrl("/fractional-cmo/")
  })
];
---

<BaseLayout
  description="Fractional CMO for Seed–Series B AI & B2B SaaS founders: embedded senior leadership on pipeline, positioning & GTM—without the £150k full-time hire."
  keywords="fractional CMO UK, AI startup GTM, B2B SaaS marketing leadership, Seed Series B growth operator, embedded CMO"
  path="/fractional-cmo/"
  schema={schemas}
  stickyCta={false}
  title="Fractional CMO for Founder-Led AI & B2B SaaS Startups | Daniel Johnson"
>
  <section class="hero-section section-space conversion-hero">
    <div class="shell">
      <div class="reveal grid gap-10 lg:grid-cols-[1fr_0.72fr] lg:items-center">
        <div class="space-y-6">
          <span class="service-label">Primary Offer · Fractional CMO</span>
          <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">
            Senior growth leadership before growth becomes a founder bottleneck.
          </h1>
          <p class="hero-subcopy conversion-subcopy text-xl leading-9 md:text-2xl">
            I embed with founder-led AI and B2B SaaS startups to build predictable pipeline, sharpen positioning, clean up reporting, and help the team decide what to scale, stop, or fix.
          </p>

          <!-- Booking trust copy surfaced EARLY so objections to "book a call" get answered before scroll. -->
          <div class="rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-4 text-sm leading-6 text-[color:var(--muted)]">
            <strong class="block font-semibold text-[color:var(--ink)]">What happens on the first call</strong>
            20 minutes. No pitch. No deck. We diagnose the bottleneck and decide together whether working together makes sense — or I'll point you to the right operator, agency, or mentor if it doesn't.
          </div>

          <div class="cta-row pt-2">
            <a class="button-accent" href="#book" data-cta="fractional-hero-primary">
              {ctas.primary.label} →
            </a>
            <a class="button-secondary" href="#faq" data-cta="fractional-hero-faq">
              Read FAQs first →
            </a>
          </div>
          <AnswerEvidenceBlock
            title="Direct answer + proof"
            answer="A fractional CMO is highest leverage when the bottleneck is senior GTM judgement, not channel capacity."
            evidence={[
              "Founders usually arrive with active channels but no stable decision system.",
              "Weekly ownership and reporting cadence convert activity into scale/stop/fix decisions.",
              "Bridge model (fractional first, full-time later) reduces mis-hire risk."
            ]}
            provenance={[
              "Source set: published case studies and recurring growth-audit diagnosis patterns.",
              "Cross-reference: /resources/fractional-cmo-vs-agency/ and /resources/fractional-cmo-vs-full-time-cmo/."
            ]}
          />
        </div>
        <aside class="card p-6 md:p-8">
          <p class="card-label">You're a fit if…</p>
          <ul class="mt-5 scan-list">
            {icpFirmographics.fitIf.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <div class="mt-6 rounded-2xl bg-[color:var(--surface-dim)] p-5">
            <strong class="block text-lg tracking-[-0.03em]">Typical first outcome</strong>
            <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">
              A clear 90-day growth plan, weekly dashboard, owner map, and the first acquisition or conversion tests in motion.
            </p>
            <p class="mt-3 text-sm leading-6">
              <a class="font-semibold text-[color:var(--accent)] underline underline-offset-4 hover:text-[color:var(--ink)]" href="/testimonials/" data-cta="fractional-sidebar-testimonials">
                Named client outcomes (metrics) →
              </a>
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="What I take off your plate"
        title="Founder-bottleneck work that needs a senior owner — not another pair of hands."
        intro="You stay on strategy and the calls only you should take. I carry the operating load that keeps GTM from stalling: priorities, sequencing, reporting, and honest kill/scale decisions."
      />
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          [
            "Weekly bottleneck read — what actually constrains pipeline this week",
            "ICP, positioning, and narrative alignment across site, outbound, and sales",
            "Experiment backlog with owners — fewer random tests, clearer learning",
            "Channel and agency steering — scope, briefs, and accountability",
            "Reporting the team actually uses — conversion, payback, stop/scale/fix",
            "Hiring and vendor context — what role to hire, what to keep fractional"
          ].map((item) => <article class="card p-5 text-sm font-semibold leading-6 tracking-[-0.02em]">{item}</article>)
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="The pain"
        title="Your team is busy, but growth still doesn't feel repeatable."
        intro="The problem is rarely effort. It's unclear priorities, weak signal, and too many growth calls living in the founder's head."
      />
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
        {painPoints.map((item) => <article class="card p-5 text-sm font-semibold leading-6 tracking-[-0.02em]">{item}</article>)}
      </div>
      <div class="mt-8">
        <RotatingTextBars
          rows={[
            ["Founder bottleneck", "Pipeline drift", "Positioning fog", "Channel noise", "Slow decisions", "Weak signal"],
            ["Constraint map", "Weekly rhythm", "Sharper ICP", "Campaign briefs", "Conversion fixes", "Board-ready reporting"]
          ]}
        />
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Related pages" title="Internal path for deeper evaluation" />
      <ul class="mt-6 grid gap-2 text-sm leading-7 text-[color:var(--muted)]">
        <li><a href="/resources/fractional-cmo-vs-agency/">Fractional CMO vs agency</a></li>
        <li><a href="/resources/fractional-cmo-vs-full-time-cmo/">Fractional CMO vs full-time CMO</a></li>
        <li><a href="/resources/faq/">Founder FAQ</a></li>
        <li><a href="/case-studies/">Case studies with named outcomes</a></li>
      </ul>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="What you get"
        title="A growth operating system your team can actually run."
        intro="Concrete artefacts, a weekly rhythm, and senior decision support across positioning, acquisition, conversion, reporting, and team execution."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
        {deliverables.map(([title, body]) => (
          <article class="card p-6">
            <h2 class="text-xl font-extrabold tracking-[-0.04em]">{title}</h2>
            <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Engagement modes"
        title="Start with the level of ownership the company needs."
        intro="Embedded leadership first. Lighter support only where it fits."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {modes.map(([title, body], index) => (
          <article class={index === 0 ? "card p-7 ring-1 ring-white/20" : "card p-7"}>
            <p class="card-label">{index === 0 ? "Recommended" : "Secondary"}</p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.05em] text-white">{title}</h2>
            <p class="mt-4 leading-7 text-white/70">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell grid gap-10 lg:grid-cols-[0.85fr_1fr]">
      <div>
        <span class="service-label">First 30 days</span>
        <h2 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] md:text-5xl">
          The first month is about finding the real constraint.
        </h2>
      </div>
      <ol class="grid gap-3">
        {first30.map((item, index) => (
          <li class="card flex gap-4 p-5">
            <span class="mono text-sm text-[color:var(--subtle)]">{String(index + 1).padStart(2, "0")}</span>
            <p class="font-semibold leading-7 tracking-[-0.02em]">{item}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="grid gap-6 lg:grid-cols-3">
        {plan.map(([title, body]) => (
          <article class="card p-7">
            <p class="card-label">{title}</p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.05em]">{title}</h2>
            <p class="mt-4 leading-8 text-[color:var(--muted)]">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Sample week" title="Enough structure to move fast. Enough space to make good decisions." />
      <div class="mt-8 overflow-hidden rounded-[1.5rem] border border-[color:var(--line)] bg-white">
        {week.map(([day, body]) => (
          <div class="grid gap-3 border-b border-[color:var(--line)] p-5 last:border-b-0 md:grid-cols-[9rem_1fr]">
            <strong>{day}</strong>
            <p class="text-[color:var(--muted)]">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ — moved up so objections get answered BEFORE the pricing section -->
  <section class="section-space pt-0" id="faq" aria-labelledby="faq-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="FAQ"
        title="Questions founders ask before a first call."
        intro="Answers to the six questions that come up most. The first is open by default — scroll down to book, or keep reading."
      />
      <div class="faq-stack mt-8 mx-auto max-w-3xl">
        {faq.map((item, index) => (
          <details class="faq-item" open={index === 0}>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Wide comparison: agency vs freelancer vs junior vs full-time vs consultant vs Daniel -->
  <section class="section-space pt-0" id="why-daniel" aria-labelledby="why-daniel-heading">
    <div class="shell">
      <SectionHeader eyebrow="Why Daniel" title="Where a fractional CMO fits — and where the other five options don't." />
      <p class="reveal mt-4 text-center text-sm leading-7 text-[color:var(--muted)]">
        Want a deeper read on the closest two? <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/resources/fractional-cmo-vs-agency/">Fractional CMO vs. Agency</a> · <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/resources/fractional-cmo-vs-full-time-cmo/">Fractional CMO vs. Full-time CMO</a> · <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/writing/the-right-window-for-a-fractional-cmo/">The right window for a fractional CMO</a>
      </p>
      <div class="mt-8 overflow-x-auto rounded-[1.5rem] border border-[color:var(--line)] bg-white">
        <table class="w-full min-w-[820px] text-left text-sm">
          <thead class="bg-[color:var(--surface-dim)]">
            <tr>
              <th class="p-4">Option</th>
              <th class="p-4">Typical cost</th>
              <th class="p-4">Who owns it</th>
              <th class="p-4">The problem</th>
            </tr>
          </thead>
          <tbody>
            {whyDaniel.map((row) => (
              <tr class:list={["border-t border-[color:var(--line)]", row.highlight && "bg-[color:var(--surface-dim)]"]}>
                <td class={`p-4 align-top leading-6 ${row.highlight ? "font-bold text-[color:var(--ink)]" : "font-bold text-[color:var(--ink)]"}`}>{row.option}</td>
                <td class="p-4 align-top leading-6 text-[color:var(--muted)]">{row.cost}</td>
                <td class="p-4 align-top leading-6 text-[color:var(--muted)]">{row.owner}</td>
                <td class="p-4 align-top leading-6 text-[color:var(--muted)]">{row.problem}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Pricing"
        title="Clear starting points before scope gets specific."
        intro="Three shapes. Pick the closest fit — we refine on the call. UK benchmark framing and what moves price: see the dedicated cost page."
      />
      <p class="reveal mt-4 text-center text-sm leading-7 text-[color:var(--muted)]">
        <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/resources/fractional-cmo-cost-uk/" data-cta="fractional-pricing-cost-uk">
          Fractional CMO cost (UK) — benchmarks & FAQ →
        </a>
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {pricing.map((tier) => (
          <article class:list={["card p-7", tier.primary && "ring-2 ring-[color:var(--accent)]"]}>
            <p class="card-label">{tier.primary ? "Core engagement" : "Option"}</p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.05em]">{tier.name}</h2>
            <div class="mt-4 flex flex-wrap items-baseline gap-2">
              <span class="text-3xl font-extrabold tracking-[-0.06em]">{tier.price}</span>
              <span class="text-sm text-[color:var(--muted)]">· {tier.cadence}</span>
            </div>
            <p class="mt-4 leading-7 text-[color:var(--muted)]">{tier.body}</p>
          </article>
        ))}
      </div>

      <!-- ROI framing — speaks to the founder's "can I justify this?" moment. -->
      <div class="mt-8 rounded-[1.5rem] border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-6 md:p-8">
        <p class="card-label">Put in context</p>
        <ul class="mt-4 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
          {roiFrames.map((frame) => (
            <li class="flex items-start gap-2 text-base leading-7 text-[color:var(--ink)]">
              <span class="mt-1 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[color:var(--accent)]" aria-hidden="true"></span>
              <span class="font-semibold tracking-[-0.02em]">{frame}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell grid gap-6 md:grid-cols-2">
      <article class="card p-7">
        <p class="card-label">Good fit</p>
        <ul class="mt-5 scan-list">{fit.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="card p-7">
        <p class="card-label">Not a fit</p>
        <ul class="mt-5 scan-list">{notFit.map((item) => <li>{item}</li>)}</ul>
      </article>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Case studies" title="Recent engagement shapes — bottleneck, approach, outcome." />
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          caseStudyEntries.slice(0, 4).map((item) => (
            <article class="card p-6 md:p-7">
              <div class="flex flex-wrap gap-2">
                <span class="chip">{item.data.engagementMode}</span>
                <span class="chip">{item.data.sector}</span>
              </div>
              <h2 class="mt-4 text-xl font-bold tracking-[-0.04em]">
                <a class="underline-offset-4 hover:text-[color:var(--accent)]" href={`/case-studies/${item.id}/`}>
                  {item.data.title}
                </a>
              </h2>
              <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{item.data.excerpt}</p>
              <a class="link-arrow mt-5 inline-flex" href={`/case-studies/${item.id}/`}>
                Read case study →
              </a>
            </article>
          ))
        }
      </div>
      <p class="reveal mt-8 text-center">
        <a class="link-arrow" href="/case-studies/">All case studies →</a>
      </p>
    </div>
  </section>

  {
    fractionalTestimonials.length > 0 && (
      <section class="section-space pt-0">
        <div class="shell">
          <SectionHeader
            eyebrow="Fractional CMO"
            title="What clients say about embedded GTM work."
            intro="Named feedback from fractional and advisory-shaped engagements — see /testimonials/ for the full set."
          />
          <div class="mt-8 grid gap-5 md:grid-cols-2">
            {fractionalTestimonials.map((t) => (
              <figure class="card p-6 md:p-7">
                <p class="card-label text-[color:var(--accent)]">{t.data.outcomeMetric}</p>
                <blockquote>
                  <p class="mt-3 text-base font-medium leading-7">&ldquo;{t.data.quote}&rdquo;</p>
                </blockquote>
                <figcaption class="mt-4 border-t border-[color:var(--line)] pt-4 text-sm text-[color:var(--muted)]">
                  <span class="font-semibold text-[color:var(--ink)]">{t.data.name}</span>
                  {t.data.role ? ` · ${t.data.role}` : ""}
                  {t.data.organisation ? ` · ${t.data.organisation}` : ""}
                </figcaption>
              </figure>
            ))}
          </div>
          <p class="reveal mt-6 text-center">
            <a class="link-arrow" href="/testimonials/">
              Full testimonials →
            </a>
          </p>
        </div>
      </section>
    )
  }

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Strategy Sprint vs Fractional CMO"
        title="Same operator — different commitment shape."
        intro="Most founders either need a fixed-scope sprint first, or already know they need embedded ownership. Here's how the two compare at a glance."
      />
      <div class="mt-8 overflow-x-auto rounded-[1.5rem] border border-[color:var(--line)] bg-white">
        <table class="w-full min-w-[640px] text-left text-sm">
          <thead class="bg-[color:var(--surface-dim)]">
            <tr>
              <th class="p-4" />
              <th class="p-4">{sprintTier.heading}</th>
              <th class="p-4">{fractionalTier.heading}</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-[color:var(--line)]">
              <td class="p-4 font-semibold">Investment</td>
              <td class="p-4 text-[color:var(--muted)]">
                {sprintTier.price} · {sprintTier.cadence}
              </td>
              <td class="p-4 text-[color:var(--muted)]">
                {fractionalTier.price} · {fractionalTier.cadence}
              </td>
            </tr>
            <tr class="border-t border-[color:var(--line)]">
              <td class="p-4 font-semibold">Best for</td>
              <td class="p-4 text-[color:var(--muted)]">{sprintTier.bestFor}</td>
              <td class="p-4 text-[color:var(--muted)]">{fractionalTier.bestFor}</td>
            </tr>
            <tr class="border-t border-[color:var(--line)]">
              <td class="p-4 font-semibold">Outcome</td>
              <td class="p-4 text-[color:var(--muted)]">{sprintTier.outcome}</td>
              <td class="p-4 text-[color:var(--muted)]">{fractionalTier.outcome}</td>
            </tr>
            <tr class="border-t border-[color:var(--line)]">
              <td class="p-4 font-semibold">Detail</td>
              <td class="p-4 text-[color:var(--muted)]">{sprintTier.body}</td>
              <td class="p-4 text-[color:var(--muted)]">{fractionalTier.body}</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="reveal mt-6 text-center text-sm text-[color:var(--muted)]">
        Not sure which fits? Start with a{" "}
        <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4" href="/growth-audit/">
          20-min Growth Audit
        </a>{" "}
        — we'll name the bottleneck and the right shape.
      </p>
    </div>
  </section>

  <section class="section-space pt-0" id="book">
    <div class="shell">
      <div class="grid gap-8 lg:grid-cols-[0.72fr_1fr] lg:items-center">
        <div class="space-y-5">
          <span class="service-label">Next step</span>
          <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] md:text-5xl">
            {ctas.primary.label}
          </h2>
          <p class="text-lg leading-8 text-[color:var(--muted)]">{siteConfig.bookingNote}</p>
        </div>
        <FractionalCmoIntakeThenCalendly />
      </div>
    </div>
  </section>
</BaseLayout>
