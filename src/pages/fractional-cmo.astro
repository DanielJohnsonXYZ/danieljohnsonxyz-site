---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { buildAggregateRatingSchema, buildBreadcrumbSchema, buildFaqPageSchema, buildServiceSchema } from "../lib/schema";
import { absoluteUrl } from "../lib/utils";
import { ctas, roiFrames, siteConfig, whyDaniel } from "../site";

const painPoints = [
  "The founder is still carrying too many revenue decisions.",
  "Pipeline arrives in bursts, then goes quiet.",
  "The team is busy, but the work isn't compounding.",
  "Paid, content, outbound, and partnerships are active without a clear owner.",
  "Reporting shows activity, not what to scale, stop, or fix."
];

const deliverables = [
  ["GTM clarity", "ICP, positioning, category narrative, customer pain map, and offer tests."],
  ["Acquisition system", "Channel map, experiment backlog, landing-page tests, campaign briefs, budget decisions."],
  ["Operating rhythm", "Weekly growth meeting, decision notes, owner map, stop / scale / fix rules."],
  ["Decision support", "Hiring, agency, tooling, pricing, investor narrative — senior context on the calls that matter."],
  ["Reporting", "Pipeline dashboard, funnel reads, payback notes, a board-ready growth summary."]
];

const modes = [
  ["Embedded Fractional CMO", "1 to 2 days a week. When growth needs a senior owner now."],
  ["Strategy Sprint", "Two to four weeks. When the team needs the plan, artefacts, and decision rules first."],
  ["Founder Office Hours", "A lower-ticket route for founders with one sharp GTM decision in front of them."]
];

const first30 = [
  "Audit ICP, pipeline, funnel, CRM, acquisition channels, positioning, and current reporting.",
  "Interview founder, sales, customer-facing team, and selected customers.",
  "Build a constraint map: what's blocking pipeline, conversion, retention, or decision speed.",
  "Agree the 90-day growth priorities and weekly operating rhythm.",
  "Ship first fixes: homepage messaging, campaign brief, reporting view, or channel test depending on the bottleneck."
];

const plan = [
  ["Days 1-30", "Diagnose the bottleneck, clean up reporting, decide the first two growth priorities, remove obvious friction."],
  ["Days 31-60", "Run focused acquisition and conversion tests, sharpen positioning, set the team rhythm."],
  ["Days 61-90", "Scale what works, stop weak activity, document the operating system, decide hiring or handoff needs."]
];

const week = [
  ["Monday", "Review pipeline, channel numbers, and founder priorities."],
  ["Tuesday", "Customer or sales-call review, messaging edits, experiment planning."],
  ["Wednesday", "Campaign, landing page, or outbound build with the team or agency."],
  ["Thursday", "Growth meeting: decisions, blockers, next tests, owners."],
  ["Friday", "Short written update: what changed, what to scale, what to stop, what needs founder input."]
];

const pricing = [
  {
    name: "Strategy Sprint",
    price: "From £6k",
    cadence: "2–4 week engagement",
    body: "Diagnose the bottleneck, set 90-day priorities, ship the first artefacts.",
    primary: false
  },
  {
    name: "Fractional CMO",
    price: "From £7.5k",
    cadence: "/ month · 3-month minimum",
    body: "Embedded senior ownership 1 day a week. GTM priorities, reporting, weekly rhythm.",
    primary: true
  },
  {
    name: "Fractional CMO Plus",
    price: "From £12k",
    cadence: "/ month · 3-month minimum",
    body: "Deeper operating support, agency management, and faster execution. Best when the team needs ~2 days a week of senior ownership.",
    primary: false
  }
];

const fit = [
  "£1m to £10m ARR or clear post-PMF traction.",
  "Founder-led sales or marketing is now a bottleneck.",
  "The team needs clearer priorities and senior growth judgement.",
  "You want fewer random experiments and more consistent pipeline."
];

const notFit = [
  "Pre-revenue teams still searching for the problem.",
  "Companies looking for a cheap ads agency.",
  "Teams that want reports but won't make hard priority calls.",
  "Founders who want growth delegated without giving access to customers, data, or decisions."
];

const faq = [
  {
    question: "When should a startup hire a fractional CMO?",
    answer:
      "The useful window is after product-market fit, when demand is real but pipeline is inconsistent, the founder is still carrying revenue, and the company needs senior GTM decisions before or alongside a full-time hire."
  },
  {
    question: "How is this different from hiring an agency or a junior marketer?",
    answer:
      "Agencies execute a defined channel scope — paid, SEO, content. They don't own the full GTM system or make senior calls. Junior marketers need your direction, so you stay the CMO. A fractional CMO gives you senior operator judgement, embedded ownership, and a system the team can run after."
  },
  {
    question: "How long does an engagement last?",
    answer:
      "Most fractional CMO engagements run 3 to 9 months. The first 90 days create the diagnosis, operating rhythm, and first growth system. After that, we either scale, hand off, or move to a lighter advisory rhythm."
  },
  {
    question: "Do you replace an agency or internal marketer?",
    answer:
      "Usually not. I often work alongside founders, marketers, agencies, and sales teams. The role is to set priorities, make senior decisions, improve the system, and help the people already doing the work produce better outcomes."
  },
  {
    question: "What happens on the first call?",
    answer:
      "30 minutes. No pitch. We map the current growth bottleneck, your stage, the team around you, what's already been tried, and whether fractional CMO support is the right shape. If it's not, you'll leave with a clearer next step anyway."
  },
  {
    question: "What does AI-assisted GTM mean here?",
    answer:
      "AI speeds up customer research synthesis, competitor reviews, message tests, content workflows, and reporting. It doesn't replace judgement. It reduces manual drag so senior decisions happen faster."
  }
];

const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Fractional CMO", url: "/fractional-cmo/" }
  ]),
  buildFaqPageSchema(faq),
  buildAggregateRatingSchema(),
  buildServiceSchema({
    name: "Fractional CMO for Seed to Series B AI & B2B SaaS",
    description:
      "Embedded senior GTM leadership for post-PMF AI and B2B SaaS startups. Predictable pipeline, sharper positioning, senior growth judgement — without a £150k+ full-time hire.",
    url: absoluteUrl("/fractional-cmo/"),
    serviceType: "Fractional CMO",
    offers: [
      { name: "Strategy Sprint", description: "2–4 weeks. Diagnose the bottleneck, set 90-day priorities, ship first artefacts.", price: "6000", billingIncrement: "per engagement" },
      { name: "Fractional CMO", description: "3-month minimum. Embedded senior ownership 1 day a week.", price: "7500", billingIncrement: "per month" },
      { name: "Fractional CMO Plus", description: "Deeper operating support, agency management, faster execution.", price: "12000", billingIncrement: "per month" }
    ]
  })
];
---

<BaseLayout
  description="Fractional CMO for Seed to Series B AI and B2B SaaS founders. Embedded senior growth leadership, predictable pipeline, sharper positioning — without a £150k full-time hire."
  keywords="fractional CMO UK, AI startup GTM, B2B SaaS marketing leadership, Seed Series B growth operator, embedded CMO"
  path="/fractional-cmo/"
  schema={schemas}
  stickyCta={false}
  title="Fractional CMO for Founder-Led AI & B2B SaaS Startups | Daniel Johnson"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal grid gap-10 lg:grid-cols-[1fr_0.72fr] lg:items-center">
        <div class="space-y-6">
          <span class="service-label">Primary Offer · Fractional CMO</span>
          <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">
            Senior growth leadership before growth becomes a founder bottleneck.
          </h1>
          <p class="hero-subcopy text-xl leading-9 md:text-2xl">
            I embed with founder-led AI and B2B SaaS startups to build predictable pipeline, sharpen positioning, clean up reporting, and help the team decide what to scale, stop, or fix.
          </p>

          <!-- Booking trust copy surfaced EARLY so objections to "book a call" get answered before scroll. -->
          <div class="rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-4 text-sm leading-6 text-[color:var(--muted)]">
            <strong class="block font-semibold text-[color:var(--ink)]">What happens on the first call</strong>
            30 minutes. No pitch. No deck. We diagnose the bottleneck and decide together whether working together makes sense — or I'll point you to the right operator, agency, or mentor if it doesn't.
          </div>

          <div class="flex flex-wrap items-center gap-3 pt-2">
            <a class="button-accent" href={ctas.primary.href} rel="noreferrer" target="_blank" data-cta="fractional-hero-primary">
              {ctas.primary.label} →
            </a>
            <a class="button-link" href="#faq" data-cta="fractional-hero-faq">
              Read FAQs first →
            </a>
          </div>
        </div>
        <aside class="card p-6 md:p-8">
          <p class="card-label">Best for</p>
          <ul class="mt-5 scan-list">
            <li>£1m to £10m ARR or clear post-PMF traction</li>
            <li>Founder-led, with inconsistent pipeline</li>
            <li>Senior GTM decisions needed now</li>
            <li>Not ready for a £150k+ full-time CMO hire</li>
          </ul>
          <div class="mt-6 rounded-2xl bg-[color:var(--surface-dim)] p-5">
            <strong class="block text-lg tracking-[-0.03em]">Typical first outcome</strong>
            <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">
              A clear 90-day growth plan, weekly dashboard, owner map, and the first acquisition or conversion tests in motion.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="The pain"
        title="Your team is busy, but growth still doesn't feel repeatable."
        intro="The problem is rarely effort. It's unclear priorities, weak signal, and too many growth calls living in the founder's head."
      />
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
        {painPoints.map((item) => <article class="card p-5 text-sm font-semibold leading-6 tracking-[-0.02em]">{item}</article>)}
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="What you get"
        title="A growth operating system your team can actually run."
        intro="Concrete artefacts, a weekly rhythm, and senior decision support across positioning, acquisition, conversion, reporting, and team execution."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
        {deliverables.map(([title, body]) => (
          <article class="card p-6">
            <h2 class="text-xl font-extrabold tracking-[-0.04em]">{title}</h2>
            <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Engagement modes"
        title="Start with the level of ownership the company needs."
        intro="Embedded leadership first. Lighter support only where it fits."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {modes.map(([title, body], index) => (
          <article class={index === 0 ? "card p-7 ring-1 ring-white/20" : "card p-7"}>
            <p class="card-label">{index === 0 ? "Recommended" : "Secondary"}</p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.05em] text-white">{title}</h2>
            <p class="mt-4 leading-7 text-white/70">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell grid gap-10 lg:grid-cols-[0.85fr_1fr]">
      <div>
        <span class="service-label">First 30 days</span>
        <h2 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] md:text-5xl">
          The first month is about finding the real constraint.
        </h2>
      </div>
      <ol class="grid gap-3">
        {first30.map((item, index) => (
          <li class="card flex gap-4 p-5">
            <span class="mono text-sm text-[color:var(--subtle)]">{String(index + 1).padStart(2, "0")}</span>
            <p class="font-semibold leading-7 tracking-[-0.02em]">{item}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="grid gap-6 lg:grid-cols-3">
        {plan.map(([title, body]) => (
          <article class="card p-7">
            <p class="card-label">{title}</p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.05em]">{title}</h2>
            <p class="mt-4 leading-8 text-[color:var(--muted)]">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Sample week" title="Enough structure to move fast. Enough space to make good decisions." />
      <div class="mt-8 overflow-hidden rounded-[1.5rem] border border-[color:var(--line)] bg-white">
        {week.map(([day, body]) => (
          <div class="grid gap-3 border-b border-[color:var(--line)] p-5 last:border-b-0 md:grid-cols-[9rem_1fr]">
            <strong>{day}</strong>
            <p class="text-[color:var(--muted)]">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ — moved up so objections get answered BEFORE the pricing section -->
  <section class="section-space pt-0" id="faq" aria-labelledby="faq-heading">
    <div class="shell">
      <SectionHeader
        eyebrow="FAQ"
        title="Questions founders ask before a first call."
        intro="Answers to the six questions that come up most. The first is open by default — scroll down to book, or keep reading."
      />
      <div class="faq-stack mt-8 mx-auto max-w-3xl">
        {faq.map((item, index) => (
          <details class="faq-item" open={index === 0}>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Wide comparison: agency vs freelancer vs junior vs full-time vs consultant vs Daniel -->
  <section class="section-space pt-0" id="why-daniel" aria-labelledby="why-daniel-heading">
    <div class="shell">
      <SectionHeader eyebrow="Why Daniel" title="Where a fractional CMO fits — and where the other five options don't." />
      <p class="reveal mt-4 text-center text-sm leading-7 text-[color:var(--muted)]">
        Want a deeper read on the closest two? <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/fractional-cmo-vs-agency/">Fractional CMO vs. Agency</a> · <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/fractional-cmo-vs-full-time-cmo/">Fractional CMO vs. Full-time CMO</a>
      </p>
      <div class="mt-8 overflow-x-auto rounded-[1.5rem] border border-[color:var(--line)] bg-white">
        <table class="w-full min-w-[820px] text-left text-sm">
          <thead class="bg-[color:var(--surface-dim)]">
            <tr>
              <th class="p-4">Option</th>
              <th class="p-4">Typical cost</th>
              <th class="p-4">Who owns it</th>
              <th class="p-4">The problem</th>
            </tr>
          </thead>
          <tbody>
            {whyDaniel.map((row) => (
              <tr class:list={["border-t border-[color:var(--line)]", row.highlight && "bg-[color:var(--surface-dim)]"]}>
                <td class={`p-4 align-top leading-6 ${row.highlight ? "font-bold text-[color:var(--ink)]" : "font-bold text-[color:var(--ink)]"}`}>{row.option}</td>
                <td class="p-4 align-top leading-6 text-[color:var(--muted)]">{row.cost}</td>
                <td class="p-4 align-top leading-6 text-[color:var(--muted)]">{row.owner}</td>
                <td class="p-4 align-top leading-6 text-[color:var(--muted)]">{row.problem}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Pricing" title="Clear starting points before scope gets specific." intro="Three shapes. Pick the closest fit — we refine on the call." />

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {pricing.map((tier) => (
          <article class:list={["card p-7", tier.primary && "ring-2 ring-[color:var(--accent)]"]}>
            <p class="card-label">{tier.primary ? "Core engagement" : "Option"}</p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.05em]">{tier.name}</h2>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-3xl font-extrabold tracking-[-0.06em]">{tier.price}</span>
              <span class="text-sm text-[color:var(--muted)]">{tier.cadence}</span>
            </div>
            <p class="mt-4 leading-7 text-[color:var(--muted)]">{tier.body}</p>
          </article>
        ))}
      </div>

      <!-- ROI framing — speaks to the founder's "can I justify this?" moment. -->
      <div class="mt-8 rounded-[1.5rem] border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-6 md:p-8">
        <p class="card-label">Put in context</p>
        <ul class="mt-4 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
          {roiFrames.map((frame) => (
            <li class="flex items-start gap-2 text-base leading-7 text-[color:var(--ink)]">
              <span class="mt-1 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[color:var(--accent)]" aria-hidden="true"></span>
              <span class="font-semibold tracking-[-0.02em]">{frame}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell grid gap-6 md:grid-cols-2">
      <article class="card p-7">
        <p class="card-label">Good fit</p>
        <ul class="mt-5 scan-list">{fit.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="card p-7">
        <p class="card-label">Not a fit</p>
        <ul class="mt-5 scan-list">{notFit.map((item) => <li>{item}</li>)}</ul>
      </article>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <article class="card grid gap-8 p-7 md:grid-cols-[0.8fr_1fr] md:p-10">
        <div>
          <p class="card-label">Featured engagement</p>
          <h2 class="mt-3 text-3xl font-extrabold tracking-[-0.05em]">6× app downloads from a 2k/mo baseline.</h2>
        </div>
        <div class="space-y-4 text-[color:var(--muted)]">
          <p><strong class="text-[color:var(--ink)]">Situation:</strong> Growth had activity but no clear acquisition system.</p>
          <p><strong class="text-[color:var(--ink)]">Rebuild:</strong> Positioning, channel mix, landing-page flow, lifecycle messaging, and reporting.</p>
          <p><strong class="text-[color:var(--ink)]">Outcome:</strong> Downloads grew from roughly 2k/month to 12k+/month over six months.</p>
          <a class="button-link" href="/case-studies/fractional-cmo-seed-b2b-saas/">Read the case study →</a>
        </div>
      </article>
    </div>
  </section>

  <section class="section-space pt-0" id="book">
    <div class="shell">
      <div class="grid gap-8 lg:grid-cols-[0.72fr_1fr] lg:items-center">
        <div class="space-y-5">
          <span class="service-label">Book a Growth Audit</span>
          <h2 class="text-4xl font-extrabold leading-[1.05] tracking-[-0.06em] md:text-5xl">
            Bring the messy growth question. Leave with a clearer next step.
          </h2>
          <p class="text-lg leading-8 text-[color:var(--muted)]">{siteConfig.bookingNote}</p>
        </div>
        <div class="card overflow-hidden p-2">
          <iframe
            title="Book a 30-min Growth Audit with Daniel Johnson"
            src="https://calendly.com/danieljohnson?hide_gdpr_banner=1"
            class="h-[720px] w-full rounded-[1rem] border-0"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
