---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site";
import { buildBreadcrumbSchema } from "../lib/schema";

const title = "Terms of Use | Daniel Johnson";
const description =
  "Terms governing use of danieljohnson.xyz. Content ownership, disclaimers, and the boundaries of advice published on the site.";

const lastUpdated = "20 April 2026";

const breadcrumb = buildBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Terms", url: "/terms" }
]);
---

<BaseLayout description={description} title={title} schema={breadcrumb} lastUpdated={false}>
  <section class="section-space">
    <div class="shell">
      <article class="reveal mx-auto max-w-3xl">
        <span class="eyebrow">Terms</span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-[-0.05em] md:text-6xl">Terms of Use</h1>
        <p class="mt-3 text-sm text-[color:var(--muted)]">Last updated: {lastUpdated}</p>

        <div class="mt-10 space-y-6 text-base leading-8 text-[color:var(--ink)]">
          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">Welcome</h2>
            <p>
              By using danieljohnson.xyz (&ldquo;the site&rdquo;) you agree to these terms. If you disagree with any part, please stop using the site.
              The site is operated by Daniel Johnson, based in {siteConfig.location}.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">Content on the site</h2>
            <p>
              Essays, talks, frameworks, and resources on this site represent the author&apos;s views at the time of publication. They are shared to help
              founders and operators think about growth, not as specific advice tailored to your company. Results vary; nothing here is a guarantee of outcomes.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">Intellectual property</h2>
            <p>
              Original writing, diagrams, and frameworks on the site are copyright Daniel Johnson. You may quote short passages with attribution and a link.
              Commercial reproduction, republication, or derivative courses require written permission first.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">Third-party content and links</h2>
            <p>
              Logos, quotes, and examples referencing other companies are used to illustrate work and ideas. Ownership of those marks and quotes rests with their respective owners.
              External links are provided for convenience; we are not responsible for third-party content.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">No professional advice</h2>
            <p>
              Content on the site is general in nature and does not constitute legal, financial, tax, or medical advice. For decisions that rely on those
              professions, speak with a qualified practitioner.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">Engagements</h2>
            <p>
              Paid advisory, fractional CMO, speaking, and mentoring engagements are governed by a separate, signed agreement. These site terms do not replace those.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">Liability</h2>
            <p>
              To the maximum extent permitted by law, the site and its author are not liable for any indirect or consequential loss arising from use of the site.
              Nothing in these terms limits liability that cannot lawfully be limited.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">Governing law</h2>
            <p>These terms are governed by the laws of England and Wales.</p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-[-0.03em]">Contact</h2>
            <p>Questions about these terms: <a class="underline" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.</p>
          </section>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
