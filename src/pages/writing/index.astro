---
import { getCollection } from "astro:content";
import SectionHeader from "../../components/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, sortByFeaturedThenOrder } from "../../lib/utils";
import { siteConfig } from "../../site";

const articles = sortByFeaturedThenOrder(await getCollection("articles"));
const archive = sortByFeaturedThenOrder(await getCollection("media"));
const primaryArchive = archive.filter((item) => ["Profile", "Interview", "Speaking", "Course"].includes(item.data.kind));
const secondaryArchive = archive.filter((item) => !primaryArchive.includes(item));
const focusTags = ["GTM", "AI", "Founder Growth", "Fractional CMO", "Pipeline"];
const allTags = [...new Set(articles.flatMap((article) => article.data.tags))];
const suggestedInterviewFormats = [
  "30-minute podcast interview",
  "45-minute founder growth teardown",
  "60-minute keynote",
  "Panel guest",
  "Written Q&A",
  "Expert quote for articles"
];

function readingTime(a: (typeof articles)[0]) {
  const words = (a.body ?? "").split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 220))} min read`;
}

function haystack(a: (typeof articles)[0]) {
  return `${a.data.title} ${a.data.description} ${a.data.tags.join(" ")}`.toLowerCase();
}

const essayBuckets: {
  title: string;
  intro: string;
  test: (a: (typeof articles)[0]) => boolean;
}[] = [
  {
    title: "Resources · Fractional CMO & pricing context",
    intro: "When the model fits, commercial shape, and UK-facing pricing reads — aligned with the /resources/ hub.",
    test: (a) => {
      const h = haystack(a);
      return h.includes("fractional") || h.includes("cmo") || h.includes("pricing");
    }
  },
  {
    title: "Resources · Growth systems & research",
    intro: "Operating rhythm, customer research, and bottlenecks before you buy more traffic or hires.",
    test: (a) => {
      const h = haystack(a);
      return (
        h.includes("operating system") ||
        h.includes("customer research") ||
        h.includes("research before") ||
        h.includes("growth-systems") ||
        h.includes("mentor") ||
        h.includes("479") ||
        h.includes("noisy")
      );
    }
  },
  {
    title: "Resources · AI-native GTM",
    intro: "Practical AI in GTM workflows — speed without outsourcing judgement.",
    test: (a) => {
      const h = haystack(a);
      return h.includes("ai-native") || h.includes(" ai ") || h.includes("genai");
    }
  }
];

const assigned = new Set<string>();
const filledBuckets = essayBuckets.map((bucket) => {
  const items = articles.filter((article) => {
    if (assigned.has(article.id)) return false;
    if (!bucket.test(article)) return false;
    assigned.add(article.id);
    return true;
  });
  return { ...bucket, items };
});
const uncategorisedEssays = articles.filter((article) => !assigned.has(article.id));
---

<BaseLayout
  description="Read Daniel Johnson's essays on AI-native GTM, growth systems, and founder-led execution, plus a curated archive of interviews, profiles, and talks."
  keywords="Daniel Johnson essays, fractional CMO writing, AI GTM blog, startup growth systems"
  path="/writing/"
  stickyCta={false}
  title="Writing | Daniel Johnson"
>
  <section class="section-space conversion-hero">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div class="reveal max-w-4xl space-y-6">
          <span class="service-label">Writing</span>
          <h1 class="text-5xl font-semibold tracking-[-0.07em] text-balance md:text-7xl">
            Essays on AI-native GTM and growth systems.
          </h1>
          <p class="conversion-subcopy max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            Native essays by Daniel on AI-native GTM, fractional leadership, and operating-system thinking — plus a smaller
            curated archive of profiles, interviews, talks, and resources that show how the point of view travels.
          </p>
          <p class="max-w-3xl text-sm font-semibold uppercase tracking-[0.12em] text-[color:var(--subtle)]">
            These essays are useful starting points for interviews, quotes, and podcast conversations.
          </p>
        </div>

        <aside class="reveal card p-6 md:p-8">
          <p class="card-label">How to use this page</p>
          <div class="mt-6 grid gap-4">
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you are evaluating Daniel</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">Start with the flagship essay and the GrowthMentor profile.</p>
            </article>
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you are solving a growth problem</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">Read the essays by bottleneck: operating system, customer research, or fractional leadership.</p>
            </article>
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you are booking media</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">Use the <a class="highlight-text" href="/media-kit/">media kit</a> for bios, headshots, topics, and producer assets.</p>
            </article>
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you want future notes</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]"><a class="highlight-text" href="/newsletter/">Subscribe to Growth Notes</a> or use the <a class="highlight-text" href="/growth-bottleneck-checklist/">bottleneck checklist</a>.</p>
            </article>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0" id="essays">
    <div class="shell">
      <SectionHeader
        eyebrow="Written by Daniel"
        intro="Original writing published on this site. These pieces are written to make startup growth clearer, not more elaborate."
        title="Native essays."
      />

      <div class="chip-row reveal mt-8" aria-label="Writing topics">
        {focusTags.map((tag) => <span class="chip">{tag}</span>)}
        {allTags.filter((tag) => !focusTags.includes(tag)).map((tag) => <span class="chip chip-quiet">{tag}</span>)}
      </div>

      <p class="reveal mt-8 text-sm text-[color:var(--muted)]">
        Deep-dive guides and comparisons also live in the{" "}
        <a class="font-semibold text-[color:var(--ink)] underline underline-offset-4 hover:text-[color:var(--accent)]" href="/resources/">
          resources hub
        </a>
        .
      </p>

      <div class="reveal mt-12 rounded-2xl border border-[color:var(--line)] p-6 md:p-8">
        <p class="card-label">New here? Start with these three.</p>
        <p class="mt-2 text-sm text-[color:var(--muted)]">The fastest way into how Daniel thinks about growth — then browse by topic below.</p>
        <div class="mt-6 grid gap-5 lg:grid-cols-3">
          {articles.slice(0, 3).map((article) => (
            <article class="card-muted p-5">
              <span class="chip">{readingTime(article)}</span>
              <h3 class="mt-4 text-lg font-semibold tracking-[-0.04em]"><a href={`/writing/${article.id}/`}>{article.data.title}</a></h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{article.data.excerpt}</p>
              <div class="mt-4"><a class="link-arrow" href={`/writing/${article.id}/`}>Read essay</a></div>
            </article>
          ))}
        </div>
      </div>

      {
        filledBuckets.map(
          (bucket) =>
            bucket.items.length > 0 && (
              <div class="mt-12">
                <SectionHeader eyebrow="Essays" intro={bucket.intro} title={bucket.title} />
                <div class="mt-8 grid gap-5 lg:grid-cols-2">
                  {bucket.items.map((article) => (
                    <article class="reveal card p-6 md:p-7">
                      <div class="flex flex-wrap gap-2">
                        <span class="chip">Essay</span>
                        <span class="chip">{formatDate(article.data.publishedAt)}</span>
                        <span class="chip">{readingTime(article)}</span>
                      </div>
                      <h2 class="mt-5 text-2xl font-semibold tracking-[-0.04em]">
                        <a href={`/writing/${article.id}/`}>{article.data.title}</a>
                      </h2>
                      <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{article.data.excerpt}</p>
                      <div class="chip-row mt-5">
                        {article.data.tags.map((tag) => (
                          <span class="chip">{tag}</span>
                        ))}
                      </div>
                      <div class="mt-6">
                        <a class="link-arrow" href={`/writing/${article.id}/`}>
                          Read essay
                        </a>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            )
        )
      }

      {
        uncategorisedEssays.length > 0 && (
          <div class="mt-12">
            <SectionHeader
              eyebrow="Essays"
              intro="Additional pieces that span multiple themes — still organised by tags on each card."
              title="More essays."
            />
            <div class="mt-8 grid gap-5 lg:grid-cols-2">
              {uncategorisedEssays.map((article) => (
                <article class="reveal card p-6 md:p-7">
                  <div class="flex flex-wrap gap-2">
                    <span class="chip">Essay</span>
                    <span class="chip">{formatDate(article.data.publishedAt)}</span>
                    <span class="chip">{readingTime(article)}</span>
                  </div>
                  <h2 class="mt-5 text-2xl font-semibold tracking-[-0.04em]">
                    <a href={`/writing/${article.id}/`}>{article.data.title}</a>
                  </h2>
                  <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{article.data.excerpt}</p>
                  <div class="chip-row mt-5">
                    {article.data.tags.map((tag) => (
                      <span class="chip">{tag}</span>
                    ))}
                  </div>
                  <div class="mt-6">
                    <a class="link-arrow" href={`/writing/${article.id}/`}>
                      Read essay
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>

  <section class="archive-section section-space" id="archive">
    <div class="shell">
      <SectionHeader
        eyebrow="Curated Archive"
        intro="Useful external material from Daniel's wider footprint. This is deliberately smaller than a blog archive."
        title="Profiles, interviews, talks, and resources."
      />

      <div class="mt-10 grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="grid gap-5">
          {
            primaryArchive.map((item) => (
              <article class="reveal card archive-card p-6 md:p-7">
                <div class="flex flex-wrap gap-2">
                  <span class="chip">{item.data.kind}</span>
                  <span class="chip">{item.data.source}</span>
                  <span class="chip">{item.data.yearLabel}</span>
                </div>
                <h2 class="mt-5 text-2xl font-semibold tracking-[-0.04em]">{item.data.title}</h2>
                <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{item.data.description}</p>
                <a class="link-arrow mt-6" href={item.data.href} rel="noreferrer" target="_blank">Open source</a>
              </article>
            ))
          }
        </div>
        <aside class="reveal card p-6 md:p-7">
          <p class="card-label">Secondary archive</p>
          <div class="mt-5 grid gap-4">
            {
              secondaryArchive.map((item) => (
                <a class="archive-mini-link" href={item.data.href} rel="noreferrer" target="_blank">
                  <span>{item.data.title}</span>
                  <small>{item.data.source} / {item.data.yearLabel}</small>
                </a>
              ))
            }
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card mb-6 p-6 md:p-8">
        <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="card-label">Suggested interview formats</p>
            <h2 class="mt-3 text-3xl font-bold tracking-[-0.05em] md:text-4xl">Send this to your producer.</h2>
            <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">Writing proves the thinking; the media kit turns it into a clean briefing pack.</p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            {suggestedInterviewFormats.map((item) => <span class="card-muted p-4 text-sm font-bold">{item}</span>)}
            <a class="button-secondary sm:col-span-2" href="/media-kit/">Open Daniel's media kit</a>
          </div>
        </div>
      </div>
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Use the thinking</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              For interviews, quotes, or a deeper commercial conversation.
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              Producers can start with the media kit. Founders with a live growth bottleneck can use the commercial route after the media context is clear.
            </p>
          </div>
          <div class="cta-stack">
            <a class="button-accent" href="/media-kit/">Open media kit</a>
            <a class="button-secondary" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
            <a class="button-secondary" href="/newsletter/">Subscribe to Growth Notes</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
