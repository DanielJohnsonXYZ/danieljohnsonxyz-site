---
import { getCollection } from "astro:content";
import SectionHeader from "../../components/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, sortByFeaturedThenOrder } from "../../lib/utils";
import { siteConfig } from "../../site";

const articles = sortByFeaturedThenOrder(await getCollection("articles"));
const [flagshipArticle, ...supportingArticles] = articles;
const archive = sortByFeaturedThenOrder(await getCollection("media"));
const primaryArchive = archive.filter((item) => ["Profile", "Interview", "Speaking", "Course"].includes(item.data.kind));
const secondaryArchive = archive.filter((item) => !primaryArchive.includes(item));
---

<BaseLayout
  description="Essays by Daniel Johnson on AI-native GTM, growth systems, and why most startup growth advice is wrong — plus a curated archive of talks, profiles, and interviews."
  path="/writing"
  title="Writing | Daniel Johnson"
>
  <section class="section-space">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div class="reveal max-w-4xl space-y-6">
          <span class="service-label">Writing</span>
          <h1 class="text-5xl font-semibold tracking-[-0.07em] text-balance md:text-7xl">
            Essays on AI-native GTM and growth systems.
          </h1>
          <p class="max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            Native essays by Daniel on AI-native GTM, fractional leadership, and operating-system thinking — plus a smaller
            curated archive of profiles, interviews, talks, and resources that show how the point of view travels.
          </p>
        </div>

        <aside class="reveal card p-6 md:p-8">
          <p class="card-label">How to use this page</p>
          <div class="mt-6 grid gap-4">
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you are evaluating Daniel</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">Start with the flagship essay and the GrowthMentor profile.</p>
            </article>
            <article class="card-muted p-4">
              <p class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">If you are solving a growth problem</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">Read the essays by bottleneck: operating system, customer research, or fractional leadership.</p>
            </article>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0" id="essays">
    <div class="shell">
      <SectionHeader
        eyebrow="Written by Daniel"
        intro="Original writing published on this site. These pieces are written to make startup growth clearer, not more elaborate."
        title="Native essays."
      />

      <article class="insights-flagship reveal card mt-10 p-6 md:p-8">
        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <div>
            <p class="card-label">Flagship essay</p>
            <h2 class="mt-4 text-4xl font-extrabold tracking-[-0.06em] md:text-6xl">
              <a href={`/writing/${flagshipArticle.id}`}>{flagshipArticle.data.title}</a>
            </h2>
            <p class="mt-5 max-w-3xl text-lg leading-8 text-[color:var(--muted)]">{flagshipArticle.data.description}</p>
          </div>
          <div>
            <div class="flex flex-wrap gap-2">
              <span class="chip">Essay</span>
              <span class="chip">{formatDate(flagshipArticle.data.publishedAt)}</span>
              {flagshipArticle.data.tags.map((tag) => <span class="chip">{tag}</span>)}
            </div>
            <a class="link-arrow mt-6" href={`/writing/${flagshipArticle.id}`}>Read flagship essay</a>
          </div>
        </div>
      </article>

      <div class="mt-5 grid gap-5 lg:grid-cols-2">
        {
          supportingArticles.map((article) => (
            <article class="reveal card p-6 md:p-7">
              <div class="flex flex-wrap gap-2">
                <span class="chip">Essay</span>
                <span class="chip">{formatDate(article.data.publishedAt)}</span>
              </div>
              <h2 class="mt-5 text-2xl font-semibold tracking-[-0.04em]">
                <a href={`/writing/${article.id}`}>{article.data.title}</a>
              </h2>
              <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{article.data.excerpt}</p>
              <div class="mt-6">
                <a class="link-arrow" href={`/writing/${article.id}`}>
                  Read essay
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="archive-section section-space" id="archive">
    <div class="shell">
      <SectionHeader
        eyebrow="Curated Archive"
        intro="Useful external material from Daniel's wider footprint. This is deliberately smaller than a blog archive."
        title="Profiles, interviews, talks, and resources."
      />

      <div class="mt-10 grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="grid gap-5">
          {
            primaryArchive.map((item) => (
              <article class="reveal card archive-card p-6 md:p-7">
                <div class="flex flex-wrap gap-2">
                  <span class="chip">{item.data.kind}</span>
                  <span class="chip">{item.data.source}</span>
                  <span class="chip">{item.data.yearLabel}</span>
                </div>
                <h2 class="mt-5 text-2xl font-semibold tracking-[-0.04em]">{item.data.title}</h2>
                <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">{item.data.description}</p>
                <a class="link-arrow mt-6" href={item.data.href} rel="noreferrer" target="_blank">Open source</a>
              </article>
            ))
          }
        </div>
        <aside class="reveal card p-6 md:p-7">
          <p class="card-label">Secondary archive</p>
          <div class="mt-5 grid gap-4">
            {
              secondaryArchive.map((item) => (
                <a class="archive-mini-link" href={item.data.href} rel="noreferrer" target="_blank">
                  <span>{item.data.title}</span>
                  <small>{item.data.source} / {item.data.yearLabel}</small>
                </a>
              ))
            }
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Apply the thinking</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              Want to apply this to your own growth bottleneck?
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              {siteConfig.bookingNote}
            </p>
          </div>
          <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
