---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildArticleSchema } from "../../lib/schema";
import { formatDate } from "../../lib/utils";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const pathname = `/writing/${article.id}`;
---

<BaseLayout
  description={article.data.description}
  ogType="article"
  path={pathname}
  schema={buildArticleSchema(article, pathname)}
  title={`${article.data.title} | Daniel Johnson`}
>
  <section class="section-space">
    <div class="shell">
      <div class="mx-auto grid max-w-6xl gap-10 xl:grid-cols-[1.1fr_0.9fr] xl:items-start">
        <div class="reveal space-y-6">
          <a class="link-arrow" href="/writing">Back to writing</a>
          <span class="eyebrow">Native essay</span>
          <h1 class="text-5xl font-semibold tracking-[-0.07em] text-balance md:text-7xl">{article.data.title}</h1>
          <p class="max-w-3xl text-lg leading-8 text-[color:var(--muted)] md:text-xl">{article.data.description}</p>
          <div class="flex flex-wrap gap-2">
            <span class="chip">{formatDate(article.data.publishedAt)}</span>
            {article.data.tags.map((tag) => <span class="chip">{tag}</span>)}
          </div>
        </div>

        <aside class="reveal card p-6 md:p-8">
          <p class="mono text-xs uppercase tracking-[0.18em] text-[color:var(--accent)]">Essay Context</p>
          <div class="mt-6 grid gap-4">
            <article class="card-muted p-4">
              <p class="mono text-[0.68rem] uppercase tracking-[0.16em] text-[color:var(--muted)]">Published</p>
              <p class="mt-2 text-base font-semibold tracking-[-0.03em] text-[color:var(--ink)]">
                {formatDate(article.data.publishedAt)}
              </p>
            </article>
            <article class="card-muted p-4">
              <p class="mono text-[0.68rem] uppercase tracking-[0.16em] text-[color:var(--muted)]">Focus</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {article.data.tags.map((tag) => <span class="chip">{tag}</span>)}
              </div>
            </article>
            <article class="card-muted p-4">
              <p class="mono text-[0.68rem] uppercase tracking-[0.16em] text-[color:var(--muted)]">Intent</p>
              <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">
                Clear thinking for founders and operators who want stronger commercial decisions, not inflated frameworks.
              </p>
            </article>
          </div>
        </aside>
      </div>

      <div class="mx-auto max-w-4xl">
        <article class="reveal prose-wrap mt-12 xl:mt-16">
          <Content />
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
