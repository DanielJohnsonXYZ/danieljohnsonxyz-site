---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ctas } from "../site";
---

<BaseLayout
  title="Revenue Operations for Founder-Led Startups | Daniel Johnson"
  description="Revenue operations support for post-PMF startups: funnel visibility, reporting cadence, pipeline process, CRM hygiene, and growth handoff."
  path="/revenue-operations"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="service-label">Revenue Operations</span>
        <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">Make growth visible enough to manage.</h1>
        <p class="hero-subcopy text-xl leading-9 md:text-2xl">Pipeline process, reporting cadence, channel-to-revenue visibility, CRM hygiene, and handoff rules for founder-led teams that need better decisions.</p>
        <div class="flex flex-wrap gap-3">
          <a class="button-accent" href={ctas.primary.href}>{ctas.primary.label} →</a>
          <a class="button-link" href={ctas.bottleneck.href}>{ctas.bottleneck.label} →</a>
        </div>
      </div>
    </div>
  </section>
  <section class="section-space pt-0">
    <div class="shell grid gap-5 md:grid-cols-3">
      <article class="card p-6"><h2 class="text-2xl font-bold">Outputs</h2><p class="mt-3 text-[color:var(--muted)]">Funnel map, reporting cadence, CRM fields, dashboard logic, pipeline review ritual, and ownership model.</p></article>
      <article class="card p-6"><h2 class="text-2xl font-bold">Best For</h2><p class="mt-3 text-[color:var(--muted)]">Teams where marketing, sales, and founder intuition disagree because the data is not decision-ready.</p></article>
      <article class="card p-6"><h2 class="text-2xl font-bold">What Changes</h2><p class="mt-3 text-[color:var(--muted)]">The team can see what is working, what is stuck, and where to invest next.</p></article>
    </div>
  </section>
</BaseLayout>
