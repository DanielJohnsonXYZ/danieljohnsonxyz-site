---
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { siteConfig } from "../site";

const shortBio =
  "Daniel Johnson is a fractional CMO and GTM operator for post-PMF AI and B2B SaaS startups. He's worked with 20+ startups, helped generate £18M+ in client revenue, managed £6M+ in ad spend, and mentored 479+ founders (rated 4.97/5 on GrowthMentor). He's a mentor for Google for Startups and Techstars, has lectured at Cambridge Judge and Imperial College, and is the founder of We Scale Startups.";

const longBio =
  "Daniel has spent 10+ years in growth — as a co-founder, an embedded operator, and a fractional CMO. He's co-founded two companies, including the mental health app eQuoo. He specialises in building AI-native growth systems for seed to Series B startups — rebuilding the GTM stack around generative and agentic workflows to ship 5× faster. He mentors founders through Google for Startups, Techstars, and GrowthMentor, has delivered workshops at Google Launchpad programmes across the UK, Europe, and Africa, and sits on the board of BASIC. He works with US clients remotely from the UK, with occasional in-person days.";

const oneLiner = "AI-native fractional CMO for post-PMF AI and B2B SaaS startups.";

const schema = buildBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Press & Media", url: "/press-and-media" }
]);
---

<BaseLayout
  description="Press assets for Daniel Johnson — bios, headshot, speaking topics, and contact details for journalists, podcast hosts, and event organisers."
  path="/press-and-media"
  schema={schema}
  title="Press & Media | Daniel Johnson"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="service-label">Press & Media</span>
        <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">
          Press &amp; media.
        </h1>
        <p class="hero-subcopy text-xl leading-9 md:text-2xl">
          Bios, headshot, topics, and contact details for journalists, podcast hosts, and event organisers.
        </p>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="mx-auto max-w-3xl space-y-8">
        <article class="reveal card p-6 md:p-7">
          <p class="card-label">One-liner</p>
          <p class="mt-3 text-xl font-bold tracking-[-0.03em]">{oneLiner}</p>
        </article>

        <article class="reveal card p-6 md:p-7">
          <p class="card-label">Short bio (50 words)</p>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">{shortBio}</p>
        </article>

        <article class="reveal card p-6 md:p-7">
          <p class="card-label">Long bio (120 words)</p>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">{longBio}</p>
        </article>

        <article class="reveal card p-6 md:p-7">
          <p class="card-label">Headshot</p>
          <div class="mt-4 flex flex-col gap-4 md:flex-row md:items-start">
            <img alt="Daniel Johnson headshot" class="w-40 rounded-lg" height="200" src={siteConfig.headshot} width="160" />
            <p class="text-sm leading-7 text-[color:var(--muted)]">
              Right-click the image to save. For higher-resolution files or on-stage photography, email
              <a class="highlight-text" href={`mailto:${siteConfig.email}`}> {siteConfig.email}</a>.
            </p>
          </div>
        </article>

        <article class="reveal card p-6 md:p-7">
          <p class="card-label">Speaking topics</p>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">
            Full topic list with track descriptions lives at <a class="highlight-text" href="/topics-and-talks">/topics-and-talks</a>.
          </p>
        </article>

        <article class="reveal card p-6 md:p-7">
          <p class="card-label">Contact</p>
          <ul class="mt-3 space-y-2 text-base leading-8 text-[color:var(--muted)]">
            <li>Email: <a class="highlight-text" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
            <li>LinkedIn: <a class="highlight-text" href={siteConfig.linkedin} rel="noreferrer" target="_blank">{siteConfig.linkedin.replace("https://www.", "")}</a></li>
            <li>Based in the UK, work with US clients remotely</li>
          </ul>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
