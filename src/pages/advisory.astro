---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildFaqPageSchema } from "../lib/schema";
import { sortByFeaturedThenOrder } from "../lib/utils";
import { siteConfig } from "../site";

const testimonials = sortByFeaturedThenOrder(await getCollection("testimonials"));
const proof = sortByFeaturedThenOrder(await getCollection("proof"));
const primaryTestimonial = testimonials.find((item) => item.data.name === "James Lethem") ?? testimonials[0];
const proofHighlights = proof.slice(0, 3);

const offerCards = [
  {
    name: "Fractional CMO",
    cadence: "Usually 3-6+ months, part-time senior leadership",
    bestFor: "Seed to Series A teams that need a commercial spine before hiring a full-time marketing leader.",
    example: "Clarify GTM priorities, positioning, reporting, experiment rhythm, and hiring plan.",
    outcome: "The leadership team leaves with sharper decisions, clearer operating cadence, and less founder bottleneck."
  },
  {
    name: "Growth advisory",
    cadence: "Usually monthly or fortnightly advisory rhythm",
    bestFor: "Founders and lean teams that need a senior thought partner on growth decisions.",
    example: "Review funnel bottlenecks, customer evidence, channel priorities, and current experiments.",
    outcome: "The team gets cleaner priorities and a better way to decide what to test next."
  },
  {
    name: "Focused strategic sprint",
    cadence: "Usually 2-4 weeks around one defined bottleneck",
    bestFor: "Teams with a specific growth problem that needs a fast, structured diagnosis.",
    example: "Funnel diagnosis, narrative refinement, channel prioritisation, or roadmap reset.",
    outcome: "The team leaves with an actionable plan, decision rules, and a clearer next 30-60 days."
  }
];

const firstTwoWeeks = [
  {
    title: "Bottleneck review",
    body: "Audit the funnel, growth activity, customer evidence, and operating rhythm to find where progress is really stuck."
  },
  {
    title: "Decision map",
    body: "Separate urgent noise from the few growth assumptions that need to be tested or clarified first."
  },
  {
    title: "Operating plan",
    body: "Translate the diagnosis into an experiment backlog, meeting cadence, reporting logic, and ownership structure."
  }
];

const fit = [
  "You have real demand or traction, but growth still feels reactive.",
  "The founder is making too many commercial calls by instinct alone.",
  "Channels are active, but the learning is not compounding.",
  "The team needs stronger strategic guidance before the next stage of hiring."
];

const faq = [
  {
    question: "Who is this best for?",
    answer: "Founder-led seed to Series A startups, post-traction teams, and innovation programmes that need senior GTM judgment rather than a menu of marketing services."
  },
  {
    question: "What does Daniel actually do in the work?",
    answer: "I help teams prioritise growth, sharpen positioning, improve customer research, build experiment quality, align product and revenue work, and create a growth rhythm internal teams can keep running."
  },
  {
    question: "Is this an agency relationship?",
    answer: "No. This is Daniel's personal fractional CMO and growth advisory practice. We Scale Startups is the company context, but the work here is positioned around direct senior input."
  },
  {
    question: "How long do engagements usually last?",
    answer: "Sprint work is usually 2-4 weeks. Advisory relationships are often monthly or fortnightly. Fractional CMO work usually runs 3-6+ months, depending on the stage and decision load."
  },
  {
    question: "What happens on the first call?",
    answer: "We identify the current growth bottleneck, discuss the operating context, outline likely priorities, and decide whether there is a useful fit. It is a diagnosis, not a pitch deck tour."
  }
];
---

<BaseLayout
  description="Advisory with Daniel Johnson: fractional CMO support, growth strategy, and focused commercial systems work for post-traction startups."
  path="/advisory"
  schema={buildFaqPageSchema(faq)}
  title="Advisory | Daniel Johnson"
>
  <section class="section-space">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="reveal space-y-6">
          <span class="service-label">Fractional CMO / Growth Advisor</span>
          <h1 class="max-w-4xl text-5xl font-bold tracking-[-0.06em] text-balance md:text-7xl">
            Senior growth support when traction exists, but the system is not repeatable yet.
          </h1>
          <p class="max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            I work with post-traction startups that need clearer GTM priorities, sharper positioning, better
            experimentation, and a rhythm the internal team can actually run.
          </p>
        </div>
        <aside class="reveal card p-6 md:p-8">
          <p class="card-label">Good fit signals</p>
          <ul class="scan-list mt-6">
            {fit.map((item) => <li>{item}</li>)}
          </ul>
          <div class="mt-6 rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface-dim)] p-4">
            <p class="text-sm font-bold tracking-[-0.02em]">{siteConfig.availability}</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Engagement Modes"
        intro="The mode depends on the stage and the decision load. The goal is always the same: better growth judgment, better rhythm, and less founder bottleneck."
        title="Three ways the work is usually structured."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {
          offerCards.map((item) => (
            <article class="reveal advisory-mode-card card p-6 md:p-7">
              <p class="card-label">{item.cadence}</p>
              <h2 class="mt-4 text-2xl font-bold tracking-[-0.04em]">{item.name}</h2>
              <dl class="mt-6 grid gap-5">
                <div>
                  <dt>Best for</dt>
                  <dd>{item.bestFor}</dd>
                </div>
                <div>
                  <dt>Example use case</dt>
                  <dd>{item.example}</dd>
                </div>
                <div>
                  <dt>Typical outcome</dt>
                  <dd>{item.outcome}</dd>
                </div>
              </dl>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label text-white/55">Proof on this page</p>
          <blockquote class="mt-5">
            <p class="text-3xl font-extrabold leading-[1.16] tracking-[-0.06em] text-white">
              "{primaryTestimonial.data.quote}"
            </p>
            <footer class="mt-6 border-t border-white/[0.08] pt-5 text-sm text-white/65">
              <p class="font-semibold text-white">{primaryTestimonial.data.name}</p>
              <p>{primaryTestimonial.data.role} &bull; {primaryTestimonial.data.organisation}</p>
            </footer>
          </blockquote>
        </article>
        <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          {
            proofHighlights.map((item) => (
              <article class="reveal card p-5">
                <p class="text-4xl font-extrabold tracking-[-0.07em] text-white">{item.data.metric}</p>
                <h2 class="mt-3 text-lg font-bold tracking-[-0.04em] text-white/90">{item.data.title}</h2>
                <p class="mt-2 text-sm leading-6 text-white/60">{item.data.summary}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="First Two Weeks"
        intro="A clear start matters. The first phase is designed to reduce ambiguity quickly, not create a long discovery project."
        title="What happens first."
      />
      <div class="process-strip mt-10">
        {
          firstTwoWeeks.map((item, index) => (
            <article class="reveal process-strip-item">
              <span>0{index + 1}</span>
              <h2>{item.title}</h2>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="FAQ"
        intro="A few practical questions founders and teams usually ask before deciding whether the fit is right."
        title="Common questions."
      />
      <div class="faq-stack mt-10">
        {
          faq.map((item, index) => (
            <details class="reveal faq-item card p-6 md:p-7" open={index === 0}>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal card px-6 py-8 md:px-10 md:py-10">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
          <div class="space-y-4">
            <span class="eyebrow">Start Here</span>
            <h2 class="text-4xl font-bold tracking-[-0.05em] md:text-5xl">
              Start with a 30-minute growth diagnosis.
            </h2>
            <p class="max-w-2xl text-base leading-8 text-[color:var(--muted)]">
              {siteConfig.bookingNote} You will know whether the right next step is a sprint, advisory rhythm, fractional support, or no engagement at all.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
            <a class="button-secondary" href={`mailto:${siteConfig.email}`}>Email Daniel</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
