---
import { getCollection } from "astro:content";
import CfEmailOff from "../components/CfEmailOff.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildTalkSchema } from "../lib/schema";
import { sortByFeaturedThenOrder } from "../lib/utils";
import { siteConfig, socialLinks, trustLogos } from "../site";

const talks = sortByFeaturedThenOrder(await getCollection("talks"));
const selectedTalks = talks.slice(0, 3);
const speakingHighlights = [
  { metric: "388+", label: "Founder and operator mentoring sessions" },
  { metric: "10+ years", label: "Startup growth experience behind the content" },
  { metric: "Google, Cambridge, Imperial", label: "Institutional rooms and programmes" },
  { metric: "10+ countries", label: "Startup audiences reached through teaching and mentoring" }
];
// Five named "Signature talks" — each is a bookable session organisers
// can propose to their committee. Named talks make event briefing easier
// and rank for specific topic searches. Source: Notion 353f99a79fdb81f0a60bec41f5e43ffc
const signatureSessions = [
  {
    title: "What the Hell Is Growth?",
    outcome: "A practical explanation of what growth actually means after early traction, and why most founders confuse channels with systems.",
    bestFor: "Founder cohorts, accelerators, early-stage operator teams"
  },
  {
    title: "AI-Native GTM for Startup Teams",
    outcome: "How smaller teams use AI to improve research, messaging, experimentation, and decision-making — without outsourcing judgement to tools.",
    bestFor: "Startup teams adopting AI, innovation programmes, AI-native founder cohorts"
  },
  {
    title: "Founder-Led Growth After the First Customers",
    outcome: "Why founder-led sales works early, where it breaks, and how to build a commercial system that does not depend on the founder's calendar.",
    bestFor: "Post-PMF founders, growth-stage operator teams, scale-up programmes"
  },
  {
    title: "Positioning Before Pipeline",
    outcome: "Why most acquisition problems are actually messaging, ICP, and category problems — and how to fix them before spending more on channels.",
    bestFor: "Seed to Series A teams, GTM workshops, marketing leadership offsites"
  },
  {
    title: "Build a Growth Machine, Not a Growth Hack",
    outcome: "A practical operating model for prioritising experiments, reading signal, and building a repeatable growth function the team can run.",
    bestFor: "Series A/B teams, growth leadership audiences, fractional-CMO conferences"
  }
];
const organiserTakeaways = [
  "A practical growth framework the audience can use after the session.",
  "Examples from founder, operator, and advisory work, not just theory.",
  "A speaker who can flex between executive-level strategy and hands-on startup detail."
];
const presentationFeedback = [
  { quote: "Finally, a growth talk that cuts through the fluff. Clear frameworks I could use the next day.", source: "Nomad Summit attendee" },
  { quote: "No-nonsense, practical, and specific to our stage. Exactly what we needed.", source: "SaaS & AI SEO session" },
  { quote: "Left with three concrete things to fix on our GTM. Highly recommended.", source: "Workshop participant" },
  { quote: "The clearest positioning session we've had. No theory, just what to change.", source: "Growth workshop attendee" },
  { quote: "Practical, actionable, and refreshingly honest about what works at our stage.", source: "Founder session" },
  { quote: "Daniel's framework gave us the clarity we'd been missing for months.", source: "Innovation programme" }
];
const eventPhotos = [
  {
    src: "/images/nomad-summit-group.webp",
    alt: "Daniel Johnson speaking at Nomad Summit — founder growth session",
    caption: "Speaking on growth systems and positioning at Nomad Summit"
  },
  {
    src: "/images/daniel-presenting-slide.webp",
    alt: "Daniel Johnson presenting a slide on SaaS and AI growth",
    caption: "SaaS & AI growth session in Shenzhen"
  },
  {
    src: "/images/shenzhen-seo-event-poster.webp",
    alt: "Shenzhen SEO & SaaS event poster featuring Daniel Johnson as speaker",
    caption: "Event poster — Shenzhen SEO & SaaS session"
  }
];
// Formats — be explicit about every shape, including the higher-value
// workshop and private formats organisers often assume aren't available.
// Source: Notion 353f99a79fdb8165ab39c4ede9d7347f
const deliverables = [
  "30-minute keynote",
  "45-minute practical talk",
  "60–90-minute workshop for founder cohorts and operator teams",
  "Founder cohort session inside an accelerator or programme",
  "Panel guest or moderated conversation",
  "Live growth teardown — Daniel reviews a real company on stage",
  "Private team session — internal training for a single company"
];
const assets = [
  { label: "Short bio", detail: "Use the speaking bio below for event pages and introductions." },
  { label: "Headshot", detail: "Use the current site headshot as a placeholder until Daniel supplies final event photography." },
  { label: "Talk topics", detail: "Use the three signature sessions as starting points, then tailor to the audience." }
];
const speakingSchema = talks.map((talk) => buildTalkSchema(talk));
---

<BaseLayout
  description="Speaking with Daniel Johnson: talks, workshops, and training for founder, startup, and innovation audiences that need practical growth and GTM thinking."
  schema={speakingSchema}
  title="Speaking | Daniel Johnson"
>
  <section class="section-space">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="reveal space-y-6">
          <span class="service-label">Speaking / Workshops</span>
          <h1 class="max-w-4xl text-5xl font-bold tracking-[-0.06em] text-balance md:text-7xl">
            Practical startup growth talks for rooms that need clarity, not hype.
          </h1>
          <p class="max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
            I speak to founders, operators, students, and innovation teams about growth systems, GTM judgment,
            experimentation, and the commercial work required to turn momentum into repeatability.
          </p>
          <ul class="scan-list max-w-3xl">
            {organiserTakeaways.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <aside class="grid gap-5">
          <article class="reveal video-panel">
            <div class="video-frame">
              <iframe
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                loading="lazy"
                src={siteConfig.youtubeUploadsEmbed}
                title="Daniel Johnson YouTube videos"
              ></iframe>
            </div>
            <div class="video-panel-copy">
              <p class="card-label">YouTube field notes</p>
              <h2>Short growth and GTM notes for founders.</h2>
              <p>Use this as a quick read on Daniel's pace, language, and practical teaching style before booking a talk or workshop.</p>
              <a class="link-arrow" href={siteConfig.youtube} rel="noreferrer" target="_blank">Watch more on YouTube</a>
            </div>
          </article>
          <div class="reveal card overflow-hidden p-4">
            <img alt="Cambridge Judge Business School building" class="aspect-[4/3] w-full rounded-xl object-cover" height="720" loading="eager" src="/images/cambridge-judge-business-school-960.webp" width="960" />
          </div>
          <div class="reveal card p-6 md:p-8">
            <p class="card-label">Formats</p>
            <ul class="mt-6 space-y-4">
              {
                deliverables.map((item) => (
                  <li class="flex gap-4 border-b border-[color:var(--line)] pb-4 text-base leading-7 last:border-b-0 last:pb-0">
                    <span class="mt-2 size-2 shrink-0 rounded-full bg-[color:var(--line-strong)]"></span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>

      <div class="mt-8 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
        {
          speakingHighlights.map((item) => (
            <article class="reveal card p-5">
              <p class="text-2xl font-bold tracking-[-0.04em] md:text-3xl">{item.metric}</p>
              <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">{item.label}</p>
            </article>
          ))
        }
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
        {
          trustLogos.map((item) => (
            <article class="reveal logo-card flex items-center justify-between gap-4 px-5 py-4">
              <img alt={item.alt} class="h-10 w-auto max-w-[10rem] object-contain" height="48" loading="lazy" src={item.src} width="180" />
              <span class="text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-[color:var(--muted)]">{item.label}</span>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Signature Sessions"
        intro="Each topic can become a keynote, workshop, training session, or founder-cohort format depending on the audience."
        title="Talks designed around what the room should do next."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          signatureSessions.map((item) => (
            <article class="reveal advisory-mode-card card p-6 md:p-7">
              <h2 class="text-2xl font-bold tracking-[-0.04em]">{item.title}</h2>
              <dl class="mt-6 grid gap-5">
                <div>
                  <dt>Best for</dt>
                  <dd>{item.bestFor}</dd>
                </div>
                <div>
                  <dt>Audience leaves with</dt>
                  <dd>{item.outcome}</dd>
                </div>
              </dl>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Presentation Feedback"
        intro="Recent attendee reactions from live sessions and workshops."
        title="What founders say after the session."
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          presentationFeedback.map((item) => (
            <blockquote class="reveal p-4 md:p-5 border-l-2 border-[color:var(--line)] bg-[color:var(--surface)]/50">
              <p class="text-sm leading-6 text-[color:var(--muted)]">"{item.quote}"</p>
              <footer class="mt-2 text-xs text-[color:var(--subtle)]">{item.source}</footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Event Photos"
        intro="Visual proof from recent speaking engagements and founder events."
        title="Daniel on stage and in the room."
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          eventPhotos.map((item) => (
            <figure class="reveal card overflow-hidden">
              <img src={item.src} alt={item.alt} class="w-full aspect-[4/3] object-cover" loading="lazy" />
              <figcaption class="p-4 text-sm text-[color:var(--muted)]">{item.caption}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label text-white/55">Event proof</p>
          <blockquote class="mt-5">
            <p class="text-3xl font-extrabold leading-[1.16] tracking-[-0.06em] text-white">
              "I am very impressed by Daniel's detailed insight when working with startups through Google Launchpad."
            </p>
            <footer class="mt-6 border-t border-white/[0.08] pt-5 text-sm text-white/65">
              <p class="font-semibold text-white">James Lethem</p>
              <p>Programme collaborator &bull; Google Launchpad</p>
            </footer>
          </blockquote>
        </article>
        <div>
          <SectionHeader
            eyebrow="Selected Rooms"
            intro="A tighter sample rather than a dense wall of cards. More examples can live in the full speaking archive later."
            title="Recent speaking and teaching footprint."
          />
          <div class="mt-8 grid gap-5">
            {
              selectedTalks.map((talk) => (
                <article class="reveal card p-6 md:p-7">
                  <div class="flex flex-wrap gap-2">
                    <span class="chip">{talk.data.organiser}</span>
                    <span class="chip">{talk.data.yearLabel}</span>
                  </div>
                  <h2 class="mt-5 text-2xl font-bold tracking-[-0.04em] text-white/90">{talk.data.title}</h2>
                  <p class="mt-3 text-sm font-medium text-white/75">{talk.data.topic}</p>
                  <p class="mt-4 text-base leading-7 text-white/64">{talk.data.summary}</p>
                  <div class="mt-5 flex flex-wrap gap-3">
                    <span class="chip">{talk.data.location}</span>
                    {talk.data.url && <a class="link-arrow" href={talk.data.url} rel="noreferrer" target="_blank">View organiser</a>}
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Booker Assets"
        intro="Practical details for organisers who already know the room and need to decide quickly whether there is a fit."
        title="Useful materials for organisers."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
        <article class="reveal card p-6 md:p-8">
          <p class="card-label">Speaking bio</p>
          <h2 class="mt-4 text-3xl font-bold tracking-[-0.05em] md:text-4xl">
            Daniel Johnson is an AI-Native GTM &amp; growth operator for post-PMF AI and B2B SaaS startups — founder,
            mentor, and speaker.
          </h2>
          <p class="mt-5 max-w-3xl text-base leading-8 text-[color:var(--muted)]">
            Over 10+ years he has worked with 20+ AI and B2B SaaS startups, managed £6M+ in paid spend, generated
            £18M+ in revenue, and helped founders raise £15M+. He mentors through Google for Startups, Techstars, and
            GrowthMentor (388+ sessions, 4.93/5), and has lectured at Cambridge Judge, Imperial College London,
            General Assembly, and the UK Space Agency.
          </p>
        </article>
        <div class="grid gap-4">
          {
            assets.map((item) => (
              <article class="reveal card p-5">
                <p class="card-label">{item.label}</p>
                <p class="mt-3 text-base leading-7 text-[color:var(--muted)]">{item.detail}</p>
              </article>
            ))
          }
          <CfEmailOff>
            <a class="button-accent" href={`mailto:${siteConfig.email}?subject=Speaking%20enquiry%20for%20Daniel%20Johnson`}>Enquire About Speaking</a>
          </CfEmailOff>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <div class="reveal social-panel">
        <div>
          <p class="card-label">Social proof and profiles</p>
          <h2>More ways to assess fit before booking.</h2>
          <p>
            Recent thinking, mentor reviews, public profiles, interviews, and current work are linked here for organisers who want a fuller picture.
          </p>
        </div>
        <div class="social-link-grid">
          {socialLinks.map((item) => (
            <a href={item.href} rel="noreferrer" target="_blank">{item.label}</a>
          ))}
          <a href="/podcast-appearances/">Podcast appearances</a>
          <a href="/now/">Now page</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
