---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { ctas, proofStats, siteConfig } from "../site";

const workSchema = [
  buildBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Work with me", url: "/work-with-me/" }
  ])
];
---

<BaseLayout
  title="Work with me | Daniel Johnson"
  description="How Daniel works with post-PMF AI and B2B SaaS founders: Growth Audit, Strategy Sprint, Fractional CMO, Office Hours, and speaking, with proof and next steps."
  path="/work-with-me/"
  schema={workSchema}
>
  <section class="section-space conversion-hero">
    <div class="shell">
      <p class="service-label">Work with me</p>
      <h1 class="max-w-4xl text-5xl font-semibold tracking-[-0.07em] text-balance md:text-7xl">
        Services that turn founder-dependent growth into a repeatable GTM system.
      </h1>
      <p class="conversion-subcopy mt-6 max-w-3xl text-lg leading-9 text-[color:var(--muted)] md:text-xl">
        Start at the smallest commitment that answers your question, usually the free 20-minute Growth Audit. Move up to a Strategy Sprint or Fractional CMO if the shape fits.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-accent" href={ctas.primary.href} data-cta="work-with-me-primary">
          {ctas.primary.label} →
        </a>
        <a class="button-secondary" href="/growth-audit/" data-cta="work-with-me-audit-page">
          {ctas.bookingFallback.label} →
        </a>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Free or paid?"
        title="Which call to book, and when to use the firm instead"
        intro="Start free; pay only when you want a plan or hands on the work. If you need a team to run it, that is We Scale Startups."
      />
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <article class="card p-6 md:p-8">
          <p class="service-label">Free · Diagnose</p>
          <h3 class="mt-2 text-xl font-bold tracking-[-0.04em]">20-minute Growth Audit</h3>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]"><strong>For</strong> founders who want their bottleneck named fast. <strong>You get</strong> a plain-English read on the binding constraint and the next best move, with no pitch.</p>
          <a class="link-arrow mt-4 inline-block" href="/growth-audit/">See what the audit covers</a>
        </article>
        <article class="card p-6 md:p-8">
          <p class="service-label">Paid · Plan</p>
          <h3 class="mt-2 text-xl font-bold tracking-[-0.04em]">Strategy Sprint · from £6k</h3>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]"><strong>For</strong> when the constraint is clear and you want a costed plan plus first wins in 2–4 weeks. <strong>You get</strong> the plan, the artefacts, and the first experiments shipped.</p>
          <a class="link-arrow mt-4 inline-block" href="/strategy-sprint/">See Strategy Sprint scope</a>
        </article>
        <article class="card p-6 md:p-8">
          <p class="service-label">Paid · Advise</p>
          <h3 class="mt-2 text-xl font-bold tracking-[-0.04em]">Founder Office Hours</h3>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]"><strong>For</strong> founders who want a senior second brain on recurring GTM decisions. <strong>You get</strong> focused working sessions with no long-term commitment.</p>
          <a class="link-arrow mt-4 inline-block" href="/founder-office-hours/">See Office Hours</a>
        </article>
        <article class="card p-6 md:p-8">
          <p class="service-label">Paid · Build</p>
          <h3 class="mt-2 text-xl font-bold tracking-[-0.04em]">Fractional CMO · from £5k/mo</h3>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]"><strong>For</strong> Seed–Series B teams that need embedded senior GTM leadership. <strong>You get</strong> Daniel inside the team, running the cadence, dashboard and decision log, building the system and transferring it.</p>
          <a class="link-arrow mt-4 inline-block" href="/fractional-cmo/">See Fractional CMO scope</a>
        </article>
      </div>
      <p class="mt-8 max-w-3xl text-base leading-8 text-[color:var(--muted)]">
        <strong>When to use We Scale Startups instead:</strong> the calls above are engagements with Daniel as the principal. If you need a growth function delivered by a team, with more execution capacity or a commercial contract through a firm, go to <a class="highlight-text" href="https://wescalestartups.com" rel="noreferrer" target="_blank">We Scale Startups</a>. Same methodology, different delivery model.
      </p>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Approach"
        title="Problem → Action → Result → System"
        intro="Every engagement uses the same structure so you can see what changed, why it stuck, and what the team owns after."
      />
      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        <article class="card p-6 md:p-8">
          <h2 class="text-xl font-bold tracking-[-0.04em]">Problem</h2>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">
            What was breaking when we started, in plain language so founders recognise themselves.
          </p>
        </article>
        <article class="card p-6 md:p-8">
          <h2 class="text-xl font-bold tracking-[-0.04em]">Action</h2>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">
            The specific interventions, described concretely enough that you could brief them to your own team: “rewrote the homepage to lead with ICP pain.”
          </p>
        </article>
        <article class="card p-6 md:p-8">
          <h2 class="text-xl font-bold tracking-[-0.04em]">Result</h2>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">
            What moved in the window we measured: metrics where possible, qualitative outcomes where clients prefer anonymity.
          </p>
        </article>
        <article class="card p-6 md:p-8">
          <h2 class="text-xl font-bold tracking-[-0.04em]">System</h2>
          <p class="mt-3 text-base leading-8 text-[color:var(--muted)]">
            Artefacts, cadence, and reporting the team runs without a full-time CMO hire.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader
        eyebrow="Outcomes"
        title="Proof at a glance."
        intro="Canonical numbers, same sources as the homepage and media kit."
      />
      <div class="hero-proof mt-10" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1rem;">
        <div>
          <strong>{proofStats.revenueImpact}</strong>
          <span>revenue generated</span>
        </div>
        <div>
          <strong>{proofStats.mentorRating}/5</strong>
          <span>GrowthMentor ({proofStats.mentorReviewCount} reviews)</span>
        </div>
        <div>
          <strong>{proofStats.mentorSessions}</strong>
          <span>sessions</span>
        </div>
        <div>
          <strong>{proofStats.startupsAdvised}</strong>
          <span>startups advised</span>
        </div>
        <div>
          <strong>{proofStats.adSpend}</strong>
          <span>ad spend managed</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Case studies" title="Read the full stories." intro="Stage, bottleneck, intervention, and timeline, anonymised where needed." />
      <div class="mt-8 text-center">
        <a class="button-accent" href="/case-studies/">View case studies →</a>
      </div>
    </div>
  </section>

  <section class="dark-section section-space">
    <div class="shell">
      <SectionHeader
        eyebrow="Testimonials"
        title="What founders say."
        intro="Founder Office Hours, Strategy Sprint, and deeper Fractional CMO engagements, with the full page linked below."
      />
      <div class="mt-8 text-center">
        <a class="button-accent" href="/testimonials/">Read testimonials →</a>
      </div>
    </div>
  </section>

  <section class="cta-gradient section-space">
    <div class="shell text-center">
      <p class="eyebrow justify-center text-white/60">{ctas.primary.label}</p>
      <h2 class="text-4xl font-extrabold tracking-[-0.06em] text-white md:text-5xl">See if this is the right fit.</h2>
      <p class="mt-4 mx-auto max-w-2xl text-lg leading-8 text-white/72">{siteConfig.bookingNote}</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a class="button-accent" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">
          {siteConfig.bookingLabel} →
        </a>
        <a class="button-link-invert" href="/case-studies/">{ctas.caseStudies.label} →</a>
      </div>
    </div>
  </section>
</BaseLayout>
