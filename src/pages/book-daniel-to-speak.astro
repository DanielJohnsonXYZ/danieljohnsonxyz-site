---
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { siteConfig } from "../site";

const schema = buildBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Speaking", url: "/speaking" },
  { name: "Book Daniel to speak", url: "/book-daniel-to-speak" }
]);

const whatToInclude = [
  "Event name, date, location, and format (in-person, virtual, hybrid).",
  "Audience — who is in the room, roughly how many, and what stage they are at.",
  "Slot length and format — keynote, workshop, panel, fireside, or training.",
  "Topic angle — which of the signature sessions fits, or what you would like Daniel to shape.",
  "Budget and any expenses the event covers (travel, accommodation, etc.)."
];

const signatureSessions = [
  "AI-native growth systems for post-PMF startups",
  "Founder-led distribution — how operators actually get in front of buyers",
  "How to build a repeatable growth system",
  "Go-to-market judgment for early teams",
  "Turning innovation into commercial traction"
];

const fitNotes = [
  "Founder cohorts at accelerators and incubators (Google for Startups, Techstars, EIT programmes, regional innovation programmes).",
  "AI and B2B SaaS industry conferences — keynotes or workshops for operator audiences.",
  "University and R&D programmes at the intersection of tech, research, and commercialisation.",
  "Private executive and investor gatherings where a practical operator voice is useful."
];
---

<BaseLayout
  description="Book Daniel Johnson to speak at your event. Keynotes, workshops, and training on AI-native GTM, growth systems, and founder-led distribution."
  path="/book-daniel-to-speak"
  schema={schema}
  title="Book Daniel to speak | Daniel Johnson"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="service-label">Speaking enquiry</span>
        <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">
          Book Daniel to speak.
        </h1>
        <p class="hero-subcopy text-xl leading-9 md:text-2xl">
          Keynotes, workshops, fireside chats, and training for founder, operator, and innovation audiences.
          Practical growth thinking — no frameworks for their own sake.
        </p>
        <div class="flex flex-wrap gap-4 pt-2">
          <a class="button-primary" href={`mailto:${siteConfig.email}?subject=Speaking%20enquiry`}>
            Email a speaking enquiry
          </a>
          <a class="button-link" href="/speaking">See the speaking page →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader eyebrow="What to include" title="Send these five things and Daniel will reply within two business days." />
      <div class="reveal mx-auto max-w-3xl">
        <ol class="space-y-4 text-lg leading-8">
          {whatToInclude.map((item, index) => (
            <li class="flex gap-4">
              <span class="flex-shrink-0 font-mono text-sm text-slate-500">{String(index + 1).padStart(2, "0")}</span>
              <span>{item}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="section-space bg-slate-50">
    <div class="shell">
      <SectionHeader eyebrow="Signature sessions" title="Start with one of these, or brief a custom angle." />
      <div class="reveal mx-auto grid max-w-4xl gap-3 md:grid-cols-2">
        {signatureSessions.map((session) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-base font-semibold">{session}</p>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-slate-600">
        Full topic detail lives on <a class="underline" href="/topics-and-talks">Topics &amp; Talks</a>.
      </p>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader eyebrow="Good fit for" title="Daniel tends to say yes to rooms like these." />
      <div class="reveal mx-auto max-w-3xl">
        <ul class="space-y-4 text-lg leading-8">
          {fitNotes.map((note) => (
            <li class="flex gap-3">
              <span class="mt-3 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-900"></span>
              <span>{note}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-space bg-slate-900 text-white">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <h2 class="text-4xl font-extrabold tracking-[-0.04em] md:text-5xl">Ready to send the brief?</h2>
        <p class="text-lg text-slate-200">
          Email the five details above and the signature session you would like, and Daniel will come back to you with
          availability, fee, and how he would tailor the session for your audience.
        </p>
        <div class="flex flex-wrap justify-center gap-4 pt-2">
          <a class="button-primary" href={`mailto:${siteConfig.email}?subject=Speaking%20enquiry`}>
            Email {siteConfig.email}
          </a>
          <a class="button-link text-white" href="/press-and-media">Grab bio &amp; headshot →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
