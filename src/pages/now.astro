---
import { getCollection } from "astro:content";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { sortByFeaturedThenOrder } from "../lib/utils";
import { siteConfig } from "../site";

const schema = buildBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Now", url: "/now" }
]);

const updatedOn = "April 2026";

const workingOn = [
  {
    title: "Active fractional CMO engagement — AI B2B SaaS, US-based, Series A",
    detail: "Rebuilding the growth system around AI-native workflows. Rewriting the GTM stack, setting up weekly experiment cadence, and hiring the next growth hire."
  },
  {
    title: "Fractional CMO engagement — UK AI-native healthtech, pre-Series A",
    detail: "Founder-led distribution, category positioning, and pipeline build for a UK-based AI healthcare product."
  },
  {
    title: "Advisory days — 1 slot open",
    detail: "Half-day strategy sessions for post-PMF founders who want a set of eyes on the growth system, not a long-term engagement."
  }
];

const writingFocus = [
  "A long-form essay on what AI-native GTM actually changes in the growth stack (in draft).",
  "Shorter case-study write-ups from the current engagements — published as they ship.",
  "A new /fractional-cmo pillar page with the full operating model behind the engagements."
];

const speakingThisQuarter = [
  "Accelerator cohort workshops on repeatable growth systems — two dates confirmed this quarter.",
  "One industry keynote in discussion for later in the year.",
  "Ongoing mentoring through Google for Startups, Techstars, and GrowthMentor."
];

const notWorkingOn = [
  "New long-term retainers until Q3 — the current two engagements are deep and take the majority of my time.",
  "One-off content or paid media audits — the work is most useful as part of a fractional CMO engagement.",
  "Speaking slots longer than 90 minutes during April–June."
];

const articles = sortByFeaturedThenOrder(await getCollection("articles")).slice(0, 3);
---

<BaseLayout
  description="What Daniel Johnson is working on right now — active client engagements, writing in progress, speaking commitments, and what he's saying no to."
  path="/now"
  schema={schema}
  title="Now | Daniel Johnson"
>
  <section class="hero-section section-space">
    <div class="shell">
      <div class="reveal mx-auto max-w-4xl space-y-6">
        <span class="service-label">Now — updated {updatedOn}</span>
        <h1 class="text-5xl font-extrabold leading-[1.02] tracking-[-0.07em] text-balance md:text-7xl">
          What I'm working on right now.
        </h1>
        <p class="hero-subcopy text-xl leading-9 md:text-2xl">
          A short monthly update on active client engagements, what I'm writing, where I'm speaking, and what I'm
          saying no to. Inspired by <a class="underline" href="https://nownownow.com/about" rel="noopener">Derek Sivers' /now page idea</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader eyebrow="Client work" title="The engagements taking most of my time this month." />
      <div class="reveal mx-auto grid max-w-5xl gap-6 md:grid-cols-2 lg:grid-cols-3">
        {workingOn.map((item) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6">
            <h3 class="text-lg font-semibold leading-snug">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space bg-slate-50">
    <div class="shell">
      <div class="mx-auto grid max-w-5xl gap-10 md:grid-cols-2">
        <div>
          <h2 class="text-3xl font-extrabold tracking-[-0.03em]">Writing</h2>
          <ul class="mt-5 space-y-3 text-base leading-7">
            {writingFocus.map((item) => (
              <li class="flex gap-3">
                <span class="mt-3 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-900"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a class="button-link mt-6 inline-block" href="/writing">See recent essays →</a>
        </div>
        <div>
          <h2 class="text-3xl font-extrabold tracking-[-0.03em]">Speaking</h2>
          <ul class="mt-5 space-y-3 text-base leading-7">
            {speakingThisQuarter.map((item) => (
              <li class="flex gap-3">
                <span class="mt-3 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-900"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a class="button-link mt-6 inline-block" href="/book-daniel-to-speak">Book a session →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell">
      <SectionHeader eyebrow="Saying no to" title="To protect the depth of the current work." />
      <div class="reveal mx-auto max-w-3xl">
        <ul class="space-y-4 text-lg leading-8">
          {notWorkingOn.map((item) => (
            <li class="flex gap-3">
              <span class="mt-3 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-500"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {articles.length > 0 && (
    <section class="section-space bg-slate-50">
      <div class="shell">
        <SectionHeader eyebrow="Recent writing" title="What I've published most recently." />
        <div class="reveal mx-auto grid max-w-5xl gap-6 md:grid-cols-3">
          {articles.map((article) => (
            <a class="group rounded-2xl border border-slate-200 bg-white p-6 transition hover:border-slate-900" href={`/writing/${article.id}`}>
              <h3 class="text-lg font-semibold leading-snug group-hover:underline">{article.data.title}</h3>
              {article.data.description && (
                <p class="mt-3 text-sm leading-7 text-slate-600">{article.data.description}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section-space bg-slate-900 text-white">
    <div class="shell">
      <div class="reveal mx-auto max-w-3xl space-y-6 text-center">
        <h2 class="text-4xl font-extrabold tracking-[-0.04em] md:text-5xl">Want to work together?</h2>
        <p class="text-lg text-slate-200">
          If the shape of what I'm working on matches something you need, get in touch. Monthly check-ins on this page
          are the most current picture of my availability.
        </p>
        <div class="flex flex-wrap justify-center gap-4 pt-2">
          <a class="button-primary" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">Book a growth call</a>
          <a class="button-link text-white" href="/fractional-cmo">See the fractional CMO offer →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
